{
  "name": "openfn-mocker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Configurable mock API server impersonating external systems for OpenFn workflow testing",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "setup": "tsx src/generate/setup.ts",
    "generate-seed": "tsx src/generate/cli.ts",
    "snapshot-default": "tsx src/generate/snapshot.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:usage": "tsx scripts/test-usage-examples.ts",
    "audit:adaptors": "tsx scripts/audit-adaptor-coverage.ts",
    "specs": "tsx src/spec-registry/cli.ts",
    "readme": "tsx scripts/generate-readme.ts",
    "readme:check": "tsx scripts/generate-readme.ts --check"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.1",
    "@fastify/formbody": "^7",
    "fastify": "^4",
    "yaml": "^2"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^2"
  }
}
