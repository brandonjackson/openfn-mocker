{
  "openapi": "3.0.3",
  "info": {
    "title": "DHIS2 Web API (mock subset)",
    "version": "2.39",
    "description": "Focused subset of the DHIS2 Web API used by the OpenFn dhis2 adaptor: metadata (organisationUnits, dataElements, programs, trackedEntityTypes), tracker (trackedEntityInstances, events, enrollments), aggregate (dataValueSets), the metadata bundle importer, and system info."
  },
  "servers": [{ "url": "http://localhost:4010" }],
  "paths": {
    "/api/system/info": {
      "get": {
        "operationId": "getSystemInfo",
        "summary": "System information",
        "responses": {
          "200": {
            "description": "System info",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SystemInfo" }
              }
            }
          }
        }
      }
    },
    "/api/organisationUnits": {
      "get": {
        "operationId": "listOrganisationUnits",
        "summary": "List organisation units",
        "parameters": [
          { "name": "filter", "in": "query", "schema": { "type": "string" }, "description": "field:op:value, e.g. name:eq:Ngelehun CHC" },
          { "name": "paging", "in": "query", "schema": { "type": "boolean" } },
          { "name": "fields", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Org unit list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/OrganisationUnitList" }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createOrganisationUnit",
        "summary": "Create an organisation unit",
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/OrganisationUnit" } }
          }
        },
        "responses": {
          "200": {
            "description": "Import summary",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ImportSummaryResponse" } }
            }
          }
        }
      }
    },
    "/api/organisationUnits/{id}": {
      "get": {
        "operationId": "getOrganisationUnit",
        "summary": "Get an organisation unit by uid",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Org unit",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/OrganisationUnit" } }
            }
          },
          "404": { "description": "Not found" }
        }
      }
    },
    "/api/dataElements": {
      "get": {
        "operationId": "listDataElements",
        "summary": "List data elements",
        "responses": {
          "200": {
            "description": "Data element list",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/DataElementList" } }
            }
          }
        }
      },
      "post": {
        "operationId": "createDataElement",
        "summary": "Create a data element",
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/DataElement" } }
          }
        },
        "responses": {
          "200": {
            "description": "Import summary",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ImportSummaryResponse" } }
            }
          }
        }
      }
    },
    "/api/dataElements/{id}": {
      "get": {
        "operationId": "getDataElement",
        "summary": "Get a data element by uid",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Data element",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/DataElement" } }
            }
          },
          "404": { "description": "Not found" }
        }
      }
    },
    "/api/programs": {
      "get": {
        "operationId": "listPrograms",
        "summary": "List programs",
        "responses": {
          "200": {
            "description": "Program list",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ProgramList" } }
            }
          }
        }
      }
    },
    "/api/programs/{id}": {
      "get": {
        "operationId": "getProgram",
        "summary": "Get a program by uid",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Program",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Program" } }
            }
          },
          "404": { "description": "Not found" }
        }
      }
    },
    "/api/trackedEntityTypes": {
      "get": {
        "operationId": "listTrackedEntityTypes",
        "summary": "List tracked entity types",
        "responses": {
          "200": {
            "description": "Tracked entity type list",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/TrackedEntityTypeList" } }
            }
          }
        }
      }
    },
    "/api/trackedEntityTypes/{id}": {
      "get": {
        "operationId": "getTrackedEntityType",
        "summary": "Get a tracked entity type by uid",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Tracked entity type",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/TrackedEntityType" } }
            }
          },
          "404": { "description": "Not found" }
        }
      }
    },
    "/api/trackedEntityInstances": {
      "get": {
        "operationId": "listTrackedEntityInstances",
        "summary": "List tracked entity instances",
        "responses": {
          "200": {
            "description": "TEI list",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/TrackedEntityInstanceList" } }
            }
          }
        }
      },
      "post": {
        "operationId": "createTrackedEntityInstance",
        "summary": "Create a tracked entity instance",
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/TrackedEntityInstance" } }
          }
        },
        "responses": {
          "200": {
            "description": "Import summary",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ImportSummaryResponse" } }
            }
          }
        }
      }
    },
    "/api/events": {
      "get": {
        "operationId": "listEvents",
        "summary": "List events",
        "responses": {
          "200": {
            "description": "Event list",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/EventList" } }
            }
          }
        }
      },
      "post": {
        "operationId": "createEvent",
        "summary": "Create an event",
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/Event" } }
          }
        },
        "responses": {
          "200": {
            "description": "Import summary",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ImportSummaryResponse" } }
            }
          }
        }
      }
    },
    "/api/enrollments": {
      "get": {
        "operationId": "listEnrollments",
        "summary": "List enrollments",
        "responses": {
          "200": {
            "description": "Enrollment list",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/EnrollmentList" } }
            }
          }
        }
      },
      "post": {
        "operationId": "createEnrollment",
        "summary": "Create an enrollment",
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/Enrollment" } }
          }
        },
        "responses": {
          "200": {
            "description": "Import summary",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ImportSummaryResponse" } }
            }
          }
        }
      }
    },
    "/api/dataValueSets": {
      "get": {
        "operationId": "getDataValueSets",
        "summary": "Read data values",
        "responses": {
          "200": {
            "description": "Data values",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/DataValueSet" } }
            }
          }
        }
      },
      "post": {
        "operationId": "postDataValueSet",
        "summary": "Import a data value set",
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/DataValueSet" } }
          }
        },
        "responses": {
          "200": {
            "description": "Import summary",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ImportSummaryResponse" } }
            }
          }
        }
      }
    },
    "/api/metadata": {
      "post": {
        "operationId": "importMetadata",
        "summary": "Import a metadata bundle",
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/MetadataBundle" } }
          }
        },
        "responses": {
          "200": {
            "description": "Import stats",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/MetadataImportResponse" } }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SystemInfo": {
        "type": "object",
        "properties": {
          "version": { "type": "string", "example": "2.39" },
          "revision": { "type": "string", "example": "9d9dcf1" },
          "serverDate": { "type": "string", "format": "date-time" },
          "contextPath": { "type": "string", "example": "http://localhost:4010" }
        }
      },
      "Pager": {
        "type": "object",
        "properties": {
          "page": { "type": "integer", "example": 1 },
          "pageSize": { "type": "integer", "example": 50 },
          "pageCount": { "type": "integer", "example": 1 },
          "total": { "type": "integer", "example": 3 }
        }
      },
      "OrganisationUnit": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "DiszpKrYNg8" },
          "name": { "type": "string", "example": "Ngelehun CHC" },
          "shortName": { "type": "string", "example": "Ngelehun" },
          "level": { "type": "integer", "example": 4 },
          "path": { "type": "string", "example": "/ImspTQPwCqd/O6uvpzGd5pu/DiszpKrYNg8" },
          "openingDate": { "type": "string", "example": "1970-01-01" },
          "parent": {
            "type": "object",
            "properties": { "id": { "type": "string", "example": "O6uvpzGd5pu" } }
          }
        }
      },
      "OrganisationUnitList": {
        "type": "object",
        "properties": {
          "pager": { "$ref": "#/components/schemas/Pager" },
          "organisationUnits": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/OrganisationUnit" }
          }
        }
      },
      "DataElement": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "fbfJHSPpUQD" },
          "name": { "type": "string", "example": "ANC 1st visit" },
          "shortName": { "type": "string", "example": "ANC 1st visit" },
          "valueType": { "type": "string", "example": "NUMBER" },
          "domainType": { "type": "string", "example": "AGGREGATE" }
        }
      },
      "DataElementList": {
        "type": "object",
        "properties": {
          "pager": { "$ref": "#/components/schemas/Pager" },
          "dataElements": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/DataElement" }
          }
        }
      },
      "ProgramStage": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "A03MvHHogjR" },
          "name": { "type": "string", "example": "Birth" },
          "sortOrder": { "type": "integer", "example": 1 },
          "repeatable": { "type": "boolean", "example": false }
        }
      },
      "Program": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "IpHINAT79UW" },
          "name": { "type": "string", "example": "Child Programme" },
          "shortName": { "type": "string", "example": "Child Programme" },
          "programType": { "type": "string", "example": "WITH_REGISTRATION" },
          "trackedEntityType": {
            "type": "object",
            "properties": { "id": { "type": "string", "example": "nEenWmSyUEp" } }
          },
          "programStages": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ProgramStage" }
          }
        }
      },
      "ProgramList": {
        "type": "object",
        "properties": {
          "pager": { "$ref": "#/components/schemas/Pager" },
          "programs": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Program" }
          }
        }
      },
      "TrackedEntityType": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "nEenWmSyUEp" },
          "name": { "type": "string", "example": "Person" }
        }
      },
      "TrackedEntityTypeList": {
        "type": "object",
        "properties": {
          "pager": { "$ref": "#/components/schemas/Pager" },
          "trackedEntityTypes": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TrackedEntityType" }
          }
        }
      },
      "Attribute": {
        "type": "object",
        "properties": {
          "attribute": { "type": "string", "example": "w75KJ2mc4zz" },
          "value": { "type": "string", "example": "Jane" }
        }
      },
      "TrackedEntityInstance": {
        "type": "object",
        "properties": {
          "trackedEntityInstance": { "type": "string", "example": "PgmUFEQYZGz" },
          "trackedEntityType": { "type": "string", "example": "nEenWmSyUEp" },
          "orgUnit": { "type": "string", "example": "DiszpKrYNg8" },
          "attributes": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Attribute" }
          }
        }
      },
      "TrackedEntityInstanceList": {
        "type": "object",
        "properties": {
          "pager": { "$ref": "#/components/schemas/Pager" },
          "trackedEntityInstances": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TrackedEntityInstance" }
          }
        }
      },
      "DataValue": {
        "type": "object",
        "properties": {
          "dataElement": { "type": "string", "example": "qrur9Dvnyt5" },
          "categoryOptionCombo": { "type": "string", "example": "HllvX50cXC0" },
          "value": { "type": "string", "example": "22" }
        }
      },
      "Event": {
        "type": "object",
        "properties": {
          "event": { "type": "string", "example": "lxAQ7Zs9VYR" },
          "program": { "type": "string", "example": "IpHINAT79UW" },
          "programStage": { "type": "string", "example": "A03MvHHogjR" },
          "orgUnit": { "type": "string", "example": "DiszpKrYNg8" },
          "eventDate": { "type": "string", "example": "2024-02-01" },
          "status": { "type": "string", "example": "COMPLETED" },
          "dataValues": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/DataValue" }
          }
        }
      },
      "EventList": {
        "type": "object",
        "properties": {
          "pager": { "$ref": "#/components/schemas/Pager" },
          "events": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Event" }
          }
        }
      },
      "Enrollment": {
        "type": "object",
        "properties": {
          "enrollment": { "type": "string", "example": "MNWZ6hnuhSw" },
          "trackedEntityInstance": { "type": "string", "example": "PgmUFEQYZGz" },
          "program": { "type": "string", "example": "IpHINAT79UW" },
          "orgUnit": { "type": "string", "example": "DiszpKrYNg8" },
          "enrollmentDate": { "type": "string", "example": "2024-02-01" },
          "incidentDate": { "type": "string", "example": "2024-02-01" },
          "status": { "type": "string", "example": "ACTIVE" }
        }
      },
      "EnrollmentList": {
        "type": "object",
        "properties": {
          "pager": { "$ref": "#/components/schemas/Pager" },
          "enrollments": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Enrollment" }
          }
        }
      },
      "DataValueSet": {
        "type": "object",
        "properties": {
          "dataSet": { "type": "string", "example": "pBOMPrpg1QX" },
          "period": { "type": "string", "example": "202401" },
          "orgUnit": { "type": "string", "example": "DiszpKrYNg8" },
          "dataValues": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/DataValue" }
          }
        }
      },
      "ImportSummaryResponse": {
        "type": "object",
        "properties": {
          "httpStatus": { "type": "string", "example": "OK" },
          "httpStatusCode": { "type": "integer", "example": 200 },
          "status": { "type": "string", "example": "OK" },
          "response": {
            "type": "object",
            "properties": {
              "responseType": { "type": "string", "example": "ImportSummary" },
              "status": { "type": "string", "example": "SUCCESS" },
              "importCount": {
                "type": "object",
                "properties": {
                  "imported": { "type": "integer", "example": 1 },
                  "updated": { "type": "integer", "example": 0 },
                  "ignored": { "type": "integer", "example": 0 },
                  "deleted": { "type": "integer", "example": 0 }
                }
              },
              "reference": { "type": "string", "example": "PgmUFEQYZGz" }
            }
          }
        }
      },
      "MetadataBundle": {
        "type": "object",
        "properties": {
          "organisationUnits": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/OrganisationUnit" }
          },
          "dataElements": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/DataElement" }
          },
          "programs": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Program" }
          },
          "trackedEntityTypes": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TrackedEntityType" }
          }
        }
      },
      "MetadataImportResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "OK" },
          "stats": {
            "type": "object",
            "properties": {
              "created": { "type": "integer", "example": 2 },
              "updated": { "type": "integer", "example": 0 },
              "deleted": { "type": "integer", "example": 0 },
              "ignored": { "type": "integer", "example": 0 },
              "total": { "type": "integer", "example": 2 }
            }
          }
        }
      }
    }
  }
}
