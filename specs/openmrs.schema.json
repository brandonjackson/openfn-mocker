{
  "openapi": "3.0.0",
  "info": {
    "title": "OpenMRS REST + FHIR R4 (mock subset)",
    "version": "2.6",
    "description": "Focused subset of the OpenMRS Web Services. Two hybrid surfaces: the OpenMRS REST API under /ws/rest/v1/{resource} (list envelope { results: [...] }, ?q= search, ?v=ref|default|full verbosity) and the FHIR R4 module under /ws/fhir2/R4/{Patient|Encounter} (FHIR searchset Bundles + resources). The FHIR Patients mirror the same seed patients as the REST person/patient records. Auth is HTTP Basic; the mock accepts all credentials."
  },
  "servers": [{ "url": "http://localhost:4012" }],
  "paths": {
    "/ws/rest/v1/patient": {
      "get": {
        "operationId": "listPatients",
        "summary": "Search patients",
        "parameters": [
          { "name": "q", "in": "query", "required": false, "schema": { "type": "string" }, "description": "Search term (matched against name/identifier)." },
          { "name": "v", "in": "query", "required": false, "schema": { "type": "string", "enum": ["ref", "default", "full"] }, "description": "Representation verbosity." }
        ],
        "responses": {
          "200": {
            "description": "Matching patients.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": { "type": "array", "items": { "$ref": "#/components/schemas/Patient" } }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createPatient",
        "summary": "Create a patient",
        "requestBody": {
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Patient" } } }
        },
        "responses": {
          "201": {
            "description": "Created patient.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Patient" } } }
          }
        }
      }
    },
    "/ws/rest/v1/patient/{uuid}": {
      "get": {
        "operationId": "getPatient",
        "parameters": [
          { "name": "uuid", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "v", "in": "query", "required": false, "schema": { "type": "string", "enum": ["ref", "default", "full"] } }
        ],
        "responses": {
          "200": {
            "description": "The patient.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Patient" } } }
          }
        }
      },
      "post": {
        "operationId": "updatePatient",
        "summary": "Update (merge) a patient",
        "parameters": [{ "name": "uuid", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Patient" } } }
        },
        "responses": {
          "200": {
            "description": "Updated patient.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Patient" } } }
          }
        }
      },
      "delete": {
        "operationId": "deletePatient",
        "parameters": [{ "name": "uuid", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "204": { "description": "Deleted." } }
      }
    },
    "/ws/rest/v1/encounter": {
      "get": {
        "operationId": "listEncounters",
        "responses": {
          "200": {
            "description": "Encounters.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "results": { "type": "array", "items": { "$ref": "#/components/schemas/Encounter" } } }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createEncounter",
        "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Encounter" } } } },
        "responses": {
          "201": {
            "description": "Created encounter.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Encounter" } } }
          }
        }
      }
    },
    "/ws/rest/v1/obs": {
      "get": {
        "operationId": "listObs",
        "responses": {
          "200": {
            "description": "Observations.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "results": { "type": "array", "items": { "$ref": "#/components/schemas/Obs" } } }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createObs",
        "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Obs" } } } },
        "responses": {
          "201": {
            "description": "Created observation.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Obs" } } }
          }
        }
      }
    },
    "/ws/rest/v1/concept": {
      "get": {
        "operationId": "listConcepts",
        "responses": {
          "200": {
            "description": "Concepts.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "results": { "type": "array", "items": { "$ref": "#/components/schemas/Concept" } } }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createConcept",
        "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Concept" } } } },
        "responses": {
          "201": {
            "description": "Created concept.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Concept" } } }
          }
        }
      }
    },
    "/ws/rest/v1/encountertype": {
      "get": {
        "operationId": "listEncounterTypes",
        "responses": {
          "200": {
            "description": "Encounter types.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "results": { "type": "array", "items": { "$ref": "#/components/schemas/EncounterType" } } }
                }
              }
            }
          }
        }
      }
    },
    "/ws/rest/v1/location": {
      "get": {
        "operationId": "listLocations",
        "responses": {
          "200": {
            "description": "Locations.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "results": { "type": "array", "items": { "$ref": "#/components/schemas/Location" } } }
                }
              }
            }
          }
        }
      }
    },
    "/ws/fhir2/R4/Patient": {
      "get": {
        "operationId": "fhirSearchPatient",
        "summary": "FHIR R4 Patient search (searchset Bundle)",
        "responses": {
          "200": {
            "description": "A FHIR searchset Bundle.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Bundle" } } }
          }
        }
      },
      "post": {
        "operationId": "fhirCreatePatient",
        "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FhirPatient" } } } },
        "responses": {
          "201": {
            "description": "Created FHIR Patient.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FhirPatient" } } }
          }
        }
      }
    },
    "/ws/fhir2/R4/Patient/{id}": {
      "get": {
        "operationId": "fhirReadPatient",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": {
            "description": "A FHIR Patient.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FhirPatient" } } }
          }
        }
      }
    },
    "/ws/fhir2/R4/Encounter": {
      "get": {
        "operationId": "fhirSearchEncounter",
        "responses": {
          "200": {
            "description": "A FHIR searchset Bundle.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Bundle" } } }
          }
        }
      },
      "post": {
        "operationId": "fhirCreateEncounter",
        "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FhirEncounter" } } } },
        "responses": {
          "201": {
            "description": "Created FHIR Encounter.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FhirEncounter" } } }
          }
        }
      }
    },
    "/ws/fhir2/R4/Encounter/{id}": {
      "get": {
        "operationId": "fhirReadEncounter",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": {
            "description": "A FHIR Encounter.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FhirEncounter" } } }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PersonName": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string", "format": "uuid" },
          "display": { "type": "string" },
          "givenName": { "type": "string" },
          "familyName": { "type": "string" },
          "preferred": { "type": "boolean" }
        }
      },
      "PersonAddress": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string", "format": "uuid" },
          "cityVillage": { "type": "string" },
          "country": { "type": "string" },
          "preferred": { "type": "boolean" }
        }
      },
      "Person": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string", "format": "uuid" },
          "display": { "type": "string" },
          "gender": { "type": "string", "enum": ["M", "F", "U"] },
          "birthdate": { "type": "string", "format": "date" },
          "names": { "type": "array", "items": { "$ref": "#/components/schemas/PersonName" } },
          "addresses": { "type": "array", "items": { "$ref": "#/components/schemas/PersonAddress" } }
        }
      },
      "PatientIdentifier": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string", "format": "uuid" },
          "identifier": { "type": "string" },
          "identifierType": {
            "type": "object",
            "properties": { "uuid": { "type": "string" }, "display": { "type": "string" } }
          },
          "preferred": { "type": "boolean" }
        }
      },
      "Patient": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string", "format": "uuid" },
          "display": { "type": "string" },
          "identifiers": { "type": "array", "items": { "$ref": "#/components/schemas/PatientIdentifier" } },
          "person": { "$ref": "#/components/schemas/Person" }
        }
      },
      "NamedRef": {
        "type": "object",
        "properties": { "uuid": { "type": "string" }, "display": { "type": "string" } }
      },
      "Encounter": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string", "format": "uuid" },
          "display": { "type": "string" },
          "encounterDatetime": { "type": "string", "format": "date-time" },
          "encounterType": { "$ref": "#/components/schemas/NamedRef" },
          "patient": { "$ref": "#/components/schemas/NamedRef" },
          "location": { "$ref": "#/components/schemas/NamedRef" }
        }
      },
      "EncounterType": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string", "format": "uuid" },
          "display": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" }
        }
      },
      "Obs": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string", "format": "uuid" },
          "display": { "type": "string" },
          "concept": { "$ref": "#/components/schemas/NamedRef" },
          "value": {},
          "obsDatetime": { "type": "string", "format": "date-time" }
        }
      },
      "Concept": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string", "format": "uuid" },
          "display": { "type": "string" },
          "datatype": {
            "type": "object",
            "properties": { "uuid": { "type": "string" }, "display": { "type": "string" } }
          },
          "conceptClass": {
            "type": "object",
            "properties": { "uuid": { "type": "string" }, "display": { "type": "string" } }
          }
        }
      },
      "Location": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string", "format": "uuid" },
          "display": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "FhirHumanName": {
        "type": "object",
        "properties": {
          "family": { "type": "string" },
          "given": { "type": "array", "items": { "type": "string" } },
          "text": { "type": "string" }
        }
      },
      "FhirPatient": {
        "type": "object",
        "properties": {
          "resourceType": { "type": "string", "enum": ["Patient"] },
          "id": { "type": "string" },
          "active": { "type": "boolean" },
          "identifier": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": { "system": { "type": "string" }, "value": { "type": "string" } }
            }
          },
          "name": { "type": "array", "items": { "$ref": "#/components/schemas/FhirHumanName" } },
          "gender": { "type": "string", "enum": ["male", "female", "unknown"] },
          "birthDate": { "type": "string", "format": "date" },
          "address": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": { "city": { "type": "string" }, "country": { "type": "string" } }
            }
          }
        }
      },
      "FhirEncounter": {
        "type": "object",
        "properties": {
          "resourceType": { "type": "string", "enum": ["Encounter"] },
          "id": { "type": "string" },
          "status": { "type": "string", "enum": ["planned", "arrived", "in-progress", "finished"] },
          "class": {
            "type": "object",
            "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } }
          },
          "subject": {
            "type": "object",
            "properties": { "reference": { "type": "string" }, "display": { "type": "string" } }
          },
          "period": {
            "type": "object",
            "properties": { "start": { "type": "string", "format": "date-time" } }
          }
        }
      },
      "BundleEntry": {
        "type": "object",
        "properties": {
          "fullUrl": { "type": "string" },
          "resource": { "type": "object" },
          "search": { "type": "object", "properties": { "mode": { "type": "string" } } }
        }
      },
      "Bundle": {
        "type": "object",
        "properties": {
          "resourceType": { "type": "string", "enum": ["Bundle"] },
          "type": { "type": "string", "enum": ["searchset"] },
          "total": { "type": "integer" },
          "link": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": { "relation": { "type": "string" }, "url": { "type": "string" } }
            }
          },
          "entry": { "type": "array", "items": { "$ref": "#/components/schemas/BundleEntry" } }
        }
      }
    }
  }
}
