{
  "openapi": "3.0.3",
  "info": {
    "title": "arcgis — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate arcgis. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "arcgis",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "editResultsResponses": {
        "resource": "EditResultsResponse",
        "schema": {
          "$ref": "#/components/schemas/EditResultsResponse"
        }
      },
      "featureSets": {
        "resource": "FeatureSet",
        "schema": {
          "$ref": "#/components/schemas/FeatureSet"
        }
      },
      "geocodeResponses": {
        "resource": "GeocodeResponse",
        "schema": {
          "$ref": "#/components/schemas/GeocodeResponse"
        }
      },
      "tokenResponses": {
        "resource": "TokenResponse",
        "schema": {
          "$ref": "#/components/schemas/TokenResponse"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "editResultsResponses": {
            "type": "object",
            "description": "Records keyed by id for the editResultsResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/EditResultsResponse"
            }
          },
          "featureSets": {
            "type": "object",
            "description": "Records keyed by id for the featureSets collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/FeatureSet"
            }
          },
          "geocodeResponses": {
            "type": "object",
            "description": "Records keyed by id for the geocodeResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/GeocodeResponse"
            }
          },
          "tokenResponses": {
            "type": "object",
            "description": "Records keyed by id for the tokenResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/TokenResponse"
            }
          }
        },
        "additionalProperties": false
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "expires": {
            "type": "integer",
            "format": "int64"
          },
          "ssl": {
            "type": "boolean"
          }
        }
      },
      "Geometry": {
        "type": "object",
        "properties": {
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          },
          "spatialReference": {
            "type": "object",
            "properties": {
              "wkid": {
                "type": "integer",
                "example": 4326
              }
            }
          }
        }
      },
      "Feature": {
        "type": "object",
        "properties": {
          "attributes": {
            "type": "object",
            "additionalProperties": true
          },
          "geometry": {
            "$ref": "#/components/schemas/Geometry"
          }
        }
      },
      "Field": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "example": "esriFieldTypeString"
          },
          "alias": {
            "type": "string"
          },
          "length": {
            "type": "integer"
          }
        }
      },
      "FeatureSet": {
        "type": "object",
        "properties": {
          "objectIdFieldName": {
            "type": "string",
            "example": "OBJECTID"
          },
          "geometryType": {
            "type": "string",
            "example": "esriGeometryPoint"
          },
          "spatialReference": {
            "type": "object",
            "properties": {
              "wkid": {
                "type": "integer",
                "example": 4326
              }
            }
          },
          "fields": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Field"
            }
          },
          "features": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Feature"
            }
          },
          "exceededTransferLimit": {
            "type": "boolean"
          }
        }
      },
      "EditResult": {
        "type": "object",
        "properties": {
          "objectId": {
            "type": "integer"
          },
          "globalId": {
            "type": "string",
            "nullable": true
          },
          "success": {
            "type": "boolean"
          },
          "error": {
            "type": "object",
            "nullable": true,
            "properties": {
              "code": {
                "type": "integer"
              },
              "description": {
                "type": "string"
              }
            }
          }
        }
      },
      "EditResultsResponse": {
        "type": "object",
        "properties": {
          "addResults": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EditResult"
            }
          },
          "updateResults": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EditResult"
            }
          },
          "deleteResults": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EditResult"
            }
          }
        }
      },
      "GeocodeCandidate": {
        "type": "object",
        "properties": {
          "address": {
            "type": "string"
          },
          "location": {
            "type": "object",
            "properties": {
              "x": {
                "type": "number"
              },
              "y": {
                "type": "number"
              }
            }
          },
          "score": {
            "type": "number"
          },
          "attributes": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "GeocodeResponse": {
        "type": "object",
        "properties": {
          "spatialReference": {
            "type": "object",
            "properties": {
              "wkid": {
                "type": "integer",
                "example": 4326
              }
            }
          },
          "candidates": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GeocodeCandidate"
            }
          }
        }
      }
    }
  }
}
