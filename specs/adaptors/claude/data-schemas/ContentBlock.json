{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "claude/ContentBlock",
  "title": "ContentBlock",
  "x-openfn-adaptor": "claude",
  "x-source": {
    "openapi": "#/components/schemas/ContentBlock",
    "capturedAt": "2026-07-06"
  },
  "type": "object",
  "description": "A block of generated content. The most common type is `text`; tool use and thinking blocks may also appear.",
  "required": [
    "type"
  ],
  "properties": {
    "type": {
      "type": "string",
      "example": "text",
      "enum": [
        "text",
        "thinking",
        "redacted_thinking",
        "tool_use",
        "server_tool_use",
        "web_search_tool_result",
        "code_execution_tool_result"
      ]
    },
    "text": {
      "type": "string",
      "description": "Present when type is `text`."
    },
    "thinking": {
      "type": "string",
      "description": "Present when type is `thinking`."
    },
    "id": {
      "type": "string",
      "description": "Present when type is `tool_use`."
    },
    "name": {
      "type": "string",
      "description": "Tool name, present when type is `tool_use`."
    },
    "input": {
      "type": "object",
      "additionalProperties": true,
      "description": "Tool input, present when type is `tool_use`."
    },
    "citations": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  }
}
