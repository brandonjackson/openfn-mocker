{
  "openapi": "3.0.3",
  "info": {
    "title": "claude — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate claude. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "claude",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "messages": {
        "resource": "Message",
        "schema": {
          "$ref": "#/components/schemas/Message"
        }
      },
      "messageBatches": {
        "resource": "MessageBatch",
        "schema": {
          "$ref": "#/components/schemas/MessageBatch"
        }
      },
      "models": {
        "resource": "Model",
        "schema": {
          "$ref": "#/components/schemas/Model"
        }
      },
      "tokenCounts": {
        "resource": "TokenCount",
        "schema": {
          "$ref": "#/components/schemas/TokenCount"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "messages": {
            "type": "object",
            "description": "Records keyed by id for the messages collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Message"
            }
          },
          "messageBatches": {
            "type": "object",
            "description": "Records keyed by id for the messageBatches collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/MessageBatch"
            }
          },
          "models": {
            "type": "object",
            "description": "Records keyed by id for the models collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Model"
            }
          },
          "tokenCounts": {
            "type": "object",
            "description": "Records keyed by id for the tokenCounts collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/TokenCount"
            }
          }
        },
        "additionalProperties": false
      },
      "InputMessage": {
        "type": "object",
        "required": [
          "role",
          "content"
        ],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "user",
              "assistant"
            ]
          },
          "content": {
            "description": "A string, or an array of content blocks.",
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            ]
          }
        }
      },
      "CreateMessageRequest": {
        "type": "object",
        "required": [
          "model",
          "max_tokens",
          "messages"
        ],
        "properties": {
          "model": {
            "type": "string",
            "example": "claude-opus-4-6"
          },
          "max_tokens": {
            "type": "integer",
            "example": 1024
          },
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/InputMessage"
            }
          },
          "system": {
            "description": "System prompt as a string or an array of text blocks.",
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            ]
          },
          "temperature": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "example": 1
          },
          "top_p": {
            "type": "number"
          },
          "top_k": {
            "type": "integer"
          },
          "stop_sequences": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "stream": {
            "type": "boolean",
            "default": false
          },
          "tools": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "tool_choice": {
            "type": "object",
            "additionalProperties": true
          },
          "thinking": {
            "type": "object",
            "additionalProperties": true
          },
          "metadata": {
            "type": "object",
            "properties": {
              "user_id": {
                "type": "string",
                "nullable": true
              }
            }
          },
          "service_tier": {
            "type": "string",
            "enum": [
              "auto",
              "standard_only"
            ]
          }
        }
      },
      "ContentBlock": {
        "type": "object",
        "description": "A block of generated content. The most common type is `text`; tool use and thinking blocks may also appear.",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string",
            "example": "text",
            "enum": [
              "text",
              "thinking",
              "redacted_thinking",
              "tool_use",
              "server_tool_use",
              "web_search_tool_result",
              "code_execution_tool_result"
            ]
          },
          "text": {
            "type": "string",
            "description": "Present when type is `text`."
          },
          "thinking": {
            "type": "string",
            "description": "Present when type is `thinking`."
          },
          "id": {
            "type": "string",
            "description": "Present when type is `tool_use`."
          },
          "name": {
            "type": "string",
            "description": "Tool name, present when type is `tool_use`."
          },
          "input": {
            "type": "object",
            "additionalProperties": true,
            "description": "Tool input, present when type is `tool_use`."
          },
          "citations": {
            "type": "array",
            "nullable": true,
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      },
      "Usage": {
        "type": "object",
        "properties": {
          "input_tokens": {
            "type": "integer",
            "example": 12
          },
          "output_tokens": {
            "type": "integer",
            "example": 68
          },
          "cache_creation_input_tokens": {
            "type": "integer",
            "nullable": true
          },
          "cache_read_input_tokens": {
            "type": "integer",
            "nullable": true
          },
          "service_tier": {
            "type": "string",
            "nullable": true,
            "enum": [
              "standard",
              "priority",
              "batch"
            ]
          }
        }
      },
      "Message": {
        "type": "object",
        "description": "A Message returned by the Messages API.",
        "required": [
          "id",
          "type",
          "role",
          "content",
          "model",
          "usage"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "msg_01XFDUDYJgAACzvnptvVoYEL"
          },
          "type": {
            "type": "string",
            "enum": [
              "message"
            ],
            "example": "message"
          },
          "role": {
            "type": "string",
            "enum": [
              "assistant"
            ],
            "example": "assistant"
          },
          "model": {
            "type": "string",
            "example": "claude-opus-4-6"
          },
          "content": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ContentBlock"
            }
          },
          "stop_reason": {
            "type": "string",
            "nullable": true,
            "enum": [
              "end_turn",
              "max_tokens",
              "stop_sequence",
              "tool_use",
              "pause_turn",
              "refusal"
            ],
            "example": "end_turn"
          },
          "stop_sequence": {
            "type": "string",
            "nullable": true
          },
          "usage": {
            "$ref": "#/components/schemas/Usage"
          }
        }
      },
      "CountTokensRequest": {
        "type": "object",
        "required": [
          "model",
          "messages"
        ],
        "properties": {
          "model": {
            "type": "string",
            "example": "claude-opus-4-6"
          },
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/InputMessage"
            }
          },
          "system": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            ]
          },
          "tools": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      },
      "TokenCount": {
        "type": "object",
        "required": [
          "input_tokens"
        ],
        "properties": {
          "input_tokens": {
            "type": "integer",
            "example": 2095
          }
        }
      },
      "Model": {
        "type": "object",
        "required": [
          "id",
          "type",
          "display_name",
          "created_at"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "claude-opus-4-6"
          },
          "type": {
            "type": "string",
            "enum": [
              "model"
            ],
            "example": "model"
          },
          "display_name": {
            "type": "string",
            "example": "Claude Opus 4.6"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2026-02-04T00:00:00Z"
          }
        }
      },
      "ModelList": {
        "type": "object",
        "required": [
          "data",
          "has_more"
        ],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Model"
            }
          },
          "has_more": {
            "type": "boolean",
            "example": true
          },
          "first_id": {
            "type": "string",
            "nullable": true
          },
          "last_id": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "RequestCounts": {
        "type": "object",
        "properties": {
          "processing": {
            "type": "integer",
            "example": 100
          },
          "succeeded": {
            "type": "integer",
            "example": 50
          },
          "errored": {
            "type": "integer",
            "example": 30
          },
          "canceled": {
            "type": "integer",
            "example": 10
          },
          "expired": {
            "type": "integer",
            "example": 10
          }
        }
      },
      "MessageBatch": {
        "type": "object",
        "required": [
          "id",
          "type",
          "processing_status",
          "request_counts",
          "created_at",
          "expires_at"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "msgbatch_013Zva2CMHLNnXjNJ2wu5wMh"
          },
          "type": {
            "type": "string",
            "enum": [
              "message_batch"
            ],
            "example": "message_batch"
          },
          "processing_status": {
            "type": "string",
            "enum": [
              "in_progress",
              "canceling",
              "ended"
            ],
            "example": "in_progress"
          },
          "request_counts": {
            "$ref": "#/components/schemas/RequestCounts"
          },
          "ended_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2024-08-20T18:37:24.100435Z"
          },
          "expires_at": {
            "type": "string",
            "format": "date-time",
            "example": "2024-08-21T18:37:24.100435Z"
          },
          "archived_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "cancel_initiated_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "results_url": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "MessageBatchList": {
        "type": "object",
        "required": [
          "data",
          "has_more"
        ],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MessageBatch"
            }
          },
          "has_more": {
            "type": "boolean"
          },
          "first_id": {
            "type": "string",
            "nullable": true
          },
          "last_id": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "BatchRequestItem": {
        "type": "object",
        "required": [
          "custom_id",
          "params"
        ],
        "properties": {
          "custom_id": {
            "type": "string",
            "example": "my-first-request"
          },
          "params": {
            "$ref": "#/components/schemas/CreateMessageRequest"
          }
        }
      },
      "CreateMessageBatchRequest": {
        "type": "object",
        "required": [
          "requests"
        ],
        "properties": {
          "requests": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BatchRequestItem"
            }
          }
        }
      }
    }
  }
}
