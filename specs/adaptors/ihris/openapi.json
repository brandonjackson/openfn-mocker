{
  "openapi": "3.0.3",
  "info": {
    "title": "iHRIS FHIR R4 API (mock subset)",
    "version": "4.0.1",
    "description": "Focused subset of the FHIR R4 REST API exposed by an iHRIS server, used by the OpenFn ihris adaptor (which re-exports @openfn/language-fhir-4 builders over an HTTP client). iHRIS is a health-workforce information system; the relevant resources are Practitioner, PractitionerRole, Organization, Location and HealthcareService. Standard FHIR create (POST), read (GET by id), update (PUT) and search (GET → Bundle) interactions. Basic auth.",
    "x-openfn-adaptor": "ihris"
  },
  "servers": [{ "url": "https://ihris.example.com/fhir" }],
  "paths": {
    "/metadata": {
      "get": {
        "operationId": "getCapabilityStatement",
        "summary": "Server capability statement",
        "responses": {
          "200": {
            "description": "CapabilityStatement",
            "content": {
              "application/fhir+json": {
                "schema": { "$ref": "#/components/schemas/CapabilityStatement" }
              }
            }
          }
        }
      }
    },
    "/Practitioner": {
      "get": {
        "operationId": "searchPractitioner",
        "summary": "Search practitioners",
        "parameters": [
          { "name": "name", "in": "query", "schema": { "type": "string" } },
          { "name": "identifier", "in": "query", "schema": { "type": "string" } },
          { "name": "_count", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "A searchset Bundle of practitioners",
            "content": {
              "application/fhir+json": {
                "schema": { "$ref": "#/components/schemas/Bundle" }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createPractitioner",
        "summary": "Create a practitioner",
        "requestBody": {
          "required": true,
          "content": { "application/fhir+json": { "schema": { "$ref": "#/components/schemas/Practitioner" } } }
        },
        "responses": {
          "201": {
            "description": "The created practitioner",
            "content": {
              "application/fhir+json": {
                "schema": { "$ref": "#/components/schemas/Practitioner" }
              }
            }
          }
        }
      }
    },
    "/Practitioner/{id}": {
      "get": {
        "operationId": "getPractitioner",
        "summary": "Read a practitioner by id",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "The practitioner",
            "content": {
              "application/fhir+json": {
                "schema": { "$ref": "#/components/schemas/Practitioner" }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updatePractitioner",
        "summary": "Update a practitioner",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/fhir+json": { "schema": { "$ref": "#/components/schemas/Practitioner" } } }
        },
        "responses": {
          "200": {
            "description": "The updated practitioner",
            "content": {
              "application/fhir+json": {
                "schema": { "$ref": "#/components/schemas/Practitioner" }
              }
            }
          }
        }
      }
    },
    "/PractitionerRole": {
      "get": {
        "operationId": "searchPractitionerRole",
        "summary": "Search practitioner roles",
        "parameters": [
          { "name": "practitioner", "in": "query", "schema": { "type": "string" } },
          { "name": "organization", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "A searchset Bundle of practitioner roles",
            "content": {
              "application/fhir+json": {
                "schema": { "$ref": "#/components/schemas/Bundle" }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createPractitionerRole",
        "summary": "Create a practitioner role",
        "requestBody": {
          "required": true,
          "content": { "application/fhir+json": { "schema": { "$ref": "#/components/schemas/PractitionerRole" } } }
        },
        "responses": {
          "201": {
            "description": "The created practitioner role",
            "content": {
              "application/fhir+json": {
                "schema": { "$ref": "#/components/schemas/PractitionerRole" }
              }
            }
          }
        }
      }
    },
    "/Organization/{id}": {
      "get": {
        "operationId": "getOrganization",
        "summary": "Read an organization by id",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "The organization",
            "content": {
              "application/fhir+json": {
                "schema": { "$ref": "#/components/schemas/Organization" }
              }
            }
          }
        }
      }
    },
    "/Location/{id}": {
      "get": {
        "operationId": "getLocation",
        "summary": "Read a location by id",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "The location",
            "content": {
              "application/fhir+json": {
                "schema": { "$ref": "#/components/schemas/Location" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HumanName": {
        "type": "object",
        "properties": {
          "use": { "type": "string", "example": "official" },
          "text": { "type": "string", "example": "Dr Jane Doe" },
          "family": { "type": "string", "example": "Doe" },
          "given": { "type": "array", "items": { "type": "string" }, "example": ["Jane"] },
          "prefix": { "type": "array", "items": { "type": "string" }, "example": ["Dr"] }
        }
      },
      "Identifier": {
        "type": "object",
        "properties": {
          "use": { "type": "string", "example": "official" },
          "system": { "type": "string", "example": "https://ihris.example.com/identifier/employee" },
          "value": { "type": "string", "example": "EMP-0001" }
        }
      },
      "ContactPoint": {
        "type": "object",
        "properties": {
          "system": { "type": "string", "example": "phone" },
          "value": { "type": "string", "example": "+254700000000" },
          "use": { "type": "string", "example": "work" }
        }
      },
      "CodeableConcept": {
        "type": "object",
        "properties": {
          "coding": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "system": { "type": "string" },
                "code": { "type": "string" },
                "display": { "type": "string" }
              }
            }
          },
          "text": { "type": "string" }
        }
      },
      "Reference": {
        "type": "object",
        "properties": {
          "reference": { "type": "string", "example": "Practitioner/123" },
          "display": { "type": "string" }
        }
      },
      "Practitioner": {
        "type": "object",
        "required": ["resourceType"],
        "properties": {
          "resourceType": { "type": "string", "enum": ["Practitioner"], "example": "Practitioner" },
          "id": { "type": "string", "example": "123" },
          "identifier": { "type": "array", "items": { "$ref": "#/components/schemas/Identifier" } },
          "active": { "type": "boolean", "example": true },
          "name": { "type": "array", "items": { "$ref": "#/components/schemas/HumanName" } },
          "telecom": { "type": "array", "items": { "$ref": "#/components/schemas/ContactPoint" } },
          "gender": { "type": "string", "example": "female" },
          "birthDate": { "type": "string", "format": "date", "example": "1985-04-12" }
        }
      },
      "PractitionerRole": {
        "type": "object",
        "required": ["resourceType"],
        "properties": {
          "resourceType": { "type": "string", "enum": ["PractitionerRole"], "example": "PractitionerRole" },
          "id": { "type": "string", "example": "456" },
          "active": { "type": "boolean", "example": true },
          "practitioner": { "$ref": "#/components/schemas/Reference" },
          "organization": { "$ref": "#/components/schemas/Reference" },
          "location": { "type": "array", "items": { "$ref": "#/components/schemas/Reference" } },
          "code": { "type": "array", "items": { "$ref": "#/components/schemas/CodeableConcept" } },
          "specialty": { "type": "array", "items": { "$ref": "#/components/schemas/CodeableConcept" } }
        }
      },
      "Organization": {
        "type": "object",
        "required": ["resourceType"],
        "properties": {
          "resourceType": { "type": "string", "enum": ["Organization"], "example": "Organization" },
          "id": { "type": "string", "example": "org-1" },
          "identifier": { "type": "array", "items": { "$ref": "#/components/schemas/Identifier" } },
          "active": { "type": "boolean", "example": true },
          "name": { "type": "string", "example": "Ministry of Health" },
          "type": { "type": "array", "items": { "$ref": "#/components/schemas/CodeableConcept" } },
          "telecom": { "type": "array", "items": { "$ref": "#/components/schemas/ContactPoint" } }
        }
      },
      "Location": {
        "type": "object",
        "required": ["resourceType"],
        "properties": {
          "resourceType": { "type": "string", "enum": ["Location"], "example": "Location" },
          "id": { "type": "string", "example": "loc-1" },
          "status": { "type": "string", "example": "active" },
          "name": { "type": "string", "example": "Nairobi County Hospital" },
          "description": { "type": "string" },
          "managingOrganization": { "$ref": "#/components/schemas/Reference" }
        }
      },
      "Bundle": {
        "type": "object",
        "required": ["resourceType"],
        "properties": {
          "resourceType": { "type": "string", "enum": ["Bundle"], "example": "Bundle" },
          "type": { "type": "string", "example": "searchset" },
          "total": { "type": "integer", "example": 1 },
          "link": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "relation": { "type": "string", "example": "self" },
                "url": { "type": "string", "format": "uri" }
              }
            }
          },
          "entry": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "fullUrl": { "type": "string", "format": "uri" },
                "resource": { "$ref": "#/components/schemas/Practitioner" },
                "search": {
                  "type": "object",
                  "properties": { "mode": { "type": "string", "example": "match" } }
                }
              }
            }
          }
        }
      },
      "CapabilityStatement": {
        "type": "object",
        "properties": {
          "resourceType": { "type": "string", "enum": ["CapabilityStatement"], "example": "CapabilityStatement" },
          "status": { "type": "string", "example": "active" },
          "fhirVersion": { "type": "string", "example": "4.0.1" },
          "format": { "type": "array", "items": { "type": "string" }, "example": ["json"] }
        }
      }
    }
  }
}
