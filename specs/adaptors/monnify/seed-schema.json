{
  "openapi": "3.0.3",
  "info": {
    "title": "monnify — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate monnify. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "monnify",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "authResponses": {
        "resource": "AuthResponse",
        "schema": {
          "$ref": "#/components/schemas/AuthResponse"
        }
      },
      "disbursementPageResponses": {
        "resource": "DisbursementPageResponse",
        "schema": {
          "$ref": "#/components/schemas/DisbursementPageResponse"
        }
      },
      "reservedAccountResponses": {
        "resource": "ReservedAccountResponse",
        "schema": {
          "$ref": "#/components/schemas/ReservedAccountResponse"
        }
      },
      "transactionPageResponses": {
        "resource": "TransactionPageResponse",
        "schema": {
          "$ref": "#/components/schemas/TransactionPageResponse"
        }
      },
      "transferResponses": {
        "resource": "TransferResponse",
        "schema": {
          "$ref": "#/components/schemas/TransferResponse"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "authResponses": {
            "type": "object",
            "description": "Records keyed by id for the authResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/AuthResponse"
            }
          },
          "disbursementPageResponses": {
            "type": "object",
            "description": "Records keyed by id for the disbursementPageResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/DisbursementPageResponse"
            }
          },
          "reservedAccountResponses": {
            "type": "object",
            "description": "Records keyed by id for the reservedAccountResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/ReservedAccountResponse"
            }
          },
          "transactionPageResponses": {
            "type": "object",
            "description": "Records keyed by id for the transactionPageResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/TransactionPageResponse"
            }
          },
          "transferResponses": {
            "type": "object",
            "description": "Records keyed by id for the transferResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/TransferResponse"
            }
          }
        },
        "additionalProperties": false
      },
      "MonnifyEnvelope": {
        "type": "object",
        "properties": {
          "requestSuccessful": {
            "type": "boolean",
            "example": true
          },
          "responseMessage": {
            "type": "string",
            "example": "success"
          },
          "responseCode": {
            "type": "string",
            "example": "0"
          }
        }
      },
      "AuthResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/MonnifyEnvelope"
          },
          {
            "type": "object",
            "properties": {
              "responseBody": {
                "type": "object",
                "properties": {
                  "accessToken": {
                    "type": "string",
                    "example": "eyJhbGciOiJIUzUxMiJ9..."
                  },
                  "expiresIn": {
                    "type": "integer",
                    "example": 3600
                  }
                }
              }
            }
          }
        ]
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "transactionReference": {
            "type": "string",
            "example": "MNFY|20250101|000123"
          },
          "paymentReference": {
            "type": "string",
            "example": "PAY-REF-001"
          },
          "amountPaid": {
            "type": "number",
            "example": 5000
          },
          "totalPayable": {
            "type": "number",
            "example": 5000
          },
          "paymentStatus": {
            "type": "string",
            "example": "PAID"
          },
          "currencyCode": {
            "type": "string",
            "example": "NGN"
          },
          "customer": {
            "type": "object",
            "properties": {
              "email": {
                "type": "string",
                "example": "customer@example.com"
              },
              "name": {
                "type": "string",
                "example": "Ada Lovelace"
              }
            }
          },
          "createdOn": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "TransactionPageResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/MonnifyEnvelope"
          },
          {
            "type": "object",
            "properties": {
              "responseBody": {
                "type": "object",
                "properties": {
                  "content": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/Transaction"
                    }
                  },
                  "totalElements": {
                    "type": "integer",
                    "example": 1
                  },
                  "totalPages": {
                    "type": "integer",
                    "example": 1
                  },
                  "number": {
                    "type": "integer",
                    "example": 0
                  }
                }
              }
            }
          }
        ]
      },
      "ReservedAccountInput": {
        "type": "object",
        "properties": {
          "accountReference": {
            "type": "string",
            "example": "cust-001-ref"
          },
          "accountName": {
            "type": "string",
            "example": "Ada Lovelace"
          },
          "currencyCode": {
            "type": "string",
            "example": "NGN"
          },
          "contractCode": {
            "type": "string",
            "example": "4934121686"
          },
          "customerEmail": {
            "type": "string",
            "example": "customer@example.com"
          },
          "customerName": {
            "type": "string",
            "example": "Ada Lovelace"
          }
        }
      },
      "ReservedAccount": {
        "type": "object",
        "properties": {
          "accountReference": {
            "type": "string",
            "example": "cust-001-ref"
          },
          "accountName": {
            "type": "string",
            "example": "Ada Lovelace"
          },
          "reservationReference": {
            "type": "string",
            "example": "RSV-0001"
          },
          "currencyCode": {
            "type": "string",
            "example": "NGN"
          },
          "customerEmail": {
            "type": "string",
            "example": "customer@example.com"
          },
          "accounts": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "bankCode": {
                  "type": "string",
                  "example": "035"
                },
                "bankName": {
                  "type": "string",
                  "example": "Wema Bank"
                },
                "accountNumber": {
                  "type": "string",
                  "example": "1234567890"
                }
              }
            }
          }
        }
      },
      "ReservedAccountResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/MonnifyEnvelope"
          },
          {
            "type": "object",
            "properties": {
              "responseBody": {
                "$ref": "#/components/schemas/ReservedAccount"
              }
            }
          }
        ]
      },
      "TransferInput": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "example": 10000
          },
          "reference": {
            "type": "string",
            "example": "TRF-REF-001"
          },
          "narration": {
            "type": "string",
            "example": "Payout"
          },
          "destinationBankCode": {
            "type": "string",
            "example": "044"
          },
          "destinationAccountNumber": {
            "type": "string",
            "example": "0035785417"
          },
          "currency": {
            "type": "string",
            "example": "NGN"
          },
          "sourceAccountNumber": {
            "type": "string",
            "example": "4864192954"
          }
        }
      },
      "Transfer": {
        "type": "object",
        "properties": {
          "reference": {
            "type": "string",
            "example": "TRF-REF-001"
          },
          "amount": {
            "type": "number",
            "example": 10000
          },
          "status": {
            "type": "string",
            "example": "SUCCESS"
          },
          "destinationAccountNumber": {
            "type": "string",
            "example": "0035785417"
          },
          "destinationBankName": {
            "type": "string",
            "example": "Access Bank"
          },
          "totalFee": {
            "type": "number",
            "example": 10
          },
          "dateCreated": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "TransferResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/MonnifyEnvelope"
          },
          {
            "type": "object",
            "properties": {
              "responseBody": {
                "$ref": "#/components/schemas/Transfer"
              }
            }
          }
        ]
      },
      "DisbursementPageResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/MonnifyEnvelope"
          },
          {
            "type": "object",
            "properties": {
              "responseBody": {
                "type": "object",
                "properties": {
                  "content": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/Transfer"
                    }
                  },
                  "totalElements": {
                    "type": "integer",
                    "example": 1
                  },
                  "totalPages": {
                    "type": "integer",
                    "example": 1
                  }
                }
              }
            }
          }
        ]
      }
    }
  }
}
