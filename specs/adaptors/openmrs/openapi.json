        "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Allergy" } } } },
        "responses": {
          "201": { "description": "Created allergy", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Allergy" } } } }
        }
      }
    },
    "/patient/{uuid}/allergy/{allergyUuid}": {
      "parameters": [
        { "name": "uuid", "in": "path", "required": true, "schema": { "type": "string" } },
        { "name": "allergyUuid", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "get": {
        "operationId": "getPatientAllergy",
        "summary": "Get one allergy subresource by UUID",
        "responses": {
          "200": { "description": "Allergy", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Allergy" } } } },
          "404": { "description": "Not found" }
        }
      }
    },
