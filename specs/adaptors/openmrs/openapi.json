{
  "openapi": "3.0.3",
  "info": {
    "title": "OpenMRS REST Web Services API (mock subset)",
    "version": "2.x",
    "description": "Focused subset of the OpenMRS REST Web Services API (module webservices.rest, served under /ws/rest/v1) used by the OpenFn openmrs adaptor. The adaptor is a generic CRUD wrapper (get/create/update/upsert/destroy) over OpenMRS resource paths. This spec covers the core resources those operations target: patient, person, encounter, obs (observation), concept, location, visit, patientidentifiertype, encountertype, visittype, provider, and the patient/allergy subresource. OpenMRS list endpoints return a { results: [...] } envelope; single-resource GETs return the object directly. Every resource carries uuid, display and links.",
    "x-openfn-adaptor": "openmrs"
  },
  "servers": [
    { "url": "https://demo.openmrs.org/openmrs/ws/rest/v1" }
  ],
  "paths": {
    "/patient": {
      "get": {
        "operationId": "listPatients",
        "summary": "Search patients",
        "parameters": [
          { "name": "q", "in": "query", "schema": { "type": "string" }, "description": "Search query (name or identifier)" },
          { "name": "identifier", "in": "query", "schema": { "type": "string" } },
          { "name": "v", "in": "query", "schema": { "type": "string" }, "description": "Representation: ref | default | full | custom:(...)" },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "startIndex", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Patient search results",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PatientList" } } }
          }
        }
      },
      "post": {
        "operationId": "createPatient",
        "summary": "Create a patient",
        "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Patient" } } } },
        "responses": {
          "201": {
            "description": "Created patient",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Patient" } } }
          }
        }
      }
    },
    "/patient/{uuid}": {
      "parameters": [{ "name": "uuid", "in": "path", "required": true, "schema": { "type": "string" } }],
      "get": {
        "operationId": "getPatient",
        "summary": "Get a patient by UUID",
        "parameters": [{ "name": "v", "in": "query", "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Patient", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Patient" } } } },
          "404": { "description": "Not found" }
        }
      },
      "post": {
        "operationId": "updatePatient",
        "summary": "Update a patient",
        "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Patient" } } } },
        "responses": {
          "200": { "description": "Updated patient", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Patient" } } } }
        }
      },
      "delete": {
        "operationId": "deletePatient",
        "summary": "Void (delete) a patient",
        "parameters": [{ "name": "purge", "in": "query", "schema": { "type": "boolean" } }],
        "responses": { "204": { "description": "Deleted" } }
      }
    },
    "/patient/{uuid}/allergy": {
      "parameters": [{ "name": "uuid", "in": "path", "required": true, "schema": { "type": "string" } }],
      "get": {
        "operationId": "listPatientAllergies",
