  "components": {
    "schemas": {
      "Link": {
        "type": "object",
        "properties": {
          "rel": { "type": "string", "example": "self" },
          "uri": { "type": "string", "example": "https://demo.openmrs.org/openmrs/ws/rest/v1/patient/da7f524f-27ce-4bb2-86d6-6d1d05312bd5" }
        }
      },
      "Reference": {
        "type": "object",
        "description": "Lightweight reference to another OpenMRS resource",
        "properties": {
          "uuid": { "type": "string", "example": "8d871386-c2cc-11de-8d13-0010c6dffd0f" },
          "display": { "type": "string", "example": "Adult Initial" },
          "links": { "type": "array", "items": { "$ref": "#/components/schemas/Link" } }
        }
      },
      "PatientList": {
        "type": "object",
        "properties": {
          "results": { "type": "array", "items": { "$ref": "#/components/schemas/Patient" } }
        }
      },
      "Patient": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string", "example": "da7f524f-27ce-4bb2-86d6-6d1d05312bd5" },
          "display": { "type": "string", "example": "10000X - John Smith" },
          "identifiers": { "type": "array", "items": { "$ref": "#/components/schemas/PatientIdentifier" } },
          "person": { "$ref": "#/components/schemas/Person" },
          "voided": { "type": "boolean", "example": false },
          "links": { "type": "array", "items": { "$ref": "#/components/schemas/Link" } }
        }
      },
      "PatientIdentifier": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string", "example": "857c1c53-c2cc-11de-8d13-0010c6dffd0f" },
          "display": { "type": "string", "example": "OpenMRS ID = 10000X" },
          "identifier": { "type": "string", "example": "10000X" },
          "identifierType": { "$ref": "#/components/schemas/Reference" },
          "location": { "$ref": "#/components/schemas/Reference" },
          "preferred": { "type": "boolean", "example": true },
          "voided": { "type": "boolean", "example": false }
        }
      },
      "PersonList": {
        "type": "object",
        "properties": {
          "results": { "type": "array", "items": { "$ref": "#/components/schemas/Person" } }
        }
      },
      "Person": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string", "example": "8d870ba0-c2cc-11de-8d13-0010c6dffd0f" },
          "display": { "type": "string", "example": "John Smith" },
          "gender": { "type": "string", "example": "M" },
          "age": { "type": "integer", "example": 45 },
          "birthdate": { "type": "string", "example": "1980-04-12T00:00:00.000+0000" },
          "birthdateEstimated": { "type": "boolean", "example": false },
          "dead": { "type": "boolean", "example": false },
          "deathDate": { "type": "string", "nullable": true, "example": null },
          "causeOfDeath": { "$ref": "#/components/schemas/Reference" },
          "preferredName": { "$ref": "#/components/schemas/PersonName" },
          "preferredAddress": { "$ref": "#/components/schemas/PersonAddress" },
          "names": { "type": "array", "items": { "$ref": "#/components/schemas/PersonName" } },
          "addresses": { "type": "array", "items": { "$ref": "#/components/schemas/PersonAddress" } },
          "attributes": { "type": "array", "items": { "$ref": "#/components/schemas/PersonAttribute" } },
          "voided": { "type": "boolean", "example": false },
          "links": { "type": "array", "items": { "$ref": "#/components/schemas/Link" } }
        }
      },
      "PersonName": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string", "example": "8d871386-c2cc-11de-8d13-0010c6dffd0f" },
          "display": { "type": "string", "example": "John Smith" },
          "givenName": { "type": "string", "example": "John" },
          "middleName": { "type": "string", "nullable": true, "example": null },
          "familyName": { "type": "string", "example": "Smith" },
          "preferred": { "type": "boolean", "example": true },
          "voided": { "type": "boolean", "example": false }
        }
      },
      "PersonAddress": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string", "example": "0675e11c-6d3a-4a2f-8f4e-c2f9a8d0e001" },
          "display": { "type": "string", "example": "123 Main St" },
          "address1": { "type": "string", "example": "123 Main St" },
          "cityVillage": { "type": "string", "example": "Boston" },
          "stateProvince": { "type": "string", "example": "MA" },
          "country": { "type": "string", "example": "USA" },
          "postalCode": { "type": "string", "example": "02118" },
          "preferred": { "type": "boolean", "example": true },
          "voided": { "type": "boolean", "example": false }
        }
      },
      "PersonAttribute": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string", "example": "d3d0e64c-9b1a-4c9a-9c2e-2b8f4b6a1234" },
          "display": { "type": "string", "example": "Telephone Number = 555-1234" },
          "value": { "type": "string", "example": "555-1234" },
          "attributeType": { "$ref": "#/components/schemas/Reference" },
          "voided": { "type": "boolean", "example": false }
        }
      },
      "EncounterList": {
        "type": "object",
        "properties": {
          "results": { "type": "array", "items": { "$ref": "#/components/schemas/Encounter" } }
        }
      },
      "Encounter": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string", "example": "e403fafb-e5e4-42d0-9d11-4f52e89d148c" },
          "display": { "type": "string", "example": "Adult Initial 01/04/2024" },
          "encounterDatetime": { "type": "string", "example": "2024-04-01T09:30:00.000+0000" },
          "patient": { "$ref": "#/components/schemas/Reference" },
          "location": { "$ref": "#/components/schemas/Reference" },
          "form": { "$ref": "#/components/schemas/Reference" },
          "encounterType": { "$ref": "#/components/schemas/Reference" },
          "visit": { "$ref": "#/components/schemas/Reference" },
          "obs": { "type": "array", "items": { "$ref": "#/components/schemas/Obs" } },
          "encounterProviders": { "type": "array", "items": { "$ref": "#/components/schemas/EncounterProvider" } },
          "voided": { "type": "boolean", "example": false },
          "links": { "type": "array", "items": { "$ref": "#/components/schemas/Link" } }
        }
      },
      "EncounterProvider": {
        "type": "object",
        "properties": {
