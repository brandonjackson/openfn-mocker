{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "collections/Collection",
  "title": "Collection",
  "x-openfn-adaptor": "collections",
  "x-source": {
    "openapi": "#/components/schemas/Collection",
    "capturedAt": "2026-07-06"
  },
  "type": "object",
  "description": "Metadata for a collection (a named key/value namespace).",
  "properties": {
    "name": {
      "type": "string",
      "description": "Unique name of the collection.",
      "example": "patients-2024"
    },
    "projectId": {
      "type": [
        "string",
        "null"
      ],
      "description": "Lightning project the collection belongs to, if scoped.",
      "example": "3a1e9c2b-5f47-4d8a-9b2e-1c0f7a6d5e4b"
    },
    "itemCount": {
      "type": "integer",
      "description": "Number of items currently stored in the collection.",
      "example": 128
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "example": "2024-01-15T08:30:00Z"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "example": "2024-06-01T12:00:00Z"
    }
  },
  "required": [
    "name"
  ]
}
