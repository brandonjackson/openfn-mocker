{
  "openapi": "3.0.3",
  "info": {
    "title": "gemini — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate gemini. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "gemini",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "generateContentResponses": {
        "resource": "GenerateContentResponse",
        "schema": {
          "$ref": "#/components/schemas/GenerateContentResponse"
        }
      },
      "predictImageResponses": {
        "resource": "PredictImageResponse",
        "schema": {
          "$ref": "#/components/schemas/PredictImageResponse"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "generateContentResponses": {
            "type": "object",
            "description": "Records keyed by id for the generateContentResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/GenerateContentResponse"
            }
          },
          "predictImageResponses": {
            "type": "object",
            "description": "Records keyed by id for the predictImageResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/PredictImageResponse"
            }
          }
        },
        "additionalProperties": false
      },
      "Blob": {
        "type": "object",
        "properties": {
          "mimeType": {
            "type": "string"
          },
          "data": {
            "type": "string",
            "description": "Base64-encoded inline data"
          }
        }
      },
      "Part": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "inlineData": {
            "$ref": "#/components/schemas/Blob"
          }
        }
      },
      "Content": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "user",
              "model"
            ]
          },
          "parts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Part"
            }
          }
        }
      },
      "GenerationConfig": {
        "type": "object",
        "properties": {
          "temperature": {
            "type": "number"
          },
          "topP": {
            "type": "number"
          },
          "topK": {
            "type": "integer"
          },
          "maxOutputTokens": {
            "type": "integer"
          },
          "candidateCount": {
            "type": "integer"
          },
          "responseMimeType": {
            "type": "string"
          }
        }
      },
      "Tool": {
        "type": "object",
        "properties": {
          "googleSearch": {
            "type": "object",
            "additionalProperties": true,
            "description": "Enables Google Search grounding (deepResearch)"
          }
        }
      },
      "GenerateContentRequest": {
        "type": "object",
        "properties": {
          "contents": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Content"
            }
          },
          "systemInstruction": {
            "$ref": "#/components/schemas/Content"
          },
          "tools": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Tool"
            }
          },
          "generationConfig": {
            "$ref": "#/components/schemas/GenerationConfig"
          }
        },
        "required": [
          "contents"
        ]
      },
      "GroundingMetadata": {
        "type": "object",
        "properties": {
          "webSearchQueries": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "groundingChunks": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "web": {
                  "type": "object",
                  "properties": {
                    "uri": {
                      "type": "string",
                      "format": "uri"
                    },
                    "title": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "Candidate": {
        "type": "object",
        "properties": {
          "content": {
            "$ref": "#/components/schemas/Content"
          },
          "finishReason": {
            "type": "string"
          },
          "index": {
            "type": "integer"
          },
          "groundingMetadata": {
            "$ref": "#/components/schemas/GroundingMetadata"
          }
        }
      },
      "UsageMetadata": {
        "type": "object",
        "properties": {
          "promptTokenCount": {
            "type": "integer"
          },
          "candidatesTokenCount": {
            "type": "integer"
          },
          "totalTokenCount": {
            "type": "integer"
          }
        }
      },
      "GenerateContentResponse": {
        "type": "object",
        "properties": {
          "candidates": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Candidate"
            }
          },
          "usageMetadata": {
            "$ref": "#/components/schemas/UsageMetadata"
          },
          "modelVersion": {
            "type": "string"
          }
        }
      },
      "PredictImageRequest": {
        "type": "object",
        "properties": {
          "instances": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "prompt": {
                  "type": "string"
                }
              }
            }
          },
          "parameters": {
            "type": "object",
            "properties": {
              "sampleCount": {
                "type": "integer"
              },
              "aspectRatio": {
                "type": "string"
              },
              "personGeneration": {
                "type": "string"
              }
            }
          }
        },
        "required": [
          "instances"
        ]
      },
      "PredictImageResponse": {
        "type": "object",
        "properties": {
          "predictions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "mimeType": {
                  "type": "string"
                },
                "bytesBase64Encoded": {
                  "type": "string",
                  "description": "Base64-encoded generated image"
                }
              }
            }
          }
        }
      }
    }
  }
}
