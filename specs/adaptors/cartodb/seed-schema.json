{
  "openapi": "3.0.3",
  "info": {
    "title": "cartodb — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate cartodb. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "cartodb",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "importCreatedResponses": {
        "resource": "ImportCreatedResponse",
        "schema": {
          "$ref": "#/components/schemas/ImportCreatedResponse"
        }
      },
      "importJobs": {
        "resource": "ImportJob",
        "schema": {
          "$ref": "#/components/schemas/ImportJob"
        }
      },
      "importLists": {
        "resource": "ImportList",
        "schema": {
          "$ref": "#/components/schemas/ImportList"
        }
      },
      "sqlResponses": {
        "resource": "SqlResponse",
        "schema": {
          "$ref": "#/components/schemas/SqlResponse"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "importCreatedResponses": {
            "type": "object",
            "description": "Records keyed by id for the importCreatedResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/ImportCreatedResponse"
            }
          },
          "importJobs": {
            "type": "object",
            "description": "Records keyed by id for the importJobs collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/ImportJob"
            }
          },
          "importLists": {
            "type": "object",
            "description": "Records keyed by id for the importLists collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/ImportList"
            }
          },
          "sqlResponses": {
            "type": "object",
            "description": "Records keyed by id for the sqlResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/SqlResponse"
            }
          }
        },
        "additionalProperties": false
      },
      "SqlRequest": {
        "type": "object",
        "required": [
          "q"
        ],
        "properties": {
          "q": {
            "type": "string",
            "description": "SQL statement to execute.",
            "example": "INSERT INTO users (name, age, city) VALUES ('Alice', 25, 'New York')"
          },
          "api_key": {
            "type": "string",
            "description": "CARTO API key."
          },
          "format": {
            "type": "string",
            "enum": [
              "json",
              "geojson",
              "csv"
            ],
            "default": "json"
          }
        }
      },
      "SqlResponse": {
        "type": "object",
        "description": "Standard JSON result of an SQL API query.",
        "properties": {
          "rows": {
            "type": "array",
            "description": "The rows returned by the query. Each row is an object keyed by column name.",
            "items": {
              "$ref": "#/components/schemas/SqlRow"
            }
          },
          "time": {
            "type": "number",
            "format": "float",
            "description": "Query execution time in seconds.",
            "example": 0.006
          },
          "fields": {
            "type": "object",
            "description": "Map of column name to its type descriptor.",
            "additionalProperties": {
              "$ref": "#/components/schemas/SqlField"
            },
            "example": {
              "cartodb_id": {
                "type": "number"
              },
              "name": {
                "type": "string"
              },
              "the_geom": {
                "type": "geometry"
              }
            }
          },
          "total_rows": {
            "type": "integer",
            "description": "Number of rows affected or returned.",
            "example": 1
          }
        }
      },
      "SqlRow": {
        "type": "object",
        "description": "A single result row keyed by column name.",
        "additionalProperties": true,
        "example": {
          "cartodb_id": 1,
          "name": "Alice",
          "age": 25,
          "city": "New York"
        }
      },
      "SqlField": {
        "type": "object",
        "description": "Type descriptor for a returned column.",
        "properties": {
          "type": {
            "type": "string",
            "description": "PostgreSQL/CARTO column type family.",
            "example": "string"
          },
          "pgtype": {
            "type": "string",
            "description": "Underlying PostgreSQL type name.",
            "example": "text"
          }
        }
      },
      "SqlError": {
        "type": "object",
        "description": "Error response from the SQL API. Contains the full PostgreSQL error text.",
        "properties": {
          "error": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "syntax error at or near \"SELECt\""
            ]
          },
          "hint": {
            "type": "string",
            "description": "Optional PostgreSQL hint."
          }
        }
      },
      "ImportRequest": {
        "type": "object",
        "description": "Payload for creating an import. Provide either an uploaded file or a remote url.",
        "properties": {
          "file": {
            "type": "string",
            "format": "binary",
            "description": "The dataset file to upload (CSV, GeoJSON, SHP zip, etc.)."
          },
          "url": {
            "type": "string",
            "description": "Remote URL of the dataset to import."
          },
          "table_name": {
            "type": "string",
            "description": "Optional target table name for the imported dataset."
          }
        }
      },
      "ImportCreatedResponse": {
        "type": "object",
        "description": "Acknowledgement returned when an import job is queued.",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "item_queue_id": {
            "type": "string",
            "description": "Identifier used to poll the import job.",
            "example": "5e35bbec-4a48-4bf0-b95a-99a67cb0d6f2"
          }
        }
      },
      "ImportList": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "imports": {
            "type": "array",
            "description": "Identifiers of import jobs.",
            "items": {
              "type": "string"
            },
            "example": [
              "5e35bbec-4a48-4bf0-b95a-99a67cb0d6f2"
            ]
          }
        }
      },
      "ImportJob": {
        "type": "object",
        "description": "State of an asynchronous import job.",
        "properties": {
          "id": {
            "type": "string",
            "example": "5e35bbec-4a48-4bf0-b95a-99a67cb0d6f2"
          },
          "item_queue_id": {
            "type": "string",
            "example": "5e35bbec-4a48-4bf0-b95a-99a67cb0d6f2"
          },
          "user_id": {
            "type": "string",
            "example": "0d3f0dfa-1e12-4b2a-9b1a-000000000000"
          },
          "table_id": {
            "type": "string",
            "nullable": true
          },
          "state": {
            "type": "string",
            "description": "Job lifecycle state.",
            "enum": [
              "enqueued",
              "pending",
              "uploading",
              "importing",
              "complete",
              "failure"
            ],
            "example": "complete"
          },
          "success": {
            "type": "boolean",
            "example": true
          },
          "table_name": {
            "type": "string",
            "nullable": true,
            "example": "my_dataset"
          },
          "tables_created_count": {
            "type": "integer",
            "example": 1
          },
          "queue_id": {
            "type": "string",
            "example": "5e35bbec-4a48-4bf0-b95a-99a67cb0d6f2"
          },
          "error_code": {
            "type": "integer",
            "nullable": true,
            "example": null
          },
          "get_error_text": {
            "type": "object",
            "nullable": true,
            "properties": {
              "title": {
                "type": "string"
              },
              "what_about": {
                "type": "string"
              },
              "source": {
                "type": "string"
              }
            }
          },
          "warnings": {
            "type": "string",
            "nullable": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
