{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cartodb/SqlResponse",
  "title": "SqlResponse",
  "x-openfn-adaptor": "cartodb",
  "x-source": {
    "openapi": "#/components/schemas/SqlResponse",
    "capturedAt": "2026-07-06"
  },
  "type": "object",
  "description": "Standard JSON result of an SQL API query.",
  "properties": {
    "rows": {
      "type": "array",
      "description": "The rows returned by the query. Each row is an object keyed by column name.",
      "items": {
        "$ref": "SqlRow.json"
      }
    },
    "time": {
      "type": "number",
      "format": "float",
      "description": "Query execution time in seconds.",
      "example": 0.006
    },
    "fields": {
      "type": "object",
      "description": "Map of column name to its type descriptor.",
      "additionalProperties": {
        "$ref": "SqlField.json"
      },
      "example": {
        "cartodb_id": {
          "type": "number"
        },
        "name": {
          "type": "string"
        },
        "the_geom": {
          "type": "geometry"
        }
      }
    },
    "total_rows": {
      "type": "integer",
      "description": "Number of rows affected or returned.",
      "example": 1
    }
  }
}
