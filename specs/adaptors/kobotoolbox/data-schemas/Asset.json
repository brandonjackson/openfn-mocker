      "type": "string",
      "format": "uri",
      "example": "https://kf.kobotoolbox.org/api/v2/assets/aBeA23YCYjkGTFvYVHuAyU/exports/",
      "readOnly": true
    },
    "export_settings": {
      "type": "array",
      "items": {
        "$ref": "AssetExportSettings.json"
      },
      "readOnly": true
    },
    "data": {
      "type": "string",
      "format": "uri",
      "example": "https://kf.kobotoolbox.org/api/v2/assets/aBeA23YCYjkGTFvYVHuAyU/data/",
