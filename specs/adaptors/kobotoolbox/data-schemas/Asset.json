          "type": "object"
        },
        "country": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "description": {
          "type": "string"
        },
        "collects_pii": {
          "type": "string"
        },
        "organization": {
          "type": "string"
        },
        "country_codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "operational_purpose": {
          "type": "string"
        }
      }
    },
    "asset_type": {
      "$ref": "AssetTypeEnum.json"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "readOnly": true
    },
    "summary": {
      "type": "object",
      "properties": {
        "geo": {
          "type": "boolean"
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "columns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "lock_all": {
          "type": "boolean"
        },
        "lock_any": {
          "type": "boolean"
        },
