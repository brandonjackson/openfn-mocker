      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "format": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      },
      "readOnly": true
    },
    "embeds": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "format": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      },
      "readOnly": true
