            "type": "object"
          }
        },
        "settings": {
          "type": "object"
        },
        "translated": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "translations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
