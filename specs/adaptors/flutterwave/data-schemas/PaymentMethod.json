{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flutterwave/PaymentMethod",
  "title": "PaymentMethod",
  "x-openfn-adaptor": "flutterwave",
  "x-source": {
    "openapi": "#/components/schemas/PaymentMethod",
    "capturedAt": "2026-07-06"
  },
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Payment method id, e.g. pmd_xxx"
    },
    "type": {
      "type": "string",
      "enum": [
        "card",
        "bank_transfer",
        "mobile_money",
        "ussd",
        "google_pay",
        "apple_pay"
      ]
    },
    "customer_id": {
      "type": "string"
    },
    "card": {
      "type": "object",
      "properties": {
        "nickname": {
          "type": "string"
        },
        "first6": {
          "type": "string"
        },
        "last4": {
          "type": "string"
        },
        "expiry_month": {
          "type": "integer"
        },
        "expiry_year": {
          "type": "integer"
        },
        "card_holder_name": {
          "type": "string"
        }
      }
    },
    "mobile_money": {
      "type": "object",
      "properties": {
        "network": {
          "type": "string"
        },
        "country_code": {
          "type": "string"
        },
        "phone_number": {
          "type": "string"
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    },
    "created_datetime": {
      "type": "string",
      "format": "date-time"
    }
  }
}
