{
  "openapi": "3.0.3",
  "info": {
    "title": "flutterwave — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate flutterwave. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "flutterwave",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "charges": {
        "resource": "Charge",
        "schema": {
          "$ref": "#/components/schemas/Charge"
        }
      },
      "customers": {
        "resource": "Customer",
        "schema": {
          "$ref": "#/components/schemas/Customer"
        }
      },
      "paymentMethods": {
        "resource": "PaymentMethod",
        "schema": {
          "$ref": "#/components/schemas/PaymentMethod"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "charges": {
            "type": "object",
            "description": "Records keyed by id for the charges collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Charge"
            }
          },
          "customers": {
            "type": "object",
            "description": "Records keyed by id for the customers collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Customer"
            }
          },
          "paymentMethods": {
            "type": "object",
            "description": "Records keyed by id for the paymentMethods collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/PaymentMethod"
            }
          }
        },
        "additionalProperties": false
      },
      "Customer": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Flutterwave customer id, e.g. cus_xxx"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "name": {
            "type": "object",
            "properties": {
              "first": {
                "type": "string"
              },
              "middle": {
                "type": "string"
              },
              "last": {
                "type": "string"
              }
            }
          },
          "phone": {
            "type": "object",
            "properties": {
              "country_code": {
                "type": "string"
              },
              "number": {
                "type": "string"
              }
            }
          },
          "address": {
            "type": "object",
            "properties": {
              "line1": {
                "type": "string"
              },
              "line2": {
                "type": "string"
              },
              "city": {
                "type": "string"
              },
              "state": {
                "type": "string"
              },
              "postal_code": {
                "type": "string"
              },
              "country": {
                "type": "string"
              }
            }
          },
          "meta": {
            "type": "object",
            "additionalProperties": true
          },
          "created_datetime": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "PaymentMethod": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Payment method id, e.g. pmd_xxx"
          },
          "type": {
            "type": "string",
            "enum": [
              "card",
              "bank_transfer",
              "mobile_money",
              "ussd",
              "google_pay",
              "apple_pay"
            ]
          },
          "customer_id": {
            "type": "string"
          },
          "card": {
            "type": "object",
            "properties": {
              "nickname": {
                "type": "string"
              },
              "first6": {
                "type": "string"
              },
              "last4": {
                "type": "string"
              },
              "expiry_month": {
                "type": "integer"
              },
              "expiry_year": {
                "type": "integer"
              },
              "card_holder_name": {
                "type": "string"
              }
            }
          },
          "mobile_money": {
            "type": "object",
            "properties": {
              "network": {
                "type": "string"
              },
              "country_code": {
                "type": "string"
              },
              "phone_number": {
                "type": "string"
              }
            }
          },
          "meta": {
            "type": "object",
            "additionalProperties": true
          },
          "created_datetime": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Charge": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Charge id, e.g. chg_xxx"
          },
          "amount": {
            "type": "number"
          },
          "currency": {
            "type": "string",
            "example": "NGN"
          },
          "customer_id": {
            "type": "string"
          },
          "payment_method_id": {
            "type": "string"
          },
          "reference": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "requires_action",
              "succeeded",
              "failed"
            ]
          },
          "processor_response": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "code": {
                "type": "string"
              }
            }
          },
          "next_action": {
            "type": "object",
            "additionalProperties": true
          },
          "redirect_url": {
            "type": "string",
            "format": "uri"
          },
          "meta": {
            "type": "object",
            "additionalProperties": true
          },
          "created_datetime": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CustomerResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "success"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/Customer"
          }
        }
      },
      "CustomerListResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "message": {
            "type": "string"
