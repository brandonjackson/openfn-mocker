{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "khanacademy/Video",
  "title": "Video",
  "x-openfn-adaptor": "khanacademy",
  "x-source": {
    "openapi": "#/components/schemas/Video",
    "capturedAt": "2026-07-06"
  },
  "type": "object",
  "description": "A Khan Academy video.",
  "properties": {
    "kind": {
      "type": "string",
      "example": "Video"
    },
    "id": {
