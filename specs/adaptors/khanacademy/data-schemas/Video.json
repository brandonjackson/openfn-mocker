      "example": "xba62d78"
    },
    "readable_id": {
      "type": "string",
      "example": "adding-and-subtracting-fractions"
    },
    "title": {
      "type": "string",
      "example": "Adding and subtracting fractions"
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "youtube_id": {
      "type": "string",
      "example": "52ZlXsFJULI"
    },
    "duration": {
      "type": "integer",
      "example": 233
    },
    "date_added": {
      "type": "string",
      "format": "date-time"
    },
    "views": {
      "type": "integer",
      "example": 123456
    },
    "keywords": {
      "type": "string",
      "example": "fractions, adding, subtracting"
    },
    "ka_url": {
      "type": "string",
      "example": "https://www.khanacademy.org/video/adding-and-subtracting-fractions"
    },
    "url": {
      "type": "string",
      "example": "https://www.youtube.com/watch?v=52ZlXsFJULI"
