{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "khanacademy/User",
  "title": "User",
  "x-openfn-adaptor": "khanacademy",
  "x-source": {
    "openapi": "#/components/schemas/User",
    "capturedAt": "2026-07-06"
  },
  "type": "object",
  "description": "A Khan Academy user profile.",
  "properties": {
    "kind": {
      "type": "string",
      "example": "UserProfile"
    },
    "user_id": {
      "type": "string",
      "example": "http://googleid.khanacademy.org/1234567890"
    },
    "username": {
      "type": "string",
      "example": "learner123"
    },
    "nickname": {
      "type": "string",
      "example": "Jane Learner"
    },
    "email": {
      "type": [
        "string",
        "null"
      ],
      "format": "email"
    },
    "prettified_user_email": {
      "type": [
        "string",
        "null"
      ]
    },
    "points": {
      "type": "integer",
      "example": 45230
    },
    "total_seconds_watched": {
      "type": "integer",
      "example": 18320
    },
    "joined": {
      "type": "string",
      "format": "date-time"
    },
    "is_registered": {
      "type": "boolean"
    },
    "badge_counts": {
      "type": "object",
      "additionalProperties": {
        "type": "integer"
      },
      "example": {
        "0": 5,
        "1": 3,
        "2": 1
      }
    }
  },
  "required": [
    "kind",
    "user_id"
  ]
}
