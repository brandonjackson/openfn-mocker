{
  "openapi": "3.0.3",
  "info": {
    "title": "khanacademy — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate khanacademy. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "khanacademy",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "badges": {
        "resource": "Badge",
        "schema": {
          "$ref": "#/components/schemas/Badge"
        }
      },
      "badgeCategories": {
        "resource": "BadgeCategory",
        "schema": {
          "$ref": "#/components/schemas/BadgeCategory"
        }
      },
      "exercises": {
        "resource": "Exercise",
        "schema": {
          "$ref": "#/components/schemas/Exercise"
        }
      },
      "playlists": {
        "resource": "Playlist",
        "schema": {
          "$ref": "#/components/schemas/Playlist"
        }
      },
      "topics": {
        "resource": "Topic",
        "schema": {
          "$ref": "#/components/schemas/Topic"
        }
      },
      "users": {
        "resource": "User",
        "schema": {
          "$ref": "#/components/schemas/User"
        }
      },
      "videos": {
        "resource": "Video",
        "schema": {
          "$ref": "#/components/schemas/Video"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "badges": {
            "type": "object",
            "description": "Records keyed by id for the badges collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Badge"
            }
          },
          "badgeCategories": {
            "type": "object",
            "description": "Records keyed by id for the badgeCategories collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/BadgeCategory"
            }
          },
          "exercises": {
            "type": "object",
            "description": "Records keyed by id for the exercises collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Exercise"
            }
          },
          "playlists": {
            "type": "object",
            "description": "Records keyed by id for the playlists collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Playlist"
            }
          },
          "topics": {
            "type": "object",
            "description": "Records keyed by id for the topics collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Topic"
            }
          },
          "users": {
            "type": "object",
            "description": "Records keyed by id for the users collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/User"
            }
          },
          "videos": {
            "type": "object",
            "description": "Records keyed by id for the videos collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Video"
            }
          }
        },
        "additionalProperties": false
      },
      "Topic": {
        "type": "object",
        "description": "A node in the Khan Academy content topic tree.",
        "properties": {
          "kind": {
            "type": "string",
            "example": "Topic"
          },
          "id": {
            "type": "string",
            "example": "x2e352b1a2d21e07e"
          },
          "slug": {
            "type": "string",
            "example": "algebra"
          },
          "title": {
            "type": "string",
            "example": "Algebra"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "node_slug": {
            "type": "string",
            "example": "math/algebra"
          },
          "extended_slug": {
            "type": "string",
            "example": "math/algebra"
          },
          "relative_url": {
            "type": "string",
            "example": "/math/algebra"
          },
          "ka_url": {
            "type": "string",
            "example": "https://www.khanacademy.org/math/algebra"
          },
          "render_type": {
            "type": "string",
            "example": "Subject"
          },
          "icon_src": {
            "type": "string",
            "nullable": true
          },
          "hide": {
            "type": "boolean"
          },
          "children": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Topic"
            }
          }
        },
        "required": [
          "kind",
          "id",
          "slug",
          "title"
        ]
      },
      "Exercise": {
        "type": "object",
