  "components": {
    "schemas": {
      "PageMeta": {
        "type": "object",
        "description": "Spring Data style pagination metadata shared by list endpoints.",
        "properties": {
          "totalElements": { "type": "integer" },
          "totalPages": { "type": "integer" },
          "number": { "type": "integer", "description": "Zero-based page index" },
          "numberOfElements": { "type": "integer" },
          "size": { "type": "integer" },
          "first": { "type": "boolean" },
          "last": { "type": "boolean" }
        }
      },
      "ObjectReference": {
        "type": "object",
        "description": "Lightweight reference to another resource by id and href.",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "href": { "type": "string" },
          "code": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "Facility": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "code": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "active": { "type": "boolean" },
          "enabled": { "type": "boolean" },
          "goLiveDate": { "type": "string", "format": "date" },
          "comment": { "type": "string" },
          "geographicZone": { "$ref": "#/components/schemas/GeographicZone" },
          "type": { "$ref": "#/components/schemas/FacilityType" },
          "operator": { "$ref": "#/components/schemas/ObjectReference" },
          "supportedPrograms": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ObjectReference" }
          }
        }
      },
      "FacilityPage": {
        "allOf": [
          { "$ref": "#/components/schemas/PageMeta" },
          {
            "type": "object",
            "properties": {
              "content": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/Facility" }
              }
            }
          }
        ]
      },
      "FacilityType": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "code": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "displayOrder": { "type": "integer" },
          "active": { "type": "boolean" }
        }
      },
      "FacilityTypePage": {
        "allOf": [
          { "$ref": "#/components/schemas/PageMeta" },
          {
            "type": "object",
            "properties": {
              "content": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/FacilityType" }
              }
            }
          }
        ]
      },
      "Program": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "code": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "active": { "type": "boolean" },
          "periodsSkippable": { "type": "boolean" },
          "skipAuthorization": { "type": "boolean" },
          "showNonFullSupplyTab": { "type": "boolean" },
          "enableDatePhysicalStockCountCompleted": { "type": "boolean" }
        }
      },
      "Orderable": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "productCode": { "type": "string" },
          "fullProductName": { "type": "string" },
          "description": { "type": "string" },
          "netContent": { "type": "integer" },
          "packRoundingThreshold": { "type": "integer" },
          "roundToZero": { "type": "boolean" },
          "dispensable": {
            "type": "object",
            "properties": {
              "dispensingUnit": { "type": "string" }
            }
          },
          "programOrderables": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "programId": { "type": "string", "format": "uuid" },
                "orderableDisplayCategoryId": { "type": "string", "format": "uuid" },
                "active": { "type": "boolean" },
                "fullSupply": { "type": "boolean" },
                "pricePerPack": { "type": "number" }
              }
            }
          },
          "identifiers": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "meta": {
            "type": "object",
            "properties": {
              "versionNumber": { "type": "integer" },
              "lastUpdated": { "type": "string", "format": "date-time" }
            }
          }
        }
      },
      "OrderablePage": {
        "allOf": [
          { "$ref": "#/components/schemas/PageMeta" },
          {
            "type": "object",
            "properties": {
              "content": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/Orderable" }
              }
            }
          }
        ]
      },
      "GeographicZone": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "code": { "type": "string" },
          "name": { "type": "string" },
          "level": { "$ref": "#/components/schemas/ObjectReference" },
          "catchmentPopulation": { "type": "integer" },
          "latitude": { "type": "number" },
          "longitude": { "type": "number" },
          "parent": { "$ref": "#/components/schemas/ObjectReference" }
        }
      },
      "GeographicZonePage": {
        "allOf": [
          { "$ref": "#/components/schemas/PageMeta" },
          {
            "type": "object",
            "properties": {
              "content": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/GeographicZone" }
              }
            }
          }
        ]
      },
      "ProcessingPeriod": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "startDate": { "type": "string", "format": "date" },
          "endDate": { "type": "string", "format": "date" },
          "durationInMonths": { "type": "integer" },
          "processingSchedule": { "$ref": "#/components/schemas/ObjectReference" }
        }
      },
      "ProcessingPeriodPage": {
        "allOf": [
          { "$ref": "#/components/schemas/PageMeta" },
          {
            "type": "object",
            "properties": {
              "content": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/ProcessingPeriod" }
              }
            }
          }
        ]
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "username": { "type": "string" },
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "jobTitle": { "type": "string" },
          "timezone": { "type": "string" },
          "homeFacilityId": { "type": "string", "format": "uuid" },
          "active": { "type": "boolean" },
          "roleAssignments": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "roleId": { "type": "string", "format": "uuid" },
                "programId": { "type": "string", "format": "uuid" },
                "supervisoryNodeId": { "type": "string", "format": "uuid" },
                "warehouseId": { "type": "string", "format": "uuid" }
              }
            }
          }
        }
      },
      "UserPage": {
        "allOf": [
          { "$ref": "#/components/schemas/PageMeta" },
          {
            "type": "object",
            "properties": {
              "content": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/User" }
              }
            }
          }
        ]
      },
      "SupplyLine": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "supervisoryNode": { "$ref": "#/components/schemas/ObjectReference" },
          "program": { "$ref": "#/components/schemas/ObjectReference" },
          "supplyingFacility": { "$ref": "#/components/schemas/ObjectReference" }
        }
      },
      "SupplyLinePage": {
        "allOf": [
          { "$ref": "#/components/schemas/PageMeta" },
          {
            "type": "object",
            "properties": {
              "content": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/SupplyLine" }
              }
            }
          }
        ]
      },
      "SupervisoryNode": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "code": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "facility": { "$ref": "#/components/schemas/ObjectReference" },
          "parentNode": { "$ref": "#/components/schemas/ObjectReference" },
          "requisitionGroup": { "$ref": "#/components/schemas/ObjectReference" }
        }
      },
      "SupervisoryNodePage": {
        "allOf": [
          { "$ref": "#/components/schemas/PageMeta" },
          {
            "type": "object",
            "properties": {
              "content": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/SupervisoryNode" }
