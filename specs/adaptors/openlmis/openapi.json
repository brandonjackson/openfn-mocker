{
  "openapi": "3.0.3",
  "info": {
    "title": "OpenLMIS API (mock subset)",
    "version": "3.x",
    "description": "Focused subset of the OpenLMIS v3 microservices REST API used by the OpenFn openlmis adaptor. The adaptor is a thin HTTP client (get/post/put/request) whose base URL points at an OpenLMIS gateway (…/api). This document covers the most commonly integrated Reference Data resources (facilities, programs, orderables/products, facility types, geographic zones, processing periods, users, supply lines, supervisory nodes, lots), Requisition and Fulfillment (orders) resources, and Stock Management summaries. List endpoints return Spring Data style paginated wrappers.",
    "x-openfn-adaptor": "openlmis"
  },
  "servers": [
    { "url": "https://demo.openlmis.org/api" }
  ],
  "paths": {
    "/facilities": {
      "get": {
        "operationId": "listFacilities",
        "summary": "List/search facilities",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "size", "in": "query", "schema": { "type": "integer" } },
          { "name": "name", "in": "query", "schema": { "type": "string" } },
          { "name": "code", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Paged facilities",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/FacilityPage" }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createFacility",
        "summary": "Create a facility",
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/Facility" } }
          }
        },
        "responses": {
          "201": {
            "description": "Created facility",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Facility" } }
            }
          }
        }
      }
    },
    "/facilities/{id}": {
      "get": {
        "operationId": "getFacility",
        "summary": "Get a facility by id",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Facility",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Facility" } }
            }
          },
          "404": { "description": "Not found" }
        }
      },
      "put": {
        "operationId": "updateFacility",
        "summary": "Create or update a facility",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/Facility" } }
          }
        },
        "responses": {
          "200": {
            "description": "Updated facility",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Facility" } }
            }
          }
        }
      }
    },
