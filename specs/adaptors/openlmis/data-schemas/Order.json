{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openlmis/Order",
  "title": "Order",
  "x-openfn-adaptor": "openlmis",
  "x-source": {
    "openapi": "#/components/schemas/Order",
    "capturedAt": "2026-07-06"
  },
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "orderCode": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "ORDERED",
        "FULFILLING",
        "SHIPPED",
        "RECEIVED",
        "TRANSFER_FAILED",
        "IN_ROUTE",
        "READY_TO_PACK"
      ]
    },
    "emergency": {
      "type": "boolean"
    },
    "program": {
      "$ref": "ObjectReference.json"
    },
    "requestingFacility": {
      "$ref": "ObjectReference.json"
    },
    "supplyingFacility": {
      "$ref": "ObjectReference.json"
    },
    "receivingFacility": {
      "$ref": "ObjectReference.json"
    },
    "processingPeriod": {
      "$ref": "ObjectReference.json"
    },
    "createdDate": {
      "type": "string",
      "format": "date-time"
    },
    "orderLineItems": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "orderable": {
            "$ref": "ObjectReference.json"
          },
          "orderedQuantity": {
            "type": "integer"
          }
        }
      }
    }
  }
}
