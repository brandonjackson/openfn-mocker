{
  "openapi": "3.0.3",
  "info": {
    "title": "Ping (SPING) adaptor surface (synthesized)",
    "version": "1.0",
    "description": "The OpenFn ping adaptor is a thin HTTP client (generic get/post/request helpers) that authenticates against an Azure AD B2C token endpoint and calls an Azure API Management-fronted 'SPING' API (scope apimurls/API.Read). It exposes no documented public operations and has no public vendor spec, so this OpenAPI 3.0 document is synthesized from the adaptor surface: a token endpoint, a connectivity/health probe, and generic resource read/write paths reflecting the get/post/request helpers.",
    "x-openfn-adaptor": "ping"
  },
  "servers": [
    { "url": "https://sping.example.azure-api.net", "description": "Azure APIM-fronted SPING API (instance-specific)" }
  ],
  "paths": {
    "/token": {
      "post": {
        "operationId": "requestToken",
        "summary": "Obtain an OAuth2 bearer token from the Azure AD B2C token endpoint",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": { "$ref": "#/components/schemas/TokenRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/TokenResponse" } }
            }
          }
        }
      }
    },
    "/ping": {
      "get": {
        "operationId": "ping",
        "summary": "Connectivity/health probe",
        "responses": {
          "200": {
            "description": "Service is reachable",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/PingResult" } }
            }
          }
        }
      }
    },
    "/records": {
      "get": {
        "operationId": "getRecords",
        "summary": "Generic GET read (get helper)",
        "parameters": [
          { "name": "query", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "A list of records",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/RecordList" } }
            }
          }
        }
      },
      "post": {
        "operationId": "postRecord",
        "summary": "Generic POST write (post helper)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/Record" } }
          }
        },
        "responses": {
          "200": {
            "description": "The created record",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Record" } }
            }
          }
        }
      }
    },
    "/records/{id}": {
      "parameters": [
        { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "get": {
        "operationId": "getRecord",
        "summary": "Fetch a single record by id",
        "responses": {
          "200": {
            "description": "A record",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Record" } }
            }
          },
          "404": { "description": "Not found" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TokenRequest": {
        "type": "object",
        "required": ["grant_type", "username", "password", "scope"],
        "properties": {
          "grant_type": { "type": "string", "example": "password" },
          "username": { "type": "string" },
          "password": { "type": "string" },
          "scope": { "type": "string", "example": "apimurls/API.Read" }
        }
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "access_token": { "type": "string" },
          "token_type": { "type": "string", "example": "Bearer" },
          "expires_in": { "type": "integer", "example": 3600 },
          "scope": { "type": "string" }
        }
      },
      "PingResult": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "ok" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "Record": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "attributes": { "type": "object", "additionalProperties": true },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "RecordList": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Record" } },
          "count": { "type": "integer" }
        }
      }
    }
  }
}
