{
  "openapi": "3.0.3",
  "info": {
    "title": "ping — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate ping. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "ping",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "pingResults": {
        "resource": "PingResult",
        "schema": {
          "$ref": "#/components/schemas/PingResult"
        }
      },
      "records": {
        "resource": "Record",
        "schema": {
          "$ref": "#/components/schemas/Record"
        }
      },
      "tokenResponses": {
        "resource": "TokenResponse",
        "schema": {
          "$ref": "#/components/schemas/TokenResponse"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "pingResults": {
            "type": "object",
            "description": "Records keyed by id for the pingResults collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/PingResult"
            }
          },
          "records": {
            "type": "object",
            "description": "Records keyed by id for the records collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Record"
            }
          },
          "tokenResponses": {
            "type": "object",
            "description": "Records keyed by id for the tokenResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/TokenResponse"
            }
          }
        },
        "additionalProperties": false
      },
      "TokenRequest": {
        "type": "object",
        "required": [
          "grant_type",
          "username",
          "password",
          "scope"
        ],
        "properties": {
          "grant_type": {
            "type": "string",
            "example": "password"
          },
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "scope": {
            "type": "string",
            "example": "apimurls/API.Read"
          }
        }
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string"
          },
          "token_type": {
            "type": "string",
            "example": "Bearer"
          },
          "expires_in": {
            "type": "integer",
            "example": 3600
          },
          "scope": {
            "type": "string"
          }
        }
      },
      "PingResult": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "ok"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Record": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "attributes": {
            "type": "object",
            "additionalProperties": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "RecordList": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Record"
            }
          },
          "count": {
            "type": "integer"
          }
        }
      }
    }
  }
}
