        "schema": {
          "$ref": "#/components/schemas/Row"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "columnDefinitions": {
            "type": "object",
            "description": "Records keyed by id for the columnDefinitions collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/ColumnDefinition"
            }
          },
          "mutationResults": {
            "type": "object",
            "description": "Records keyed by id for the mutationResults collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/MutationResult"
            }
          },
          "queryResults": {
            "type": "object",
            "description": "Records keyed by id for the queryResults collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/QueryResult"
            }
          },
          "rows": {
            "type": "object",
            "description": "Records keyed by id for the rows collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Row"
            }
          }
        },
        "additionalProperties": false
      },
      "Row": {
        "type": "object",
        "description": "A table row / record. Columns are dynamic; example fields shown.",
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "Alice"
          },
          "email": {
            "type": "string",
            "example": "alice@example.com"
          }
        }
      },
      "SqlRequest": {
        "type": "object",
        "required": [
          "query"
        ],
        "properties": {
          "query": {
            "type": "string",
            "example": "SELECT TOP 10 * FROM users"
          }
        }
      },
      "FindValueRequest": {
        "type": "object",
        "required": [
          "filter"
        ],
        "properties": {
          "filter": {
            "type": "object",
            "properties": {
              "uuid": {
                "type": "string",
                "example": "email"
              },
              "relation": {
                "type": "string",
                "example": "users"
              },
              "where": {
                "type": "object",
                "additionalProperties": true,
                "example": {
                  "name": "Alice"
                }
              }
            }
          }
        }
      },
      "ColumnDefinition": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "id"
          },
          "type": {
            "type": "string",
            "example": "INT"
          },
          "nullable": {
            "type": "boolean",
            "example": false
          },
          "identity": {
            "type": "boolean",
            "example": true
          },
          "default": {
            "type": "string",
            "nullable": true,
            "example": null
          }
        }
      },
      "QueryResult": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Row"
            }
          },
          "rowsAffected": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "example": [
              10
            ]
          }
        }
      },
      "MutationResult": {
        "type": "object",
        "properties": {
          "rowsAffected": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "example": [
              1
            ]
          },
          "recordset": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Row"
            }
          }
        }
      }
    }
