{
  "openapi": "3.0.3",
  "info": {
    "title": "nexmo — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate nexmo. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "nexmo",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "accountBalances": {
        "resource": "AccountBalance",
        "schema": {
          "$ref": "#/components/schemas/AccountBalance"
        }
      },
      "sMSResponses": {
        "resource": "SMSResponse",
        "schema": {
          "$ref": "#/components/schemas/SMSResponse"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "accountBalances": {
            "type": "object",
            "description": "Records keyed by id for the accountBalances collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/AccountBalance"
            }
          },
          "sMSResponses": {
            "type": "object",
            "description": "Records keyed by id for the sMSResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/SMSResponse"
            }
          }
        },
        "additionalProperties": false
      },
      "SendSMSRequest": {
        "type": "object",
        "required": [
          "api_key",
          "api_secret",
          "from",
          "to",
          "text"
        ],
        "properties": {
          "api_key": {
            "type": "string",
            "description": "Vonage API key"
          },
          "api_secret": {
            "type": "string",
            "description": "Vonage API secret"
          },
          "from": {
            "type": "string",
            "description": "Sender ID (alphanumeric or MSISDN)",
            "example": "OpenFn"
          },
          "to": {
            "type": "string",
            "description": "Recipient phone number in E.164 format",
            "example": "447700900000"
          },
          "text": {
            "type": "string",
            "description": "Message body",
            "example": "Hello World!"
          },
          "type": {
            "type": "string",
            "enum": [
              "text",
              "unicode",
              "binary"
            ],
            "default": "text"
          },
          "client-ref": {
            "type": "string",
            "description": "Client reference, max 40 chars"
          },
          "callback": {
            "type": "string",
            "description": "Delivery receipt webhook URL"
          }
        }
      },
      "SMSResponse": {
        "type": "object",
        "properties": {
          "message-count": {
            "type": "string",
            "description": "Number of message parts",
            "example": "1"
          },
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SMSMessage"
            }
          }
        }
      },
      "SMSMessage": {
        "type": "object",
        "properties": {
          "to": {
            "type": "string",
            "example": "447700900000"
          },
          "message-id": {
            "type": "string",
            "example": "0A0000000123ABCD1"
          },
          "status": {
            "type": "string",
            "description": "0 indicates success; any other value is an error code",
            "example": "0"
          },
          "remaining-balance": {
            "type": "string",
            "example": "3.14159265"
          },
          "message-price": {
            "type": "string",
            "example": "0.03330000"
          },
          "network": {
            "type": "string",
            "example": "12345"
          },
          "client-ref": {
            "type": "string"
          },
          "account-ref": {
            "type": "string"
          },
          "error-text": {
            "type": "string",
            "description": "Present when status is non-zero"
          }
        }
      },
      "AccountBalance": {
        "type": "object",
        "properties": {
          "value": {
            "type": "number",
            "format": "float",
            "example": 3.14159265
          },
          "autoReload": {
            "type": "boolean",
            "example": false
          }
        }
      }
    }
  }
}
