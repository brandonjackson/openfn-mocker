        "schema": {
          "$ref": "#/components/schemas/Prescription"
        }
      },
      "stockOutItems": {
        "resource": "StockOutItem",
        "schema": {
          "$ref": "#/components/schemas/StockOutItem"
        }
      }
    }
  },
  "components": {
