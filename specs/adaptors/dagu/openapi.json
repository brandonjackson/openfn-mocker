{
  "openapi": "3.0.3",
  "info": {
    "title": "Dagu Pharmacy/Dispensing API (synthesized)",
    "version": "1.0.0",
    "description": "Synthesized OpenAPI surface for the OpenFn dagu adaptor. Dagu exposes no public machine-readable spec; the adaptor is a thin HTTP client (get/post/request) against a Dagu dispensing-unit backend. This document models the concrete endpoints exercised in the adaptor examples (stock-out reporting, prescription checks and history, dispensing requests) plus a generic passthrough request.",
    "x-openfn-adaptor": "dagu"
  },
  "servers": [{ "url": "http://localhost:4010" }],
  "paths": {
    "/DispensingUnit/Dashboard/StockOutReport": {
      "get": {
        "operationId": "getStockOutReport",
        "summary": "Stock-out report for a dispensing unit",
        "responses": {
          "200": {
            "description": "Stock-out report",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StockOutReport" }
              }
            }
          }
        }
      }
    },
    "/Patient/CheckPrescription": {
      "post": {
        "operationId": "checkPrescription",
        "summary": "Check a patient prescription by row GUID",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PrescriptionCheckRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Prescription check result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Prescription" }
              }
            }
          }
        }
      }
    },
    "/Patient/Prescription/History": {
      "post": {
        "operationId": "getPrescriptionHistory",
        "summary": "Paged prescription history",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DataTableQuery" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Prescription history page",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PrescriptionHistoryPage" }
              }
            }
          }
        }
      }
    },
    "/DispensingUnit/Request/History": {
      "post": {
        "operationId": "getRequestHistory",
        "summary": "Dispensing-unit request history",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RequestHistoryQuery" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Request history",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DispensingRequestList" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "StockOutReport": {
        "type": "object",
        "properties": {
          "generatedAt": { "type": "string", "format": "date-time" },
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/StockOutItem" }
          }
        }
      },
      "StockOutItem": {
        "type": "object",
        "properties": {
          "itemGuid": { "type": "string" },
          "itemName": { "type": "string" },
          "unit": { "type": "string" },
          "onHand": { "type": "integer" },
          "daysOutOfStock": { "type": "integer" }
        }
      },
      "PrescriptionCheckRequest": {
        "type": "object",
        "required": ["prescriptionRowGuid"],
        "properties": {
          "prescriptionRowGuid": { "type": "string", "format": "uuid" }
        }
      },
      "Prescription": {
        "type": "object",
        "properties": {
          "prescriptionRowGuid": { "type": "string", "format": "uuid" },
          "patientName": { "type": "string" },
          "drugName": { "type": "string" },
          "dose": { "type": "string" },
          "quantity": { "type": "integer" },
          "status": { "type": "string", "enum": ["Pending", "Dispensed", "Rejected"] },
          "prescribedAt": { "type": "string", "format": "date-time" }
        }
      },
      "DataTableQuery": {
        "type": "object",
        "properties": {
          "start": { "type": "integer" },
          "length": { "type": "integer" },
          "draw": { "type": "integer" },
          "additionalParameters": {
            "type": "object",
            "properties": {
              "filter": { "type": "array", "items": { "type": "object" } }
            }
          }
        }
      },
      "PrescriptionHistoryPage": {
        "type": "object",
        "properties": {
          "draw": { "type": "integer" },
          "recordsTotal": { "type": "integer" },
          "recordsFiltered": { "type": "integer" },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Prescription" }
          }
        }
      },
      "RequestHistoryQuery": {
        "type": "object",
        "properties": {
          "search": { "type": "object" }
        }
      },
      "DispensingRequestList": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/DispensingRequest" }
          }
        }
      },
      "DispensingRequest": {
        "type": "object",
        "properties": {
          "requestGuid": { "type": "string", "format": "uuid" },
          "requestNumber": { "type": "string" },
          "dispensingUnit": { "type": "string" },
          "status": { "type": "string" },
          "requestedAt": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
