{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "commcare/Form",
  "title": "Form",
  "x-openfn-adaptor": "commcare",
  "x-source": {
    "openapi": "#/components/schemas/Form",
    "capturedAt": "2026-07-06"
  },
  "type": "object",
  "description": "A submitted CommCare form (XForm instance).",
  "properties": {
    "id": {
      "type": "string",
      "example": "form-abc-123"
    },
    "domain": {
      "type": "string",
      "example": "demo"
    },
    "app_id": {
      "type": "string",
      "example": "app-xyz-789"
    },
    "build_id": {
      "type": [
        "string",
        "null"
      ],
      "example": "build-001"
    },
    "archived": {
      "type": "boolean",
      "example": false
    },
    "type": {
      "type": "string",
      "example": "data"
    },
    "received_on": {
      "type": "string",
      "example": "2026-06-30T12:34:56.000000Z"
    },
    "server_modified_on": {
      "type": "string",
      "example": "2026-06-30T12:34:57.000000Z"
    },
    "indexed_on": {
      "type": "string",
      "example": "2026-06-30T12:35:00.000000Z"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "Form metadata (deviceID, timeStart, timeEnd, userID, username, instanceID, etc.).",
      "example": {
        "deviceID": "cloudcare",
        "timeStart": "2026-06-30T12:30:00.000000Z",
        "timeEnd": "2026-06-30T12:34:56.000000Z",
        "userID": "a1b2c3d4e5f6",
        "username": "worker@demo.commcarehq.org",
        "instanceID": "form-abc-123"
      }
    },
    "form": {
      "type": "object",
      "additionalProperties": true,
      "description": "The parsed form question/answer data, keyed by question id.",
      "example": {
        "@xmlns": "http://openrosa.org/formdesigner/ABC",
        "question1": "answer1",
        "question2": "answer2"
      }
    },
    "resource_uri": {
      "type": "string",
      "example": "/a/demo/api/v0.5/form/form-abc-123/"
    }
  }
}
