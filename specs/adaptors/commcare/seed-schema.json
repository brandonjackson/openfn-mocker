{
  "openapi": "3.0.3",
  "info": {
    "title": "commcare — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate commcare. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "commcare",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "bulkUploadResponses": {
        "resource": "BulkUploadResponse",
        "schema": {
          "$ref": "#/components/schemas/BulkUploadResponse"
        }
      },
      "cases": {
        "resource": "Case",
        "schema": {
          "$ref": "#/components/schemas/Case"
        }
      },
      "fixtures": {
        "resource": "Fixture",
        "schema": {
          "$ref": "#/components/schemas/Fixture"
        }
      },
      "forms": {
        "resource": "Form",
        "schema": {
          "$ref": "#/components/schemas/Form"
        }
      },
      "groups": {
        "resource": "Group",
        "schema": {
          "$ref": "#/components/schemas/Group"
        }
      },
      "reportDatas": {
        "resource": "ReportData",
        "schema": {
          "$ref": "#/components/schemas/ReportData"
        }
      },
      "submissionResponses": {
        "resource": "SubmissionResponse",
        "schema": {
          "$ref": "#/components/schemas/SubmissionResponse"
        }
      },
      "users": {
        "resource": "User",
        "schema": {
          "$ref": "#/components/schemas/User"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "bulkUploadResponses": {
            "type": "object",
            "description": "Records keyed by id for the bulkUploadResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/BulkUploadResponse"
            }
          },
          "cases": {
            "type": "object",
            "description": "Records keyed by id for the cases collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Case"
            }
          },
          "fixtures": {
            "type": "object",
            "description": "Records keyed by id for the fixtures collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Fixture"
            }
          },
          "forms": {
            "type": "object",
            "description": "Records keyed by id for the forms collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Form"
            }
          },
          "groups": {
            "type": "object",
            "description": "Records keyed by id for the groups collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Group"
            }
          },
          "reportDatas": {
            "type": "object",
            "description": "Records keyed by id for the reportDatas collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/ReportData"
            }
          },
          "submissionResponses": {
            "type": "object",
            "description": "Records keyed by id for the submissionResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/SubmissionResponse"
            }
          },
          "users": {
            "type": "object",
            "description": "Records keyed by id for the users collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/User"
            }
          }
        },
        "additionalProperties": false
      },
      "Meta": {
        "type": "object",
        "description": "Tastypie list-response pagination envelope.",
        "properties": {
          "limit": {
            "type": "integer",
            "example": 20
          },
          "offset": {
            "type": "integer",
            "example": 0
          },
          "total_count": {
            "type": "integer",
            "example": 2
          },
          "next": {
            "type": "string",
            "nullable": true,
            "example": null
          },
          "previous": {
            "type": "string",
            "nullable": true,
            "example": null
          }
        }
      },
      "Case": {
        "type": "object",
        "description": "A CommCare case.",
        "properties": {
          "id": {
            "type": "string",
            "example": "5c05f79e-2ec7-4c30-a3b2-9f3f6d0ae1b1"
          },
          "case_id": {
            "type": "string",
            "example": "5c05f79e-2ec7-4c30-a3b2-9f3f6d0ae1b1"
          },
          "domain": {
            "type": "string",
            "example": "demo"
          },
          "closed": {
            "type": "boolean",
            "example": false
          },
          "date_closed": {
            "type": "string",
            "nullable": true,
            "example": null
          },
          "date_modified": {
            "type": "string",
            "example": "2026-06-30T12:34:56.000000"
          },
          "server_date_modified": {
            "type": "string",
            "example": "2026-06-30T12:34:57.000000"
          },
          "server_date_opened": {
            "type": "string",
            "example": "2026-06-01T09:00:00.000000"
          },
          "user_id": {
            "type": "string",
            "example": "a1b2c3d4e5f6"
          },
          "indices": {
            "type": "object",
            "additionalProperties": true,
            "example": {}
          },
          "properties": {
            "type": "object",
            "additionalProperties": true,
            "description": "Case properties, including reserved keys such as case_name, case_type, owner_id.",
            "example": {
              "case_name": "Mamadou",
              "case_type": "student",
              "owner_id": "a1b2c3d4e5f6",
              "date_opened": "2026-06-01T09:00:00.000000",
              "external_id": "STU-0001",
              "phone": "000000"
            }
          },
          "xform_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "form-abc-123"
            ]
          },
          "resource_uri": {
            "type": "string",
            "example": "/a/demo/api/v0.5/case/5c05f79e-2ec7-4c30-a3b2-9f3f6d0ae1b1/"
          }
        }
      },
      "CaseListResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/Meta"
          },
          "objects": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Case"
            }
          }
        }
      },
      "Form": {
        "type": "object",
        "description": "A submitted CommCare form (XForm instance).",
        "properties": {
          "id": {
            "type": "string",
            "example": "form-abc-123"
          },
          "domain": {
            "type": "string",
            "example": "demo"
          },
          "app_id": {
            "type": "string",
            "example": "app-xyz-789"
          },
          "build_id": {
            "type": "string",
            "nullable": true,
            "example": "build-001"
          },
          "archived": {
            "type": "boolean",
            "example": false
          },
          "type": {
            "type": "string",
            "example": "data"
          },
          "received_on": {
            "type": "string",
            "example": "2026-06-30T12:34:56.000000Z"
          },
          "server_modified_on": {
            "type": "string",
            "example": "2026-06-30T12:34:57.000000Z"
          },
          "indexed_on": {
            "type": "string",
            "example": "2026-06-30T12:35:00.000000Z"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true,
            "description": "Form metadata (deviceID, timeStart, timeEnd, userID, username, instanceID, etc.).",
            "example": {
              "deviceID": "cloudcare",
              "timeStart": "2026-06-30T12:30:00.000000Z",
              "timeEnd": "2026-06-30T12:34:56.000000Z",
              "userID": "a1b2c3d4e5f6",
              "username": "worker@demo.commcarehq.org",
              "instanceID": "form-abc-123"
            }
          },
          "form": {
            "type": "object",
            "additionalProperties": true,
            "description": "The parsed form question/answer data, keyed by question id.",
            "example": {
              "@xmlns": "http://openrosa.org/formdesigner/ABC",
              "question1": "answer1",
              "question2": "answer2"
            }
          },
          "resource_uri": {
            "type": "string",
            "example": "/a/demo/api/v0.5/form/form-abc-123/"
          }
        }
      },
      "FormListResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/Meta"
          },
          "objects": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Form"
            }
          }
        }
      },
      "User": {
        "type": "object",
        "description": "A CommCare mobile worker user.",
        "properties": {
          "id": {
            "type": "string",
            "example": "a1b2c3d4e5f6"
          },
          "username": {
            "type": "string",
            "example": "worker@demo.commcarehq.org"
          },
          "first_name": {
            "type": "string",
            "example": "Test"
          },
          "last_name": {
            "type": "string",
            "example": "Worker"
          },
          "default_phone_number": {
            "type": "string",
            "nullable": true,
            "example": "000000"
          },
          "email": {
            "type": "string",
            "nullable": true,
            "example": "worker@example.org"
          },
          "groups": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": []
          },
          "phone_numbers": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "000000"
            ]
          },
          "user_data": {
            "type": "object",
            "additionalProperties": true,
            "example": {}
          },
          "resource_uri": {
            "type": "string",
            "example": "/a/demo/api/v0.5/user/a1b2c3d4e5f6/"
          }
        }
      },
      "UserListResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/Meta"
          },
          "objects": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/User"
            }
          }
        }
      },
      "Group": {
        "type": "object",
        "description": "A CommCare group.",
        "properties": {
          "id": {
            "type": "string",
            "example": "grp-001"
          },
          "name": {
            "type": "string",
            "example": "Field Team"
          },
          "domain": {
            "type": "string",
            "example": "demo"
          },
          "case_sharing": {
            "type": "boolean",
            "example": true
          },
          "reporting": {
            "type": "boolean",
            "example": true
          },
          "users": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "a1b2c3d4e5f6"
            ]
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true,
            "example": {}
          },
          "resource_uri": {
            "type": "string",
            "example": "/a/demo/api/v0.5/group/grp-001/"
          }
        }
      },
      "GroupListResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/Meta"
          },
          "objects": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Group"
            }
          }
        }
      },
      "Fixture": {
        "type": "object",
        "description": "A CommCare fixture (lookup table) item.",
        "properties": {
          "id": {
            "type": "string",
            "example": "fix-001"
          },
          "fixture_type": {
            "type": "string",
            "example": "district"
          },
          "fields": {
            "type": "object",
            "additionalProperties": true,
            "description": "The lookup table row field values.",
            "example": {
              "name": "North",
              "code": "N01"
            }
          },
          "resource_uri": {
            "type": "string",
            "example": "/a/demo/api/v0.5/fixture/fix-001/"
          }
        }
      },
      "FixtureListResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/Meta"
          },
          "objects": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Fixture"
            }
          }
        }
      },
      "ReportData": {
        "type": "object",
        "description": "Configurable (UCR) report data response.",
        "properties": {
          "data": {
            "type": "array",
            "description": "The report rows.",
            "items": {
              "type": "object",
              "additionalProperties": true
            },
            "example": [
              {
                "district": "North",
                "total_cases": 42
              }
            ]
          },
          "columns": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "slug": {
                  "type": "string",
                  "example": "district"
                },
                "header": {
                  "type": "string",
                  "example": "District"
                }
              }
            }
          },
          "total_records": {
            "type": "integer",
            "example": 1
          },
          "next_page": {
            "type": "string",
            "nullable": true,
            "example": null
          }
        }
      },
      "SubmissionResponse": {
        "type": "object",
        "description": "Result of submitting a form to the OpenRosa receiver.",
        "properties": {
          "status": {
            "type": "string",
            "example": "success"
          },
          "nature": {
            "type": "string",
            "example": "submit_success"
          },
          "message": {
            "type": "string",
            "example": "Thanks for submitting!"
          },
          "form_id": {
            "type": "string",
            "example": "form-abc-123"
          }
        }
      },
      "BulkUploadResponse": {
        "type": "object",
        "description": "Result of a bulk Excel upload (case data or lookup table).",
        "properties": {
          "status": {
            "type": "string",
            "example": "success"
          },
          "message": {
            "type": "string",
            "example": "Upload complete."
          },
          "created_count": {
            "type": "integer",
            "example": 1
          },
          "updated_count": {
            "type": "integer",
            "example": 0
          },
          "error_count": {
            "type": "integer",
            "example": 0
          }
        }
      }
    }
  }
}
