{
  "openapi": "3.0.3",
  "info": {
    "title": "browserless — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate browserless. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "browserless",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "contentResults": {
        "resource": "ContentResult",
        "schema": {
          "$ref": "#/components/schemas/ContentResult"
        }
      },
      "pdfResults": {
        "resource": "PdfResult",
        "schema": {
          "$ref": "#/components/schemas/PdfResult"
        }
      },
      "scrapeResults": {
        "resource": "ScrapeResult",
        "schema": {
          "$ref": "#/components/schemas/ScrapeResult"
        }
      },
      "screenshotResults": {
        "resource": "ScreenshotResult",
        "schema": {
          "$ref": "#/components/schemas/ScreenshotResult"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "contentResults": {
            "type": "object",
            "description": "Records keyed by id for the contentResults collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/ContentResult"
            }
          },
          "pdfResults": {
            "type": "object",
            "description": "Records keyed by id for the pdfResults collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/PdfResult"
            }
          },
          "scrapeResults": {
            "type": "object",
            "description": "Records keyed by id for the scrapeResults collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/ScrapeResult"
            }
          },
          "screenshotResults": {
            "type": "object",
            "description": "Records keyed by id for the screenshotResults collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/ScreenshotResult"
            }
          }
        },
        "additionalProperties": false
      },
      "GotoOptions": {
        "type": "object",
        "properties": {
          "timeout": {
            "type": "integer"
          },
          "waitUntil": {
            "type": "string",
            "example": "networkidle2"
          }
        }
      },
      "PdfOptions": {
        "type": "object",
        "properties": {
          "format": {
            "type": "string",
            "example": "A4"
          },
          "printBackground": {
            "type": "boolean"
          },
          "displayHeaderFooter": {
            "type": "boolean"
          },
          "landscape": {
            "type": "boolean"
          },
          "scale": {
            "type": "number"
          }
        }
      },
      "PdfRequest": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "html": {
            "type": "string"
          },
          "options": {
            "$ref": "#/components/schemas/PdfOptions"
          },
          "gotoOptions": {
            "$ref": "#/components/schemas/GotoOptions"
          }
        }
      },
      "PdfResult": {
        "type": "object",
        "properties": {
          "base64": {
            "type": "string",
            "description": "Base64-encoded PDF bytes"
          },
          "type": {
            "type": "string",
            "example": "application/pdf"
          }
        }
      },
      "ScreenshotRequest": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "html": {
            "type": "string"
          },
          "options": {
            "type": "object",
            "properties": {
              "fullPage": {
                "type": "boolean"
              },
              "type": {
                "type": "string",
                "example": "png"
              }
            }
          },
          "gotoOptions": {
            "$ref": "#/components/schemas/GotoOptions"
          }
        }
      },
      "ScreenshotResult": {
        "type": "object",
        "properties": {
          "base64": {
            "type": "string",
            "description": "Base64-encoded image bytes"
          },
          "type": {
            "type": "string",
            "example": "image/png"
          }
        }
      },
      "ContentRequest": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "html": {
            "type": "string"
          },
          "gotoOptions": {
            "$ref": "#/components/schemas/GotoOptions"
          }
        }
      },
      "ContentResult": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "description": "Rendered HTML"
          }
        }
      },
      "ScrapeRequest": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "html": {
            "type": "string"
          },
          "elements": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "selector": {
                  "type": "string"
                }
              }
            }
          },
          "gotoOptions": {
            "$ref": "#/components/schemas/GotoOptions"
          }
        }
      },
      "ScrapeResult": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "selector": {
                  "type": "string"
                },
                "results": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "text": {
                        "type": "string"
                      },
                      "html": {
                        "type": "string"
                      },
                      "attributes": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "additionalProperties": true
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
