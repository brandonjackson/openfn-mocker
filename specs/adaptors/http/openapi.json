{
  "openapi": "3.0.3",
  "info": {
    "title": "Generic HTTP API (synthesized)",
    "version": "1.0.0",
    "description": "Synthesized OpenAPI facade for the OpenFn http adaptor, a generic REST/HTTP client with no fixed upstream API. Its operations (request, get, post, put, patch, del, parseXML) target arbitrary endpoints. This document models a generic RESTful resource collection so mocker can serve conventional GET/POST/PUT/PATCH/DELETE interactions and seed a reusable resource shape. Point servers[0].url at the real target when using it against a specific API.",
    "x-openfn-adaptor": "http"
  },
  "servers": [{ "url": "http://localhost:4010" }],
  "paths": {
    "/resources": {
      "get": {
        "operationId": "listResources",
        "summary": "List resources (get)",
        "parameters": [
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "offset", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "A list of resources",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Resource" }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createResource",
        "summary": "Create a resource (post)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/Resource" } }
          }
        },
        "responses": {
          "201": {
            "description": "The created resource",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Resource" }
              }
            }
          }
        }
      }
    },
    "/resources/{id}": {
      "get": {
        "operationId": "getResource",
        "summary": "Get a resource by id (get)",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "The resource",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Resource" }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "replaceResource",
        "summary": "Replace a resource (put)",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/Resource" } }
          }
        },
        "responses": {
          "200": {
            "description": "The replaced resource",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Resource" }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updateResource",
        "summary": "Partially update a resource (patch)",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/Resource" } }
          }
        },
        "responses": {
          "200": {
            "description": "The updated resource",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Resource" }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteResource",
        "summary": "Delete a resource (del)",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Deletion result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DeleteResult" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Resource": {
        "type": "object",
        "description": "A generic JSON resource. Concrete fields depend on the target API.",
        "properties": {
          "id": { "type": "string", "example": "1" },
          "name": { "type": "string", "example": "example" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": true
      },
      "DeleteResult": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "1" },
          "deleted": { "type": "boolean", "example": true }
        }
      }
    }
  }
}
