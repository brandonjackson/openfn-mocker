{
  "openapi": "3.0.3",
  "info": {
    "title": "memento — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate memento. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "memento",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "entries": {
        "resource": "Entry",
        "schema": {
          "$ref": "#/components/schemas/Entry"
        }
      },
      "entryLists": {
        "resource": "EntryList",
        "schema": {
          "$ref": "#/components/schemas/EntryList"
        }
      },
      "libraries": {
        "resource": "Library",
        "schema": {
          "$ref": "#/components/schemas/Library"
        }
      },
      "libraryLists": {
        "resource": "LibraryList",
        "schema": {
          "$ref": "#/components/schemas/LibraryList"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "entries": {
            "type": "object",
            "description": "Records keyed by id for the entries collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Entry"
            }
          },
          "entryLists": {
            "type": "object",
            "description": "Records keyed by id for the entryLists collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/EntryList"
            }
          },
          "libraries": {
            "type": "object",
            "description": "Records keyed by id for the libraries collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Library"
            }
          },
          "libraryLists": {
            "type": "object",
            "description": "Records keyed by id for the libraryLists collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/LibraryList"
            }
          }
        },
        "additionalProperties": false
      },
      "LibraryList": {
        "type": "object",
        "properties": {
          "libraries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Library"
            }
          }
        }
      },
      "Library": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "HyZV7AYk0"
          },
          "name": {
            "type": "string",
            "example": "Patients"
          },
          "owner": {
            "type": "string"
          },
          "createdTime": {
            "type": "string",
            "format": "date-time"
          },
          "revision": {
            "type": "integer"
          },
          "size": {
            "type": "integer"
          },
          "fields": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Field"
            }
          }
        }
      },
      "Field": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "Name"
          },
          "type": {
            "type": "string",
            "example": "text"
          }
        }
      },
      "EntryList": {
        "type": "object",
        "properties": {
          "entries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Entry"
            }
          }
        }
      },
      "Entry": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "T0xIYmE-V2QoMmRTWF1sVVJUKnU"
          },
          "author": {
            "type": "string"
          },
          "createdTime": {
            "type": "string",
            "format": "date-time"
          },
          "modifiedTime": {
            "type": "string",
            "format": "date-time"
          },
          "fields": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EntryFieldValue"
            }
          }
        }
      },
      "EntryFieldValue": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "Name"
          },
          "type": {
            "type": "string",
            "example": "text"
          },
          "value": {
            "example": "Record 1"
          }
        }
      },
      "EntryInput": {
        "type": "object",
        "properties": {
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer"
                },
                "value": {}
              }
            }
          }
        }
      }
    }
