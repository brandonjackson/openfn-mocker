{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "chatgpt/Response",
  "title": "Response",
  "x-openfn-adaptor": "chatgpt",
  "x-source": {
    "openapi": "#/components/schemas/Response",
    "capturedAt": "2026-07-06"
  },
  "type": "object",
  "description": "A response object returned by the Responses API.",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the response."
    },
    "object": {
      "type": "string",
      "enum": [
        "response"
      ],
      "description": "The object type."
    },
    "created_at": {
      "type": "integer",
      "description": "Unix timestamp (seconds) of when the response was created."
    },
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "failed",
        "in_progress",
        "incomplete"
      ],
      "description": "The status of the response generation."
    },
    "model": {
      "type": "string",
      "description": "The model used to generate the response."
    },
    "output": {
      "type": "array",
      "description": "An array of output items generated by the model.",
      "items": {
        "$ref": "ResponseOutputItem.json"
      }
    },
    "output_text": {
      "type": [
        "string",
        "null"
      ],
      "description": "SDK-only convenience aggregation of text output."
    },
    "error": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "usage": {
      "$ref": "ResponseUsage.json"
    }
  },
  "required": [
    "id",
    "object",
    "created_at",
    "status",
    "model",
    "output"
  ]
}
