{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "chatgpt/ChatCompletionChoice",
  "title": "ChatCompletionChoice",
  "x-openfn-adaptor": "chatgpt",
  "x-source": {
    "openapi": "#/components/schemas/ChatCompletionChoice",
    "capturedAt": "2026-07-06"
  },
  "type": "object",
  "description": "A single chat completion choice.",
  "properties": {
    "index": {
      "type": "integer",
      "description": "The index of the choice in the list of choices."
    },
    "message": {
      "$ref": "ChatCompletionMessage.json"
    },
    "finish_reason": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "stop",
        "length",
        "tool_calls",
        "content_filter",
        "function_call"
      ],
      "description": "The reason the model stopped generating tokens."
    },
    "logprobs": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "index",
    "message",
    "finish_reason"
  ]
}
