{
  "openapi": "3.0.3",
  "info": {
    "title": "IBM Maximo REST API (maxrest)",
    "version": "7.6.0",
    "description": "Focused OpenAPI describing the endpoints of the legacy IBM Maximo Integration Framework REST API (the `maxrest/rest` service) that the OpenFn maximo adaptor talks to. The adaptor is a thin passthrough exposing three operations: `fetch` (GET against an object structure or MBO endpoint), `update` (POST with header `x-methodoverride: PATCH`, Maximo 7.6+) and `update75` (POST with header `x-methodoverride: PATCH`, Maximo 7.5). Resources are reached under two families: Object Structures (`/maxrest/rest/os/{objectStructure}`, e.g. mxinventory, mxwo, mxasset) and Maximo Business Objects (`/maxrest/rest/mbo/{mbo}`, e.g. workorder, asset, inventory, invbalances). Add `_format=json` to receive JSON.",
    "x-openfn-adaptor": "maximo"
  },
  "servers": [
    {
      "url": "https://{host}",
      "description": "Maximo application server host",
      "variables": {
        "host": {
          "default": "maximo.example.com",
          "description": "Maximo host (baseUrl in the adaptor configuration)"
        }
      }
    }
  ],
  "paths": {
    "/maxrest/rest/os/{objectStructure}": {
      "parameters": [
        { "$ref": "#/components/parameters/ObjectStructure" },
        { "$ref": "#/components/parameters/Format" }
      ],
      "get": {
        "operationId": "queryObjectStructure",
        "summary": "Query an object structure",
        "description": "Query records of an integration object structure. Attribute names may be supplied as query parameters to filter (e.g. ITEMNUM=01226). Used by the adaptor `fetch` operation, e.g. endpoint `maxrest/rest/os/mxinventory`.",
        "parameters": [
          { "$ref": "#/components/parameters/Compact" },
          { "$ref": "#/components/parameters/DropNulls" },
          { "$ref": "#/components/parameters/RsStart" },
          { "$ref": "#/components/parameters/MaxItems" }
        ],
        "responses": {
          "200": {
            "description": "Query response set",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/QueryResponse" }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createObjectStructure",
        "summary": "Create a record via an object structure",
        "description": "Create a new record through an integration object structure.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/GenericRecord" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created record",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GenericRecord" }
              }
            }
          }
        }
      }
    },
    "/maxrest/rest/os/{objectStructure}/{id}": {
      "parameters": [
        { "$ref": "#/components/parameters/ObjectStructure" },
        { "$ref": "#/components/parameters/Id" },
        { "$ref": "#/components/parameters/Format" }
      ],
      "get": {
        "operationId": "getObjectStructureById",
        "summary": "Get a single object structure record by unique id",
        "parameters": [
          { "$ref": "#/components/parameters/Compact" }
        ],
        "responses": {
          "200": {
            "description": "Single record",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GenericRecord" }
              }
            }
          }
        }
      }
    },
    "/maxrest/rest/mbo/workorder": {
      "parameters": [ { "$ref": "#/components/parameters/Format" } ],
      "get": {
        "operationId": "queryWorkOrders",
        "summary": "Query work orders (WORKORDER MBO)",
        "parameters": [
          { "$ref": "#/components/parameters/Compact" },
          { "$ref": "#/components/parameters/RsStart" },
          { "$ref": "#/components/parameters/MaxItems" }
        ],
        "responses": {
          "200": {
            "description": "Work order set",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "rsStart": { "type": "integer" },
                    "rsCount": { "type": "integer" },
                    "rsTotal": { "type": "integer" },
                    "member": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/WorkOrder" }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createWorkOrder",
        "summary": "Create a work order (WORKORDER MBO)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WorkOrder" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created work order",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WorkOrder" }
              }
            }
          }
        }
      }
    },
    "/maxrest/rest/mbo/workorder/{id}": {
      "parameters": [
        { "$ref": "#/components/parameters/Id" },
        { "$ref": "#/components/parameters/Format" }
      ],
      "get": {
        "operationId": "getWorkOrderById",
        "summary": "Get a work order by WORKORDERID",
        "responses": {
          "200": {
            "description": "Work order",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WorkOrder" }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "updateWorkOrder",
        "summary": "Update a work order (POST + x-methodoverride: PATCH)",
        "description": "The adaptor `update` operation posts to an MBO instance endpoint with the header `x-methodoverride: PATCH` to update the record (Maximo 7.6+). Example endpoint: `maxrest/rest/mbo/workorder/1234`.",
        "parameters": [ { "$ref": "#/components/parameters/MethodOverride" } ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WorkOrder" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated work order",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WorkOrder" }
              }
            }
          }
        }
      }
    },
    "/maxrest/rest/mbo/asset": {
      "parameters": [ { "$ref": "#/components/parameters/Format" } ],
      "get": {
        "operationId": "queryAssets",
        "summary": "Query assets (ASSET MBO)",
        "parameters": [
          { "$ref": "#/components/parameters/Compact" },
          { "$ref": "#/components/parameters/RsStart" },
          { "$ref": "#/components/parameters/MaxItems" }
        ],
        "responses": {
          "200": {
            "description": "Asset set",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "rsStart": { "type": "integer" },
                    "rsCount": { "type": "integer" },
                    "rsTotal": { "type": "integer" },
                    "member": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Asset" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/maxrest/rest/mbo/asset/{id}": {
      "parameters": [
        { "$ref": "#/components/parameters/Id" },
        { "$ref": "#/components/parameters/Format" }
      ],
      "post": {
        "operationId": "updateAsset",
        "summary": "Update an asset (POST + x-methodoverride: PATCH)",
        "parameters": [ { "$ref": "#/components/parameters/MethodOverride" } ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Asset" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated asset",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Asset" }
              }
            }
          }
        }
      }
    },
    "/maxrest/rest/mbo/inventory": {
      "parameters": [ { "$ref": "#/components/parameters/Format" } ],
      "get": {
        "operationId": "queryInventory",
        "summary": "Query inventory items (INVENTORY MBO)",
        "parameters": [
          { "$ref": "#/components/parameters/Compact" },
          { "$ref": "#/components/parameters/RsStart" },
          { "$ref": "#/components/parameters/MaxItems" }
        ],
        "responses": {
          "200": {
            "description": "Inventory set",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "rsStart": { "type": "integer" },
                    "rsCount": { "type": "integer" },
                    "rsTotal": { "type": "integer" },
                    "member": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/InventoryItem" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/maxrest/rest/mbo/invbalances": {
      "parameters": [ { "$ref": "#/components/parameters/Format" } ],
      "get": {
        "operationId": "queryInvBalances",
        "summary": "Query inventory balances (INVBALANCES MBO)",
        "responses": {
          "200": {
            "description": "Inventory balances set",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "rsStart": { "type": "integer" },
                    "rsCount": { "type": "integer" },
                    "rsTotal": { "type": "integer" },
                    "member": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/InvBalance" }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "updateInvBalances",
        "summary": "Update inventory balances (Maximo 7.5, POST + x-methodoverride: PATCH)",
        "description": "The adaptor `update75` operation posts to an MBO collection endpoint with the header `x-methodoverride: PATCH`. Example endpoint: `maxrest/rest/mbo/invbalances`.",
        "parameters": [ { "$ref": "#/components/parameters/MethodOverride" } ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/InvBalance" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated inventory balance",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/InvBalance" }
              }
            }
          }
        }
      }
    },
    "/maxrest/rest/mbo/person": {
      "parameters": [ { "$ref": "#/components/parameters/Format" } ],
      "get": {
        "operationId": "queryPersons",
        "summary": "Query people (PERSON MBO)",
        "parameters": [
          { "$ref": "#/components/parameters/Compact" },
          { "$ref": "#/components/parameters/RsStart" },
          { "$ref": "#/components/parameters/MaxItems" }
        ],
        "responses": {
          "200": {
            "description": "Person set",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "rsStart": { "type": "integer" },
                    "rsCount": { "type": "integer" },
                    "rsTotal": { "type": "integer" },
                    "member": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Person" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "ObjectStructure": {
        "name": "objectStructure",
        "in": "path",
        "required": true,
        "description": "Integration object structure name (e.g. mxinventory, mxwo, mxasset, mxperson).",
        "schema": { "type": "string" }
      },
      "Id": {
        "name": "id",
        "in": "path",
        "required": true,
        "description": "Unique id of the record (e.g. WORKORDERID, ASSETID).",
        "schema": { "type": "string" }
      },
      "Format": {
        "name": "_format",
        "in": "query",
        "required": false,
        "description": "Response payload format. Use `json` for JSON.",
        "schema": { "type": "string", "enum": ["json", "xml"], "default": "json" }
      },
      "Compact": {
        "name": "_compact",
        "in": "query",
        "required": false,
        "description": "Set to 1 to serialize the resource in a compact JSON format.",
        "schema": { "type": "integer", "enum": [0, 1] }
      },
      "DropNulls": {
        "name": "_dropnulls",
        "in": "query",
        "required": false,
        "description": "Set to 1/true to drop null-valued attributes from the response.",
        "schema": { "type": "boolean" }
      },
      "RsStart": {
        "name": "_rsStart",
        "in": "query",
        "required": false,
        "description": "Zero-based index of the first record to return (paging).",
        "schema": { "type": "integer", "default": 0 }
      },
      "MaxItems": {
        "name": "_maxItems",
        "in": "query",
        "required": false,
        "description": "Maximum number of records to return.",
        "schema": { "type": "integer" }
      },
      "MethodOverride": {
        "name": "x-methodoverride",
        "in": "header",
        "required": false,
        "description": "Set to PATCH to instruct the server to update the addressed resource on a POST.",
        "schema": { "type": "string", "enum": ["PATCH", "MERGE"] }
      }
    },
    "schemas": {
      "QueryResponse": {
        "type": "object",
        "description": "Generic query response wrapper returned by object structure queries.",
        "properties": {
          "rsStart": { "type": "integer", "description": "Index of the first returned record." },
          "rsCount": { "type": "integer", "description": "Number of records in this response." },
          "rsTotal": { "type": "integer", "description": "Total number of matching records." },
          "member": {
            "type": "array",
            "description": "The returned records.",
            "items": { "$ref": "#/components/schemas/GenericRecord" }
          }
        }
      },
      "GenericRecord": {
        "type": "object",
        "description": "A generic Maximo record. Attribute names are upper-case MBO field names; contents vary by object structure.",
        "additionalProperties": true,
        "properties": {
          "_rowstamp": { "type": "string", "description": "Optimistic-locking row stamp." },
          "href": { "type": "string", "description": "Self reference URI of the record." }
        }
      },
      "WorkOrder": {
        "type": "object",
        "description": "Work order record (WORKORDER MBO / MXWO object structure).",
        "properties": {
          "WORKORDERID": { "type": "integer", "description": "Unique numeric id of the work order." },
          "WONUM": { "type": "string", "description": "Work order number." },
          "DESCRIPTION": { "type": "string" },
          "STATUS": { "type": "string", "description": "Work order status (e.g. WAPPR, APPR, COMP, CLOSE)." },
          "STATUSDATE": { "type": "string", "format": "date-time" },
          "SITEID": { "type": "string" },
          "ORGID": { "type": "string" },
          "ASSETNUM": { "type": "string" },
          "LOCATION": { "type": "string" },
          "WOPRIORITY": { "type": "integer" },
          "WORKTYPE": { "type": "string" },
          "REPORTDATE": { "type": "string", "format": "date-time" },
          "SCHEDSTART": { "type": "string", "format": "date-time" },
          "ESTDUR": { "type": "number" },
          "_rowstamp": { "type": "string" },
          "href": { "type": "string" }
        }
      },
      "Asset": {
        "type": "object",
        "description": "Asset record (ASSET MBO / MXASSET object structure).",
        "properties": {
          "ASSETID": { "type": "integer", "description": "Unique numeric id of the asset." },
          "ASSETNUM": { "type": "string" },
          "DESCRIPTION": { "type": "string" },
          "STATUS": { "type": "string", "description": "Asset status (e.g. OPERATING, DECOMMISSIONED)." },
          "SITEID": { "type": "string" },
          "ORGID": { "type": "string" },
          "LOCATION": { "type": "string" },
          "SERIALNUM": { "type": "string" },
          "ASSETTYPE": { "type": "string" },
          "PARENT": { "type": "string" },
          "PRIORITY": { "type": "integer" },
          "_rowstamp": { "type": "string" },
          "href": { "type": "string" }
        }
      },
      "InventoryItem": {
        "type": "object",
        "description": "Inventory record (INVENTORY MBO / MXINVENTORY object structure).",
        "properties": {
          "INVENTORYID": { "type": "integer" },
          "ITEMNUM": { "type": "string", "description": "Item number." },
          "ITEMSETID": { "type": "string" },
          "DESCRIPTION": { "type": "string" },
          "LOCATION": { "type": "string" },
          "SITEID": { "type": "string" },
          "STATUS": { "type": "string" },
          "CURBAL": { "type": "number", "description": "Current balance." },
          "ISSUEUNIT": { "type": "string" },
          "ORDERUNIT": { "type": "string" },
          "_rowstamp": { "type": "string" },
          "href": { "type": "string" }
        }
      },
      "InvBalance": {
        "type": "object",
        "description": "Inventory balance record (INVBALANCES MBO).",
        "properties": {
          "INVBALANCESID": { "type": "integer" },
          "ITEMNUM": { "type": "string" },
          "ITEMSETID": { "type": "string" },
          "LOCATION": { "type": "string" },
          "BINNUM": { "type": "string" },
          "LOTNUM": { "type": "string" },
          "SITEID": { "type": "string" },
          "CURBAL": { "type": "number", "description": "Current balance." },
          "PHYSCNT": { "type": "number", "description": "Physical count." },
          "PHYSCNTDATE": { "type": "string", "format": "date-time" },
          "_rowstamp": { "type": "string" },
          "href": { "type": "string" }
        }
      },
      "Person": {
        "type": "object",
        "description": "Person record (PERSON MBO / MXPERSON object structure).",
        "properties": {
          "PERSONID": { "type": "string", "description": "Unique person id." },
          "FIRSTNAME": { "type": "string" },
          "LASTNAME": { "type": "string" },
          "DISPLAYNAME": { "type": "string" },
          "STATUS": { "type": "string" },
          "PRIMARYEMAIL": { "type": "string", "format": "email" },
          "PRIMARYPHONE": { "type": "string" },
          "LOCATIONORG": { "type": "string" },
          "_rowstamp": { "type": "string" },
          "href": { "type": "string" }
        }
      }
    }
  }
}
