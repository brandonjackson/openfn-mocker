{
  "openapi": "3.0.3",
  "info": {
    "title": "googlesheets — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate googlesheets. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "googlesheets",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "appendValuesResponses": {
        "resource": "AppendValuesResponse",
        "schema": {
          "$ref": "#/components/schemas/AppendValuesResponse"
        }
      },
      "batchUpdateValuesResponses": {
        "resource": "BatchUpdateValuesResponse",
        "schema": {
          "$ref": "#/components/schemas/BatchUpdateValuesResponse"
        }
      },
      "valueRanges": {
        "resource": "ValueRange",
        "schema": {
          "$ref": "#/components/schemas/ValueRange"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "appendValuesResponses": {
            "type": "object",
            "description": "Records keyed by id for the appendValuesResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/AppendValuesResponse"
            }
          },
          "batchUpdateValuesResponses": {
            "type": "object",
            "description": "Records keyed by id for the batchUpdateValuesResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/BatchUpdateValuesResponse"
            }
          },
          "valueRanges": {
            "type": "object",
            "description": "Records keyed by id for the valueRanges collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/ValueRange"
            }
          }
        },
        "additionalProperties": false
      },
      "ValueRange": {
        "type": "object",
        "description": "Data within a range of a spreadsheet.",
        "properties": {
          "range": {
            "type": "string",
            "example": "Sheet1!A1:D5"
          },
          "majorDimension": {
            "type": "string",
            "enum": [
              "ROWS",
              "COLUMNS"
            ],
            "example": "ROWS"
          },
          "values": {
            "type": "array",
            "description": "A 2D array of cell values.",
            "items": {
              "type": "array",
              "items": {}
            },
            "example": [
              [
                "Name",
                "Age"
              ],
              [
                "Ama",
                "34"
              ],
              [
                "Kwame",
                "42"
              ]
            ]
          }
        }
      },
      "AppendValuesResponse": {
        "type": "object",
        "description": "The response when appending values.",
        "properties": {
          "spreadsheetId": {
            "type": "string",
            "example": "1BxiMVs0XRA5nFMdKvBd_B4hhaZ"
          },
          "tableRange": {
            "type": "string",
            "example": "Sheet1!A1:D3"
          },
          "updates": {
            "$ref": "#/components/schemas/UpdateValuesResponse"
          }
        }
      },
      "BatchUpdateValuesRequest": {
        "type": "object",
        "description": "The request for updating more than one range of values in a spreadsheet.",
        "properties": {
          "valueInputOption": {
            "type": "string",
            "enum": [
              "RAW",
              "USER_ENTERED"
            ],
            "example": "USER_ENTERED"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ValueRange"
            }
          },
          "includeValuesInResponse": {
            "type": "boolean"
          }
        }
      },
      "BatchUpdateValuesResponse": {
        "type": "object",
        "description": "The response when updating a range of values in a spreadsheet.",
        "properties": {
          "spreadsheetId": {
            "type": "string",
            "example": "1BxiMVs0XRA5nFMdKvBd_B4hhaZ"
          },
          "totalUpdatedRows": {
            "type": "integer",
            "format": "int32",
            "example": 3
          },
          "totalUpdatedColumns": {
            "type": "integer",
            "format": "int32",
            "example": 2
          },
          "totalUpdatedCells": {
            "type": "integer",
            "format": "int32",
            "example": 6
          },
          "totalUpdatedSheets": {
            "type": "integer",
            "format": "int32",
            "example": 1
          },
          "responses": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UpdateValuesResponse"
            }
          }
        }
      },
      "UpdateValuesResponse": {
        "type": "object",
        "description": "The result of updating a range of values.",
        "properties": {
          "spreadsheetId": {
            "type": "string",
            "example": "1BxiMVs0XRA5nFMdKvBd_B4hhaZ"
          },
          "updatedRange": {
            "type": "string",
            "example": "Sheet1!A4:B4"
          },
          "updatedRows": {
            "type": "integer",
            "format": "int32",
            "example": 1
          },
          "updatedColumns": {
            "type": "integer",
            "format": "int32",
            "example": 2
          },
          "updatedCells": {
            "type": "integer",
            "format": "int32",
            "example": 2
          },
          "updatedData": {
            "$ref": "#/components/schemas/ValueRange"
          }
        }
      }
    }
  }
}
