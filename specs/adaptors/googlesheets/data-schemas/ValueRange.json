{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "googlesheets/ValueRange",
  "title": "ValueRange",
  "x-openfn-adaptor": "googlesheets",
  "x-source": {
    "openapi": "#/components/schemas/ValueRange",
    "capturedAt": "2026-07-06"
  },
  "type": "object",
  "description": "Data within a range of a spreadsheet.",
  "properties": {
    "range": {
      "type": "string",
      "example": "Sheet1!A1:D5"
    },
    "majorDimension": {
      "type": "string",
      "enum": [
        "ROWS",
        "COLUMNS"
      ],
      "example": "ROWS"
    },
    "values": {
      "type": "array",
      "description": "A 2D array of cell values.",
      "items": {
        "type": "array",
        "items": {}
      },
      "example": [
        [
          "Name",
          "Age"
        ],
        [
          "Ama",
          "34"
        ],
        [
          "Kwame",
          "42"
        ]
      ]
    }
  }
}
