{
  "openapi": "3.0.3",
  "info": {
    "title": "mysql — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate mysql. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "mysql",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "mutationResults": {
        "resource": "MutationResult",
        "schema": {
          "$ref": "#/components/schemas/MutationResult"
        }
      },
      "queryResults": {
        "resource": "QueryResult",
        "schema": {
          "$ref": "#/components/schemas/QueryResult"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "mutationResults": {
            "type": "object",
            "description": "Records keyed by id for the mutationResults collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/MutationResult"
            }
          },
          "queryResults": {
            "type": "object",
            "description": "Records keyed by id for the queryResults collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/QueryResult"
            }
          }
        },
        "additionalProperties": false
      },
      "Row": {
        "type": "object",
        "description": "A table row / record. Columns are dynamic; example fields shown.",
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "Alice"
          },
          "email": {
            "type": "string",
            "example": "alice@example.com"
          }
        }
      },
      "SqlRequest": {
        "type": "object",
        "required": [
          "sqlQuery"
        ],
        "properties": {
          "sqlQuery": {
            "type": "string",
            "example": "SELECT * FROM users LIMIT 10"
          }
        }
      },
      "QueryResult": {
        "type": "object",
        "description": "mysql2 SELECT result: an array of row objects.",
        "properties": {
          "rows": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Row"
            }
          }
        }
      },
      "MutationResult": {
        "type": "object",
        "description": "mysql2 OkPacket returned for INSERT/UPDATE/UPSERT statements.",
        "properties": {
          "fieldCount": {
            "type": "integer",
            "example": 0
          },
          "affectedRows": {
            "type": "integer",
            "example": 1
          },
          "insertId": {
            "type": "integer",
            "example": 42
          },
          "serverStatus": {
            "type": "integer",
            "example": 2
          },
          "warningCount": {
            "type": "integer",
            "example": 0
          },
          "changedRows": {
            "type": "integer",
            "example": 0
          }
        }
      }
    }
  }
}
