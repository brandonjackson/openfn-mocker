{
  "openapi": "3.0.3",
  "info": {
    "title": "MySQL API (synthesized)",
    "version": "1.0.0",
    "description": "Synthesized OpenAPI surface for the OpenFn mysql adaptor. MySQL is a relational database accessed over the MySQL wire protocol (via the mysql2 driver), not a REST API. This spec models the adaptor operations (sql, insert, upsert, upsertMany) as HTTP endpoints so the mocker can seed and serve representative SQL result shapes. servers.url is a mock placeholder.",
    "x-openfn-adaptor": "mysql"
  },
  "servers": [
    { "url": "http://localhost:4010", "description": "Mock server (MySQL speaks its own wire protocol, not REST)" }
  ],
  "paths": {
    "/sql": {
      "post": {
        "operationId": "sql",
        "summary": "Execute a SQL statement",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SqlRequest" } } }
        },
        "responses": {
          "200": {
            "description": "Query result",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/QueryResult" } } }
          }
        }
      }
    },
    "/tables/{table}/insert": {
      "post": {
        "operationId": "insert",
        "summary": "Insert a record",
        "parameters": [ { "name": "table", "in": "path", "required": true, "schema": { "type": "string" } } ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Row" } } }
        },
        "responses": {
          "200": {
            "description": "Insert result",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MutationResult" } } }
          }
        }
      }
    },
    "/tables/{table}/upsert": {
      "post": {
        "operationId": "upsert",
        "summary": "Insert or update a record if matched (ON DUPLICATE KEY UPDATE)",
        "parameters": [ { "name": "table", "in": "path", "required": true, "schema": { "type": "string" } } ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Row" } } }
        },
        "responses": {
          "200": {
            "description": "Upsert result",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MutationResult" } } }
          }
        }
      }
    },
    "/tables/{table}/upsertMany": {
      "post": {
        "operationId": "upsertMany",
        "summary": "Insert or update multiple records (ON DUPLICATE KEY UPDATE)",
        "parameters": [ { "name": "table", "in": "path", "required": true, "schema": { "type": "string" } } ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Row" } } } }
        },
        "responses": {
          "200": {
            "description": "Bulk upsert result",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MutationResult" } } }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Row": {
        "type": "object",
        "description": "A table row / record. Columns are dynamic; example fields shown.",
        "additionalProperties": true,
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "name": { "type": "string", "example": "Alice" },
          "email": { "type": "string", "example": "alice@example.com" }
        }
      },
      "SqlRequest": {
        "type": "object",
        "required": ["sqlQuery"],
        "properties": {
          "sqlQuery": { "type": "string", "example": "SELECT * FROM users LIMIT 10" }
        }
      },
      "QueryResult": {
        "type": "object",
        "description": "mysql2 SELECT result: an array of row objects.",
        "properties": {
          "rows": { "type": "array", "items": { "$ref": "#/components/schemas/Row" } }
        }
      },
      "MutationResult": {
        "type": "object",
        "description": "mysql2 OkPacket returned for INSERT/UPDATE/UPSERT statements.",
        "properties": {
          "fieldCount": { "type": "integer", "example": 0 },
          "affectedRows": { "type": "integer", "example": 1 },
          "insertId": { "type": "integer", "example": 42 },
          "serverStatus": { "type": "integer", "example": 2 },
          "warningCount": { "type": "integer", "example": 0 },
          "changedRows": { "type": "integer", "example": 0 }
        }
      }
    }
  }
}
