{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "zoho/ActionResponse",
  "title": "ActionResponse",
  "x-openfn-adaptor": "zoho",
  "x-source": {
    "openapi": "#/components/schemas/ActionResponse",
    "capturedAt": "2026-07-06"
  },
  "type": "object",
  "description": "Standard Zoho Reports success envelope for data actions (ADDROW, UPDATE, DELETE, IMPORT, EXPORT).",
  "required": [
    "response"
  ],
  "properties": {
    "response": {
      "type": "object",
      "properties": {
        "uri": {
          "type": "string"
        },
        "action": {
          "type": "string",
          "example": "ADDROW"
        },
        "result": {
          "description": "Action result. For ADDROW/EXPORT this is row data; for IMPORT it may carry an import summary.",
          "oneOf": [
            {
              "$ref": "RowResult.json"
            },
            {
              "$ref": "ImportSummary.json"
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        }
      }
    }
  }
}
