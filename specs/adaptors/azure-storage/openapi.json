{
  "openapi": "3.0.3",
  "info": {
    "title": "Azure Blob Storage (OpenFn focused subset)",
    "version": "2021-12-02",
    "description": "Focused OpenAPI description of the Azure Blob Storage blob operations used by the OpenFn azure-storage adaptor (uploadBlob, downloadBlob, getBlobProperties). The adaptor wraps the @azure/storage-blob SDK; responses are modelled as JSON to reflect the shapes the adaptor exposes on state.",
    "x-openfn-adaptor": "azure-storage"
  },
  "servers": [
    { "url": "https://{account}.blob.core.windows.net", "variables": { "account": { "default": "myaccount" } } }
  ],
  "paths": {
    "/{containerName}/{blobName}": {
      "put": {
        "operationId": "uploadBlob",
        "summary": "Upload (Put) a block blob",
        "parameters": [
          { "name": "containerName", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "blobName", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "x-ms-blob-type", "in": "header", "required": false, "schema": { "type": "string", "example": "BlockBlob" } },
          { "name": "x-ms-blob-content-type", "in": "header", "required": false, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/octet-stream": { "schema": { "type": "string", "format": "binary" } }
          }
        },
        "responses": {
          "201": {
            "description": "Blob created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UploadBlobResult" }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "downloadBlob",
        "summary": "Download (Get) a blob",
        "parameters": [
          { "name": "containerName", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "blobName", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Blob content. Adaptor returns the content as a string, Buffer or base64 per downloadAs option.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DownloadBlobResult" }
              }
            }
          }
        }
      },
      "head": {
        "operationId": "getBlobProperties",
        "summary": "Get blob properties",
        "parameters": [
          { "name": "containerName", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "blobName", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Blob properties",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BlobProperties" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "UploadBlobResult": {
        "type": "object",
        "properties": {
          "requestId": { "type": "string" },
          "etag": { "type": "string" },
          "lastModified": { "type": "string", "format": "date-time" },
          "contentMD5": { "type": "string", "nullable": true },
          "clientRequestId": { "type": "string", "nullable": true },
          "date": { "type": "string", "format": "date-time" },
          "version": { "type": "string" },
          "isServerEncrypted": { "type": "boolean" }
        }
      },
      "DownloadBlobResult": {
        "type": "object",
        "properties": {
          "containerName": { "type": "string" },
          "blobName": { "type": "string" },
          "contentType": { "type": "string" },
          "contentLength": { "type": "integer" },
          "etag": { "type": "string" },
          "lastModified": { "type": "string", "format": "date-time" },
          "content": { "type": "string", "description": "Blob content as string" },
          "base64": { "type": "string", "description": "Base64 content when downloadAs is base64" }
        }
      },
      "BlobProperties": {
        "type": "object",
        "properties": {
          "blobType": { "type": "string", "example": "BlockBlob" },
          "contentLength": { "type": "integer" },
          "contentType": { "type": "string" },
          "contentEncoding": { "type": "string", "nullable": true },
          "contentMD5": { "type": "string", "nullable": true },
          "etag": { "type": "string" },
          "lastModified": { "type": "string", "format": "date-time" },
          "createdOn": { "type": "string", "format": "date-time" },
          "leaseState": { "type": "string", "example": "available" },
          "leaseStatus": { "type": "string", "example": "unlocked" },
          "accessTier": { "type": "string", "example": "Hot" },
          "serverEncrypted": { "type": "boolean" },
          "metadata": { "type": "object", "additionalProperties": { "type": "string" } }
        }
      }
    }
  }
}
