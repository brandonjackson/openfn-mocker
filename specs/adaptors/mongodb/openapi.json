{
  "openapi": "3.0.3",
  "info": {
    "title": "MongoDB Document Operations (synthesized)",
    "version": "1.0.0",
    "description": "Synthesized OpenAPI 3.0.3 describing the document operations exercised by the OpenFn mongodb adaptor. MongoDB is a document database driven over the wire protocol, not a REST/JSON HTTP API; this document models the adaptor's insert/find/update operations as JSON REST endpoints so mocker can seed and serve document collections.",
    "x-openfn-adaptor": "mongodb"
  },
  "servers": [{ "url": "http://localhost:8080" }],
  "paths": {
    "/{database}/{collection}/insert": {
      "post": {
        "operationId": "insertDocuments",
        "summary": "Insert documents into a collection",
        "parameters": [
          { "name": "database", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "collection", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "documents": { "type": "array", "items": { "$ref": "#/components/schemas/Document" } }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Insert result",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/InsertResult" } }
            }
          }
        }
      }
    },
    "/{database}/{collection}/find": {
      "post": {
        "operationId": "findDocuments",
        "summary": "Find documents in a collection",
        "parameters": [
          { "name": "database", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "collection", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "query": { "type": "object", "additionalProperties": true },
                  "projection": { "type": "object", "additionalProperties": true }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Matching documents",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/FindResult" } }
            }
          }
        }
      }
    },
    "/{database}/{collection}/update": {
      "post": {
        "operationId": "updateDocument",
        "summary": "Update (optionally upsert) documents in a collection",
        "parameters": [
          { "name": "database", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "collection", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "filter": { "type": "object", "additionalProperties": true },
                  "changes": { "type": "object", "additionalProperties": true },
                  "options": {
                    "type": "object",
                    "properties": { "upsert": { "type": "boolean" } }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Update result",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/UpdateResult" } }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Document": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "_id": { "type": "string", "example": "665f1c2b9a1e4d0012ab34cd" }
        }
      },
      "InsertResult": {
        "type": "object",
        "properties": {
          "acknowledged": { "type": "boolean", "example": true },
          "insertedCount": { "type": "integer", "example": 3 },
          "insertedIds": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      },
      "FindResult": {
        "type": "object",
        "properties": {
          "documents": { "type": "array", "items": { "$ref": "#/components/schemas/Document" } }
        }
      },
      "UpdateResult": {
        "type": "object",
        "properties": {
          "acknowledged": { "type": "boolean", "example": true },
          "matchedCount": { "type": "integer", "example": 1 },
          "modifiedCount": { "type": "integer", "example": 1 },
          "upsertedCount": { "type": "integer", "example": 0 },
          "upsertedId": { "type": "string", "nullable": true }
        }
      }
    }
  }
}
