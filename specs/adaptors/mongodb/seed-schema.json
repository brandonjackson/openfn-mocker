{
  "openapi": "3.0.3",
  "info": {
    "title": "mongodb — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate mongodb. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "mongodb",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "findResults": {
        "resource": "FindResult",
        "schema": {
          "$ref": "#/components/schemas/FindResult"
        }
      },
      "insertResults": {
        "resource": "InsertResult",
        "schema": {
          "$ref": "#/components/schemas/InsertResult"
        }
      },
      "updateResults": {
        "resource": "UpdateResult",
        "schema": {
          "$ref": "#/components/schemas/UpdateResult"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "findResults": {
            "type": "object",
            "description": "Records keyed by id for the findResults collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/FindResult"
            }
          },
          "insertResults": {
            "type": "object",
            "description": "Records keyed by id for the insertResults collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/InsertResult"
            }
          },
          "updateResults": {
            "type": "object",
            "description": "Records keyed by id for the updateResults collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/UpdateResult"
            }
          }
        },
        "additionalProperties": false
      },
      "Document": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "_id": {
            "type": "string",
            "example": "665f1c2b9a1e4d0012ab34cd"
          }
        }
      },
      "InsertResult": {
        "type": "object",
        "properties": {
          "acknowledged": {
            "type": "boolean",
            "example": true
          },
          "insertedCount": {
            "type": "integer",
            "example": 3
          },
          "insertedIds": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "FindResult": {
        "type": "object",
        "properties": {
          "documents": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Document"
            }
          }
        }
      },
      "UpdateResult": {
        "type": "object",
        "properties": {
          "acknowledged": {
            "type": "boolean",
            "example": true
          },
          "matchedCount": {
            "type": "integer",
            "example": 1
          },
          "modifiedCount": {
            "type": "integer",
            "example": 1
          },
          "upsertedCount": {
            "type": "integer",
            "example": 0
          },
          "upsertedId": {
            "type": "string",
            "nullable": true
          }
        }
      }
    }
  }
}
