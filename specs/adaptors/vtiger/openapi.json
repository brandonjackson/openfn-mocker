{
  "openapi": "3.0.3",
  "info": {
    "title": "Vtiger CRM Webservices API",
    "version": "1.0.0",
    "description": "Focused OpenAPI description of the Vtiger CRM Webservices (REST) API, covering the operations exercised by the OpenFn `@openfn/language-vtiger` adaptor. The real Vtiger API is RPC-style: every call is issued against the single `/webservice.php` endpoint and the action is selected via an `operation` parameter (form-encoded for POST, query string for GET). To make the surface mockable, each RPC operation is modelled here as a distinct path segment under `/webservice.php`. Every response is wrapped in the standard envelope `{ \"success\": boolean, \"result\": ... }` (or `{ \"success\": false, \"error\": {...} }` on failure). The adaptor authenticates with a getchallenge -> login handshake (accessKey = md5(token + accessKey)) and drives records through a generic `postElement({ operation, elementType, element })` helper that maps onto create/update/delete/revise.",
    "x-openfn-adaptor": "vtiger"
  },
  "servers": [
    {
      "url": "https://{instance}.od1.vtiger.com",
      "description": "Vtiger On-Demand / self-hosted CRM instance host. The adaptor appends `/webservice.php` to the configured hostUrl.",
      "variables": {
        "instance": {
          "default": "mycompany",
          "description": "Vtiger instance / subdomain (self-hosted installs use their own host)."
        }
      }
    }
  ],
  "paths": {
    "/webservice.php/getchallenge": {
      "get": {
        "operationId": "getChallenge",
        "summary": "Get authentication challenge token",
        "description": "First step of the login handshake. Returns a short-lived challenge token that must be combined with the user's access key (md5(token + accessKey)) to produce the login accessKey.",
        "parameters": [
          { "$ref": "#/components/parameters/OperationGet" },
          {
            "name": "username",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "CRM username requesting the challenge."
          }
        ],
        "responses": {
          "200": {
            "description": "Challenge token issued.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ChallengeResponse" }
              }
            }
          }
        }
      }
    },
    "/webservice.php/login": {
      "post": {
        "operationId": "login",
        "summary": "Log in and open a session",
        "description": "Second step of the handshake. Exchanges the username and computed accessKey (md5(challengeToken + userAccessKey)) for a session.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": { "$ref": "#/components/schemas/LoginRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session established.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LoginResponse" }
              }
            }
          }
        }
      }
    },
    "/webservice.php/logout": {
      "get": {
        "operationId": "logout",
        "summary": "Close the current session",
        "parameters": [
          { "$ref": "#/components/parameters/OperationGet" },
          { "$ref": "#/components/parameters/SessionNameQuery" }
        ],
        "responses": {
          "200": {
            "description": "Session closed.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LogoutResponse" }
              }
            }
          }
        }
      }
    },
    "/webservice.php/listtypes": {
      "post": {
        "operationId": "listTypes",
        "summary": "List accessible module (element) types",
        "description": "Returns the CRM modules the authenticated user can access, along with per-module metadata. Called by the adaptor's `listTypes()` operation.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["operation", "sessionName"],
                "properties": {
                  "operation": { "type": "string", "enum": ["listTypes"] },
                  "sessionName": { "type": "string", "description": "Active session id from login." }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Module types listing.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListTypesResponse" }
              }
            }
          }
        }
      }
    },
    "/webservice.php/describe": {
      "get": {
        "operationId": "describe",
        "summary": "Describe a module's fields and metadata",
        "parameters": [
          { "$ref": "#/components/parameters/OperationGet" },
          { "$ref": "#/components/parameters/SessionNameQuery" },
          {
            "name": "elementType",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Module name to describe, e.g. Contacts, Accounts, Leads."
          }
        ],
        "responses": {
          "200": {
            "description": "Module description.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DescribeResponse" }
              }
            }
          }
        }
      }
    },
    "/webservice.php/create": {
      "post": {
        "operationId": "createElement",
        "summary": "Create a CRM record",
        "description": "Creates a record in the given module. Reached via the adaptor's `postElement({ operation: 'create', elementType, element })`.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": { "$ref": "#/components/schemas/CreateElementRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Record created.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ElementResponse" }
              }
            }
          }
        }
      }
    },
    "/webservice.php/retrieve": {
      "get": {
        "operationId": "retrieveElement",
        "summary": "Retrieve a CRM record by id",
        "parameters": [
          { "$ref": "#/components/parameters/OperationGet" },
          { "$ref": "#/components/parameters/SessionNameQuery" },
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Webservice record id, e.g. \"12x45\" (moduleId x recordId)."
          }
        ],
        "responses": {
          "200": {
            "description": "Record retrieved.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ElementResponse" }
              }
            }
          }
        }
      }
    },
    "/webservice.php/update": {
      "post": {
        "operationId": "updateElement",
        "summary": "Update (fully replace) a CRM record",
        "description": "Replaces a record with the supplied element. Reached via `postElement({ operation: 'update', ... })`.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": { "$ref": "#/components/schemas/UpdateElementRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Record updated.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ElementResponse" }
              }
            }
          }
        }
      }
    },
    "/webservice.php/revise": {
      "post": {
        "operationId": "reviseElement",
        "summary": "Partially update a CRM record",
        "description": "Updates only the supplied fields of a record (partial update). Reached via `postElement({ operation: 'revise', ... })`.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": { "$ref": "#/components/schemas/UpdateElementRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Record revised.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ElementResponse" }
              }
            }
          }
        }
      }
    },
    "/webservice.php/delete": {
      "post": {
        "operationId": "deleteElement",
        "summary": "Delete a CRM record",
        "description": "Deletes a record by id. Reached via `postElement({ operation: 'delete', ... })`.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["operation", "sessionName", "id"],
                "properties": {
                  "operation": { "type": "string", "enum": ["delete"] },
                  "sessionName": { "type": "string" },
                  "id": { "type": "string", "description": "Webservice record id to delete." }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Record deleted.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DeleteResponse" }
              }
            }
          }
        }
      }
    },
    "/webservice.php/query": {
      "get": {
        "operationId": "query",
        "summary": "Run a VtigerQL query",
        "description": "Executes a read-only, SQL-like query (VtigerQL). Query strings must end with a semicolon.",
        "parameters": [
          { "$ref": "#/components/parameters/OperationGet" },
          { "$ref": "#/components/parameters/SessionNameQuery" },
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "example": "SELECT * FROM Contacts WHERE lastname = 'Smith' LIMIT 0,10;",
            "description": "VtigerQL statement terminated by a semicolon."
          }
        ],
        "responses": {
          "200": {
            "description": "Query results.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/QueryResponse" }
              }
            }
          }
        }
      }
    },
    "/webservice.php/sync": {
      "get": {
        "operationId": "sync",
        "summary": "Fetch records changed since a timestamp",
        "parameters": [
          { "$ref": "#/components/parameters/OperationGet" },
          { "$ref": "#/components/parameters/SessionNameQuery" },
          {
            "name": "modifiedTime",
            "in": "query",
            "required": true,
            "schema": { "type": "integer", "format": "int64" },
            "description": "Unix epoch seconds; records modified at or after this time are returned."
          },
          {
            "name": "elementType",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Optional module name to restrict the sync to."
          }
        ],
        "responses": {
          "200": {
            "description": "Changed and deleted records.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SyncResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "OperationGet": {
        "name": "operation",
        "in": "query",
        "required": true,
        "schema": { "type": "string" },
        "description": "RPC operation name selecting the action performed against /webservice.php."
      },
      "SessionNameQuery": {
        "name": "sessionName",
        "in": "query",
        "required": true,
        "schema": { "type": "string" },
        "description": "Active session id returned by login (result.sessionName / sessionId)."
      }
    },
    "schemas": {
      "ChallengeResult": {
        "type": "object",
        "description": "Challenge token payload.",
        "properties": {
          "token": { "type": "string", "description": "Challenge token to hash with the user access key." },
          "serverTime": { "type": "integer", "format": "int64", "description": "Server time (epoch seconds)." },
          "expireTime": { "type": "integer", "format": "int64", "description": "Token expiry (epoch seconds)." }
        },
        "required": ["token"]
      },
      "ChallengeResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "result": { "$ref": "#/components/schemas/ChallengeResult" }
        },
        "required": ["success", "result"]
      },
      "LoginRequest": {
        "type": "object",
        "required": ["operation", "username", "accessKey"],
        "properties": {
          "operation": { "type": "string", "enum": ["login"] },
          "username": { "type": "string", "description": "CRM username." },
          "accessKey": { "type": "string", "description": "md5(challengeToken + userAccessKey)." }
        }
      },
      "LoginResult": {
        "type": "object",
        "description": "Session details returned on successful login.",
        "properties": {
          "sessionName": { "type": "string", "description": "Session id used to authenticate subsequent calls." },
          "sessionId": { "type": "string", "description": "Alias of sessionName in some Vtiger versions." },
          "userId": { "type": "string", "description": "Webservice id of the logged-in user, e.g. \"19x1\"." },
          "version": { "type": "string", "description": "Webservice API version." },
          "vtigerVersion": { "type": "string", "description": "CRM version." }
        },
        "required": ["sessionName"]
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "result": { "$ref": "#/components/schemas/LoginResult" }
        },
        "required": ["success", "result"]
      },
      "LogoutResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "result": {
            "type": "object",
            "description": "Empty or informational result object on logout.",
            "additionalProperties": true
          }
        },
        "required": ["success"]
      },
      "ModuleType": {
        "type": "object",
        "description": "Metadata for a single CRM module (element type).",
        "properties": {
          "name": { "type": "string", "description": "Module name, e.g. Contacts." },
          "label": { "type": "string", "description": "Human-readable module label." },
          "singular": { "type": "string", "description": "Singular label." },
          "isEntity": { "type": "boolean", "description": "Whether the module represents an entity with records." }
        },
        "required": ["name"]
      },
      "ListTypesResult": {
        "type": "object",
        "description": "Result of listTypes: accessible module names plus per-module info.",
        "properties": {
          "types": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Accessible module names."
          },
          "information": {
            "type": "object",
            "additionalProperties": { "$ref": "#/components/schemas/ModuleType" },
            "description": "Map of module name to module metadata."
          }
        }
      },
      "ListTypesResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "result": { "$ref": "#/components/schemas/ListTypesResult" }
        },
        "required": ["success", "result"]
      },
      "FieldType": {
        "type": "object",
        "description": "Data type descriptor for a module field.",
        "properties": {
          "name": { "type": "string", "description": "Field type name, e.g. string, picklist, reference." },
          "picklistValues": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "label": { "type": "string" },
                "value": { "type": "string" }
              }
            }
          },
          "refersTo": {
            "type": "array",
            "items": { "type": "string" },
            "description": "For reference fields, the modules referenced."
          }
        }
      },
      "Field": {
        "type": "object",
        "description": "A single field definition within a module description.",
        "properties": {
          "name": { "type": "string" },
          "label": { "type": "string" },
          "mandatory": { "type": "boolean" },
          "type": { "$ref": "#/components/schemas/FieldType" },
          "nullable": { "type": "boolean" },
          "editable": { "type": "boolean" }
        },
        "required": ["name"]
      },
      "DescribeResult": {
        "type": "object",
        "description": "Field-level description of a module.",
        "properties": {
          "label": { "type": "string" },
          "name": { "type": "string" },
          "createable": { "type": "boolean" },
          "updateable": { "type": "boolean" },
          "deleteable": { "type": "boolean" },
          "retrieveable": { "type": "boolean" },
          "idPrefix": { "type": "string", "description": "Numeric module prefix used in webservice ids." },
          "isEntity": { "type": "boolean" },
          "fields": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Field" }
          }
        },
        "required": ["name"]
      },
      "DescribeResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "result": { "$ref": "#/components/schemas/DescribeResult" }
        },
        "required": ["success", "result"]
      },
      "Element": {
        "type": "object",
        "description": "A generic Vtiger CRM record. Field set varies by module; `id` and `assigned_user_id` are common. Additional module fields are permitted.",
        "properties": {
          "id": { "type": "string", "description": "Webservice record id, e.g. \"12x45\"." },
          "assigned_user_id": { "type": "string", "description": "Owner user/group webservice id." },
          "createdtime": { "type": "string", "description": "Creation timestamp." },
          "modifiedtime": { "type": "string", "description": "Last modified timestamp." }
        },
        "additionalProperties": true
      },
      "Contact": {
        "type": "object",
        "description": "A record from the Contacts module.",
        "properties": {
          "id": { "type": "string" },
          "firstname": { "type": "string" },
          "lastname": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" },
          "mobile": { "type": "string" },
          "account_id": { "type": "string", "description": "Reference to the parent Account." },
          "assigned_user_id": { "type": "string" }
        },
        "required": ["lastname"],
        "additionalProperties": true
      },
      "Account": {
        "type": "object",
        "description": "A record from the Accounts (organizations) module.",
        "properties": {
          "id": { "type": "string" },
          "accountname": { "type": "string" },
          "email1": { "type": "string" },
          "phone": { "type": "string" },
          "website": { "type": "string" },
          "industry": { "type": "string" },
          "assigned_user_id": { "type": "string" }
        },
        "required": ["accountname"],
        "additionalProperties": true
      },
      "Lead": {
        "type": "object",
        "description": "A record from the Leads module.",
        "properties": {
          "id": { "type": "string" },
          "firstname": { "type": "string" },
          "lastname": { "type": "string" },
          "company": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" },
          "leadstatus": { "type": "string" },
          "leadsource": { "type": "string" },
          "assigned_user_id": { "type": "string" }
        },
        "required": ["lastname", "company"],
        "additionalProperties": true
      },
      "CreateElementRequest": {
        "type": "object",
        "required": ["operation", "sessionName", "elementType", "element"],
        "properties": {
          "operation": { "type": "string", "enum": ["create"] },
          "sessionName": { "type": "string" },
          "elementType": { "type": "string", "description": "Module name, e.g. Contacts." },
          "element": { "type": "string", "description": "JSON-encoded record object (the adaptor JSON.stringifies `element`)." }
        }
      },
      "UpdateElementRequest": {
        "type": "object",
        "required": ["operation", "sessionName", "element"],
        "properties": {
          "operation": { "type": "string", "enum": ["update", "revise"] },
          "sessionName": { "type": "string" },
          "elementType": { "type": "string", "description": "Module name (optional for update/revise)." },
          "element": { "type": "string", "description": "JSON-encoded record object; must include `id`." }
        }
      },
      "ElementResponse": {
        "type": "object",
        "description": "Envelope for operations that return a single record (create/retrieve/update/revise).",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "result": { "$ref": "#/components/schemas/Element" }
        },
        "required": ["success", "result"]
      },
      "DeleteResult": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "successful" }
        }
      },
      "DeleteResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "result": { "$ref": "#/components/schemas/DeleteResult" }
        },
        "required": ["success", "result"]
      },
      "QueryResult": {
        "type": "array",
        "description": "Query returns an array of matching records.",
        "items": { "$ref": "#/components/schemas/Element" }
      },
      "QueryResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "result": { "$ref": "#/components/schemas/QueryResult" }
        },
        "required": ["success", "result"]
      },
      "SyncResult": {
        "type": "object",
        "description": "Result of a sync call.",
        "properties": {
          "updated": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Element" },
            "description": "Records created or updated since modifiedTime."
          },
          "deleted": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Webservice ids of deleted records."
          },
          "lastModifiedTime": { "type": "integer", "format": "int64", "description": "Cursor to pass to the next sync call." },
          "more": { "type": "boolean", "description": "Whether additional pages remain." }
        }
      },
      "SyncResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "result": { "$ref": "#/components/schemas/SyncResult" }
        },
        "required": ["success", "result"]
      },
      "Error": {
        "type": "object",
        "description": "Error payload returned when success is false.",
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "error": { "$ref": "#/components/schemas/Error" }
        },
        "required": ["success", "error"]
      }
    }
  }
}
