{
  "openapi": "3.0.3",
  "info": {
    "title": "googlehealthcare — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate googlehealthcare. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "googlehealthcare",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "bundles": {
        "resource": "Bundle",
        "schema": {
          "$ref": "#/components/schemas/Bundle"
        }
      },
      "fhirResources": {
        "resource": "FhirResource",
        "schema": {
          "$ref": "#/components/schemas/FhirResource"
        }
      },
      "operationOutcomes": {
        "resource": "OperationOutcome",
        "schema": {
          "$ref": "#/components/schemas/OperationOutcome"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "bundles": {
            "type": "object",
            "description": "Records keyed by id for the bundles collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Bundle"
            }
          },
          "fhirResources": {
            "type": "object",
            "description": "Records keyed by id for the fhirResources collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/FhirResource"
            }
          },
          "operationOutcomes": {
            "type": "object",
            "description": "Records keyed by id for the operationOutcomes collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/OperationOutcome"
            }
          }
        },
        "additionalProperties": false
      },
      "FhirResource": {
        "type": "object",
        "description": "A generic FHIR R4 resource. resourceType is required; other fields vary by type.",
        "required": [
          "resourceType"
        ],
        "properties": {
          "resourceType": {
            "type": "string",
            "example": "Patient"
          },
          "id": {
            "type": "string",
            "example": "a1b2c3d4-0000-0000-0000-000000000000"
          },
          "meta": {
            "type": "object",
            "properties": {
              "versionId": {
                "type": "string",
                "example": "1"
              },
              "lastUpdated": {
                "type": "string",
                "format": "date-time",
                "example": "2024-03-05T12:30:00.000Z"
              }
            }
          },
          "identifier": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "system": {
                  "type": "string",
                  "example": "urn:oid:2.16.840.1.113883.2.4.6.3"
                },
                "value": {
                  "type": "string",
                  "example": "12345"
                }
              }
            }
          }
        },
        "additionalProperties": true,
        "example": {
          "resourceType": "Patient",
          "id": "a1b2c3d4-0000-0000-0000-000000000000",
          "meta": {
            "versionId": "1",
            "lastUpdated": "2024-03-05T12:30:00.000Z"
          },
          "name": [
            {
              "use": "official",
              "family": "Mensah",
              "given": [
                "Ama"
              ]
            }
          ],
          "gender": "female",
          "birthDate": "1990-05-12"
        }
      },
      "Bundle": {
        "type": "object",
        "description": "A FHIR Bundle (searchset).",
        "required": [
          "resourceType"
        ],
        "properties": {
          "resourceType": {
            "type": "string",
            "example": "Bundle"
          },
          "type": {
            "type": "string",
            "example": "searchset"
          },
          "total": {
            "type": "integer",
            "format": "int32",
            "example": 1
          },
          "link": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "relation": {
                  "type": "string",
                  "example": "self"
                },
                "url": {
                  "type": "string"
                }
              }
            }
          },
          "entry": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "fullUrl": {
                  "type": "string"
                },
                "resource": {
                  "$ref": "#/components/schemas/FhirResource"
                },
                "search": {
                  "type": "object",
                  "properties": {
                    "mode": {
                      "type": "string",
                      "example": "match"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "OperationOutcome": {
        "type": "object",
        "description": "A FHIR OperationOutcome, returned for errors.",
        "required": [
          "resourceType"
        ],
        "properties": {
          "resourceType": {
            "type": "string",
            "example": "OperationOutcome"
          },
          "issue": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "severity": {
                  "type": "string",
                  "example": "error"
                },
                "code": {
                  "type": "string",
                  "example": "invalid"
                },
                "diagnostics": {
                  "type": "string",
                  "example": "Resource type in URL does not match resourceType in body."
                }
              }
            }
          }
        }
      }
    }
  }
}
