{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "googlehealthcare/FhirResource",
  "title": "FhirResource",
  "x-openfn-adaptor": "googlehealthcare",
  "x-source": {
    "openapi": "#/components/schemas/FhirResource",
    "capturedAt": "2026-07-06"
  },
  "type": "object",
  "description": "A generic FHIR R4 resource. resourceType is required; other fields vary by type.",
  "required": [
    "resourceType"
  ],
  "properties": {
    "resourceType": {
      "type": "string",
      "example": "Patient"
    },
    "id": {
      "type": "string",
      "example": "a1b2c3d4-0000-0000-0000-000000000000"
    },
    "meta": {
      "type": "object",
      "properties": {
        "versionId": {
          "type": "string",
          "example": "1"
        },
        "lastUpdated": {
          "type": "string",
          "format": "date-time",
          "example": "2024-03-05T12:30:00.000Z"
        }
      }
    },
    "identifier": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "system": {
            "type": "string",
            "example": "urn:oid:2.16.840.1.113883.2.4.6.3"
          },
          "value": {
            "type": "string",
            "example": "12345"
          }
        }
      }
    }
  },
  "additionalProperties": true,
  "example": {
    "resourceType": "Patient",
    "id": "a1b2c3d4-0000-0000-0000-000000000000",
    "meta": {
      "versionId": "1",
      "lastUpdated": "2024-03-05T12:30:00.000Z"
    },
    "name": [
      {
        "use": "official",
        "family": "Mensah",
        "given": [
          "Ama"
        ]
      }
    ],
    "gender": "female",
    "birthDate": "1990-05-12"
  }
}
