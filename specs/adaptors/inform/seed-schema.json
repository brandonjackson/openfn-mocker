{
  "openapi": "3.0.3",
  "info": {
    "title": "inform — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate inform. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "inform",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "attachments": {
        "resource": "Attachment",
        "schema": {
          "$ref": "#/components/schemas/Attachment"
        }
      },
      "forms": {
        "resource": "Form",
        "schema": {
          "$ref": "#/components/schemas/Form"
        }
      },
      "formStructures": {
        "resource": "FormStructure",
        "schema": {
          "$ref": "#/components/schemas/FormStructure"
        }
      },
      "submissions": {
        "resource": "Submission",
        "schema": {
          "$ref": "#/components/schemas/Submission"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "attachments": {
            "type": "object",
            "description": "Records keyed by id for the attachments collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Attachment"
            }
          },
          "forms": {
            "type": "object",
            "description": "Records keyed by id for the forms collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Form"
            }
          },
          "formStructures": {
            "type": "object",
            "description": "Records keyed by id for the formStructures collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/FormStructure"
            }
          },
          "submissions": {
            "type": "object",
            "description": "Records keyed by id for the submissions collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Submission"
            }
          }
        },
        "additionalProperties": false
      },
      "Form": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri"
          },
          "formid": {
            "type": "integer",
            "example": 6225
          },
          "uuid": {
            "type": "string",
            "example": "853fa4a8f52e4b4c9f0d3d2c1b0a9e8f"
          },
          "id_string": {
            "type": "string",
            "example": "household_survey"
          },
          "title": {
            "type": "string",
            "example": "Household Survey"
          },
          "description": {
            "type": "string"
          },
          "downloadable": {
            "type": "boolean"
          },
          "encrypted": {
            "type": "boolean"
          },
          "owner": {
            "type": "string",
            "format": "uri"
          },
          "public": {
            "type": "boolean"
          },
          "public_data": {
            "type": "boolean"
          },
          "num_of_submissions": {
            "type": "integer",
            "example": 42
          },
          "date_created": {
            "type": "string",
            "format": "date-time"
          },
          "date_modified": {
            "type": "string",
            "format": "date-time"
          },
          "last_updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "FormStructure": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "household_survey"
          },
          "title": {
            "type": "string",
            "example": "Household Survey"
          },
          "id_string": {
            "type": "string",
            "example": "household_survey"
          },
          "type": {
            "type": "string",
            "example": "survey"
          },
          "default_language": {
            "type": "string",
            "example": "default"
          },
          "children": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "Submission": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "integer",
            "example": 7783155
          },
          "_uuid": {
            "type": "string",
            "example": "b1a2c3d4-e5f6-7890-abcd-ef1234567890"
          },
          "_submission_time": {
            "type": "string",
            "format": "date-time",
            "example": "2024-11-05T09:30:00"
          },
          "_xform_id_string": {
            "type": "string",
            "example": "household_survey"
          },
          "_status": {
            "type": "string",
            "example": "submitted_via_web"
          },
          "_geolocation": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "nullable": true
          },
          "_attachments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Attachment"
            }
          },
          "formhub/uuid": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "Attachment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 621985
          },
          "xform": {
            "type": "integer",
            "example": 6225
          },
          "instance": {
            "type": "integer",
            "example": 7783155
          },
          "filename": {
            "type": "string",
            "example": "project/attachments/download_1.png"
          },
          "mimetype": {
            "type": "string",
            "example": "image/png"
          },
          "download_url": {
            "type": "string",
            "format": "uri"
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    }
  }
}
