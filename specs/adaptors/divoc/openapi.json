{
  "openapi": "3.0.3",
  "info": {
    "title": "DIVOC Vaccination Certification API (subset)",
    "version": "1.0.0",
    "description": "Focused OpenAPI subset of the DIVOC (Digital Infrastructure for Vaccination Open Credentialing) vaccination certification API, covering the single endpoint used by the OpenFn divoc adaptor: POST /v1/certify, which submits vaccination event data and triggers generation of a verifiable digital certificate.",
    "x-openfn-adaptor": "divoc"
  },
  "servers": [{ "url": "http://localhost:4010" }],
  "paths": {
    "/v1/certify": {
      "post": {
        "operationId": "certifyVaccination",
        "summary": "Certify a vaccination and generate a verifiable certificate",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  { "$ref": "#/components/schemas/CertificationRequest" },
                  {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/CertificationRequest" }
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Certificate issued",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Certificate" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CertificationRequest": {
        "type": "object",
        "required": ["preEnrollmentCode", "recipient", "vaccination"],
        "properties": {
          "preEnrollmentCode": { "type": "string" },
          "recipient": { "$ref": "#/components/schemas/Recipient" },
          "vaccination": { "$ref": "#/components/schemas/Vaccination" },
          "vaccinator": { "$ref": "#/components/schemas/Vaccinator" },
          "facility": { "$ref": "#/components/schemas/Facility" }
        }
      },
      "Recipient": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "dob": { "type": "string", "format": "date" },
          "age": { "type": "string" },
          "gender": { "type": "string" },
          "nationality": { "type": "string" },
          "identity": { "type": "string" },
          "contact": { "type": "array", "items": { "type": "string" } },
          "address": { "$ref": "#/components/schemas/Address" }
        }
      },
      "Vaccination": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "batch": { "type": "string" },
          "manufacturer": { "type": "string" },
          "date": { "type": "string", "format": "date-time" },
          "effectiveStart": { "type": "string", "format": "date" },
          "effectiveUntil": { "type": "string", "format": "date" },
          "dose": { "type": "integer" },
          "totalDoses": { "type": "integer" }
        }
      },
      "Vaccinator": {
        "type": "object",
        "properties": {
          "name": { "type": "string" }
        }
      },
      "Facility": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "address": { "$ref": "#/components/schemas/Address" }
        }
      },
      "Address": {
        "type": "object",
        "properties": {
          "addressLine1": { "type": "string" },
          "addressLine2": { "type": "string" },
          "district": { "type": "string" },
          "city": { "type": "string" },
          "state": { "type": "string" },
          "pincode": { "type": "string" }
        }
      },
      "Certificate": {
        "type": "object",
        "properties": {
          "certificateId": { "type": "string" },
          "preEnrollmentCode": { "type": "string" },
          "issuedDate": { "type": "string", "format": "date-time" },
          "status": { "type": "string" },
          "signedCertificate": { "type": "object" },
          "qrCode": { "type": "string" }
        }
      }
    }
  }
}
