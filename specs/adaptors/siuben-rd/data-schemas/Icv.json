{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "siuben-rd/Icv",
  "title": "Icv",
  "x-openfn-adaptor": "siuben-rd",
  "x-source": {
    "openapi": "#/components/schemas/Icv",
    "capturedAt": "2026-07-06"
  },
  "type": "object",
  "description": "Índice de Calidad de Vida (Quality of Life Index) classification for a household.",
  "properties": {
    "hogarId": {
      "type": "string"
    },
    "puntaje": {
      "type": "number",
      "description": "Score on a 0–100 scale.",
      "example": 42.7
    },
    "categoria": {
      "type": "string",
      "description": "ICV poverty category.",
      "example": "ICV-2"
    },
    "cisehVersion": {
      "type": "string",
      "example": "CISEH-2023"
    }
  }
}
