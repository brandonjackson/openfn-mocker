{
  "openapi": "3.0.3",
  "info": {
    "title": "siuben-rd — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate siuben-rd. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "siuben-rd",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "authResponses": {
        "resource": "AuthResponse",
        "schema": {
          "$ref": "#/components/schemas/AuthResponse"
        }
      },
      "beneficiarios": {
        "resource": "Beneficiario",
        "schema": {
          "$ref": "#/components/schemas/Beneficiario"
        }
      },
      "hogars": {
        "resource": "Hogar",
        "schema": {
          "$ref": "#/components/schemas/Hogar"
        }
      },
      "icvs": {
        "resource": "Icv",
        "schema": {
          "$ref": "#/components/schemas/Icv"
        }
      },
      "miembroHogars": {
        "resource": "MiembroHogar",
        "schema": {
          "$ref": "#/components/schemas/MiembroHogar"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "authResponses": {
            "type": "object",
            "description": "Records keyed by id for the authResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/AuthResponse"
            }
          },
          "beneficiarios": {
            "type": "object",
            "description": "Records keyed by id for the beneficiarios collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Beneficiario"
            }
          },
          "hogars": {
            "type": "object",
            "description": "Records keyed by id for the hogars collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Hogar"
            }
          },
          "icvs": {
            "type": "object",
            "description": "Records keyed by id for the icvs collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Icv"
            }
          },
          "miembroHogars": {
            "type": "object",
            "description": "Records keyed by id for the miembroHogars collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/MiembroHogar"
            }
          }
        },
        "additionalProperties": false
      },
      "AuthRequest": {
        "type": "object",
        "required": [
          "username",
          "password"
        ],
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "Token": {
            "type": "string",
            "description": "Bearer token used for subsequent Authorization headers."
          },
          "Expiration": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Beneficiario": {
        "type": "object",
        "properties": {
          "cedula": {
            "type": "string",
            "description": "National ID (cédula) of the beneficiary.",
            "example": "00112345678"
          },
          "nombres": {
            "type": "string"
          },
          "apellidos": {
            "type": "string"
          },
          "sexo": {
            "type": "string",
            "enum": [
              "M",
              "F"
            ]
          },
          "fechaNacimiento": {
            "type": "string",
            "format": "date"
          },
          "hogarId": {
            "type": "string"
          },
          "estatus": {
            "type": "string",
            "description": "Registration status of the beneficiary.",
            "example": "REGISTRADO"
          }
        }
      },
      "Hogar": {
        "type": "object",
        "properties": {
          "hogarId": {
            "type": "string"
          },
          "jefeHogarCedula": {
            "type": "string"
          },
          "provincia": {
            "type": "string"
          },
          "municipio": {
            "type": "string"
          },
          "sector": {
            "type": "string"
          },
          "direccion": {
            "type": "string"
          },
          "cantidadMiembros": {
            "type": "integer"
          },
          "icv": {
            "$ref": "#/components/schemas/Icv"
          }
        }
      },
      "MiembroHogar": {
        "type": "object",
        "properties": {
          "cedula": {
            "type": "string"
          },
          "nombres": {
            "type": "string"
          },
          "apellidos": {
            "type": "string"
          },
          "parentesco": {
            "type": "string",
            "description": "Relationship to the head of household.",
            "example": "HIJO"
          },
          "edad": {
            "type": "integer"
          }
        }
      },
      "Icv": {
        "type": "object",
        "description": "Índice de Calidad de Vida (Quality of Life Index) classification for a household.",
        "properties": {
          "hogarId": {
            "type": "string"
          },
          "puntaje": {
            "type": "number",
            "description": "Score on a 0–100 scale.",
            "example": 42.7
          },
          "categoria": {
            "type": "string",
            "description": "ICV poverty category.",
            "example": "ICV-2"
          },
          "cisehVersion": {
            "type": "string",
            "example": "CISEH-2023"
          }
        }
      },
      "ListaBeneficiarios": {
        "type": "object",
        "properties": {
          "total": {
            "type": "integer"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Beneficiario"
            }
          }
        }
      },
      "ListaMiembros": {
        "type": "object",
        "properties": {
          "total": {
            "type": "integer"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MiembroHogar"
            }
          }
        }
      }
    }
  }
}
