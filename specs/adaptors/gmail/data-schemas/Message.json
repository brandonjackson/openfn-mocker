{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gmail/Message",
  "title": "Message",
  "x-openfn-adaptor": "gmail",
  "x-source": {
    "openapi": "#/components/schemas/Message",
    "capturedAt": "2026-07-06"
  },
  "type": "object",
  "description": "A Gmail message.",
  "properties": {
    "id": {
      "type": "string",
      "example": "18f1a2b3c4d5e6f7"
    },
    "threadId": {
      "type": "string",
      "example": "18f1a2b3c4d5e6f0"
    },
    "labelIds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "example": [
        "INBOX",
        "UNREAD"
      ]
    },
    "snippet": {
      "type": "string",
      "example": "Hi there, just following up on the report..."
    },
    "historyId": {
      "type": "string",
      "example": "123456"
    },
    "internalDate": {
      "type": "string",
      "description": "Epoch ms as string",
      "example": "1709641234000"
    },
    "sizeEstimate": {
      "type": "integer",
      "format": "int32",
      "example": 4096
    },
    "raw": {
      "type": "string",
      "format": "byte",
      "description": "The entire email message in an RFC 2822 formatted and base64url encoded string. Used when sending."
    },
    "payload": {
      "$ref": "MessagePart.json"
    }
  }
}
