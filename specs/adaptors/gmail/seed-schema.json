{
  "openapi": "3.0.3",
  "info": {
    "title": "gmail — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate gmail. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "gmail",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "messages": {
        "resource": "Message",
        "schema": {
          "$ref": "#/components/schemas/Message"
        }
      },
      "messageRefs": {
        "resource": "MessageRef",
        "schema": {
          "$ref": "#/components/schemas/MessageRef"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "messages": {
            "type": "object",
            "description": "Records keyed by id for the messages collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Message"
            }
          },
          "messageRefs": {
            "type": "object",
            "description": "Records keyed by id for the messageRefs collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/MessageRef"
            }
          }
        },
        "additionalProperties": false
      },
      "ListMessagesResponse": {
        "type": "object",
        "description": "Response from listing messages.",
        "properties": {
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MessageRef"
            }
          },
          "nextPageToken": {
            "type": "string"
          },
          "resultSizeEstimate": {
            "type": "integer",
            "format": "int64",
            "example": 42
          }
        }
      },
      "MessageRef": {
        "type": "object",
        "description": "A reference to a message returned in a list result (id + threadId only).",
        "properties": {
          "id": {
            "type": "string",
            "example": "18f1a2b3c4d5e6f7"
          },
          "threadId": {
            "type": "string",
            "example": "18f1a2b3c4d5e6f0"
          }
        }
      },
      "Message": {
        "type": "object",
        "description": "A Gmail message.",
        "properties": {
          "id": {
            "type": "string",
            "example": "18f1a2b3c4d5e6f7"
          },
          "threadId": {
            "type": "string",
            "example": "18f1a2b3c4d5e6f0"
          },
          "labelIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "INBOX",
              "UNREAD"
            ]
          },
          "snippet": {
            "type": "string",
            "example": "Hi there, just following up on the report..."
          },
          "historyId": {
            "type": "string",
            "example": "123456"
          },
          "internalDate": {
            "type": "string",
            "description": "Epoch ms as string",
            "example": "1709641234000"
          },
          "sizeEstimate": {
            "type": "integer",
            "format": "int32",
            "example": 4096
          },
          "raw": {
            "type": "string",
            "format": "byte",
            "description": "The entire email message in an RFC 2822 formatted and base64url encoded string. Used when sending."
          },
          "payload": {
            "$ref": "#/components/schemas/MessagePart"
          }
        }
      },
      "MessagePart": {
        "type": "object",
        "description": "A single MIME message part.",
        "properties": {
          "partId": {
            "type": "string",
            "example": "0"
          },
          "mimeType": {
            "type": "string",
            "example": "text/plain"
          },
          "filename": {
            "type": "string",
            "example": ""
          },
          "headers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MessagePartHeader"
            }
          },
          "body": {
            "$ref": "#/components/schemas/MessagePartBody"
          },
          "parts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MessagePart"
            }
          }
        }
      },
      "MessagePartHeader": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "From"
          },
          "value": {
            "type": "string",
            "example": "Someone <someone@example.com>"
          }
        }
      },
      "MessagePartBody": {
        "type": "object",
        "description": "The body of a single MIME message part.",
        "properties": {
          "attachmentId": {
            "type": "string"
          },
          "size": {
            "type": "integer",
            "format": "int32",
            "example": 512
          },
          "data": {
            "type": "string",
            "format": "byte",
            "description": "Base64url encoded body data."
          }
        }
      }
    }
  }
}
