{
  "openapi": "3.0.3",
  "info": {
    "title": "Punto Solidario RD adaptor surface (synthesized)",
    "version": "1.0",
    "description": "Punto Solidario is a Dominican Republic single-window social-subsidy service (ADESS / Supérate). The OpenFn puntosolidario-rd adaptor is a thin HTTP client exposing generic http get/post/request helpers against a configured base URL; there is no public vendor machine spec. This OpenAPI 3.0 document is synthesized from the adaptor surface, modeling representative beneficiary, subsidy and payment/transaction resources the get/post/request helpers operate on.",
    "x-openfn-adaptor": "puntosolidario-rd"
  },
  "servers": [
    { "url": "https://api.puntosolidario.example.gob.do", "description": "Punto Solidario API (instance-specific placeholder)" }
  ],
  "paths": {
    "/beneficiarios": {
      "get": {
        "operationId": "listBeneficiarios",
        "summary": "List beneficiaries",
        "parameters": [
          { "name": "cedula", "in": "query", "schema": { "type": "string" }, "description": "National ID (cédula)" },
          { "name": "page", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "A list of beneficiaries",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/BeneficiaryList" } }
            }
          }
        }
      },
      "post": {
        "operationId": "createBeneficiario",
        "summary": "Register a beneficiary",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/Beneficiary" } }
          }
        },
        "responses": {
          "200": {
            "description": "The created beneficiary",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Beneficiary" } }
            }
          }
        }
      }
    },
    "/beneficiarios/{id}": {
      "parameters": [
        { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "get": {
        "operationId": "getBeneficiario",
        "summary": "Get a beneficiary by id",
        "responses": {
          "200": {
            "description": "A beneficiary",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Beneficiary" } }
            }
          },
          "404": { "description": "Not found" }
        }
      }
    },
    "/subsidios": {
      "get": {
        "operationId": "listSubsidios",
        "summary": "List subsidy programs",
        "responses": {
          "200": {
            "description": "A list of subsidies",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/SubsidyList" } }
            }
          }
        }
      }
    },
    "/transacciones": {
      "get": {
        "operationId": "listTransacciones",
        "summary": "List payment transactions",
        "parameters": [
          { "name": "beneficiarioId", "in": "query", "schema": { "type": "string" } },
          { "name": "desde", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "hasta", "in": "query", "schema": { "type": "string", "format": "date" } }
        ],
        "responses": {
          "200": {
            "description": "A list of transactions",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/TransactionList" } }
            }
          }
        }
      },
      "post": {
        "operationId": "createTransaccion",
        "summary": "Record a subsidy payment transaction",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/Transaction" } }
          }
        },
        "responses": {
          "200": {
            "description": "The recorded transaction",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Transaction" } }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Beneficiary": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "cedula": { "type": "string", "description": "National ID (cédula)" },
          "nombres": { "type": "string" },
          "apellidos": { "type": "string" },
          "sexo": { "type": "string" },
          "fechaNacimiento": { "type": "string", "format": "date" },
          "provincia": { "type": "string" },
          "municipio": { "type": "string" },
          "estado": { "type": "string", "example": "activo" },
          "subsidios": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "BeneficiaryList": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Beneficiary" } },
          "total": { "type": "integer" },
          "page": { "type": "integer" }
        }
      },
      "Subsidy": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "codigo": { "type": "string", "example": "BONOGAS" },
          "nombre": { "type": "string", "example": "Bonogás Hogar" },
          "monto": { "type": "number" },
          "moneda": { "type": "string", "example": "DOP" },
          "activo": { "type": "boolean" }
        }
      },
      "SubsidyList": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Subsidy" } }
        }
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "beneficiarioId": { "type": "string" },
          "subsidioCodigo": { "type": "string" },
          "monto": { "type": "number" },
          "moneda": { "type": "string", "example": "DOP" },
          "comercio": { "type": "string" },
          "fecha": { "type": "string", "format": "date-time" },
          "estado": { "type": "string", "example": "completada" }
        }
      },
      "TransactionList": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Transaction" } },
          "total": { "type": "integer" }
        }
      }
    }
  }
}
