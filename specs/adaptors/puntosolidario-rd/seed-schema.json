{
  "openapi": "3.0.3",
  "info": {
    "title": "puntosolidario-rd — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate puntosolidario-rd. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "puntosolidario-rd",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "beneficiaries": {
        "resource": "Beneficiary",
        "schema": {
          "$ref": "#/components/schemas/Beneficiary"
        }
      },
      "subsidies": {
        "resource": "Subsidy",
        "schema": {
          "$ref": "#/components/schemas/Subsidy"
        }
      },
      "transactions": {
        "resource": "Transaction",
        "schema": {
          "$ref": "#/components/schemas/Transaction"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "beneficiaries": {
            "type": "object",
            "description": "Records keyed by id for the beneficiaries collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Beneficiary"
            }
          },
          "subsidies": {
            "type": "object",
            "description": "Records keyed by id for the subsidies collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Subsidy"
            }
          },
          "transactions": {
            "type": "object",
            "description": "Records keyed by id for the transactions collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Transaction"
            }
          }
        },
        "additionalProperties": false
      },
      "Beneficiary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "cedula": {
            "type": "string",
            "description": "National ID (cédula)"
          },
          "nombres": {
            "type": "string"
          },
          "apellidos": {
            "type": "string"
          },
          "sexo": {
            "type": "string"
          },
          "fechaNacimiento": {
            "type": "string",
            "format": "date"
          },
          "provincia": {
            "type": "string"
          },
          "municipio": {
            "type": "string"
          },
          "estado": {
            "type": "string",
            "example": "activo"
          },
          "subsidios": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "BeneficiaryList": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Beneficiary"
            }
          },
          "total": {
            "type": "integer"
          },
          "page": {
            "type": "integer"
          }
        }
      },
      "Subsidy": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "codigo": {
            "type": "string",
            "example": "BONOGAS"
          },
          "nombre": {
            "type": "string",
            "example": "Bonogás Hogar"
          },
          "monto": {
            "type": "number"
          },
          "moneda": {
            "type": "string",
            "example": "DOP"
          },
          "activo": {
            "type": "boolean"
          }
        }
      },
      "SubsidyList": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Subsidy"
            }
          }
        }
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "beneficiarioId": {
            "type": "string"
          },
          "subsidioCodigo": {
            "type": "string"
          },
          "monto": {
            "type": "number"
          },
          "moneda": {
            "type": "string",
            "example": "DOP"
          },
          "comercio": {
            "type": "string"
          },
          "fecha": {
            "type": "string",
            "format": "date-time"
          },
          "estado": {
            "type": "string",
            "example": "completada"
          }
        }
      },
      "TransactionList": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Transaction"
            }
          },
          "total": {
            "type": "integer"
          }
        }
      }
    }
  }
}
