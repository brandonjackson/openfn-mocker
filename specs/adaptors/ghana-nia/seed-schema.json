{
  "openapi": "3.0.3",
  "info": {
    "title": "ghana-nia — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate ghana-nia. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "ghana-nia",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "nationalIdResponses": {
        "resource": "NationalIdResponse",
        "schema": {
          "$ref": "#/components/schemas/NationalIdResponse"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "nationalIdResponses": {
            "type": "object",
            "description": "Records keyed by id for the nationalIdResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/NationalIdResponse"
            }
          }
        },
        "additionalProperties": false
      },
      "BabyRegistrationRequest": {
        "type": "object",
        "description": "Payload posted to register a newborn with the NIA.",
        "properties": {
          "babyData": {
            "$ref": "#/components/schemas/BabyData"
          },
          "personVouching": {
            "$ref": "#/components/schemas/PersonVouching"
          }
        },
        "required": [
          "babyData",
          "personVouching"
        ]
      },
      "BabyData": {
        "type": "object",
        "properties": {
          "dateOfBirth": {
            "type": "string",
            "example": "2024-03-05"
          },
          "fatherName": {
            "type": "string",
            "example": "Nyarkoa Osei-Akoto"
          },
          "forenames": {
            "type": "string",
            "example": "Kharis"
          },
          "gender": {
            "type": "string",
            "example": "Female"
          },
          "lightwaveETrackerID": {
            "type": "string",
            "example": "00313180/24-03"
          },
          "motherName": {
            "type": "string",
            "example": "Gifty Osei-Akoto"
          },
          "noSiblingsInDelivery": {
            "type": "string",
            "example": "0"
          },
          "placeOfBirth": {
            "type": "string",
            "example": "New Market Health Centre"
          },
          "surname": {
            "type": "string",
            "example": "Osei"
          },
          "timeOfbirth": {
            "type": "string",
            "example": "09:34"
          },
          "weightAtBirth": {
            "type": "string",
            "example": "2.7"
          },
          "birthCertificateNumber": {
            "type": "string",
            "example": "011803-48-2024"
          },
          "babyPicture": {
            "type": "string",
            "description": "Base64 encoded image",
            "example": "...base64 encoded image goes here..."
          }
        }
      },
      "PersonVouching": {
        "type": "object",
        "properties": {
          "etrackerLightwaveID": {
            "type": "string",
            "example": "00313180/24-03"
          },
          "ghanaCardPIN": {
            "type": "string",
            "example": "GHA-001097272-4"
          },
          "relationToBaby": {
            "type": "string",
            "example": "Mother"
          },
          "relativePhone": {
            "type": "string",
            "example": "0248403076"
          },
          "relativePicture": {
            "type": "string",
            "description": "Base64 encoded image",
            "example": "...base64 encoded image goes here..."
          }
        }
      },
      "NationalIdResponse": {
        "type": "object",
        "description": "Successful registration response with generated national ID PINs.",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "babyPin": {
                "type": "string",
                "example": "GHA-000000000-1"
              },
              "voucherPin": {
                "type": "string",
                "example": "GHA-000000000-4"
              },
              "etrackerLightwaveId": {
                "type": "string",
                "example": "00000000/24-03"
              },
              "lightwaveEtrackerId": {
                "type": "string",
                "nullable": true,
                "example": null
              }
            }
          },
          "success": {
            "type": "boolean",
            "example": true
          },
          "code": {
            "type": "string",
            "example": "00"
          },
          "msg": {
            "type": "string",
            "example": "Saved Successfully"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "code": {
            "type": "string",
            "example": "05"
          },
          "data": {
            "type": "object",
            "nullable": true,
            "example": null
          },
          "msg": {
            "type": "string",
            "example": "Error in Verifiation Process"
          }
        }
      }
    }
  }
}
