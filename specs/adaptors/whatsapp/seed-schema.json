{
  "openapi": "3.0.3",
  "info": {
    "title": "whatsapp — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate whatsapp. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "whatsapp",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "mediaInfos": {
        "resource": "MediaInfo",
        "schema": {
          "$ref": "#/components/schemas/MediaInfo"
        }
      },
      "mediaUploadResponses": {
        "resource": "MediaUploadResponse",
        "schema": {
          "$ref": "#/components/schemas/MediaUploadResponse"
        }
      },
      "messageResponses": {
        "resource": "MessageResponse",
        "schema": {
          "$ref": "#/components/schemas/MessageResponse"
        }
      },
      "successResponses": {
        "resource": "SuccessResponse",
        "schema": {
          "$ref": "#/components/schemas/SuccessResponse"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "mediaInfos": {
            "type": "object",
            "description": "Records keyed by id for the mediaInfos collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/MediaInfo"
            }
          },
          "mediaUploadResponses": {
            "type": "object",
            "description": "Records keyed by id for the mediaUploadResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/MediaUploadResponse"
            }
          },
          "messageResponses": {
            "type": "object",
            "description": "Records keyed by id for the messageResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/MessageResponse"
            }
          },
          "successResponses": {
            "type": "object",
            "description": "Records keyed by id for the successResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/SuccessResponse"
            }
          }
        },
        "additionalProperties": false
      },
      "MessageRequest": {
        "type": "object",
        "required": [
          "messaging_product"
        ],
        "description": "Body for POST /{phoneNumberId}/messages. The set of fields present depends on `type` (or `status` for read receipts).",
        "properties": {
          "messaging_product": {
            "type": "string",
            "enum": [
              "whatsapp"
            ],
            "description": "Always `whatsapp`."
          },
          "recipient_type": {
            "type": "string",
            "enum": [
              "individual"
            ],
            "default": "individual"
          },
          "to": {
            "type": "string",
            "description": "Recipient WhatsApp phone number in E.164 (no + required), e.g. `254712345678`."
          },
          "type": {
            "type": "string",
            "enum": [
              "text",
              "template",
              "image",
              "audio",
              "video",
              "document",
              "sticker",
              "location",
              "contacts",
              "interactive",
              "reaction"
            ],
            "description": "Message type. Determines which content object must be present."
          },
          "text": {
            "$ref": "#/components/schemas/TextObject"
          },
          "template": {
            "$ref": "#/components/schemas/TemplateObject"
          },
          "image": {
            "$ref": "#/components/schemas/MediaObject"
          },
          "audio": {
            "$ref": "#/components/schemas/MediaObject"
          },
          "video": {
            "$ref": "#/components/schemas/MediaObject"
          },
          "document": {
            "$ref": "#/components/schemas/MediaObject"
          },
          "sticker": {
            "$ref": "#/components/schemas/MediaObject"
          },
          "interactive": {
            "$ref": "#/components/schemas/InteractiveObject"
          },
          "location": {
            "$ref": "#/components/schemas/LocationObject"
          },
          "reaction": {
            "$ref": "#/components/schemas/ReactionObject"
          },
          "context": {
            "type": "object",
            "description": "Reference to a prior message to reply to.",
            "properties": {
              "message_id": {
                "type": "string"
              }
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "read"
            ],
            "description": "Set to `read` (with `message_id`) to mark an inbound message as read instead of sending content."
          },
          "message_id": {
            "type": "string",
            "description": "ID of the inbound message to mark as read (used with `status: read`)."
          }
        }
      },
      "TextObject": {
        "type": "object",
        "required": [
          "body"
        ],
        "properties": {
          "body": {
            "type": "string",
            "description": "Message text (up to 4096 characters)."
          },
          "preview_url": {
            "type": "boolean",
            "description": "Render link previews for URLs in the body."
          }
        }
      },
      "TemplateObject": {
        "type": "object",
        "required": [
          "name",
          "language"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Registered template name, e.g. `hello_world`."
          },
          "language": {
            "type": "object",
            "required": [
              "code"
            ],
            "properties": {
              "code": {
                "type": "string",
                "description": "BCP-47 language/locale code, e.g. `en_US`."
              }
            }
          },
          "components": {
            "type": "array",
            "description": "Header/body/button parameter components.",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "header",
                    "body",
                    "button"
                  ]
                },
                "sub_type": {
                  "type": "string"
                },
                "index": {
                  "type": "string"
                },
                "parameters": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true
                  }
                }
              }
            }
          }
        }
      },
      "MediaObject": {
        "type": "object",
        "description": "Media reference for image/audio/video/document/sticker messages. Provide either `id` (uploaded media) or `link` (public URL).",
        "properties": {
          "id": {
            "type": "string",
            "description": "Uploaded media ID."
          },
          "link": {
            "type": "string",
            "format": "uri",
            "description": "Public HTTPS URL to the media."
          },
          "caption": {
            "type": "string",
            "description": "Caption (image/video/document)."
          },
          "filename": {
            "type": "string",
            "description": "Document filename."
          }
        }
      },
      "InteractiveObject": {
        "type": "object",
        "required": [
          "type"
        ],
        "description": "Interactive message (buttons, list, product, etc.).",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "button",
              "list",
              "product",
              "product_list",
              "cta_url",
              "flow"
            ]
          },
          "header": {
            "type": "object",
            "additionalProperties": true
          },
          "body": {
            "type": "object",
            "properties": {
              "text": {
                "type": "string"
              }
            }
          },
          "footer": {
            "type": "object",
            "properties": {
              "text": {
                "type": "string"
              }
            }
          },
          "action": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "LocationObject": {
        "type": "object",
        "required": [
          "latitude",
          "longitude"
        ],
        "properties": {
          "latitude": {
            "type": "number"
          },
          "longitude": {
            "type": "number"
          },
          "name": {
            "type": "string"
          },
          "address": {
            "type": "string"
          }
        }
      },
      "ReactionObject": {
        "type": "object",
        "required": [
          "message_id",
          "emoji"
        ],
        "properties": {
          "message_id": {
            "type": "string",
            "description": "ID of the message to react to."
          },
          "emoji": {
            "type": "string",
            "description": "Emoji to apply, or empty string to remove."
          }
        }
      },
      "MessageResponse": {
        "type": "object",
        "description": "Successful response from POST /{phoneNumberId}/messages.",
        "properties": {
          "messaging_product": {
            "type": "string",
            "example": "whatsapp"
          },
          "contacts": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "input": {
                  "type": "string",
                  "description": "The number provided in the request."
                },
                "wa_id": {
                  "type": "string",
                  "description": "The normalized WhatsApp ID for the contact."
                }
              }
            }
          },
          "messages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "The message ID (wamid...)."
                },
                "message_status": {
                  "type": "string",
                  "enum": [
                    "accepted",
                    "held_for_quality_assessment",
                    "paused"
                  ],
                  "description": "Status of the message when a template quality pause is in effect."
                }
              }
            }
          }
        }
      },
      "MediaUploadRequest": {
        "type": "object",
        "required": [
          "messaging_product",
          "file",
          "type"
        ],
        "properties": {
          "messaging_product": {
            "type": "string",
            "enum": [
              "whatsapp"
            ]
          },
          "file": {
            "type": "string",
            "format": "binary",
            "description": "The media file to upload."
          },
          "type": {
            "type": "string",
            "description": "MIME type of the file, e.g. `image/jpeg`."
          }
        }
      },
      "MediaUploadResponse": {
        "type": "object",
        "description": "Response from POST /{phoneNumberId}/media.",
        "properties": {
          "id": {
            "type": "string",
            "description": "The uploaded media ID."
          }
        }
      },
      "MediaInfo": {
        "type": "object",
        "description": "Response from GET /{mediaId}.",
        "properties": {
          "messaging_product": {
            "type": "string",
            "example": "whatsapp"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Temporary download URL (valid for 5 minutes)."
          },
          "mime_type": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          },
          "file_size": {
            "type": "integer",
            "description": "File size in bytes."
          },
          "id": {
            "type": "string"
          }
        }
      },
      "RegisterRequest": {
        "type": "object",
        "required": [
          "messaging_product",
          "pin"
        ],
        "properties": {
          "messaging_product": {
            "type": "string",
            "enum": [
              "whatsapp"
            ]
          },
          "pin": {
            "type": "string",
            "description": "6-digit two-step verification PIN.",
            "pattern": "^[0-9]{6}$"
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "description": "Generic boolean success response used by register, deregister, and delete-media.",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "description": "Standard Graph API error envelope.",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string"
              },
              "type": {
                "type": "string"
              },
              "code": {
                "type": "integer"
              },
              "error_subcode": {
                "type": "integer"
              },
              "error_data": {
                "type": "object",
                "properties": {
                  "messaging_product": {
                    "type": "string"
                  },
                  "details": {
                    "type": "string"
                  }
                }
              },
              "fbtrace_id": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
