      "Biometric": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "patientId": {
            "type": "integer"
          },
          "biometricType": {
            "type": "string",
            "nullable": true
          },
          "template": {
            "type": "string",
            "description": "Base64-encoded biometric template",
            "nullable": true
          },
          "fingerType": {
            "type": "string",
            "nullable": true
          },
