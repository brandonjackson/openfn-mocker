{
  "openapi": "3.0.3",
  "info": {
    "title": "lamisplus — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate lamisplus. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "lamisplus",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "biometrics": {
        "resource": "Biometric",
        "schema": {
          "$ref": "#/components/schemas/Biometric"
        }
      },
      "encounters": {
        "resource": "Encounter",
        "schema": {
          "$ref": "#/components/schemas/Encounter"
        }
      },
      "loginResponses": {
        "resource": "LoginResponse",
        "schema": {
          "$ref": "#/components/schemas/LoginResponse"
        }
      },
      "patients": {
        "resource": "Patient",
        "schema": {
          "$ref": "#/components/schemas/Patient"
        }
      },
      "patientListResponses": {
        "resource": "PatientListResponse",
        "schema": {
          "$ref": "#/components/schemas/PatientListResponse"
        }
      },
      "visits": {
        "resource": "Visit",
        "schema": {
          "$ref": "#/components/schemas/Visit"
        }
      },
      "visitListResponses": {
        "resource": "VisitListResponse",
        "schema": {
          "$ref": "#/components/schemas/VisitListResponse"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "biometrics": {
            "type": "object",
            "description": "Records keyed by id for the biometrics collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Biometric"
            }
          },
          "encounters": {
            "type": "object",
            "description": "Records keyed by id for the encounters collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Encounter"
            }
          },
          "loginResponses": {
            "type": "object",
            "description": "Records keyed by id for the loginResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/LoginResponse"
            }
          },
          "patients": {
            "type": "object",
            "description": "Records keyed by id for the patients collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Patient"
            }
          },
          "patientListResponses": {
            "type": "object",
            "description": "Records keyed by id for the patientListResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/PatientListResponse"
            }
          },
          "visits": {
            "type": "object",
            "description": "Records keyed by id for the visits collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Visit"
