            }
          }
        },
        "additionalProperties": false
      },
      "LoginRequest": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "format": "password"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "JWT bearer token"
          },
          "tokenType": {
            "type": "string",
            "example": "Bearer"
          },
          "expiresIn": {
            "type": "integer",
            "description": "Seconds until token expiry"
          }
        }
      },
      "Patient": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "uuid": {
            "type": "string",
            "format": "uuid"
          },
          "hospitalNumber": {
            "type": "string",
            "description": "Facility patient/hospital number"
          },
          "firstName": {
            "type": "string"
          },
          "surname": {
            "type": "string"
          },
          "otherName": {
            "type": "string",
            "nullable": true
          },
          "sex": {
            "type": "string",
            "enum": [
              "Male",
              "Female"
            ]
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date"
          },
          "maritalStatus": {
            "type": "string",
            "nullable": true
          },
          "phoneNumber": {
            "type": "string",
            "nullable": true
          },
          "address": {
            "type": "string",
            "nullable": true
          },
          "facilityId": {
            "type": "integer",
            "nullable": true
          },
          "dateOfRegistration": {
            "type": "string",
            "format": "date",
            "nullable": true
          },
          "archived": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "PatientInput": {
        "type": "object",
        "required": [
          "firstName",
          "surname",
          "sex",
          "dateOfBirth"
        ],
        "properties": {
          "hospitalNumber": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "surname": {
            "type": "string"
          },
          "otherName": {
            "type": "string"
          },
          "sex": {
            "type": "string",
            "enum": [
              "Male",
              "Female"
            ]
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date"
          },
          "maritalStatus": {
            "type": "string"
          },
          "phoneNumber": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "facilityId": {
            "type": "integer"
          }
        }
      },
      "PatientListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
