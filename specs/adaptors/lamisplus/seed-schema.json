      },
      "Visit": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "uuid": {
            "type": "string",
            "format": "uuid"
          },
          "patientId": {
            "type": "integer"
          },
          "visitDate": {
            "type": "string",
            "format": "date"
          },
          "visitType": {
            "type": "string",
            "nullable": true
          },
          "facilityId": {
            "type": "integer",
            "nullable": true
          },
          "checkInDateTime": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "checkOutDateTime": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "VisitInput": {
        "type": "object",
        "required": [
          "patientId",
          "visitDate"
        ],
        "properties": {
          "patientId": {
            "type": "integer"
          },
          "visitDate": {
            "type": "string",
            "format": "date"
          },
          "visitType": {
            "type": "string"
          },
          "facilityId": {
            "type": "integer"
          }
        }
