{
  "openapi": "3.0.3",
  "info": {
    "title": "minio — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate minio. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "minio",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "buckets": {
        "resource": "Bucket",
        "schema": {
          "$ref": "#/components/schemas/Bucket"
        }
      },
      "putObjectResults": {
        "resource": "PutObjectResult",
        "schema": {
          "$ref": "#/components/schemas/PutObjectResult"
        }
      },
      "storageObjects": {
        "resource": "StorageObject",
        "schema": {
          "$ref": "#/components/schemas/StorageObject"
        }
      },
      "tagSets": {
        "resource": "TagSet",
        "schema": {
          "$ref": "#/components/schemas/TagSet"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "buckets": {
            "type": "object",
            "description": "Records keyed by id for the buckets collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Bucket"
            }
          },
          "putObjectResults": {
            "type": "object",
            "description": "Records keyed by id for the putObjectResults collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/PutObjectResult"
            }
          },
          "storageObjects": {
            "type": "object",
            "description": "Records keyed by id for the storageObjects collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/StorageObject"
            }
          },
          "tagSets": {
            "type": "object",
            "description": "Records keyed by id for the tagSets collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/TagSet"
            }
          }
        },
        "additionalProperties": false
      },
      "Bucket": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "my-new-bucket"
          },
          "region": {
            "type": "string",
            "example": "us-east-1"
          },
          "creationDate": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "StorageObject": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "records/patient-001.json"
          },
          "bucketName": {
            "type": "string",
            "example": "my-bucket"
          },
          "size": {
            "type": "integer",
            "example": 1024
          },
          "etag": {
            "type": "string",
            "example": "d41d8cd98f00b204e9800998ecf8427e"
          },
          "lastModified": {
            "type": "string",
            "format": "date-time"
          },
          "contentType": {
            "type": "string",
            "example": "application/json"
          }
        }
      },
      "ObjectList": {
        "type": "object",
        "properties": {
          "bucketName": {
            "type": "string",
            "example": "my-bucket"
          },
          "prefix": {
            "type": "string"
          },
          "objects": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/StorageObject"
            }
          }
        }
      },
      "PutObjectResult": {
        "type": "object",
        "properties": {
          "etag": {
            "type": "string",
            "example": "d41d8cd98f00b204e9800998ecf8427e"
          },
          "versionId": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "TagSet": {
        "type": "object",
        "properties": {
          "tags": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "example": {
              "source": "openmrs",
              "status": "raw"
            }
          }
        }
      }
    }
  }
}
