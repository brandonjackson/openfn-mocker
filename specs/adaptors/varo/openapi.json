{
  "openapi": "3.0.3",
  "info": {
    "title": "OpenFn Varo Adaptor (synthesized surface)",
    "version": "1.0.0",
    "description": "SYNTHESIZED spec. The @openfn/language-varo adaptor performs NO HTTP I/O against any external API. It is a pure, in-process data-transformation adaptor for vaccine cold-chain data: it converts proprietary Varo/FridgeTag message contents (typically pulled from Gmail attachments) into EMS-compliant (Electronic Management/monitoring System) reports and records, and back into Varo-compatible message components. Because there is no upstream API, the operations below are modeled as local transformation endpoints on a placeholder base URL purely so the mocker can represent the adaptor's input/output resource shapes. There is no real server to mock.",
    "x-openfn-adaptor": "varo"
  },
  "servers": [
    {
      "url": "https://varo.local/transform",
      "description": "Placeholder. The adaptor has no network target; operations are pure functions executed in-process."
    }
  ],
  "paths": {
    "/convertToEms": {
      "post": {
        "operationId": "convertToEms",
        "summary": "Convert Varo/FridgeTag message contents to EMS-compliant data",
        "description": "Processes EMS data from the provided list of message contents (as produced by the Gmail adaptor) and returns the EMS-compliant version of each.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "messageContents": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/MessageContent" }
                  }
                },
                "required": ["messageContents"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "EMS-compliant converted data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/EmsRecord" }
                }
              }
            }
          }
        }
      }
    },
    "/convertItemsToReports": {
      "post": {
        "operationId": "convertItemsToReports",
        "summary": "Convert EMS-like records to an EMS report",
        "description": "Reads a collection of EMS-like data records and converts them to a standard EMS report/record format, separating report properties from record properties.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "items": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/EmsRecord" }
                  },
                  "reportType": {
                    "type": "string",
                    "default": "unknown",
                    "description": "Source of the report, e.g. \"ems\" or \"rtmd\"."
                  }
                },
                "required": ["items"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The converted EMS report with records",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EmsReport" }
              }
            }
          }
        }
      }
    },
    "/convertReportsToMessageContents": {
      "post": {
        "operationId": "convertReportsToMessageContents",
        "summary": "Convert an EMS report to Varo message components",
        "description": "Converts an EMS-compliant report into Varo-compatible message components (subject line and data file) ready to be emailed via the Gmail adaptor.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "reports": { "$ref": "#/components/schemas/EmsReport" },
                  "reportType": {
                    "type": "string",
                    "default": "unknown",
                    "description": "Source of the report, e.g. \"ems\" or \"rtmd\"."
                  }
                },
                "required": ["reports"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Varo-compatible message component",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VaroMessageComponent" }
              }
            }
          }
        }
      }
    },
    "/parseUtcForDataRange": {
      "post": {
        "operationId": "parseUtcForDataRange",
        "summary": "Compute the UTC datetime range for a timezone",
        "description": "Computes the UTC datetime range that corresponds to a given IANA timezone and ISO date bounds.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "timeZone": {
                    "type": "string",
                    "description": "IANA time zone identifier, e.g. \"America/Los_Angeles\"."
                  },
                  "startIso": { "type": "string", "format": "date-time" },
                  "endIso": { "type": "string", "format": "date-time" }
                },
                "required": ["timeZone", "startIso", "endIso"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The computed UTC range",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UtcRange" }
              }
            }
          }
        }
      }
    },
    "/isKeyInRange": {
      "post": {
        "operationId": "isKeyInRange",
        "summary": "Check whether a key's embedded timestamp is within a UTC range",
        "description": "Checks whether the timestamp embedded in a key (format YYYYMMDDTHHMMSS following a colon) falls within a UTC datetime range.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "key": {
                    "type": "string",
                    "description": "Key containing a UTC timestamp, e.g. \"prefix:20250624T101530\"."
                  },
                  "start": { "type": "string", "format": "date-time" },
                  "end": { "type": "string", "format": "date-time" }
                },
                "required": ["key", "start", "end"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Whether the key is within range",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/KeyInRangeResult" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "FileContent": {
        "type": "object",
        "description": "A single file's content and name, as extracted from a Gmail message attachment.",
        "properties": {
          "content": { "type": "string", "description": "Raw file content (text or JSON string)." },
          "filename": { "type": "string" }
        }
      },
      "MessageContent": {
        "type": "object",
        "description": "A Varo/FridgeTag message content bundle produced by the Gmail adaptor.",
        "properties": {
          "metadata": { "$ref": "#/components/schemas/FileContent" },
          "data": { "$ref": "#/components/schemas/FileContent" },
          "fridgeTag": { "$ref": "#/components/schemas/FileContent" }
        }
      },
      "EmsRecord": {
        "type": "object",
        "description": "An EMS-compliant atomic sensor reading.",
        "properties": {
          "ASER": { "type": "string", "description": "Asset/device serial identifier." },
          "ABST": { "type": "string", "description": "Absolute ISO-8601 timestamp of the reading, e.g. \"2024-10-08T08:15:00.000Z\"." },
          "TVC": { "type": "number", "description": "Temperature value in degrees Celsius." },
          "ALRM": { "type": "string", "nullable": true, "description": "Optional alarm flag, e.g. \"HEAT\" or \"FRZE\"." },
          "zdescription": { "type": "string", "description": "Human-readable label for context." }
        }
      },
      "EmsReport": {
        "type": "object",
        "description": "An EMS report: report-level properties plus an array of EMS records. Also carries optional out-of-spec zReports.",
        "properties": {
          "ASER": { "type": "string", "description": "Asset/device serial identifier for the report." },
          "records": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/EmsRecord" }
          },
          "zReports": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ZReport" }
          }
        }
      },
      "ZReport": {
        "type": "object",
        "description": "Out-of-spec daily aggregate and alarm summary (FridgeTag). Ignored by EMS consumers; retained for dashboards.",
        "properties": {
          "date": { "type": "string", "format": "date-time" },
          "duration": { "type": "string", "description": "Aggregation window, e.g. \"1D\"." },
          "alarms": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "condition": { "type": "string" },
                "conditionMinutes": { "type": "integer" },
                "alarmTime": { "type": "string", "format": "date-time" }
              }
            }
          },
          "aggregates": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "min": { "type": "number" },
                "max": { "type": "number" },
                "average": { "type": "number" }
              }
            }
          }
        }
      },
      "VaroMessageComponent": {
        "type": "object",
        "description": "A Varo-compatible message component: an email subject and a data file, ready for the Gmail adaptor.",
        "properties": {
          "subject": { "type": "string", "description": "Email subject, e.g. \"OpenFn | EMS\"." },
          "data": { "$ref": "#/components/schemas/FileContent" }
        }
      },
      "UtcRange": {
        "type": "object",
        "description": "A UTC datetime range derived from a wall-clock timezone window.",
        "properties": {
          "wallClock": { "type": "string", "format": "date-time", "description": "Current local datetime in the specified timezone." },
          "startUtc": { "type": "string", "format": "date-time", "description": "UTC start of range (inclusive)." },
          "endUtc": { "type": "string", "format": "date-time", "description": "UTC end of range (exclusive)." },
          "collectionKeys": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Wildcard patterns matching UTC dates in range, e.g. \"*20250624*\"."
          }
        }
      },
      "KeyInRangeResult": {
        "type": "object",
        "description": "Result of an isKeyInRange check.",
        "properties": {
          "result": { "type": "boolean" }
        }
      }
    }
  }
}
