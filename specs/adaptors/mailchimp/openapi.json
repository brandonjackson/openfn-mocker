{
  "openapi": "3.0.3",
  "info": {
    "title": "Mailchimp Marketing API (OpenFn subset)",
    "version": "3.0",
    "description": "Focused subset of the Mailchimp Marketing API covering the endpoints exercised by the OpenFn mailchimp adaptor: audiences (lists), list members, member tags, list/segment batch operations, and batch jobs. Authored from the official Mailchimp Marketing API v3 machine spec and developer docs.",
    "x-openfn-adaptor": "mailchimp"
  },
  "servers": [
    {
      "url": "https://{dc}.api.mailchimp.com/3.0",
      "description": "Mailchimp Marketing API. {dc} is the data center suffix of your API key (e.g. us1, us21).",
      "variables": {
        "dc": {
          "default": "us1",
          "description": "Data center / server prefix, e.g. us1, us21"
        }
      }
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    { "name": "lists", "description": "Audiences (lists) and members" },
    { "name": "segments", "description": "List segments / tags" },
    { "name": "batches", "description": "Batch operation jobs" }
  ],
  "paths": {
    "/lists": {
      "get": {
        "tags": ["lists"],
        "operationId": "getAllLists",
        "summary": "Get information about all lists in the account",
        "parameters": [
          { "name": "count", "in": "query", "schema": { "type": "integer", "default": 10 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } },
          { "name": "email", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "A collection of lists (audiences).",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Lists" }
              }
            }
          }
        }
      }
    },
    "/lists/{list_id}": {
      "get": {
        "tags": ["lists"],
        "operationId": "getList",
        "summary": "Get information about a specific list",
        "parameters": [
          { "$ref": "#/components/parameters/ListId" }
        ],
        "responses": {
          "200": {
            "description": "Information about a specific list.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/List" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["lists"],
        "operationId": "batchListMembers",
        "summary": "Batch subscribe or unsubscribe list members (upsert)",
        "parameters": [
          { "$ref": "#/components/parameters/ListId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "members": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/MemberInput" }
                  },
                  "update_existing": { "type": "boolean" },
                  "sync_tags": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The result of the batch add/update operation.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BatchMembersResult" }
              }
            }
          }
        }
      }
    },
    "/lists/{list_id}/members": {
      "get": {
        "tags": ["lists"],
        "operationId": "getListMembersInfo",
        "summary": "Get information about members in a list",
        "parameters": [
          { "$ref": "#/components/parameters/ListId" },
          { "name": "count", "in": "query", "schema": { "type": "integer", "default": 10 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } },
          { "name": "status", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "A collection of members in a list.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListMembers" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["lists"],
        "operationId": "addListMember",
        "summary": "Add a member to a list",
        "parameters": [
          { "$ref": "#/components/parameters/ListId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/MemberInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The newly added list member.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Member" }
              }
            }
          }
        }
      }
    },
    "/lists/{list_id}/members/{subscriber_hash}": {
      "get": {
        "tags": ["lists"],
        "operationId": "getListMember",
        "summary": "Get information about a specific list member",
        "parameters": [
          { "$ref": "#/components/parameters/ListId" },
          { "$ref": "#/components/parameters/SubscriberHash" }
        ],
        "responses": {
          "200": {
            "description": "Information about a specific list member.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Member" }
              }
            }
          }
        }
      },
      "patch": {
        "tags": ["lists"],
        "operationId": "updateListMember",
        "summary": "Update a list member",
        "parameters": [
          { "$ref": "#/components/parameters/ListId" },
          { "$ref": "#/components/parameters/SubscriberHash" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/MemberInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The updated list member.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Member" }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["lists"],
        "operationId": "deleteListMember",
        "summary": "Archive a list member",
        "parameters": [
          { "$ref": "#/components/parameters/ListId" },
          { "$ref": "#/components/parameters/SubscriberHash" }
        ],
        "responses": {
          "204": { "description": "The member was archived." }
        }
      }
    },
    "/lists/{list_id}/members/{subscriber_hash}/tags": {
      "get": {
        "tags": ["lists"],
        "operationId": "getListMemberTags",
        "summary": "Get the tags on a list member",
        "parameters": [
          { "$ref": "#/components/parameters/ListId" },
          { "$ref": "#/components/parameters/SubscriberHash" }
        ],
        "responses": {
          "200": {
            "description": "A collection of tags assigned to a list member.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MemberTags" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["lists"],
        "operationId": "updateListMemberTags",
        "summary": "Add or remove tags on a list member",
        "parameters": [
          { "$ref": "#/components/parameters/ListId" },
          { "$ref": "#/components/parameters/SubscriberHash" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "tags": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": { "type": "string" },
                        "status": { "type": "string", "enum": ["active", "inactive"] }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": { "description": "The member tags were updated." }
        }
      }
    },
    "/lists/{list_id}/members/{subscriber_hash}/actions/delete-permanent": {
      "post": {
        "tags": ["lists"],
        "operationId": "deleteListMemberPermanent",
        "summary": "Permanently delete a list member",
        "parameters": [
          { "$ref": "#/components/parameters/ListId" },
          { "$ref": "#/components/parameters/SubscriberHash" }
        ],
        "responses": {
          "204": { "description": "The member was permanently deleted." }
        }
      }
    },
    "/lists/{list_id}/segments/{segment_id}": {
      "post": {
        "tags": ["segments"],
        "operationId": "batchSegmentMembers",
        "summary": "Batch add or remove members from a segment (tag)",
        "parameters": [
          { "$ref": "#/components/parameters/ListId" },
          { "$ref": "#/components/parameters/SegmentId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "members_to_add": { "type": "array", "items": { "type": "string" } },
                  "members_to_remove": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The result of the batch segment operation.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SegmentMembersResult" }
              }
            }
          }
        }
      }
    },
    "/batches": {
      "get": {
        "tags": ["batches"],
        "operationId": "listBatches",
        "summary": "Get a summary of batch requests in the account",
        "parameters": [
          { "name": "count", "in": "query", "schema": { "type": "integer", "default": 10 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } }
        ],
        "responses": {
          "200": {
            "description": "A collection of batch operations.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Batches" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["batches"],
        "operationId": "startBatch",
        "summary": "Start a batch of operations",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "operations": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/BatchOperationInput" }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The newly started batch.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Batch" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic auth: any username with the API key as the password (openfn:apikey)."
      }
    },
    "parameters": {
      "ListId": {
        "name": "list_id",
        "in": "path",
        "required": true,
        "description": "The unique ID for the list (audience).",
        "schema": { "type": "string" }
      },
      "SubscriberHash": {
        "name": "subscriber_hash",
        "in": "path",
        "required": true,
        "description": "The MD5 hash of the lowercase version of the list member's email address.",
        "schema": { "type": "string" }
      },
      "SegmentId": {
        "name": "segment_id",
        "in": "path",
        "required": true,
        "description": "The unique ID for the segment (tag).",
        "schema": { "type": "integer" }
      }
    },
    "schemas": {
      "Link": {
        "type": "object",
        "properties": {
          "rel": { "type": "string" },
          "href": { "type": "string" },
          "method": { "type": "string" },
          "targetSchema": { "type": "string" },
          "schema": { "type": "string" }
        }
      },
      "Contact": {
        "type": "object",
        "properties": {
          "company": { "type": "string" },
          "address1": { "type": "string" },
          "address2": { "type": "string" },
          "city": { "type": "string" },
          "state": { "type": "string" },
          "zip": { "type": "string" },
          "country": { "type": "string" },
          "phone": { "type": "string" }
        }
      },
      "ListStats": {
        "type": "object",
        "properties": {
          "member_count": { "type": "integer" },
          "unsubscribe_count": { "type": "integer" },
          "cleaned_count": { "type": "integer" },
          "member_count_since_send": { "type": "integer" },
          "campaign_count": { "type": "integer" },
          "avg_sub_rate": { "type": "number" },
          "open_rate": { "type": "number" },
          "click_rate": { "type": "number" }
        }
      },
      "List": {
        "type": "object",
        "description": "A Mailchimp audience (list).",
        "properties": {
          "id": { "type": "string" },
          "web_id": { "type": "integer" },
          "name": { "type": "string" },
          "contact": { "$ref": "#/components/schemas/Contact" },
          "permission_reminder": { "type": "string" },
          "use_archive_bar": { "type": "boolean" },
          "date_created": { "type": "string", "format": "date-time" },
          "list_rating": { "type": "integer" },
          "email_type_option": { "type": "boolean" },
          "subscribe_url_short": { "type": "string" },
          "subscribe_url_long": { "type": "string" },
          "beamer_address": { "type": "string" },
          "visibility": { "type": "string" },
          "double_optin": { "type": "boolean" },
          "has_welcome": { "type": "boolean" },
          "marketing_permissions": { "type": "boolean" },
          "stats": { "$ref": "#/components/schemas/ListStats" },
          "_links": { "type": "array", "items": { "$ref": "#/components/schemas/Link" } }
        }
      },
      "Lists": {
        "type": "object",
        "properties": {
          "lists": { "type": "array", "items": { "$ref": "#/components/schemas/List" } },
          "total_items": { "type": "integer" },
          "constraints": { "type": "object" },
          "_links": { "type": "array", "items": { "$ref": "#/components/schemas/Link" } }
        }
      },
      "MemberInput": {
        "type": "object",
        "properties": {
          "email_address": { "type": "string", "format": "email" },
          "status": {
            "type": "string",
            "enum": ["subscribed", "unsubscribed", "cleaned", "pending", "transactional"]
          },
          "email_type": { "type": "string" },
          "merge_fields": { "type": "object", "additionalProperties": true },
          "interests": { "type": "object", "additionalProperties": true },
          "language": { "type": "string" },
          "vip": { "type": "boolean" },
          "tags": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["email_address", "status"]
      },
      "Member": {
        "type": "object",
        "description": "A member of a Mailchimp list (audience).",
        "properties": {
          "id": { "type": "string" },
          "email_address": { "type": "string", "format": "email" },
          "unique_email_id": { "type": "string" },
          "contact_id": { "type": "string" },
          "full_name": { "type": "string" },
          "web_id": { "type": "integer" },
          "email_type": { "type": "string" },
          "status": { "type": "string" },
          "unsubscribe_reason": { "type": "string" },
          "merge_fields": { "type": "object", "additionalProperties": true },
          "interests": { "type": "object", "additionalProperties": true },
          "stats": { "type": "object" },
          "ip_signup": { "type": "string" },
          "timestamp_signup": { "type": "string" },
          "ip_opt": { "type": "string" },
          "timestamp_opt": { "type": "string" },
          "member_rating": { "type": "integer" },
          "last_changed": { "type": "string", "format": "date-time" },
          "language": { "type": "string" },
          "vip": { "type": "boolean" },
          "email_client": { "type": "string" },
          "location": { "type": "object" },
          "source": { "type": "string" },
          "tags_count": { "type": "integer" },
          "tags": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "integer" },
                "name": { "type": "string" }
              }
            }
          },
          "list_id": { "type": "string" },
          "_links": { "type": "array", "items": { "$ref": "#/components/schemas/Link" } }
        }
      },
      "ListMembers": {
        "type": "object",
        "properties": {
          "members": { "type": "array", "items": { "$ref": "#/components/schemas/Member" } },
          "list_id": { "type": "string" },
          "total_items": { "type": "integer" },
          "_links": { "type": "array", "items": { "$ref": "#/components/schemas/Link" } }
        }
      },
      "MemberTag": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "date_added": { "type": "string", "format": "date-time" }
        }
      },
      "MemberTags": {
        "type": "object",
        "properties": {
          "tags": { "type": "array", "items": { "$ref": "#/components/schemas/MemberTag" } },
          "total_items": { "type": "integer" },
          "_links": { "type": "array", "items": { "$ref": "#/components/schemas/Link" } }
        }
      },
      "BatchMembersResult": {
        "type": "object",
        "description": "Result of a batch subscribe/unsubscribe operation on a list.",
        "properties": {
          "new_members": { "type": "array", "items": { "$ref": "#/components/schemas/Member" } },
          "updated_members": { "type": "array", "items": { "$ref": "#/components/schemas/Member" } },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "email_address": { "type": "string" },
                "error": { "type": "string" },
                "error_code": { "type": "string" }
              }
            }
          },
          "total_created": { "type": "integer" },
          "total_updated": { "type": "integer" },
          "error_count": { "type": "integer" },
          "_links": { "type": "array", "items": { "$ref": "#/components/schemas/Link" } }
        }
      },
      "SegmentMembersResult": {
        "type": "object",
        "description": "Result of a batch add/remove of members from a segment (tag).",
        "properties": {
          "members_added": { "type": "array", "items": { "$ref": "#/components/schemas/Member" } },
          "members_removed": { "type": "array", "items": { "$ref": "#/components/schemas/Member" } },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "email_addresses": { "type": "array", "items": { "type": "string" } },
                "error": { "type": "string" }
              }
            }
          },
          "total_added": { "type": "integer" },
          "total_removed": { "type": "integer" },
          "error_count": { "type": "integer" },
          "_links": { "type": "array", "items": { "$ref": "#/components/schemas/Link" } }
        }
      },
      "BatchOperationInput": {
        "type": "object",
        "properties": {
          "method": { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
          "path": { "type": "string" },
          "params": { "type": "object", "additionalProperties": true },
          "body": { "type": "string" },
          "operation_id": { "type": "string" }
        },
        "required": ["method", "path"]
      },
      "Batch": {
        "type": "object",
        "description": "A batch operation job.",
        "properties": {
          "id": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pending", "preprocessing", "started", "finalizing", "finished"]
          },
          "total_operations": { "type": "integer" },
          "finished_operations": { "type": "integer" },
          "errored_operations": { "type": "integer" },
          "submitted_at": { "type": "string", "format": "date-time" },
          "completed_at": { "type": "string", "format": "date-time" },
          "response_body_url": { "type": "string" },
          "_links": { "type": "array", "items": { "$ref": "#/components/schemas/Link" } }
        }
      },
      "Batches": {
        "type": "object",
        "properties": {
          "batches": { "type": "array", "items": { "$ref": "#/components/schemas/Batch" } },
          "total_items": { "type": "integer" },
          "_links": { "type": "array", "items": { "$ref": "#/components/schemas/Link" } }
        }
      }
    }
  }
}
