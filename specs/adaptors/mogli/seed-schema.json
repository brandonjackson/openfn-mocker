{
  "openapi": "3.0.3",
  "info": {
    "title": "mogli — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate mogli. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "mogli",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "smsResults": {
        "resource": "SmsResult",
        "schema": {
          "$ref": "#/components/schemas/SmsResult"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "smsResults": {
            "type": "object",
            "description": "Records keyed by id for the smsResults collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/SmsResult"
            }
          }
        },
        "additionalProperties": false
      },
      "SmsInput": {
        "type": "object",
        "properties": {
          "sender": {
            "type": "string",
            "example": "+15551234567"
          },
          "receivedAt": {
            "type": "string",
            "format": "date-time"
          },
          "message": {
            "type": "string",
            "example": "Hello from the field"
          }
        }
      },
      "SmsUpdateInput": {
        "type": "object",
        "properties": {
          "Id": {
            "type": "string",
            "example": "a0B5f000000abcdEAA"
          },
          "status": {
            "type": "string",
            "example": "Delivered"
          }
        }
      },
      "SmsResult": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "a0B5f000000abcdEAA"
          },
          "success": {
            "type": "boolean",
            "example": true
          },
          "sender": {
            "type": "string",
            "example": "+15551234567"
          },
          "message": {
            "type": "string",
            "example": "Hello from the field"
          },
          "status": {
            "type": "string",
            "example": "Received"
          },
          "receivedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
