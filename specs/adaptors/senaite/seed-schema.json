{
  "openapi": "3.0.3",
  "info": {
    "title": "senaite — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate senaite. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "senaite",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "catalogItems": {
        "resource": "CatalogItem",
        "schema": {
          "$ref": "#/components/schemas/CatalogItem"
        }
      },
      "catalogListResponses": {
        "resource": "CatalogListResponse",
        "schema": {
          "$ref": "#/components/schemas/CatalogListResponse"
        }
      },
      "userListResponses": {
        "resource": "UserListResponse",
        "schema": {
          "$ref": "#/components/schemas/UserListResponse"
        }
      },
      "versionResponses": {
        "resource": "VersionResponse",
        "schema": {
          "$ref": "#/components/schemas/VersionResponse"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "catalogItems": {
            "type": "object",
            "description": "Records keyed by id for the catalogItems collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/CatalogItem"
            }
          },
          "catalogListResponses": {
            "type": "object",
            "description": "Records keyed by id for the catalogListResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/CatalogListResponse"
            }
          },
          "userListResponses": {
            "type": "object",
            "description": "Records keyed by id for the userListResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/UserListResponse"
            }
          },
          "versionResponses": {
            "type": "object",
            "description": "Records keyed by id for the versionResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/VersionResponse"
            }
          }
        },
        "additionalProperties": false
      },
      "APIResponse": {
        "type": "object",
        "description": "Standard paged JSON API response envelope.",
        "properties": {
          "count": {
            "type": "integer",
            "description": "Number of items in the current page."
          },
          "pagesize": {
            "type": "integer"
          },
          "page": {
            "type": "integer"
          },
          "pages": {
            "type": "integer"
          },
          "_runtime": {
            "type": "number",
            "description": "Server processing time in seconds."
          },
          "next": {
            "type": "string",
            "nullable": true,
            "description": "URL of the next page."
          },
          "previous": {
            "type": "string",
            "nullable": true,
            "description": "URL of the previous page."
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CatalogItem"
            }
          }
        }
      },
      "CatalogItem": {
        "type": "object",
        "description": "Generic SENAITE content object summary as returned in items[].",
        "properties": {
          "uid": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "portal_type": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "api_url": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "parent_id": {
            "type": "string"
          },
          "parent_uid": {
            "type": "string"
          },
          "parent_path": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "created": {
            "type": "string"
          },
          "modified": {
            "type": "string"
          },
          "review_state": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "AnalysisRequest": {
        "type": "object",
        "description": "A sample / analysis request (portal_type AnalysisRequest).",
        "allOf": [
          {
            "$ref": "#/components/schemas/CatalogItem"
          },
          {
            "type": "object",
            "properties": {
              "ClientID": {
                "type": "string"
              },
              "ClientSampleID": {
                "type": "string"
              },
              "SampleTypeTitle": {
                "type": "string"
              },
              "DateSampled": {
                "type": "string"
              },
              "DateReceived": {
                "type": "string"
              },
              "Priority": {
                "type": "string"
              },
              "getClientTitle": {
                "type": "string"
              }
            }
          }
        ]
      },
      "Client": {
        "type": "object",
        "description": "A laboratory client (portal_type Client).",
