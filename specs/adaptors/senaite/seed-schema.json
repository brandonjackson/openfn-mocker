          {
            "$ref": "#/components/schemas/CatalogItem"
          },
          {
            "type": "object",
            "properties": {
              "ClientID": {
                "type": "string"
              },
              "Name": {
                "type": "string"
              },
              "EmailAddress": {
                "type": "string"
              },
              "Phone": {
                "type": "string"
              },
              "TaxNumber": {
                "type": "string"
              }
            }
          }
        ]
      },
      "Sample": {
