        "allOf": [
          {
            "$ref": "#/components/schemas/CatalogItem"
          },
          {
            "type": "object",
            "properties": {
              "Firstname": {
                "type": "string"
              },
              "Surname": {
                "type": "string"
              },
              "EmailAddress": {
                "type": "string"
              },
