          "email": {
            "type": "string"
          },
          "fullname": {
            "type": "string"
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "groups": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "authenticated": {
            "type": "boolean"
          },
          "api_url": {
            "type": "string"
          }
        }
      },
      "UserListResponse": {
        "type": "object",
        "allOf": [
