      },
      "CreateRequest": {
        "type": "object",
        "description": "Request body for creating a content object.",
        "required": [
          "portal_type"
        ],
        "properties": {
          "portal_type": {
            "type": "string",
            "description": "Type of object to create (e.g. Client, AnalysisRequest)."
          },
          "parent_path": {
            "type": "string",
            "description": "Path of the target container."
          },
          "parent_uid": {
            "type": "string",
            "description": "UID of the target container."
          },
          "title": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "UpdateRequest": {
        "type": "object",
        "description": "Request body for updating a content object. Identify the object by uid (path param), or by path/id, and include fields to change plus an optional workflow transition.",
        "properties": {
          "uid": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "transition": {
            "type": "string",
            "description": "Optional workflow transition to apply."
          }
        },
        "additionalProperties": true
      }
    }
