{
  "openapi": "3.0.3",
  "info": {
    "title": "Sunbird RC - Registry & Credentialing APIs",
    "version": "1.0.0",
    "description": "OpenAPI description of the Sunbird RC (Registry & Credentialing) APIs called by the OpenFn sunbird-rc adaptor. Covers the generic registry entity CRUD/search endpoints (get/post/put/del) and the Verifiable Credential issuance endpoints (issueCredential/getCredential/downloadCredential). The credential operations are taken from the official Sunbird-RC issuance OpenAPI document; the generic registry CRUD paths are authored from the Sunbird RC registry API docs.",
    "termsOfService": "https://sunbirdrc.dev/",
    "contact": {
      "email": "sunbird@example.com"
    },
    "license": {
      "name": "Apache 2.0",
      "url": "https://www.apache.org/licenses/LICENSE-2.0.html"
    },
    "x-openfn-adaptor": "sunbird-rc"
  },
  "servers": [
    {
      "url": "http://localhost:8081/api/v1",
      "description": "Local Sunbird RC registry base (placeholder; production is e.g. https://sunbirdrc.dev/api/v1)"
    }
  ],
  "tags": [
    { "name": "Registry", "description": "Generic registry entity CRUD and search" },
    { "name": "Issuing", "description": "Verifiable Credential issuance" },
    { "name": "Verifying", "description": "Verifiable Credential verification" }
  ],
  "paths": {
    "/{entityType}": {
      "post": {
        "tags": ["Registry"],
        "summary": "Create (invite) a registry entity",
        "operationId": "createEntity",
        "parameters": [
          { "$ref": "#/components/parameters/EntityType" }
        ],
        "requestBody": {
          "required": true,
          "description": "Entity attributes conforming to the entity's schema",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Entity" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Entity created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EntityResponse" }
              }
            }
          }
        }
      }
    },
    "/{entityType}/{entityId}": {
      "get": {
        "tags": ["Registry"],
        "summary": "Get a registry entity by id",
        "operationId": "getEntityById",
        "parameters": [
          { "$ref": "#/components/parameters/EntityType" },
          { "$ref": "#/components/parameters/EntityId" }
        ],
        "responses": {
          "200": {
            "description": "Entity found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Entity" }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["Registry"],
        "summary": "Update a registry entity by id",
        "operationId": "updateEntity",
        "parameters": [
          { "$ref": "#/components/parameters/EntityType" },
          { "$ref": "#/components/parameters/EntityId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Entity" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Entity updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EntityResponse" }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Registry"],
        "summary": "Delete a registry entity by id",
        "operationId": "deleteEntity",
        "parameters": [
          { "$ref": "#/components/parameters/EntityType" },
          { "$ref": "#/components/parameters/EntityId" }
        ],
        "responses": {
          "200": {
            "description": "Entity deleted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EntityResponse" }
              }
            }
          }
        }
      }
    },
    "/{entityType}/search": {
      "post": {
        "tags": ["Registry"],
        "summary": "Search registry entities",
        "operationId": "searchEntities",
        "parameters": [
          { "$ref": "#/components/parameters/EntityType" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SearchRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Matching entities",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Entity" }
                }
              }
            }
          }
        }
      }
    },
    "/credentials/issue": {
      "post": {
        "tags": ["Issuing"],
        "summary": "Issue a Verifiable Credential",
        "operationId": "credentialIssue",
        "requestBody": {
          "description": "Credential payload",
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/credentialRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Credential successfully issued",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/credentialResponse" }
              }
            }
          }
        }
      }
    },
    "/credentials/{id}": {
      "get": {
        "tags": ["Issuing"],
        "summary": "Get a Verifiable Credential by id (JSON, or a rendered PDF/HTML/SVG via the accept header)",
        "operationId": "getCredentialsById",
        "parameters": [
          { "$ref": "#/components/parameters/CredentialId" },
          {
            "name": "templateId",
            "in": "header",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "accept",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "application/json",
                "application/vc+ld+json",
                "text/html",
                "image/svg+xml",
                "text/plain",
                "image/jpeg",
                "application/pdf"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The credential (default JSON representation)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/verifiableCredential" }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Issuing"],
        "summary": "Revoke a Verifiable Credential by id",
        "operationId": "revokeCredentialsById",
        "parameters": [
          { "$ref": "#/components/parameters/CredentialId" }
        ],
        "responses": {
          "200": {
            "description": "Credential revoked",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/revokedResponse" }
              }
            }
          }
        }
      }
    },
    "/credentials/search": {
      "post": {
        "tags": ["Issuing"],
        "summary": "Search credentials by issuer and subject",
        "operationId": "searchCredentials",
        "requestBody": {
          "description": "Search payload",
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/credentialSearchRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Matching credentials",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/verifiableCredential" }
                }
              }
            }
          }
        }
      }
    },
    "/credentials/{id}/verify": {
      "get": {
        "tags": ["Verifying"],
        "summary": "Verify a Verifiable Credential and return a verification result",
        "operationId": "verifyCredentialById",
        "parameters": [
          { "$ref": "#/components/parameters/CredentialId" }
        ],
        "responses": {
          "200": {
            "description": "Verification result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/verifyResponse" }
              }
            }
          }
        }
      }
    },
    "/credentials/revocation-list": {
      "get": {
        "tags": ["Verifying"],
        "summary": "Get the revocation list for an issuer",
        "operationId": "getRevocationList",
        "parameters": [
          {
            "name": "issuerId",
            "in": "query",
            "description": "The ID of the issuer",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Revocation list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/revokedResponse" }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "EntityType": {
        "name": "entityType",
        "in": "path",
        "required": true,
        "description": "The registry entity/schema name (e.g. Student, Institute)",
        "schema": { "type": "string" }
      },
      "EntityId": {
        "name": "entityId",
        "in": "path",
        "required": true,
        "description": "The osid (registry object id) of the entity",
        "schema": { "type": "string" }
      },
      "CredentialId": {
        "name": "id",
        "in": "path",
        "required": true,
        "description": "The credential id (e.g. did:rcw:123abc)",
        "schema": { "type": "string" }
      }
    },
    "schemas": {
      "Entity": {
        "type": "object",
        "description": "A generic registry entity. The concrete attributes depend on the entity's registered schema. osid is assigned by the registry.",
        "properties": {
          "osid": { "type": "string", "description": "Registry-assigned object id" },
          "osOwner": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      },
      "EntityResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "sunbird-rc.registry.create" },
          "ver": { "type": "string", "example": "1.0" },
          "ets": { "type": "integer", "format": "int64" },
          "params": {
            "type": "object",
            "properties": {
              "resmsgid": { "type": "string" },
              "msgid": { "type": "string" },
              "err": { "type": "string" },
              "status": { "type": "string", "example": "SUCCESSFUL" },
              "errmsg": { "type": "string" }
            }
          },
          "responseCode": { "type": "string", "example": "OK" },
          "result": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "osid": { "type": "string" }
              },
              "additionalProperties": true
            }
          }
        }
      },
      "SearchRequest": {
        "type": "object",
        "properties": {
          "offset": { "type": "integer" },
          "limit": { "type": "integer" },
          "filters": {
            "type": "object",
            "additionalProperties": true,
            "description": "Field filters, e.g. { \"name\": { \"eq\": \"John\" } }"
          }
        }
      },
      "credentialRequest": {
        "type": "object",
        "properties": {
          "credential": { "$ref": "#/components/schemas/verifiableCredentialType" },
          "credentialSchemaId": { "type": "string" },
          "credentialSchemaVersion": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "credentialResponse": {
        "type": "object",
        "properties": {
          "credential": {
            "allOf": [
              { "$ref": "#/components/schemas/verifiableCredentialType" },
              {
                "type": "object",
                "properties": {
                  "proof": { "$ref": "#/components/schemas/proof" }
                }
              }
            ]
          },
          "credentialSchemaId": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "createdAt": { "type": "string" },
          "updatedAt": { "type": "string" },
          "createdBy": { "type": "string" },
          "updatedBy": { "type": "string" }
        }
      },
      "credentialSearchRequest": {
        "type": "object",
        "properties": {
          "issuer": {
            "type": "object",
            "properties": {
              "id": { "type": "string" }
            }
          },
          "subject": {
            "type": "object",
            "properties": {
              "id": { "type": "string" }
            }
          },
          "type": {
            "type": "string",
            "enum": ["claim", "sign"]
          }
        }
      },
      "verifiableCredentialType": {
        "type": "object",
        "properties": {
          "@context": {
            "type": "array",
            "items": { "type": "string" }
          },
          "id": { "type": "string" },
          "type": {
            "type": "array",
            "items": { "type": "string" }
          },
          "issuer": { "type": "object", "additionalProperties": true },
          "issuanceDate": { "type": "string", "format": "date-time" },
          "expirationDate": { "type": "string", "format": "date-time" },
          "credentialSubject": { "type": "object", "additionalProperties": true }
        }
      },
      "verifiableCredential": {
        "type": "object",
        "properties": {
          "@context": {
            "type": "array",
            "items": { "type": "string" }
          },
          "id": { "type": "string" },
          "type": {
            "type": "array",
            "items": { "type": "string" }
          },
          "issuer": { "type": "object", "additionalProperties": true },
          "issuanceDate": { "type": "string", "format": "date-time" },
          "expirationDate": { "type": "string", "format": "date-time" },
          "credentialSubject": { "type": "object", "additionalProperties": true },
          "proof": { "$ref": "#/components/schemas/proof" }
        }
      },
      "proof": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "created": { "type": "string", "format": "date-time" },
          "challenge": { "type": "string" },
          "domain": { "type": "string" },
          "nonce": { "type": "string" },
          "verificationMethod": { "type": "string" },
          "proofPurpose": { "type": "string" },
          "jws": { "type": "string" },
          "proofValue": { "type": "string" }
        }
      },
      "revokedResponse": {
        "type": "object",
        "properties": {
          "revocationListIndex": { "type": "string" }
        }
      },
      "verifyResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["Active", "Revoked", "Expired"]
          },
          "checks": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "active": { "type": "string" },
                "revoked": { "type": "string" },
                "expired": { "type": "string" },
                "proof": { "type": "string" }
              }
            }
          },
          "warnings": {
            "type": "array",
            "items": { "type": "string" }
          },
          "errors": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "securitySchemes": {
      "Authorization": {
        "type": "apiKey",
        "name": "Authorization",
        "in": "header"
      }
    }
  },
  "security": [
    { "Authorization": [] }
  ]
}
