{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mtn-momo/RequestToPayResult",
  "title": "RequestToPayResult",
  "x-openfn-adaptor": "mtn-momo",
  "x-source": {
    "openapi": "#/components/schemas/RequestToPayResult",
    "capturedAt": "2026-07-06"
  },
  "type": "object",
  "properties": {
    "amount": {
      "type": "string",
      "example": "100"
    },
    "currency": {
      "type": "string",
      "example": "EUR"
    },
    "financialTransactionId": {
      "type": "string",
      "example": "23503452"
    },
    "externalId": {
      "type": "string",
      "example": "6353636"
    },
    "payer": {
      "$ref": "Party.json"
    },
    "payerMessage": {
      "type": "string",
      "example": "Payment for order 123"
    },
    "payeeNote": {
      "type": "string",
      "example": "Thank you"
    },
    "status": {
      "type": "string",
      "enum": [
        "PENDING",
        "SUCCESSFUL",
        "FAILED"
      ],
      "example": "SUCCESSFUL"
    },
    "reason": {
      "type": "string",
      "example": "PAYER_NOT_FOUND"
    }
  },
  "required": [
    "amount",
    "currency",
    "externalId",
    "payer",
    "status"
  ]
}
