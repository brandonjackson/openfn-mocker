{
  "openapi": "3.0.3",
  "info": {
    "title": "openhim — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate openhim. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "openhim",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "channels": {
        "resource": "Channel",
        "schema": {
          "$ref": "#/components/schemas/Channel"
        }
      },
      "clients": {
        "resource": "Client",
        "schema": {
          "$ref": "#/components/schemas/Client"
        }
      },
      "tasks": {
        "resource": "Task",
        "schema": {
          "$ref": "#/components/schemas/Task"
        }
      },
      "transactions": {
        "resource": "Transaction",
        "schema": {
          "$ref": "#/components/schemas/Transaction"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "channels": {
            "type": "object",
            "description": "Records keyed by id for the channels collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Channel"
            }
          },
          "clients": {
            "type": "object",
            "description": "Records keyed by id for the clients collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Client"
            }
          },
          "tasks": {
            "type": "object",
            "description": "Records keyed by id for the tasks collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Task"
            }
          },
          "transactions": {
            "type": "object",
            "description": "Records keyed by id for the transactions collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Transaction"
            }
          }
        },
        "additionalProperties": false
      },
      "Transaction": {
        "type": "object",
        "description": "A logged request/response transaction routed through OpenHIM.",
        "properties": {
          "_id": {
            "type": "string"
          },
          "clientID": {
            "type": "string"
          },
          "channelID": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "Processing",
              "Successful",
              "Completed",
              "Completed with error(s)",
              "Failed"
            ]
          },
          "request": {
            "type": "object",
            "properties": {
              "host": {
                "type": "string"
              },
              "port": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "querystring": {
                "type": "string"
              },
              "method": {
                "type": "string"
              },
              "headers": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              },
              "body": {
                "type": "string"
              },
              "timestamp": {
                "type": "string",
                "format": "date-time"
              }
            }
          },
          "response": {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer"
              },
              "headers": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              },
              "body": {
                "type": "string"
              },
              "timestamp": {
                "type": "string",
                "format": "date-time"
              }
            }
          },
          "routes": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "orchestrations": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "Client": {
        "type": "object",
        "description": "A registered client that authenticates to OpenHIM to submit requests.",
        "required": [
          "clientID",
          "name"
        ],
        "properties": {
          "_id": {
            "type": "string"
          },
          "clientID": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "passwordAlgorithm": {
            "type": "string"
          },
          "passwordSalt": {
            "type": "string"
          },
          "passwordHash": {
            "type": "string"
          },
          "certFingerprint": {
            "type": "string"
          },
          "organization": {
            "type": "string"
          },
          "contactPerson": {
            "type": "string"
          }
        }
      },
      "Channel": {
        "type": "object",
        "description": "A routing configuration that maps incoming requests to upstream routes.",
        "required": [
          "name",
          "urlPattern",
          "routes"
        ],
        "properties": {
          "_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "urlPattern": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "http",
              "tcp",
              "tls",
              "polling"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "enabled",
              "disabled",
              "deleted"
            ]
          },
          "authType": {
            "type": "string",
            "enum": [
              "public",
              "private"
            ]
          },
          "methods": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "GET",
                "POST",
                "PUT",
                "DELETE",
                "OPTIONS",
                "HEAD",
                "TRACE",
                "CONNECT",
                "PATCH"
              ]
            }
          },
          "allow": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "whitelist": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "routes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Route"
            }
          },
          "requestBody": {
            "type": "boolean"
          },
          "responseBody": {
            "type": "boolean"
          },
          "rewriteUrls": {
            "type": "boolean"
          },
          "matchContentTypes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "pollingSchedule": {
            "type": "string"
          },
          "tcpHost": {
            "type": "string"
          },
          "tcpPort": {
            "type": "integer"
          }
        }
      },
      "Route": {
        "type": "object",
        "required": [
          "name",
          "host",
          "port"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "host": {
            "type": "string"
          },
          "port": {
            "type": "integer"
          },
          "path": {
            "type": "string"
          },
          "pathTransform": {
            "type": "string"
          },
          "primary": {
            "type": "boolean"
          },
          "type": {
            "type": "string",
            "enum": [
              "http",
              "tcp",
              "mllp"
            ]
          },
          "secured": {
            "type": "boolean"
          },
          "status": {
            "type": "string",
            "enum": [
              "enabled",
              "disabled"
            ]
          }
        }
      },
      "Task": {
        "type": "object",
        "description": "A batch job to rerun a set of transactions.",
        "properties": {
          "_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "NotStarted",
              "Queued",
              "Processing",
              "Paused",
              "Cancelled",
              "Completed"
            ]
          },
          "transactions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "tid": {
                  "type": "string"
                },
                "tstatus": {
                  "type": "string"
                }
              }
            }
          },
          "totalTransactions": {
            "type": "integer"
          },
          "remainingTransactions": {
            "type": "integer"
          },
          "batchSize": {
            "type": "integer"
          },
          "user": {
            "type": "string"
          },
          "created": {
            "type": "string",
            "format": "date-time"
          },
          "completed": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "TaskCreateRequest": {
        "type": "object",
        "description": "Payload to create a rerun task.",
        "required": [
          "tids"
        ],
        "properties": {
          "tids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Transaction IDs to rerun"
          },
          "batchSize": {
            "type": "integer",
            "description": "Number of transactions processed concurrently"
          },
          "paused": {
            "type": "boolean",
            "description": "If true the task is created paused and not run immediately"
          }
        }
      }
    }
  }
}
