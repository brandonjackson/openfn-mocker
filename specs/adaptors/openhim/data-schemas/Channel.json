{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openhim/Channel",
  "title": "Channel",
  "x-openfn-adaptor": "openhim",
  "x-source": {
    "openapi": "#/components/schemas/Channel",
    "capturedAt": "2026-07-06"
  },
  "type": "object",
  "description": "A routing configuration that maps incoming requests to upstream routes.",
  "required": [
    "name",
    "urlPattern",
    "routes"
  ],
  "properties": {
    "_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "urlPattern": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "http",
        "tcp",
        "tls",
        "polling"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "enabled",
        "disabled",
        "deleted"
      ]
    },
    "authType": {
      "type": "string",
      "enum": [
        "public",
        "private"
      ]
    },
    "methods": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "GET",
          "POST",
          "PUT",
          "DELETE",
          "OPTIONS",
          "HEAD",
          "TRACE",
          "CONNECT",
          "PATCH"
        ]
      }
    },
    "allow": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "whitelist": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "routes": {
      "type": "array",
      "items": {
        "$ref": "Route.json"
      }
    },
    "requestBody": {
      "type": "boolean"
    },
    "responseBody": {
      "type": "boolean"
    },
    "rewriteUrls": {
      "type": "boolean"
    },
    "matchContentTypes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pollingSchedule": {
      "type": "string"
    },
    "tcpHost": {
      "type": "string"
    },
    "tcpPort": {
      "type": "integer"
    }
  }
}
