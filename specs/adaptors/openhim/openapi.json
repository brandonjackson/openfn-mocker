{
  "openapi": "3.0.3",
  "info": {
    "title": "OpenHIM Core API (mock subset)",
    "version": "8.4.0",
    "description": "Focused subset of the OpenHIM (Open Health Information Mediator) Core API used by the OpenFn openhim adaptor: transactions (read), clients (read/create), channels (read/create), and tasks (read/create rerun). The OpenHIM Core API is served over HTTPS on port 8080 and is authenticated. Schemas cover the resources the adaptor reads and writes.",
    "x-openfn-adaptor": "openhim"
  },
  "servers": [{ "url": "http://localhost:8080" }],
  "paths": {
    "/transactions": {
      "get": {
        "operationId": "getTransactions",
        "summary": "Read all transactions",
        "parameters": [
          { "name": "filterLimit", "in": "query", "schema": { "type": "integer" }, "description": "Maximum number of transactions to return" },
          { "name": "filterPage", "in": "query", "schema": { "type": "integer" }, "description": "Zero-indexed page number, used with filterLimit" },
          { "name": "filterRepresentation", "in": "query", "schema": { "type": "string", "enum": ["simple", "simpledetails", "bulkrerun", "full", "fulltruncate"] }, "description": "Level of detail returned" },
          { "name": "channelID", "in": "query", "schema": { "type": "string" }, "description": "Restrict to a single channel" },
          { "name": "filters", "in": "query", "schema": { "type": "string" }, "description": "JSON object of advanced field filters, e.g. {\"response.status\":\"200\"}" }
        ],
        "responses": {
          "200": {
            "description": "List of transactions",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Transaction" } }
              }
            }
          }
        }
      }
    },
    "/transactions/{transactionId}": {
      "get": {
        "operationId": "getTransaction",
        "summary": "Read a single transaction by id",
        "parameters": [
          { "name": "transactionId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "A transaction",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Transaction" } }
            }
          },
          "404": { "description": "Not found" }
        }
      }
    },
    "/clients": {
      "get": {
        "operationId": "getClients",
        "summary": "Read all registered client records",
        "responses": {
          "200": {
            "description": "List of clients",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Client" } }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createClient",
        "summary": "Create a new client record",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/Client" } }
          }
        },
        "responses": {
          "201": {
            "description": "Client created",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Client" } }
            }
          }
        }
      }
    },
    "/clients/{clientId}": {
      "get": {
        "operationId": "getClient",
        "summary": "Read a specific client record",
        "parameters": [
          { "name": "clientId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "A client",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Client" } }
            }
          },
          "404": { "description": "Not found" }
        }
      }
    },
    "/channels": {
      "get": {
        "operationId": "getChannels",
        "summary": "Read all channel records",
        "responses": {
          "200": {
            "description": "List of channels",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Channel" } }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createChannel",
        "summary": "Create a new channel",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/Channel" } }
          }
        },
        "responses": {
          "201": {
            "description": "Channel created",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Channel" } }
            }
          }
        }
      }
    },
    "/channels/{channelId}": {
      "get": {
        "operationId": "getChannel",
        "summary": "Read a specific channel record",
        "parameters": [
          { "name": "channelId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "A channel",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Channel" } }
            }
          },
          "404": { "description": "Not found" }
        }
      }
    },
    "/tasks": {
      "get": {
        "operationId": "getTasks",
        "summary": "Read all tasks",
        "parameters": [
          { "name": "filterLimit", "in": "query", "schema": { "type": "integer" } },
          { "name": "filterPage", "in": "query", "schema": { "type": "integer" } },
          { "name": "filters", "in": "query", "schema": { "type": "string" }, "description": "JSON object of advanced field filters" }
        ],
        "responses": {
          "200": {
            "description": "List of tasks",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Task" } }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createTask",
        "summary": "Create a new task to rerun transactions",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/TaskCreateRequest" } }
          }
        },
        "responses": {
          "201": {
            "description": "Task created",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Task" } }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Transaction": {
        "type": "object",
        "description": "A logged request/response transaction routed through OpenHIM.",
        "properties": {
          "_id": { "type": "string" },
          "clientID": { "type": "string" },
          "channelID": { "type": "string" },
          "status": { "type": "string", "enum": ["Processing", "Successful", "Completed", "Completed with error(s)", "Failed"] },
          "request": {
            "type": "object",
            "properties": {
              "host": { "type": "string" },
              "port": { "type": "string" },
              "path": { "type": "string" },
              "querystring": { "type": "string" },
              "method": { "type": "string" },
              "headers": { "type": "object", "additionalProperties": { "type": "string" } },
              "body": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          },
          "response": {
            "type": "object",
            "properties": {
              "status": { "type": "integer" },
              "headers": { "type": "object", "additionalProperties": { "type": "string" } },
              "body": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          },
          "routes": { "type": "array", "items": { "type": "object" } },
          "orchestrations": { "type": "array", "items": { "type": "object" } }
        }
      },
      "Client": {
        "type": "object",
        "description": "A registered client that authenticates to OpenHIM to submit requests.",
        "required": ["clientID", "name"],
        "properties": {
          "_id": { "type": "string" },
          "clientID": { "type": "string" },
          "name": { "type": "string" },
          "roles": { "type": "array", "items": { "type": "string" } },
          "passwordAlgorithm": { "type": "string" },
          "passwordSalt": { "type": "string" },
          "passwordHash": { "type": "string" },
          "certFingerprint": { "type": "string" },
          "organization": { "type": "string" },
          "contactPerson": { "type": "string" }
        }
      },
      "Channel": {
        "type": "object",
        "description": "A routing configuration that maps incoming requests to upstream routes.",
        "required": ["name", "urlPattern", "routes"],
        "properties": {
          "_id": { "type": "string" },
          "name": { "type": "string" },
          "urlPattern": { "type": "string" },
          "type": { "type": "string", "enum": ["http", "tcp", "tls", "polling"] },
          "status": { "type": "string", "enum": ["enabled", "disabled", "deleted"] },
          "authType": { "type": "string", "enum": ["public", "private"] },
          "methods": { "type": "array", "items": { "type": "string", "enum": ["GET", "POST", "PUT", "DELETE", "OPTIONS", "HEAD", "TRACE", "CONNECT", "PATCH"] } },
          "allow": { "type": "array", "items": { "type": "string" } },
          "whitelist": { "type": "array", "items": { "type": "string" } },
          "routes": { "type": "array", "items": { "$ref": "#/components/schemas/Route" } },
          "requestBody": { "type": "boolean" },
          "responseBody": { "type": "boolean" },
          "rewriteUrls": { "type": "boolean" },
          "matchContentTypes": { "type": "array", "items": { "type": "string" } },
          "pollingSchedule": { "type": "string" },
          "tcpHost": { "type": "string" },
          "tcpPort": { "type": "integer" }
        }
      },
      "Route": {
        "type": "object",
        "required": ["name", "host", "port"],
        "properties": {
          "name": { "type": "string" },
          "host": { "type": "string" },
          "port": { "type": "integer" },
          "path": { "type": "string" },
          "pathTransform": { "type": "string" },
          "primary": { "type": "boolean" },
          "type": { "type": "string", "enum": ["http", "tcp", "mllp"] },
          "secured": { "type": "boolean" },
          "status": { "type": "string", "enum": ["enabled", "disabled"] }
        }
      },
      "Task": {
        "type": "object",
        "description": "A batch job to rerun a set of transactions.",
        "properties": {
          "_id": { "type": "string" },
          "status": { "type": "string", "enum": ["NotStarted", "Queued", "Processing", "Paused", "Cancelled", "Completed"] },
          "transactions": { "type": "array", "items": { "type": "object", "properties": { "tid": { "type": "string" }, "tstatus": { "type": "string" } } } },
          "totalTransactions": { "type": "integer" },
          "remainingTransactions": { "type": "integer" },
          "batchSize": { "type": "integer" },
          "user": { "type": "string" },
          "created": { "type": "string", "format": "date-time" },
          "completed": { "type": "string", "format": "date-time" }
        }
      },
      "TaskCreateRequest": {
        "type": "object",
        "description": "Payload to create a rerun task.",
        "required": ["tids"],
        "properties": {
          "tids": { "type": "array", "items": { "type": "string" }, "description": "Transaction IDs to rerun" },
          "batchSize": { "type": "integer", "description": "Number of transactions processed concurrently" },
          "paused": { "type": "boolean", "description": "If true the task is created paused and not run immediately" }
        }
      }
    }
  }
}
