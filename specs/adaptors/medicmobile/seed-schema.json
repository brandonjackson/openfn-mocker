{
  "openapi": "3.0.3",
  "info": {
    "title": "medicmobile — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate medicmobile. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "medicmobile",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "allDocsResponses": {
        "resource": "AllDocsResponse",
        "schema": {
          "$ref": "#/components/schemas/AllDocsResponse"
        }
      },
      "changes": {
        "resource": "Change",
        "schema": {
          "$ref": "#/components/schemas/Change"
        }
      },
      "reports": {
        "resource": "Report",
        "schema": {
          "$ref": "#/components/schemas/Report"
        }
      },
      "submissionAcks": {
        "resource": "SubmissionAck",
        "schema": {
          "$ref": "#/components/schemas/SubmissionAck"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "allDocsResponses": {
            "type": "object",
            "description": "Records keyed by id for the allDocsResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/AllDocsResponse"
            }
          },
          "changes": {
            "type": "object",
            "description": "Records keyed by id for the changes collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Change"
            }
          },
          "reports": {
            "type": "object",
            "description": "Records keyed by id for the reports collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Report"
            }
          },
          "submissionAcks": {
            "type": "object",
            "description": "Records keyed by id for the submissionAcks collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/SubmissionAck"
            }
          }
        },
        "additionalProperties": false
      },
      "ChangesResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Change"
            }
          },
          "last_seq": {
            "type": "string",
            "example": "334-g1AAAA"
          },
          "pending": {
            "type": "integer",
            "example": 0
          }
        }
      },
      "Change": {
        "type": "object",
        "properties": {
          "seq": {
            "type": "string",
            "example": "334-g1AAAA"
          },
          "id": {
            "type": "string",
            "example": "abc-123-xyz"
          },
          "changes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "rev": {
                  "type": "string"
                }
              }
            }
          },
          "doc": {
            "$ref": "#/components/schemas/Report"
          }
        }
      },
      "AllDocsResponse": {
        "type": "object",
        "properties": {
          "total_rows": {
            "type": "integer",
            "example": 1
          },
          "offset": {
            "type": "integer",
            "example": 0
          },
          "rows": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "key": {
                  "type": "string"
                },
                "value": {
                  "type": "object",
                  "properties": {
                    "rev": {
                      "type": "string"
                    }
                  }
                },
                "doc": {
                  "$ref": "#/components/schemas/Report"
                }
              }
            }
          }
        }
      },
      "Report": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "example": "abc-123-xyz"
          },
          "_rev": {
            "type": "string",
            "example": "1-967a00dff5e02add41819138abb3284d"
          },
          "type": {
            "type": "string",
            "example": "data_record"
          },
          "form": {
            "type": "string",
            "example": "pregnancy"
          },
          "reported_date": {
            "type": "integer",
            "format": "int64",
            "example": 1656460800000
          },
          "contact": {
            "type": "object",
            "additionalProperties": true
          },
          "fields": {
            "$ref": "#/components/schemas/ReportFields"
          }
        }
      },
      "ReportFields": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "patient_name": {
            "type": "string",
            "example": "Jane Doe"
          },
          "meta": {
            "type": "object",
            "properties": {
              "instanceID": {
                "type": "string",
                "example": "uuid:abc-123-xyz"
              }
            }
          }
        }
      },
      "Submission": {
        "type": "object",
        "properties": {
          "form": {
            "type": "string",
            "example": "pregnancy"
          },
          "fields": {
            "$ref": "#/components/schemas/ReportFields"
          }
        }
      },
      "SubmissionAck": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true
          },
          "id": {
            "type": "string",
            "example": "abc-123-xyz"
          }
        }
      }
    }
  }
}
