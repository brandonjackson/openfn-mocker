{
  "openapi": "3.0.3",
  "info": {
    "title": "Medic Mobile / CHT CouchDB API (mock subset)",
    "version": "1.0.0",
    "description": "Focused subset of the CouchDB-backed API behind a Medic Mobile / Community Health Toolkit instance, covering what the OpenFn medicmobile adaptor calls: the CouchDB _changes feed, fetching a document, and posting extracted form submissions to an inbox endpoint.",
    "x-openfn-adaptor": "medicmobile"
  },
  "servers": [{ "url": "http://localhost:5984" }],
  "paths": {
    "/{db}/_changes": {
      "get": {
        "operationId": "getChanges",
        "summary": "Read the CouchDB changes feed",
        "parameters": [
          { "name": "db", "in": "path", "required": true, "schema": { "type": "string", "example": "medic" } },
          { "name": "include_docs", "in": "query", "schema": { "type": "boolean" } },
          { "name": "since", "in": "query", "schema": { "type": "string" }, "description": "Sequence cursor (lastSeq)" },
          { "name": "filter", "in": "query", "schema": { "type": "string" } },
          { "name": "last-event-id", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Changes feed",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ChangesResponse" } }
            }
          }
        }
      }
    },
    "/{db}/_all_docs": {
      "get": {
        "operationId": "getAllDocs",
        "summary": "List all documents in a database",
        "parameters": [
          { "name": "db", "in": "path", "required": true, "schema": { "type": "string", "example": "medic" } },
          { "name": "include_docs", "in": "query", "schema": { "type": "boolean" } }
        ],
        "responses": {
          "200": {
            "description": "All docs listing",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/AllDocsResponse" } }
            }
          }
        }
      }
    },
    "/{db}/{docId}": {
      "get": {
        "operationId": "getDocument",
        "summary": "Fetch a single document",
        "parameters": [
          { "name": "db", "in": "path", "required": true, "schema": { "type": "string", "example": "medic" } },
          { "name": "docId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "A report/document",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Report" } }
            }
          }
        }
      }
    },
    "/inbox": {
      "post": {
        "operationId": "postSubmission",
        "summary": "Post an extracted form submission to an inbox endpoint",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/Submission" } }
          }
        },
        "responses": {
          "200": {
            "description": "Submission acknowledged",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/SubmissionAck" } }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ChangesResponse": {
        "type": "object",
        "properties": {
          "results": { "type": "array", "items": { "$ref": "#/components/schemas/Change" } },
          "last_seq": { "type": "string", "example": "334-g1AAAA" },
          "pending": { "type": "integer", "example": 0 }
        }
      },
      "Change": {
        "type": "object",
        "properties": {
          "seq": { "type": "string", "example": "334-g1AAAA" },
          "id": { "type": "string", "example": "abc-123-xyz" },
          "changes": {
            "type": "array",
            "items": { "type": "object", "properties": { "rev": { "type": "string" } } }
          },
          "doc": { "$ref": "#/components/schemas/Report" }
        }
      },
      "AllDocsResponse": {
        "type": "object",
        "properties": {
          "total_rows": { "type": "integer", "example": 1 },
          "offset": { "type": "integer", "example": 0 },
          "rows": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "key": { "type": "string" },
                "value": { "type": "object", "properties": { "rev": { "type": "string" } } },
                "doc": { "$ref": "#/components/schemas/Report" }
              }
            }
          }
        }
      },
      "Report": {
        "type": "object",
        "properties": {
          "_id": { "type": "string", "example": "abc-123-xyz" },
          "_rev": { "type": "string", "example": "1-967a00dff5e02add41819138abb3284d" },
          "type": { "type": "string", "example": "data_record" },
          "form": { "type": "string", "example": "pregnancy" },
          "reported_date": { "type": "integer", "format": "int64", "example": 1656460800000 },
          "contact": { "type": "object", "additionalProperties": true },
          "fields": { "$ref": "#/components/schemas/ReportFields" }
        }
      },
      "ReportFields": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "patient_name": { "type": "string", "example": "Jane Doe" },
          "meta": {
            "type": "object",
            "properties": {
              "instanceID": { "type": "string", "example": "uuid:abc-123-xyz" }
            }
          }
        }
      },
      "Submission": {
        "type": "object",
        "properties": {
          "form": { "type": "string", "example": "pregnancy" },
          "fields": { "$ref": "#/components/schemas/ReportFields" }
        }
      },
      "SubmissionAck": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean", "example": true },
          "id": { "type": "string", "example": "abc-123-xyz" }
        }
      }
    }
  }
}
