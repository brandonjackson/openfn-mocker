{
  "openapi": "3.0.3",
  "info": {
    "title": "OpenCRVS API (mock subset)",
    "version": "1.5.0",
    "description": "Synthesized OpenAPI 3.x model of the OpenCRVS endpoints exercised by the OpenFn opencrvs adaptor, derived from the adaptor surface (Adaptor.js, http.js, Utils.js, query.js). OpenCRVS is a civil registration system. The adaptor talks to several hosts under one domain: gateway (FHIR notification + GraphQL), register (v2 events REST API), countryconfig (locations) and auth (token). Because these share a domain and the adaptor uses relative paths, this document models them as paths on a single server. Covers: client-credentials auth, FHIR birth notification, the searchEvents GraphQL query, v2 event create/notify, and locations.",
    "x-openfn-adaptor": "opencrvs"
  },
  "servers": [{ "url": "https://gateway.example.opencrvs.org" }],
  "paths": {
    "/token": {
      "post": {
        "operationId": "authorize",
        "summary": "Obtain an access token (client_credentials)",
        "description": "Auth host: POST https://auth.{domain}/token. Returns a bearer token used on all other calls.",
        "parameters": [
          { "name": "grant_type", "in": "query", "schema": { "type": "string", "default": "client_credentials" } },
          { "name": "client_id", "in": "query", "schema": { "type": "string" } },
          { "name": "client_secret", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Access token",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TokenResponse" }
              }
            }
          }
        }
      }
    },
    "/notification": {
      "post": {
        "operationId": "createBirthNotification",
        "summary": "Submit a FHIR birth notification bundle",
        "description": "Gateway host. Accepts a FHIR document Bundle whose entry array is built from createDocumentEntry() helpers.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/FhirBundle" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Notification accepted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NotificationResponse" }
              }
            }
          }
        }
      }
    },
    "/graphql": {
      "post": {
        "operationId": "queryEvents",
        "summary": "Run the searchEvents GraphQL query",
        "description": "Gateway host. Executes the searchEvents advanced search. The adaptor unwraps data.searchEvents.results.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/GraphQLRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "GraphQL response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SearchEventsResponse" }
              }
            }
          }
        }
      }
    },
    "/api/events/events": {
      "post": {
        "operationId": "createEvent",
        "summary": "Create a v2 event",
        "description": "Register host. Creates an OpenCRVS v2 event (e.g. birth or death registration).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateEventRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created event",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Event" }
              }
            }
          }
        }
      }
    },
    "/api/events/events/{eventId}/notify": {
      "post": {
        "operationId": "notifyEvent",
        "summary": "Notify a v2 event with declaration data",
        "description": "Register host. Adds declaration data (flat dotted keys) to an existing event.",
        "parameters": [
          { "name": "eventId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/NotifyEventRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated event",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Event" }
              }
            }
          }
        }
      }
    },
    "/api/events/locations": {
      "get": {
        "operationId": "getLocations",
        "summary": "List configured locations",
        "description": "Countryconfig host. Returns the list of administrative structure and facility locations.",
        "responses": {
          "200": {
            "description": "Location list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Location" }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TokenResponse": {
        "type": "object",
        "properties": {
          "access_token": { "type": "string", "example": "eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9..." }
        }
      },
      "FhirBundle": {
        "type": "object",
        "properties": {
          "resourceType": { "type": "string", "example": "Bundle" },
          "type": { "type": "string", "example": "document" },
          "meta": {
            "type": "object",
            "properties": { "lastUpdated": { "type": "string", "format": "date-time" } }
          },
          "entry": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/BundleEntry" }
          }
        }
      },
      "BundleEntry": {
        "type": "object",
        "properties": {
          "fullUrl": { "type": "string", "example": "urn:uuid:abcde" },
          "resource": {
            "type": "object",
            "description": "A FHIR resource (Composition, Patient, Observation, etc.)",
            "properties": {
              "resourceType": { "type": "string", "example": "Composition" }
            },
            "additionalProperties": true
          }
        }
      },
      "NotificationResponse": {
        "type": "object",
        "properties": {
          "resourceType": { "type": "string", "example": "Bundle" },
          "type": { "type": "string", "example": "transaction-response" },
          "entry": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "response": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "201 Created" },
                    "location": { "type": "string", "example": "Composition/abcde/_history/1" }
                  }
                }
              }
            }
          }
        }
      },
      "GraphQLRequest": {
        "type": "object",
        "properties": {
          "operationName": { "type": "string", "example": "searchEvents" },
          "query": { "type": "string" },
          "variables": {
            "type": "object",
            "properties": {
              "advancedSearchParameters": { "$ref": "#/components/schemas/AdvancedSearchParameters" }
            }
          },
          "count": { "type": "integer", "example": 10 },
          "skip": { "type": "integer", "example": 0 }
        }
      },
      "AdvancedSearchParameters": {
        "type": "object",
        "properties": {
          "event": { "type": "string", "example": "birth" },
          "registrationStatuses": { "type": "array", "items": { "type": "string" }, "example": ["REGISTERED"] },
          "childGender": { "type": "string", "example": "male" },
          "dateOfRegistrationStart": { "type": "string", "format": "date" },
          "dateOfRegistrationEnd": { "type": "string", "format": "date" },
          "declarationJurisdictionId": { "type": "string" },
          "eventLocationId": { "type": "string" },
          "motherFirstNames": { "type": "string" },
          "fatherFirstNames": { "type": "string" }
        }
      },
      "SearchEventsResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "searchEvents": {
                "type": "object",
                "properties": {
                  "totalItems": { "type": "integer", "example": 1 },
                  "results": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/EventSearchResult" }
                  }
                }
              }
            }
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": { "message": { "type": "string" } }
            }
          }
        }
      },
      "EventSearchResult": {
        "type": "object",
        "properties": {
          "__typename": { "type": "string", "example": "BirthEventSearchSet" },
          "id": { "type": "string", "example": "b1a2c3d4" },
          "type": { "type": "string", "example": "Birth" },
          "dateOfBirth": { "type": "string", "format": "date", "example": "2026-05-01" },
          "childName": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/HumanName" }
          },
          "registration": {
            "type": "object",
            "properties": {
              "status": { "type": "string", "example": "REGISTERED" },
              "contactNumber": { "type": "string" },
              "trackingId": { "type": "string", "example": "BQSQREY" },
              "registrationNumber": { "type": "string" },
              "registeredLocationId": { "type": "string" },
              "createdAt": { "type": "string", "format": "date-time" },
              "modifiedAt": { "type": "string", "format": "date-time" }
            }
          }
        }
      },
      "HumanName": {
        "type": "object",
        "properties": {
          "use": { "type": "string", "example": "en" },
          "firstNames": { "type": "string", "example": "Test" },
          "familyName": { "type": "string", "example": "Baby" }
        }
      },
      "CreateEventRequest": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "example": "birth" },
          "transactionId": { "type": "string", "example": "b8f9a1e2-0000-0000-0000-000000000000" },
          "createdAtLocation": { "type": "string", "example": "a1b2-c3d4" }
        }
      },
      "NotifyEventRequest": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "example": "NOTIFY" },
          "transactionId": { "type": "string" },
          "createdAtLocation": { "type": "string" },
          "declaration": {
            "type": "object",
            "description": "Flat dotted-key declaration data, e.g. 'child.name', 'child.dob', 'child.gender'.",
            "additionalProperties": true,
            "example": {
              "child.name": { "firstname": "Test", "surname": "Baby" },
              "child.dob": "2026-05-01",
              "child.gender": "male"
            }
          },
          "annotation": { "type": "object", "additionalProperties": true }
        }
      },
      "Event": {
        "type": "object",
        "description": "OpenCRVS v2 event. The adaptor relies on data.id; other fields are inferred from the v2 events API.",
        "properties": {
          "id": { "type": "string", "example": "e1f2a3b4-0000-0000-0000-000000000000" },
          "type": { "type": "string", "example": "birth" },
          "status": { "type": "string", "example": "NOTIFIED" },
          "transactionId": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "createdAtLocation": { "type": "string", "example": "a1b2-c3d4" },
          "declaration": { "type": "object", "additionalProperties": true }
        }
      },
      "Location": {
        "type": "object",
        "description": "OpenCRVS location (administrative structure or facility).",
        "properties": {
          "statisticalID": { "type": "string", "example": "ADMIN_STRUCTURE_1" },
          "name": { "type": "string", "example": "Ibombo" },
          "alias": { "type": "string", "example": "Ibombo" },
          "partOf": { "type": "string", "example": "Location/0" },
          "code": { "type": "string", "example": "ADMIN_STRUCTURE" },
          "jurisdictionType": { "type": "string", "example": "DISTRICT" },
          "statistics": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "year": { "type": "integer", "example": 2021 },
                "male_population": { "type": "integer" },
                "female_population": { "type": "integer" },
                "population": { "type": "integer" },
                "crude_birth_rate": { "type": "number" }
              }
            }
          }
        }
      }
    }
  }
}
