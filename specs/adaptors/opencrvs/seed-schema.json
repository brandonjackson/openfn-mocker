{
  "openapi": "3.0.3",
  "info": {
    "title": "opencrvs — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate opencrvs. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "opencrvs",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "events": {
        "resource": "Event",
        "schema": {
          "$ref": "#/components/schemas/Event"
        }
      },
      "locations": {
        "resource": "Location",
        "schema": {
          "$ref": "#/components/schemas/Location"
        }
      },
      "notificationResponses": {
        "resource": "NotificationResponse",
        "schema": {
          "$ref": "#/components/schemas/NotificationResponse"
        }
      },
      "searchEventsResponses": {
        "resource": "SearchEventsResponse",
        "schema": {
          "$ref": "#/components/schemas/SearchEventsResponse"
        }
      },
      "tokenResponses": {
        "resource": "TokenResponse",
        "schema": {
          "$ref": "#/components/schemas/TokenResponse"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "events": {
            "type": "object",
            "description": "Records keyed by id for the events collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Event"
            }
          },
          "locations": {
            "type": "object",
            "description": "Records keyed by id for the locations collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Location"
            }
          },
          "notificationResponses": {
            "type": "object",
            "description": "Records keyed by id for the notificationResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/NotificationResponse"
            }
          },
          "searchEventsResponses": {
            "type": "object",
            "description": "Records keyed by id for the searchEventsResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/SearchEventsResponse"
            }
          },
          "tokenResponses": {
            "type": "object",
            "description": "Records keyed by id for the tokenResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/TokenResponse"
            }
          }
        },
        "additionalProperties": false
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "example": "eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9..."
          }
        }
      },
      "FhirBundle": {
        "type": "object",
        "properties": {
          "resourceType": {
            "type": "string",
            "example": "Bundle"
          },
          "type": {
            "type": "string",
            "example": "document"
          },
          "meta": {
            "type": "object",
            "properties": {
              "lastUpdated": {
                "type": "string",
                "format": "date-time"
              }
            }
          },
          "entry": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BundleEntry"
            }
          }
        }
      },
      "BundleEntry": {
        "type": "object",
        "properties": {
          "fullUrl": {
            "type": "string",
            "example": "urn:uuid:abcde"
          },
          "resource": {
            "type": "object",
            "description": "A FHIR resource (Composition, Patient, Observation, etc.)",
            "properties": {
              "resourceType": {
                "type": "string",
                "example": "Composition"
              }
            },
            "additionalProperties": true
          }
        }
      },
      "NotificationResponse": {
        "type": "object",
        "properties": {
          "resourceType": {
            "type": "string",
            "example": "Bundle"
          },
          "type": {
            "type": "string",
            "example": "transaction-response"
          },
          "entry": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "response": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "201 Created"
                    },
                    "location": {
                      "type": "string",
                      "example": "Composition/abcde/_history/1"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "GraphQLRequest": {
        "type": "object",
        "properties": {
          "operationName": {
            "type": "string",
            "example": "searchEvents"
          },
          "query": {
            "type": "string"
          },
          "variables": {
            "type": "object",
            "properties": {
              "advancedSearchParameters": {
                "$ref": "#/components/schemas/AdvancedSearchParameters"
              }
            }
          },
          "count": {
            "type": "integer",
            "example": 10
          },
          "skip": {
            "type": "integer",
            "example": 0
          }
        }
      },
      "AdvancedSearchParameters": {
        "type": "object",
        "properties": {
          "event": {
            "type": "string",
            "example": "birth"
          },
          "registrationStatuses": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "REGISTERED"
            ]
          },
          "childGender": {
            "type": "string",
            "example": "male"
          },
          "dateOfRegistrationStart": {
            "type": "string",
            "format": "date"
          },
          "dateOfRegistrationEnd": {
            "type": "string",
            "format": "date"
          },
          "declarationJurisdictionId": {
            "type": "string"
          },
          "eventLocationId": {
            "type": "string"
          },
          "motherFirstNames": {
            "type": "string"
          },
          "fatherFirstNames": {
            "type": "string"
          }
        }
      },
      "SearchEventsResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "searchEvents": {
                "type": "object",
                "properties": {
                  "totalItems": {
                    "type": "integer",
                    "example": 1
                  },
                  "results": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/EventSearchResult"
                    }
                  }
                }
              }
            }
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "EventSearchResult": {
        "type": "object",
        "properties": {
          "__typename": {
            "type": "string",
            "example": "BirthEventSearchSet"
          },
          "id": {
            "type": "string",
            "example": "b1a2c3d4"
          },
          "type": {
            "type": "string",
            "example": "Birth"
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date",
            "example": "2026-05-01"
          },
          "childName": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/HumanName"
            }
          },
          "registration": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string",
                "example": "REGISTERED"
              },
              "contactNumber": {
                "type": "string"
              },
              "trackingId": {
                "type": "string",
                "example": "BQSQREY"
              },
              "registrationNumber": {
                "type": "string"
              },
              "registeredLocationId": {
                "type": "string"
              },
              "createdAt": {
                "type": "string",
                "format": "date-time"
              },
              "modifiedAt": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        }
      },
      "HumanName": {
        "type": "object",
        "properties": {
          "use": {
            "type": "string",
            "example": "en"
          },
          "firstNames": {
            "type": "string",
            "example": "Test"
          },
          "familyName": {
            "type": "string",
            "example": "Baby"
          }
        }
      },
      "CreateEventRequest": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "example": "birth"
          },
          "transactionId": {
            "type": "string",
            "example": "b8f9a1e2-0000-0000-0000-000000000000"
          },
          "createdAtLocation": {
            "type": "string",
            "example": "a1b2-c3d4"
          }
        }
      },
      "NotifyEventRequest": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "example": "NOTIFY"
          },
          "transactionId": {
            "type": "string"
          },
          "createdAtLocation": {
            "type": "string"
          },
          "declaration": {
            "type": "object",
            "description": "Flat dotted-key declaration data, e.g. 'child.name', 'child.dob', 'child.gender'.",
            "additionalProperties": true,
            "example": {
              "child.name": {
                "firstname": "Test",
                "surname": "Baby"
              },
              "child.dob": "2026-05-01",
              "child.gender": "male"
            }
          },
          "annotation": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "Event": {
        "type": "object",
        "description": "OpenCRVS v2 event. The adaptor relies on data.id; other fields are inferred from the v2 events API.",
        "properties": {
          "id": {
            "type": "string",
            "example": "e1f2a3b4-0000-0000-0000-000000000000"
          },
          "type": {
            "type": "string",
            "example": "birth"
          },
          "status": {
            "type": "string",
            "example": "NOTIFIED"
          },
          "transactionId": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "createdAtLocation": {
            "type": "string",
            "example": "a1b2-c3d4"
          },
          "declaration": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "Location": {
        "type": "object",
        "description": "OpenCRVS location (administrative structure or facility).",
        "properties": {
          "statisticalID": {
            "type": "string",
            "example": "ADMIN_STRUCTURE_1"
          },
          "name": {
            "type": "string",
            "example": "Ibombo"
          },
          "alias": {
            "type": "string",
            "example": "Ibombo"
          },
          "partOf": {
            "type": "string",
            "example": "Location/0"
          },
          "code": {
            "type": "string",
            "example": "ADMIN_STRUCTURE"
          },
          "jurisdictionType": {
            "type": "string",
            "example": "DISTRICT"
          },
          "statistics": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "year": {
                  "type": "integer",
                  "example": 2021
                },
                "male_population": {
                  "type": "integer"
                },
                "female_population": {
                  "type": "integer"
                },
                "population": {
                  "type": "integer"
                },
                "crude_birth_rate": {
                  "type": "number"
                }
              }
            }
          }
        }
      }
    }
  }
}
