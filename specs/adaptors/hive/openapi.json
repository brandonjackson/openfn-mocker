{
  "openapi": "3.0.3",
  "info": {
    "title": "Hive database query API (synthesized)",
    "version": "1.0.0",
    "description": "Synthesized OpenAPI facade for the OpenFn hive adaptor. The real adaptor executes SQL statements against a Hive database over a JDBC/Thrift connection (host, port, database, username, password) and has a single public operation: query(sql). There is no native HTTP surface, so this document models the query interaction as a POST /query endpoint that accepts an SQL statement and returns a tabular result set, giving mocker a reusable result-row shape to seed.",
    "x-openfn-adaptor": "hive"
  },
  "servers": [{ "url": "http://localhost:4010" }],
  "paths": {
    "/query": {
      "post": {
        "operationId": "query",
        "summary": "Execute an SQL statement against the Hive database",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/QueryRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The query result set",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/QueryResult" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "QueryRequest": {
        "type": "object",
        "required": ["sql"],
        "properties": {
          "sql": {
            "type": "string",
            "description": "The SQL statement to execute",
            "example": "select count(*) as patient_count from patient"
          },
          "options": {
            "type": "object",
            "description": "Optional execution options",
            "additionalProperties": true
          }
        }
      },
      "QueryResult": {
        "type": "object",
        "properties": {
          "columns": {
            "type": "array",
            "description": "Column names in result order",
            "items": { "type": "string" },
            "example": ["patient_count"]
          },
          "rows": {
            "type": "array",
            "description": "Result rows, each keyed by column name",
            "items": { "$ref": "#/components/schemas/QueryRow" }
          },
          "rowCount": { "type": "integer", "example": 1 }
        }
      },
      "QueryRow": {
        "type": "object",
        "description": "A single result row (columns are query-dependent)",
        "additionalProperties": true,
        "example": { "patient_count": 4213 }
      }
    }
  }
}
