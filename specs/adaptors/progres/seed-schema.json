{
  "openapi": "3.0.3",
  "info": {
    "title": "progres — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate progres. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "progres",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "submissionResults": {
        "resource": "SubmissionResult",
        "schema": {
          "$ref": "#/components/schemas/SubmissionResult"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "submissionResults": {
            "type": "object",
            "description": "Records keyed by id for the submissionResults collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/SubmissionResult"
            }
          }
        },
        "additionalProperties": false
      },
      "DataSubmission": {
        "type": "object",
        "description": "Arbitrary JSON payload posted by the generic postData operation",
        "additionalProperties": true
      },
      "SubmissionResult": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "id": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "Student": {
        "type": "object",
        "properties": {
          "identifiant": {
            "type": "string",
            "description": "Student national identifier"
          },
          "nom": {
            "type": "string"
          },
          "prenom": {
            "type": "string"
          },
          "dateNaissance": {
            "type": "string",
            "format": "date"
          },
          "sexe": {
            "type": "string"
          },
          "etablissement": {
            "type": "string"
          }
        }
      },
      "Enrollment": {
        "type": "object",
        "properties": {
          "identifiantEtudiant": {
            "type": "string"
          },
          "anneeUniversitaire": {
            "type": "string",
            "example": "2025-2026"
          },
          "niveau": {
            "type": "string"
          },
          "filiere": {
            "type": "string"
          },
          "etablissement": {
            "type": "string"
          }
        }
      }
    }
  }
}
