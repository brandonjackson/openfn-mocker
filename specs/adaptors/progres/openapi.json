{
  "openapi": "3.0.3",
  "info": {
    "title": "PROGRES adaptor surface (synthesized)",
    "version": "1.0",
    "description": "The OpenFn progres adaptor exposes a single operation, postData, which makes a mutual-TLS POST (client key + certificate via agentOptions) with an Ocp-Apim-Subscription-Key header to an Azure API Management endpoint of Algeria's PROGRES higher-education platform (MESRS). There is no public vendor machine spec, so this OpenAPI 3.0 document is synthesized from the adaptor surface: a generic data-submission endpoint plus representative student-record submission paths reflecting the postData usage.",
    "x-openfn-adaptor": "progres"
  },
  "servers": [
    { "url": "https://progres.example.azure-api.net", "description": "Azure APIM-fronted PROGRES API (instance-specific)" }
  ],
  "paths": {
    "/data": {
      "post": {
        "operationId": "postData",
        "summary": "Submit a data payload via mutual-TLS POST (generic postData)",
        "parameters": [
          {
            "name": "Ocp-Apim-Subscription-Key",
            "in": "header",
            "required": true,
            "schema": { "type": "string" },
            "description": "Azure API Management subscription key"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/DataSubmission" } }
          }
        },
        "responses": {
          "200": {
            "description": "Submission acknowledgement",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/SubmissionResult" } }
            }
          }
        }
      }
    },
    "/students": {
      "post": {
        "operationId": "postStudent",
        "summary": "Submit a student record",
        "parameters": [
          {
            "name": "Ocp-Apim-Subscription-Key",
            "in": "header",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/Student" } }
          }
        },
        "responses": {
          "200": {
            "description": "The accepted student record",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/SubmissionResult" } }
            }
          }
        }
      }
    },
    "/enrollments": {
      "post": {
        "operationId": "postEnrollment",
        "summary": "Submit a student enrollment record",
        "parameters": [
          {
            "name": "Ocp-Apim-Subscription-Key",
            "in": "header",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/Enrollment" } }
          }
        },
        "responses": {
          "200": {
            "description": "The accepted enrollment record",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/SubmissionResult" } }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "DataSubmission": {
        "type": "object",
        "description": "Arbitrary JSON payload posted by the generic postData operation",
        "additionalProperties": true
      },
      "SubmissionResult": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "id": { "type": "string" },
          "message": { "type": "string" },
          "errors": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "Student": {
        "type": "object",
        "properties": {
          "identifiant": { "type": "string", "description": "Student national identifier" },
          "nom": { "type": "string" },
          "prenom": { "type": "string" },
          "dateNaissance": { "type": "string", "format": "date" },
          "sexe": { "type": "string" },
          "etablissement": { "type": "string" }
        }
      },
      "Enrollment": {
        "type": "object",
        "properties": {
          "identifiantEtudiant": { "type": "string" },
          "anneeUniversitaire": { "type": "string", "example": "2025-2026" },
          "niveau": { "type": "string" },
          "filiere": { "type": "string" },
          "etablissement": { "type": "string" }
        }
      }
    }
  }
}
