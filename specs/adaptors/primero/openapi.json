{
  "openapi": "3.0.3",
  "info": {
    "title": "Primero API v2 (mock subset)",
    "version": "2.0",
    "description": "Focused subset of the Primero (primeroIMS) REST API v2 used by the OpenFn primero adaptor: token auth, cases (list, get, create, update, upsert), case referrals (list, bulk create, update), and reference data (forms, lookups, locations). Responses wrap payloads in a top-level data object.",
    "x-openfn-adaptor": "primero"
  },
  "servers": [
    { "url": "https://primero.example.org", "description": "Primero instance base (instance-specific)" }
  ],
  "paths": {
    "/api/v2/tokens": {
      "post": {
        "operationId": "createToken",
        "summary": "Authenticate and obtain a session token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/TokenRequest" } }
          }
        },
        "responses": {
          "200": {
            "description": "Auth token",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/TokenResponse" } }
            }
          }
        }
      }
    },
    "/api/v2/cases": {
      "get": {
        "operationId": "getCases",
        "summary": "Query cases",
        "parameters": [
          { "name": "query", "in": "query", "schema": { "type": "string" }, "description": "Free-text search" },
          { "name": "fields", "in": "query", "schema": { "type": "string" }, "description": "Comma-separated field list or 'short'" },
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "per", "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": {
            "description": "A paged list of cases",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/CaseList" } }
            }
          }
        }
      },
      "post": {
        "operationId": "createCase",
        "summary": "Create a case",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/CaseWrapper" } }
          }
        },
        "responses": {
          "200": {
            "description": "The created case",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/CaseResponse" } }
            }
          }
        }
      }
    },
    "/api/v2/cases/{id}": {
      "parameters": [
        { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "get": {
        "operationId": "getCase",
        "summary": "Get a case by id",
        "responses": {
          "200": {
            "description": "A single case",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/CaseResponse" } }
            }
          },
          "404": { "description": "Not found" }
        }
      },
      "patch": {
        "operationId": "updateCase",
        "summary": "Update a case",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/CaseWrapper" } }
          }
        },
        "responses": {
          "200": {
            "description": "The updated case",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/CaseResponse" } }
            }
          }
        }
      }
    },
    "/api/v2/cases/{caseId}/referrals": {
      "parameters": [
        { "name": "caseId", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "get": {
        "operationId": "getReferrals",
        "summary": "List referrals for a case",
        "responses": {
          "200": {
            "description": "Referrals for the case",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ReferralList" } }
            }
          }
        }
      }
    },
    "/api/v2/cases/referrals": {
      "post": {
        "operationId": "createReferrals",
        "summary": "Bulk refer one or more cases",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/BulkReferralWrite" } }
          }
        },
        "responses": {
          "200": {
            "description": "Created referrals",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ReferralList" } }
            }
          }
        }
      }
    },
    "/api/v2/cases/{caseId}/referrals/{id}": {
      "parameters": [
        { "name": "caseId", "in": "path", "required": true, "schema": { "type": "string" } },
        { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "patch": {
        "operationId": "updateReferral",
        "summary": "Update a single referral for a case",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/ReferralWrapper" } }
          }
        },
        "responses": {
          "200": {
            "description": "The updated referral",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ReferralResponse" } }
            }
          }
        }
      }
    },
    "/api/v2/forms": {
      "get": {
        "operationId": "getForms",
        "summary": "List form sections",
        "responses": {
          "200": {
            "description": "Forms accessible to the user",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/FormList" } }
            }
          }
        }
      }
    },
    "/api/v2/lookups": {
      "get": {
        "operationId": "getLookups",
        "summary": "List lookups",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "per", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Paged lookups",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/LookupList" } }
            }
          }
        }
      }
    },
    "/api/v2/locations": {
      "get": {
        "operationId": "getLocations",
        "summary": "List locations",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "per", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Paged locations",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/LocationList" } }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TokenRequest": {
        "type": "object",
        "required": ["user"],
        "properties": {
          "user": {
            "type": "object",
            "properties": {
              "user_name": { "type": "string" },
              "password": { "type": "string" }
            }
          }
        }
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "token": { "type": "string" },
          "id": { "type": "integer" },
          "user_name": { "type": "string" }
        }
      },
      "Case": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "UUID" },
          "case_id_display": { "type": "string" },
          "name": { "type": "string" },
          "age": { "type": "integer" },
          "sex": { "type": "string" },
          "owned_by": { "type": "string" },
          "registration_date": { "type": "string", "format": "date" },
          "created_at": { "type": "string", "format": "date-time" },
          "photos": { "type": "array", "items": { "type": "string" } }
        }
      },
      "CaseWrapper": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": { "$ref": "#/components/schemas/Case" }
        }
      },
      "CaseResponse": {
        "type": "object",
        "properties": {
          "data": { "$ref": "#/components/schemas/Case" }
        }
      },
      "CaseList": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Case" } },
          "metadata": { "$ref": "#/components/schemas/PageMetadata" }
        }
      },
      "PageMetadata": {
        "type": "object",
        "properties": {
          "total": { "type": "integer" },
          "per": { "type": "integer" },
          "page": { "type": "integer" }
        }
      },
      "Referral": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "record_id": { "type": "string" },
          "record_type": { "type": "string", "example": "cases" },
          "transitioned_to": { "type": "string" },
          "transitioned_by": { "type": "string" },
          "status": { "type": "string" },
          "notes": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "ReferralWrapper": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": { "$ref": "#/components/schemas/Referral" }
        }
      },
      "ReferralResponse": {
        "type": "object",
        "properties": {
          "data": { "$ref": "#/components/schemas/Referral" }
        }
      },
      "ReferralList": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Referral" } }
        }
      },
      "BulkReferralWrite": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "transitioned_to": { "type": "string" },
              "notes": { "type": "string" },
              "ids": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      },
      "Form": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "unique_id": { "type": "string" },
          "name": { "type": "object", "additionalProperties": { "type": "string" } },
          "parent_form": { "type": "string" },
          "visible": { "type": "boolean" }
        }
      },
      "FormList": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Form" } }
        }
      },
      "Lookup": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "unique_id": { "type": "string" },
          "name": { "type": "object", "additionalProperties": { "type": "string" } },
          "values": { "type": "array", "items": { "type": "object", "additionalProperties": true } }
        }
      },
      "LookupList": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Lookup" } },
          "metadata": { "$ref": "#/components/schemas/PageMetadata" }
        }
      },
      "Location": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "code": { "type": "string" },
          "admin_level": { "type": "integer" },
          "type": { "type": "string" },
          "name": { "type": "object", "additionalProperties": { "type": "string" } },
          "hierarchy_path": { "type": "string" }
        }
      },
      "LocationList": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Location" } },
          "metadata": { "$ref": "#/components/schemas/PageMetadata" }
        }
      }
    }
  }
}
