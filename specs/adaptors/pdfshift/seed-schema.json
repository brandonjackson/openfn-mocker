{
  "openapi": "3.0.3",
  "info": {
    "title": "pdfshift — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate pdfshift. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "pdfshift",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "accounts": {
        "resource": "Account",
        "schema": {
          "$ref": "#/components/schemas/Account"
        }
      },
      "conversionResults": {
        "resource": "ConversionResult",
        "schema": {
          "$ref": "#/components/schemas/ConversionResult"
        }
      },
      "creditses": {
        "resource": "Credits",
        "schema": {
          "$ref": "#/components/schemas/Credits"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "accounts": {
            "type": "object",
            "description": "Records keyed by id for the accounts collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Account"
            }
          },
          "conversionResults": {
            "type": "object",
            "description": "Records keyed by id for the conversionResults collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/ConversionResult"
            }
          },
          "creditses": {
            "type": "object",
            "description": "Records keyed by id for the creditses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Credits"
            }
          }
        },
        "additionalProperties": false
      },
      "ConvertRequest": {
        "type": "object",
        "required": [
          "source"
        ],
        "properties": {
          "source": {
            "type": "string",
            "description": "The HTML document (raw string) or a URL to convert to PDF."
          },
          "sandbox": {
            "type": "boolean",
            "description": "Generate the PDF in dev/sandbox mode. Produces a watermarked document that does not consume credits."
          },
          "encode": {
            "type": "boolean",
            "description": "Return the generated PDF as a Base64-encoded string instead of raw binary. Defaults to true in the adaptor.",
            "default": true
          },
          "filename": {
            "type": "string",
            "description": "Optional. 7+ characters (letters, numbers, '-' or '_'). When set, the file is stored and the API returns a JSON result containing a temporary download URL (kept ~2 days) instead of the binary PDF.",
            "pattern": "^[A-Za-z0-9_-]{7,}$"
          },
          "webhook": {
            "type": "string",
            "format": "uri",
            "description": "Optional callback URL for async conversion. When set, the API responds with a queued acknowledgement and later POSTs the result to this URL."
          },
          "use_print": {
            "type": "boolean",
            "description": "Use the print CSS stylesheet instead of the screen stylesheet."
          },
          "format": {
            "type": "string",
            "description": "Page format, e.g. 'A4', 'Letter', 'Legal', or a custom 'widthxheight' value.",
            "example": "A4"
          },
          "landscape": {
            "type": "boolean",
            "description": "Render the document in landscape orientation."
          },
          "css": {
            "type": "string",
            "description": "Additional CSS (URL or raw string) applied before conversion."
          }
        }
      },
      "ConversionResult": {
        "type": "object",
        "description": "JSON result returned by a conversion endpoint when filename/webhook is used or encode is true.",
        "required": [
          "success",
          "url",
          "filesize",
          "duration",
          "response",
          "executed"
        ],
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Whether the conversion succeeded."
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Temporary download URL for the generated document (when filename/webhook is used)."
          },
          "filesize": {
            "type": "integer",
            "description": "Size of the generated document in bytes."
          },
          "duration": {
            "type": "integer",
            "description": "Total time taken to generate the document, in milliseconds."
          },
          "response": {
            "type": "object",
            "description": "Details about loading the source document.",
            "properties": {
              "duration": {
                "type": "integer",
                "description": "Milliseconds spent loading the source."
              },
              "status-code": {
                "type": "integer",
                "description": "HTTP status code PDFShift received when loading an HTTP source."
              }
            }
          },
          "executed": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp at which the conversion ran."
          },
          "pdf_pages": {
            "type": "integer",
            "description": "Total number of pages in the generated PDF."
          }
        }
      },
      "Credits": {
        "type": "object",
        "description": "Current credit usage for the account.",
        "properties": {
          "credits": {
            "type": "object",
            "properties": {
              "base": {
                "type": "integer",
                "format": "int32",
                "description": "Default credit limit from the current plan."
              },
              "remaining": {
                "type": "integer",
                "format": "int32",
                "description": "Credits still available for the current period."
              },
              "total": {
                "type": "integer",
                "format": "int32",
                "description": "Total credit limit (may exceed base if overage is enabled)."
              },
              "used": {
                "type": "integer",
                "format": "int32",
                "description": "Credits consumed so far this period."
              }
            }
          },
          "success": {
            "type": "boolean"
          }
        }
      },
      "Account": {
        "type": "object",
        "description": "Account details.",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "account": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "firstname": {
                "type": "string"
              },
              "email": {
                "type": "string",
                "format": "email"
              },
              "created": {
                "type": "integer",
                "format": "int64"
              },
              "company_name": {
                "type": "string"
              },
              "country": {
                "type": "string"
              },
              "renew_date": {
                "type": "integer",
                "format": "int64"
              },
              "avatar": {
                "type": "string",
                "format": "uri"
              },
              "plan": {
                "type": "object",
                "properties": {
                  "display": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "credits": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "filesize": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "timeout": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "price": {
                    "type": "number",
                    "format": "float"
                  },
                  "yearly": {
                    "type": "boolean"
                  },
                  "overage": {
                    "type": "number",
                    "format": "float"
                  }
                }
              }
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "error": {
            "type": "string"
          },
          "code": {
            "type": "integer",
            "format": "int32"
          }
        }
      }
    }
  }
}
