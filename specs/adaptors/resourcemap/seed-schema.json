{
  "openapi": "3.0.3",
  "info": {
    "title": "resourcemap — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate resourcemap. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "resourcemap",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "collections": {
        "resource": "Collection",
        "schema": {
          "$ref": "#/components/schemas/Collection"
        }
      },
      "collectionDetails": {
        "resource": "CollectionDetail",
        "schema": {
          "$ref": "#/components/schemas/CollectionDetail"
        }
      },
      "layers": {
        "resource": "Layer",
        "schema": {
          "$ref": "#/components/schemas/Layer"
        }
      },
      "memberships": {
        "resource": "Membership",
        "schema": {
          "$ref": "#/components/schemas/Membership"
        }
      },
      "sites": {
        "resource": "Site",
        "schema": {
          "$ref": "#/components/schemas/Site"
        }
      },
      "siteHistories": {
        "resource": "SiteHistory",
        "schema": {
          "$ref": "#/components/schemas/SiteHistory"
        }
      },
      "statusResponses": {
        "resource": "StatusResponse",
        "schema": {
          "$ref": "#/components/schemas/StatusResponse"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "collections": {
            "type": "object",
            "description": "Records keyed by id for the collections collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Collection"
            }
          },
          "collectionDetails": {
            "type": "object",
            "description": "Records keyed by id for the collectionDetails collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/CollectionDetail"
            }
          },
          "layers": {
            "type": "object",
            "description": "Records keyed by id for the layers collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Layer"
            }
          },
          "memberships": {
            "type": "object",
            "description": "Records keyed by id for the memberships collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Membership"
            }
          },
          "sites": {
            "type": "object",
            "description": "Records keyed by id for the sites collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Site"
            }
          },
          "siteHistories": {
            "type": "object",
            "description": "Records keyed by id for the siteHistories collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/SiteHistory"
            }
          },
          "statusResponses": {
            "type": "object",
            "description": "Records keyed by id for the statusResponses collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/StatusResponse"
            }
          }
        },
        "additionalProperties": false
      },
      "Collection": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 303
          },
          "name": {
            "type": "string",
            "example": "Health Facilities"
          },
          "description": {
            "type": "string"
          },
          "lat": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "lng": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "count": {
            "type": "integer",
            "description": "Number of sites in the collection"
          }
        },
        "required": [
          "id",
          "name"
        ]
      },
      "CollectionDetail": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "sites": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Site"
            }
          }
        }
      },
      "Site": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1234
          },
          "uuid": {
            "type": "string",
            "example": "b3f4c1a2-7d8e-4f90-9a11-2c3d4e5f6a7b"
          },
          "name": {
            "type": "string",
            "example": "My Site"
          },
          "lat": {
            "type": "number",
            "format": "double",
            "nullable": true,
            "example": 48.86
          },
          "lng": {
            "type": "number",
            "format": "double",
            "nullable": true,
            "example": 2.35
          },
          "collection_id": {
            "type": "integer",
            "example": 303
          },
          "version": {
            "type": "integer",
            "example": 1
          },
          "properties": {
            "type": "object",
            "additionalProperties": true,
            "description": "Map of field es_code (or code) to value",
            "example": {
              "phone": "85512345678",
              "Comment": "sample"
            }
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "name"
        ]
      },
      "SiteInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "My Site"
          },
          "lat": {
            "type": "number",
            "format": "double",
            "example": 48.86
          },
          "lng": {
            "type": "number",
            "format": "double",
            "example": 2.35
          },
          "lon": {
            "type": "number",
            "format": "double",
            "description": "Alias accepted for longitude",
            "example": 2.35
          },
          "properties": {
            "type": "object",
            "additionalProperties": true,
            "example": {
              "phone": "85512345678",
              "Comment": "sample"
            }
          }
        },
        "required": [
          "name"
        ]
      },
      "Layer": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 12
          },
          "name": {
            "type": "string",
            "example": "Basic info"
          },
          "ord": {
            "type": "integer",
            "example": 1
          },
          "fields": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Field"
            }
          }
        }
      },
      "Field": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 45
          },
          "es_code": {
            "type": "string",
            "example": "45"
          },
          "code": {
            "type": "string",
            "example": "phone"
          },
          "name": {
            "type": "string",
            "example": "Phone"
          },
          "kind": {
            "type": "string",
            "description": "Field type",
            "example": "text",
            "enum": [
              "text",
              "numeric",
              "yes_no",
              "select_one",
              "select_many",
              "date",
              "site",
              "user",
              "email",
              "phone",
              "hierarchy"
            ]
          },
          "config": {
            "type": "object",
            "additionalProperties": true,
            "nullable": true
          }
        }
      },
      "LayerInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Basic info"
          },
          "ord": {
            "type": "integer",
            "example": 1
          },
          "fields_attributes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "kind": {
                  "type": "string"
                },
                "ord": {
                  "type": "integer"
                }
              }
            }
          }
        },
        "required": [
          "name"
        ]
      },
      "SiteHistory": {
        "type": "object",
        "properties": {
          "version": {
            "type": "integer",
            "example": 2
          },
          "name": {
            "type": "string"
          },
          "lat": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "lng": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "valid_since": {
            "type": "string",
            "format": "date-time"
          },
          "valid_to": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "user": {
            "type": "string",
            "format": "email",
            "example": "user@example.org"
          },
          "properties": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "Membership": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "integer",
            "example": 7
          },
          "user_display_name": {
            "type": "string",
            "example": "Jane Doe"
          },
          "admin": {
            "type": "boolean",
            "example": false
          },
          "layers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "layer_id": {
                  "type": "integer"
                },
                "read": {
                  "type": "boolean"
                },
                "write": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      },
      "StatusResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "ok"
          }
        }
      }
    }
  }
