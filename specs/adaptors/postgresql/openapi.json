{
  "openapi": "3.0.3",
  "info": {
    "title": "PostgreSQL adaptor surface (synthesized HTTP facade)",
    "version": "1.0",
    "description": "PostgreSQL is a SQL database with no REST API. This document synthesizes an OpenAPI 3.0 HTTP facade from the OpenFn postgresql adaptor surface so the mocker can serve representative responses. Each adaptor operation (sql, findValue, insert, insertMany, upsert, describeTable, insertTable, modifyTable) is modeled as an HTTP path with a request body reflecting the operation arguments and a JSON response reflecting the return shape (query result rows, insert/upsert summaries, column descriptions).",
    "x-openfn-adaptor": "postgresql"
  },
  "servers": [
    { "url": "http://localhost:4010", "description": "Mock facade (Postgres has no HTTP API)" }
  ],
  "paths": {
    "/sql": {
      "post": {
        "operationId": "sql",
        "summary": "Execute a raw SQL statement",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/SqlRequest" } }
          }
        },
        "responses": {
          "200": {
            "description": "Query result",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/QueryResult" } }
            }
          }
        }
      }
    },
    "/find-value": {
      "post": {
        "operationId": "findValue",
        "summary": "Fetch a single value given a filter (SELECT ... WHERE ... LIMIT 1)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/FindValueRequest" } }
          }
        },
        "responses": {
          "200": {
            "description": "The matched value (or null)",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/FindValueResult" } }
            }
          }
        }
      }
    },
    "/tables/{table}/rows": {
      "parameters": [
        { "name": "table", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "post": {
        "operationId": "insert",
        "summary": "Insert a single record",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/RecordWrite" } }
          }
        },
        "responses": {
          "200": {
            "description": "Insert result",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/WriteResult" } }
            }
          }
        }
      },
      "put": {
        "operationId": "upsert",
        "summary": "Insert or update a record using ON CONFLICT (uuid) DO UPDATE",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/UpsertWrite" } }
          }
        },
        "responses": {
          "200": {
            "description": "Upsert result",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/WriteResult" } }
            }
          }
        }
      }
    },
    "/tables/{table}/rows/bulk": {
      "parameters": [
        { "name": "table", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "post": {
        "operationId": "insertMany",
        "summary": "Insert many records (columns templated from the first record)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/BulkRecordWrite" } }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk insert result",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/WriteResult" } }
            }
          }
        }
      },
      "put": {
        "operationId": "upsertMany",
        "summary": "Insert or update many records using ON CONFLICT (uuid) DO UPDATE",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/BulkUpsertWrite" } }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk upsert result",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/WriteResult" } }
            }
          }
        }
      }
    },
    "/tables/{table}/columns": {
      "parameters": [
        { "name": "table", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "get": {
        "operationId": "describeTable",
        "summary": "List the columns of a table",
        "responses": {
          "200": {
            "description": "Column descriptions",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ColumnList" } }
            }
          }
        }
      }
    },
    "/tables": {
      "post": {
        "operationId": "insertTable",
        "summary": "Create a table from an array of column definitions",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/TableDefinition" } }
          }
        },
        "responses": {
          "200": {
            "description": "Created table",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/TableResult" } }
            }
          }
        }
      }
    },
    "/tables/{table}": {
      "parameters": [
        { "name": "table", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "patch": {
        "operationId": "modifyTable",
        "summary": "Alter an existing table by adding columns",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/TableDefinition" } }
          }
        },
        "responses": {
          "200": {
            "description": "Altered table",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/TableResult" } }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SqlRequest": {
        "type": "object",
        "required": ["query"],
        "properties": {
          "query": { "type": "string", "example": "select * from users where id = 1" },
          "options": { "type": "object", "additionalProperties": true }
        }
      },
      "QueryResult": {
        "type": "object",
        "properties": {
          "command": { "type": "string", "example": "SELECT" },
          "rowCount": { "type": "integer" },
          "rows": {
            "type": "array",
            "items": { "type": "object", "additionalProperties": true }
          },
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "dataTypeID": { "type": "integer" }
              }
            }
          }
        }
      },
      "FindValueRequest": {
        "type": "object",
        "required": ["filter"],
        "properties": {
          "filter": {
            "type": "object",
            "properties": {
              "uuid": { "type": "string" },
              "relation": { "type": "string" },
              "where": { "type": "object", "additionalProperties": true }
            }
          }
        }
      },
      "FindValueResult": {
        "type": "object",
        "properties": {
          "value": { "nullable": true, "description": "The matched value, or null when no row matched" }
        }
      },
      "RecordWrite": {
        "type": "object",
        "required": ["record"],
        "properties": {
          "record": { "type": "object", "additionalProperties": true },
          "options": { "type": "object", "additionalProperties": true }
        }
      },
      "BulkRecordWrite": {
        "type": "object",
        "required": ["records"],
        "properties": {
          "records": {
            "type": "array",
            "items": { "type": "object", "additionalProperties": true }
          },
          "options": { "type": "object", "additionalProperties": true }
        }
      },
      "UpsertWrite": {
        "type": "object",
        "required": ["uuid", "record"],
        "properties": {
          "uuid": { "type": "string", "description": "Conflict-target column name" },
          "record": { "type": "object", "additionalProperties": true },
          "options": { "type": "object", "additionalProperties": true }
        }
      },
      "BulkUpsertWrite": {
        "type": "object",
        "required": ["uuid", "data"],
        "properties": {
          "uuid": { "type": "string" },
          "data": {
            "type": "array",
            "items": { "type": "object", "additionalProperties": true }
          },
          "options": { "type": "object", "additionalProperties": true }
        }
      },
      "WriteResult": {
        "type": "object",
        "properties": {
          "command": { "type": "string", "example": "INSERT" },
          "rowCount": { "type": "integer" },
          "rows": {
            "type": "array",
            "items": { "type": "object", "additionalProperties": true }
          }
        }
      },
      "Column": {
        "type": "object",
        "properties": {
          "column_name": { "type": "string" },
          "data_type": { "type": "string", "example": "character varying" },
          "is_nullable": { "type": "string", "example": "YES" },
          "column_default": { "type": "string", "nullable": true }
        }
      },
      "ColumnList": {
        "type": "object",
        "properties": {
          "rows": { "type": "array", "items": { "$ref": "#/components/schemas/Column" } }
        }
      },
      "TableDefinition": {
        "type": "object",
        "required": ["columns"],
        "properties": {
          "columns": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string", "example": "varchar(255)" },
                "required": { "type": "boolean" },
                "unique": { "type": "boolean" }
              }
            }
          },
          "options": { "type": "object", "additionalProperties": true }
        }
      },
      "TableResult": {
        "type": "object",
        "properties": {
          "command": { "type": "string", "example": "CREATE" },
          "table": { "type": "string" },
          "columns": { "type": "array", "items": { "$ref": "#/components/schemas/Column" } }
        }
      }
    }
  }
}
