{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openspp/Program",
  "title": "Program",
  "x-openfn-adaptor": "openspp",
  "x-source": {
    "openapi": "#/components/schemas/Program",
    "capturedAt": "2026-07-06"
  },
  "type": "object",
  "description": "A g2p.program social-protection program.",
  "properties": {
    "id": {
