{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openspp/ProgramMembership",
  "title": "ProgramMembership",
  "x-openfn-adaptor": "openspp",
  "x-source": {
    "openapi": "#/components/schemas/ProgramMembership",
    "capturedAt": "2026-07-06"
  },
  "type": "object",
  "description": "A g2p.program_membership enrollment record.",
  "properties": {
    "id": {
      "type": "integer"
    },
    "partner_id": {
      "description": "Registrant (many2one, [id, name])",
      "example": [
        42,
        "Jane Doe"
      ]
    },
    "program_id": {
      "description": "Program (many2one, [id, name])",
      "example": [
        3,
        "Cash Transfer 2023"
      ]
    },
    "state": {
      "type": "string",
      "enum": [
        "draft",
        "enrolled",
        "not_eligible",
        "paused",
        "exited"
      ],
      "example": "enrolled"
    }
  }
}
