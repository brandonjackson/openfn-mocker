{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openspp/Individual",
  "title": "Individual",
  "x-openfn-adaptor": "openspp",
  "x-source": {
    "openapi": "#/components/schemas/Individual",
    "capturedAt": "2026-07-06"
  },
  "type": "object",
  "description": "An individual registrant — res.partner with is_group=false, is_registrant=true.",
  "properties": {
    "id": {
      "type": "integer"
    },
    "spp_id": {
      "type": "string",
      "example": "IND_Q4VGGZPF"
    },
    "name": {
      "type": "string",
      "example": "Jane Doe"
    },
    "address": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "gender": {
      "type": "string",
      "example": "Female"
    },
    "birthdate": {
      "type": "string",
      "format": "date"
    },
    "category_id": {
      "description": "Category tags (many2many list of ids)",
      "type": "array",
      "items": {
        "type": "integer"
      }
    }
  },
  "required": [
    "name"
  ]
}
