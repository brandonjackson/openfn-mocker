{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openspp/ServicePoint",
  "title": "ServicePoint",
  "x-openfn-adaptor": "openspp",
  "x-source": {
    "openapi": "#/components/schemas/ServicePoint",
    "capturedAt": "2026-07-06"
  },
  "type": "object",
  "description": "A spp.service.point (agent/shop delivering services).",
  "properties": {
    "id": {
      "type": "integer"
    },
    "spp_id": {
      "type": "string",
      "example": "SVP_8P4KP4RT"
    },
    "name": {
      "type": "string"
    },
    "area_id": {
      "description": "Area (many2one, [id, name])",
      "example": [
        12,
        "Central District"
      ]
    },
    "service_type_ids": {
      "type": "array",
      "items": {
        "type": "integer"
      }
    },
    "phone_sanitized": {
      "type": "string"
    },
    "shop_address": {
      "type": "string"
    },
    "is_contract_active": {
      "type": "boolean"
    },
    "is_disabled": {
      "type": "boolean"
    }
  }
}
