{
  "openapi": "3.0.3",
  "info": {
    "title": "OpenSPP API (synthesized from adaptor surface)",
    "version": "1.0.0",
    "description": "REST-style projection of the OpenSPP operations exposed by the OpenFn openspp adaptor. OpenSPP is a social-protection platform built on Odoo; the adaptor talks to Odoo's external API through the odoo-await client (JSON-RPC: common.authenticate for login, then object.execute_kw for search_read/create/write on models). The paths below are a synthetic REST surface where each operation maps to an Odoo model call: Groups & Individuals -> res.partner (is_group true/false, is_registrant=true), group members -> g2p.group.membership, programs -> g2p.program, enrollment -> g2p.program_membership, service points -> spp.service.point, areas -> spp.area. Domains are Odoo search domains (arrays of [field, op, value] triples) and options carry limit/offset/order.",
    "x-openfn-adaptor": "openspp"
  },
  "servers": [{ "url": "http://localhost:4010" }],
  "paths": {
    "/groups/{spp_id}": {
      "get": {
        "operationId": "getGroup",
        "summary": "Get a group registrant by spp_id (res.partner where is_group=true)",
        "parameters": [
          { "name": "spp_id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "The spp_id of the group, e.g. GRP_Q4VGGZPF" }
        ],
        "responses": {
          "200": {
            "description": "Group record",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Group" } } }
          }
        }
      }
    },
    "/individuals/{spp_id}": {
      "get": {
        "operationId": "getIndividual",
        "summary": "Get an individual registrant by spp_id (res.partner where is_group=false)",
        "parameters": [
          { "name": "spp_id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "The spp_id of the individual, e.g. IND_Q4VGGZPF" }
        ],
        "responses": {
          "200": {
            "description": "Individual record",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Individual" } } }
          }
        }
      }
    },
    "/groups/{spp_id}/members": {
      "get": {
        "operationId": "getGroupMembers",
        "summary": "List members of a group (g2p.group.membership)",
        "parameters": [
          { "name": "spp_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 100 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } },
          { "name": "order", "in": "query", "schema": { "type": "string", "default": "id desc" } }
        ],
        "responses": {
          "200": {
            "description": "Group members",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/GroupMember" } } } }
          }
        }
      },
      "post": {
        "operationId": "addToGroup",
        "summary": "Add an individual to a group with a role/kind (g2p.group.membership)",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AddToGroupRequest" } } }
        },
        "responses": {
          "200": {
            "description": "Created or updated membership",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/GroupMember" } } }
          }
        }
      }
    },
    "/groups/{group_id}/members/{individual_id}": {
      "delete": {
        "operationId": "removeFromGroup",
        "summary": "Remove an individual from a group (ends the g2p.group.membership)",
        "parameters": [
          { "name": "group_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "individual_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Write result",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WriteResult" } } }
          }
        }
      }
    },
    "/groups/search": {
      "post": {
        "operationId": "searchGroup",
        "summary": "Search group registrants by Odoo domain (res.partner where is_group=true)",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SearchRequest" } } }
        },
        "responses": {
          "200": {
            "description": "Matching groups",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Group" } } } }
          }
        }
      }
    },
    "/individuals/search": {
      "post": {
        "operationId": "searchIndividual",
        "summary": "Search individual registrants by Odoo domain (res.partner where is_group=false)",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SearchRequest" } } }
        },
        "responses": {
          "200": {
            "description": "Matching individuals",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Individual" } } } }
          }
        }
      }
    },
    "/individuals": {
      "post": {
        "operationId": "createIndividual",
        "summary": "Create a new individual registrant (res.partner create)",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Individual" } } }
        },
        "responses": {
          "200": {
            "description": "spp_id of the created individual",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateResult" } } }
          }
        }
      }
    },
    "/groups": {
      "get": {
        "operationId": "listGroups",
        "summary": "List group registrants (res.partner where is_group=true)",
        "parameters": [
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 100 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } }
        ],
        "responses": {
          "200": {
            "description": "Groups",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Group" } } } }
          }
        }
      },
      "post": {
        "operationId": "createGroup",
        "summary": "Create a new group registrant (res.partner create)",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Group" } } }
        },
        "responses": {
          "200": {
            "description": "spp_id of the created group",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateResult" } } }
          }
        }
      }
    },
    "/groups/{group_id}": {
      "patch": {
        "operationId": "updateGroup",
        "summary": "Update a group registrant (res.partner write)",
        "parameters": [
          { "name": "group_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Group" } } }
        },
        "responses": {
          "200": {
            "description": "Write result",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WriteResult" } } }
          }
        }
      }
    },
    "/individuals/{individual_id}": {
      "patch": {
        "operationId": "updateIndividual",
        "summary": "Update an individual registrant (res.partner write)",
        "parameters": [
          { "name": "individual_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Individual" } } }
        },
        "responses": {
          "200": {
            "description": "Write result",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WriteResult" } } }
          }
        }
      }
    },
    "/programs": {
      "get": {
        "operationId": "getPrograms",
        "summary": "List programs (g2p.program)",
        "parameters": [
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 100 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } },
          { "name": "order", "in": "query", "schema": { "type": "string", "default": "id desc" } }
        ],
        "responses": {
          "200": {
            "description": "Programs",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Program" } } } }
          }
        }
      }
    },
    "/programs/{program_id}": {
      "get": {
        "operationId": "getProgram",
        "summary": "Get a program by program_id (g2p.program)",
        "parameters": [
          { "name": "program_id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "e.g. PROG_2023_00000001" }
        ],
        "responses": {
          "200": {
            "description": "Program record",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Program" } } }
          }
        }
      }
    },
    "/registrants/{spp_id}/programs": {
      "get": {
        "operationId": "getEnrolledPrograms",
        "summary": "List programs a registrant is enrolled in (g2p.program_membership -> g2p.program)",
        "parameters": [
          { "name": "spp_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Enrolled programs",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Program" } } } }
          }
        }
      }
    },
    "/registrants/{spp_id}/programs/{program_id}/enroll": {
      "post": {
        "operationId": "enroll",
        "summary": "Enroll a registrant into a program (g2p.program_membership state=enrolled)",
        "parameters": [
          { "name": "spp_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "program_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Program membership",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProgramMembership" } } }
          }
        }
      }
    },
    "/registrants/{spp_id}/programs/{program_id}/unenroll": {
      "post": {
        "operationId": "unenroll",
        "summary": "Unenroll a registrant from a program (g2p.program_membership state=not_eligible)",
        "parameters": [
          { "name": "spp_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "program_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Program membership",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProgramMembership" } } }
          }
        }
      }
    },
    "/service-points/{spp_id}": {
      "get": {
        "operationId": "getServicePoint",
        "summary": "Get service point(s) by spp_id (spp.service.point)",
        "parameters": [
          { "name": "spp_id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "e.g. SVP_8P4KP4RT" }
        ],
        "responses": {
          "200": {
            "description": "Service points",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/ServicePoint" } } } }
          }
        }
      }
    },
    "/service-points/search": {
      "post": {
        "operationId": "searchServicePoint",
        "summary": "Search service points by Odoo domain (spp.service.point)",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SearchRequest" } } }
        },
        "responses": {
          "200": {
            "description": "Matching service points",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/ServicePoint" } } } }
          }
        }
      }
    },
    "/areas/{spp_id}": {
      "get": {
        "operationId": "getArea",
        "summary": "Get area by spp_id (spp.area)",
        "parameters": [
          { "name": "spp_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Area record(s)",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Area" } } } }
          }
        }
      }
    },
    "/areas/search": {
      "post": {
        "operationId": "searchArea",
        "summary": "Search areas by Odoo domain (spp.area)",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SearchRequest" } } }
        },
        "responses": {
          "200": {
            "description": "Matching areas",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Area" } } } }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Group": {
        "type": "object",
        "description": "A group registrant (household/family) — res.partner with is_group=true, is_registrant=true.",
        "properties": {
          "id": { "type": "integer", "description": "Odoo database id" },
          "spp_id": { "type": "string", "example": "GRP_Q4VGGZPF" },
          "name": { "type": "string", "example": "Doe Household" },
          "address": { "type": "string" },
          "phone": { "type": "string" },
          "kind": { "description": "Group kind (many2one, [id, name])", "example": [1, "Household"], "nullable": true },
          "registration_date": { "type": "string", "format": "date" }
        },
        "required": ["name"]
      },
      "Individual": {
        "type": "object",
        "description": "An individual registrant — res.partner with is_group=false, is_registrant=true.",
        "properties": {
          "id": { "type": "integer" },
          "spp_id": { "type": "string", "example": "IND_Q4VGGZPF" },
          "name": { "type": "string", "example": "Jane Doe" },
          "address": { "type": "string" },
          "phone": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "gender": { "type": "string", "example": "Female" },
          "birthdate": { "type": "string", "format": "date" },
          "category_id": { "description": "Category tags (many2many list of ids)", "type": "array", "items": { "type": "integer" } }
        },
        "required": ["name"]
      },
      "GroupMember": {
        "type": "object",
        "description": "A g2p.group.membership record linking an individual to a group.",
        "properties": {
          "id": { "type": "integer" },
          "individual": { "description": "Linked individual (many2one, [id, name])", "example": [42, "Jane Doe"] },
          "group": { "description": "Linked group (many2one, [id, name])", "example": [7, "Doe Household"] },
          "kind": { "description": "Membership roles (many2many)", "type": "array", "items": { "type": "string" }, "example": ["Head"] },
          "start_date": { "type": "string", "format": "date" },
          "ended_date": { "type": "string", "format": "date", "nullable": true },
          "is_ended": { "type": "boolean" },
          "individual_birthdate": { "type": "string", "format": "date" },
          "individual_gender": { "type": "string" }
        }
      },
      "Program": {
        "type": "object",
        "description": "A g2p.program social-protection program.",
        "properties": {
          "id": { "type": "integer" },
          "program_id": { "type": "string", "example": "PROG_2023_00000001" },
          "name": { "type": "string", "example": "Cash Transfer 2023" },
          "eligible_beneficiaries_count": { "type": "integer" },
          "cycles_count": { "type": "integer" },
          "state": { "type": "string", "example": "active" },
          "target_type": { "type": "string", "example": "group" }
        }
      },
      "ProgramMembership": {
        "type": "object",
        "description": "A g2p.program_membership enrollment record.",
        "properties": {
          "id": { "type": "integer" },
          "partner_id": { "description": "Registrant (many2one, [id, name])", "example": [42, "Jane Doe"] },
          "program_id": { "description": "Program (many2one, [id, name])", "example": [3, "Cash Transfer 2023"] },
          "state": { "type": "string", "enum": ["draft", "enrolled", "not_eligible", "paused", "exited"], "example": "enrolled" }
        }
      },
      "ServicePoint": {
        "type": "object",
        "description": "A spp.service.point (agent/shop delivering services).",
        "properties": {
          "id": { "type": "integer" },
          "spp_id": { "type": "string", "example": "SVP_8P4KP4RT" },
          "name": { "type": "string" },
          "area_id": { "description": "Area (many2one, [id, name])", "example": [12, "Central District"] },
          "service_type_ids": { "type": "array", "items": { "type": "integer" } },
          "phone_sanitized": { "type": "string" },
          "shop_address": { "type": "string" },
          "is_contract_active": { "type": "boolean" },
          "is_disabled": { "type": "boolean" }
        }
      },
      "Area": {
        "type": "object",
        "description": "A spp.area administrative area.",
        "properties": {
          "id": { "type": "integer" },
          "parent_id": { "description": "Parent area (many2one, [id, name])", "example": [1, "Country"], "nullable": true },
          "name": { "type": "string", "example": "Central District" },
          "code": { "type": "string" },
          "altnames": { "type": "string" },
          "area_level": { "type": "integer" },
          "kind": { "description": "Area kind (many2one, [id, name])", "example": [2, "District"] }
        }
      },
      "SearchRequest": {
        "type": "object",
        "description": "Odoo search-read request: a search domain plus optional paging/order options.",
        "properties": {
          "domain": {
            "type": "array",
            "description": "Odoo search domain — list of [field, operator, value] triples (and optional '|','&','!' logical operators).",
            "items": {},
            "example": [["spp_id", "ilike", "GRP"]]
          },
          "options": {
            "type": "object",
            "properties": {
              "limit": { "type": "integer", "default": 100 },
              "offset": { "type": "integer", "default": 0 },
              "order": { "type": "string", "default": "id desc" }
            }
          }
        },
        "required": ["domain"]
      },
      "AddToGroupRequest": {
        "type": "object",
        "properties": {
          "individual_id": { "type": "string", "example": "IND_Q4VGGZPF" },
          "role": { "type": "string", "description": "Membership kind/role name", "example": "Head" }
        },
        "required": ["individual_id"]
      },
      "CreateResult": {
        "type": "object",
        "description": "Result of a create — the new registrant's spp_id.",
        "properties": {
          "spp_id": { "type": "string", "example": "IND_Q4VGGZPF" }
        }
      },
      "WriteResult": {
        "type": "object",
        "description": "Result of an Odoo write/unlink call.",
        "properties": {
          "success": { "type": "boolean", "example": true }
        }
      }
    }
  }
}
