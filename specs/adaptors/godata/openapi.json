{
  "openapi": "3.0.3",
  "info": {
    "title": "Go.Data API (mock subset)",
    "version": "2.x",
    "description": "Focused subset of the WHO Go.Data outbreak-investigation API used by the OpenFn godata adaptor: outbreaks, and per-outbreak contacts and cases, plus locations and reference-data. Go.Data is a LoopBack application; list endpoints return JSON arrays and accept a stringified LoopBack `filter`. Authored from the adaptor surface and the official Go.Data API documentation.",
    "x-openfn-adaptor": "godata"
  },
  "servers": [{ "url": "http://localhost:3000/api" }],
  "paths": {
    "/outbreaks": {
      "get": {
        "operationId": "listOutbreaks",
        "summary": "List / filter outbreaks",
        "parameters": [
          { "name": "filter", "in": "query", "schema": { "type": "string" }, "description": "Stringified LoopBack filter, e.g. {\"where\":{\"id\":\"...\"}}" },
          { "name": "access_token", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Array of outbreaks",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Outbreak" } }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createOutbreak",
        "summary": "Create an outbreak",
        "parameters": [{ "name": "access_token", "in": "query", "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Outbreak" } } }
        },
        "responses": {
          "200": {
            "description": "The created outbreak",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Outbreak" } } }
          }
        }
      }
    },
    "/outbreaks/{id}": {
      "put": {
        "operationId": "updateOutbreak",
        "summary": "Update an outbreak",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "access_token", "in": "query", "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Outbreak" } } }
        },
        "responses": {
          "200": {
            "description": "The updated outbreak",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Outbreak" } } }
          }
        }
      }
    },
    "/outbreaks/{outbreakId}/contacts": {
      "get": {
        "operationId": "listContacts",
        "summary": "List / filter contacts for an outbreak",
        "parameters": [
          { "name": "outbreakId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "filter", "in": "query", "schema": { "type": "string" } },
          { "name": "access_token", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Array of contacts",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Contact" } }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createContact",
        "summary": "Create a contact in an outbreak",
        "parameters": [
          { "name": "outbreakId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "access_token", "in": "query", "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Contact" } } }
        },
        "responses": {
          "200": {
            "description": "The created contact",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Contact" } } }
          }
        }
      }
    },
    "/outbreaks/{outbreakId}/contacts/{contactId}": {
      "put": {
        "operationId": "updateContact",
        "summary": "Update a contact",
        "parameters": [
          { "name": "outbreakId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "contactId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "access_token", "in": "query", "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Contact" } } }
        },
        "responses": {
          "200": {
            "description": "The updated contact",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Contact" } } }
          }
        }
      }
    },
    "/outbreaks/{outbreakId}/cases": {
      "get": {
        "operationId": "listCases",
        "summary": "List / filter cases for an outbreak",
        "parameters": [
          { "name": "outbreakId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "filter", "in": "query", "schema": { "type": "string" } },
          { "name": "access_token", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Array of cases",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Case" } }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createCase",
        "summary": "Create a case in an outbreak",
        "parameters": [
          { "name": "outbreakId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "access_token", "in": "query", "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Case" } } }
        },
        "responses": {
          "200": {
            "description": "The created case",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Case" } } }
          }
        }
      }
    },
    "/outbreaks/{outbreakId}/cases/{caseId}": {
      "put": {
        "operationId": "updateCase",
        "summary": "Update a case",
        "parameters": [
          { "name": "outbreakId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "caseId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "access_token", "in": "query", "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Case" } } }
        },
        "responses": {
          "200": {
            "description": "The updated case",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Case" } } }
          }
        }
      }
    },
    "/locations": {
      "get": {
        "operationId": "listLocations",
        "summary": "List / filter locations",
        "parameters": [
          { "name": "filter", "in": "query", "schema": { "type": "string" } },
          { "name": "access_token", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Array of locations",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Location" } }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createLocation",
        "summary": "Create a location",
        "parameters": [{ "name": "access_token", "in": "query", "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Location" } } }
        },
        "responses": {
          "200": {
            "description": "The created location",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Location" } } }
          }
        }
      }
    },
    "/locations/{id}": {
      "put": {
        "operationId": "updateLocation",
        "summary": "Update a location",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "access_token", "in": "query", "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Location" } } }
        },
        "responses": {
          "200": {
            "description": "The updated location",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Location" } } }
          }
        }
      }
    },
    "/reference-data": {
      "get": {
        "operationId": "listReferenceData",
        "summary": "List / filter reference data",
        "parameters": [
          { "name": "filter", "in": "query", "schema": { "type": "string" } },
          { "name": "access_token", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Array of reference-data entries",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/ReferenceData" } }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createReferenceData",
        "summary": "Create a reference-data entry",
        "parameters": [{ "name": "access_token", "in": "query", "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ReferenceData" } } }
        },
        "responses": {
          "200": {
            "description": "The created reference-data entry",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ReferenceData" } } }
          }
        }
      }
    },
    "/reference-data/{id}": {
      "put": {
        "operationId": "updateReferenceData",
        "summary": "Update a reference-data entry",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "access_token", "in": "query", "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ReferenceData" } } }
        },
        "responses": {
          "200": {
            "description": "The updated reference-data entry",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ReferenceData" } } }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Outbreak": {
        "type": "object",
        "description": "A Go.Data outbreak.",
        "properties": {
          "id": { "type": "string", "example": "3b5554d7-2c19-41d0-b9af-475ad25a382b" },
          "name": { "type": "string", "example": "Ebola outbreak 2024" },
          "description": { "type": "string" },
          "disease": { "type": "string", "example": "Ebola virus disease" },
          "countries": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": { "id": { "type": "string", "example": "GHA" } }
            }
          },
          "startDate": { "type": "string", "format": "date-time", "example": "2024-01-01T00:00:00.000Z" },
          "endDate": { "type": "string", "format": "date-time", "nullable": true },
          "active": { "type": "boolean", "example": true },
          "reportingGeographicalLevelId": { "type": "string", "example": "LNG_REFERENCE_DATA_CATEGORY_LOCATION_GEOGRAPHICAL_LEVEL_ADMIN_LEVEL_1" },
          "caseIdMask": { "type": "string", "example": "*" },
          "contactIdMask": { "type": "string", "example": "*" },
          "periodOfFollowup": { "type": "integer", "example": 21 },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" },
          "deleted": { "type": "boolean", "example": false }
        }
      },
      "Contact": {
        "type": "object",
        "description": "A Go.Data contact (person exposed to a case).",
        "properties": {
          "id": { "type": "string", "example": "6f9c1a2b-3d4e-5f60-7890-abcdef123456" },
          "firstName": { "type": "string", "example": "Ama" },
          "middleName": { "type": "string" },
          "lastName": { "type": "string", "example": "Mensah" },
          "gender": { "type": "string", "example": "LNG_REFERENCE_DATA_CATEGORY_GENDER_FEMALE" },
          "dob": { "type": "string", "format": "date", "nullable": true, "example": "1990-05-12" },
          "age": {
            "type": "object",
            "properties": { "years": { "type": "integer", "example": 34 }, "months": { "type": "integer", "example": 0 } }
          },
          "riskLevel": { "type": "string", "example": "LNG_REFERENCE_DATA_CATEGORY_RISK_LEVEL_2_MEDIUM" },
          "dateOfReporting": { "type": "string", "format": "date-time", "example": "2024-02-01T00:00:00.000Z" },
          "visualId": { "type": "string", "example": "CONTACT-0001" },
          "addresses": { "type": "array", "items": { "$ref": "#/components/schemas/Address" } },
          "documents": { "type": "array", "items": { "$ref": "#/components/schemas/Document" } },
          "outbreakId": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" },
          "deleted": { "type": "boolean", "example": false }
        }
      },
      "Case": {
        "type": "object",
        "description": "A Go.Data case.",
        "properties": {
          "id": { "type": "string", "example": "a1b2c3d4-e5f6-7890-1234-567890abcdef" },
          "firstName": { "type": "string", "example": "Kwame" },
          "middleName": { "type": "string" },
          "lastName": { "type": "string", "example": "Owusu" },
          "gender": { "type": "string", "example": "LNG_REFERENCE_DATA_CATEGORY_GENDER_MALE" },
          "dob": { "type": "string", "format": "date", "nullable": true },
          "age": {
            "type": "object",
            "properties": { "years": { "type": "integer", "example": 42 }, "months": { "type": "integer", "example": 0 } }
          },
          "classification": { "type": "string", "example": "LNG_REFERENCE_DATA_CATEGORY_CASE_CLASSIFICATION_CONFIRMED" },
          "dateOfReporting": { "type": "string", "format": "date-time", "example": "2024-01-15T00:00:00.000Z" },
          "dateOfOnset": { "type": "string", "format": "date-time", "example": "2024-01-10T00:00:00.000Z" },
          "outcomeId": { "type": "string", "example": "LNG_REFERENCE_DATA_CATEGORY_OUTCOME_ALIVE" },
          "visualId": { "type": "string", "example": "CASE-0001" },
          "addresses": { "type": "array", "items": { "$ref": "#/components/schemas/Address" } },
          "documents": { "type": "array", "items": { "$ref": "#/components/schemas/Document" } },
          "outbreakId": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" },
          "deleted": { "type": "boolean", "example": false }
        }
      },
      "Location": {
        "type": "object",
        "description": "A Go.Data location (administrative area).",
        "properties": {
          "id": { "type": "string", "example": "loc-ghana-greater-accra" },
          "name": { "type": "string", "example": "Greater Accra" },
          "synonyms": { "type": "array", "items": { "type": "string" } },
          "identifiers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": { "code": { "type": "string" }, "description": { "type": "string" } }
            }
          },
          "active": { "type": "boolean", "example": true },
          "populationDensity": { "type": "integer", "nullable": true },
          "geoLocation": {
            "type": "object",
            "properties": {
              "lat": { "type": "number", "format": "double", "example": 5.6037 },
              "lng": { "type": "number", "format": "double", "example": -0.187 }
            }
          },
          "geographicalLevelId": { "type": "string", "example": "LNG_REFERENCE_DATA_CATEGORY_LOCATION_GEOGRAPHICAL_LEVEL_ADMIN_LEVEL_1" },
          "parentLocationId": { "type": "string", "nullable": true, "example": "loc-ghana" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" },
          "deleted": { "type": "boolean", "example": false }
        }
      },
      "ReferenceData": {
        "type": "object",
        "description": "A Go.Data reference-data entry (categorized lookup value).",
        "properties": {
          "id": { "type": "string", "example": "LNG_REFERENCE_DATA_CATEGORY_GENDER_FEMALE" },
          "categoryId": { "type": "string", "example": "LNG_REFERENCE_DATA_CATEGORY_GENDER" },
          "value": { "type": "string", "example": "LNG_REFERENCE_DATA_CATEGORY_GENDER_FEMALE" },
          "description": { "type": "string", "example": "LNG_REFERENCE_DATA_CATEGORY_GENDER_FEMALE_DESCRIPTION" },
          "readOnly": { "type": "boolean", "example": false },
          "active": { "type": "boolean", "example": true },
          "colorCode": { "type": "string", "example": "#e91e63" },
          "order": { "type": "integer", "nullable": true, "example": 1 },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" },
          "deleted": { "type": "boolean", "example": false }
        }
      },
      "Address": {
        "type": "object",
        "properties": {
          "typeId": { "type": "string", "example": "LNG_REFERENCE_DATA_CATEGORY_ADDRESS_TYPE_USUAL_PLACE_OF_RESIDENCE" },
          "country": { "type": "string", "example": "Ghana" },
          "city": { "type": "string", "example": "Accra" },
          "addressLine1": { "type": "string" },
          "postalCode": { "type": "string" },
          "locationId": { "type": "string", "example": "loc-ghana-greater-accra" },
          "phoneNumber": { "type": "string" }
        }
      },
      "Document": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "example": "LNG_REFERENCE_DATA_CATEGORY_DOCUMENT_TYPE_PASSPORT" },
          "number": { "type": "string", "example": "G1234567" }
        }
      }
    }
  }
}
