{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "godata/Outbreak",
  "title": "Outbreak",
  "x-openfn-adaptor": "godata",
  "x-source": {
    "openapi": "#/components/schemas/Outbreak",
    "capturedAt": "2026-07-06"
  },
  "type": "object",
  "description": "A Go.Data outbreak.",
  "properties": {
    "id": {
      "type": "string",
      "example": "3b5554d7-2c19-41d0-b9af-475ad25a382b"
    },
    "name": {
      "type": "string",
      "example": "Ebola outbreak 2024"
    },
    "description": {
      "type": "string"
    },
    "disease": {
      "type": "string",
      "example": "Ebola virus disease"
    },
    "countries": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "GHA"
          }
        }
      }
    },
    "startDate": {
      "type": "string",
      "format": "date-time",
      "example": "2024-01-01T00:00:00.000Z"
    },
    "endDate": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "active": {
      "type": "boolean",
      "example": true
    },
    "reportingGeographicalLevelId": {
      "type": "string",
      "example": "LNG_REFERENCE_DATA_CATEGORY_LOCATION_GEOGRAPHICAL_LEVEL_ADMIN_LEVEL_1"
    },
    "caseIdMask": {
      "type": "string",
      "example": "*"
    },
    "contactIdMask": {
      "type": "string",
      "example": "*"
    },
    "periodOfFollowup": {
      "type": "integer",
      "example": 21
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "deleted": {
      "type": "boolean",
      "example": false
    }
  }
}
