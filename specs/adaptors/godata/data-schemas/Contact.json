{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "godata/Contact",
  "title": "Contact",
  "x-openfn-adaptor": "godata",
  "x-source": {
    "openapi": "#/components/schemas/Contact",
    "capturedAt": "2026-07-06"
  },
  "type": "object",
  "description": "A Go.Data contact (person exposed to a case).",
  "properties": {
    "id": {
      "type": "string",
      "example": "6f9c1a2b-3d4e-5f60-7890-abcdef123456"
    },
    "firstName": {
      "type": "string",
      "example": "Ama"
    },
    "middleName": {
      "type": "string"
    },
    "lastName": {
      "type": "string",
      "example": "Mensah"
    },
    "gender": {
      "type": "string",
      "example": "LNG_REFERENCE_DATA_CATEGORY_GENDER_FEMALE"
    },
    "dob": {
      "type": [
        "string",
        "null"
      ],
      "format": "date",
      "example": "1990-05-12"
    },
    "age": {
      "type": "object",
      "properties": {
        "years": {
          "type": "integer",
          "example": 34
        },
        "months": {
          "type": "integer",
          "example": 0
        }
      }
    },
    "riskLevel": {
      "type": "string",
      "example": "LNG_REFERENCE_DATA_CATEGORY_RISK_LEVEL_2_MEDIUM"
    },
    "dateOfReporting": {
      "type": "string",
      "format": "date-time",
      "example": "2024-02-01T00:00:00.000Z"
    },
    "visualId": {
      "type": "string",
      "example": "CONTACT-0001"
    },
    "addresses": {
      "type": "array",
      "items": {
        "$ref": "Address.json"
      }
    },
    "documents": {
      "type": "array",
      "items": {
        "$ref": "Document.json"
      }
    },
    "outbreakId": {
      "type": "string"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "deleted": {
      "type": "boolean",
      "example": false
    }
  }
}
