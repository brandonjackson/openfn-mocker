{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "godata/Location",
  "title": "Location",
  "x-openfn-adaptor": "godata",
  "x-source": {
    "openapi": "#/components/schemas/Location",
    "capturedAt": "2026-07-06"
  },
  "type": "object",
  "description": "A Go.Data location (administrative area).",
  "properties": {
    "id": {
      "type": "string",
      "example": "loc-ghana-greater-accra"
    },
    "name": {
      "type": "string",
      "example": "Greater Accra"
    },
    "synonyms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "identifiers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "active": {
      "type": "boolean",
      "example": true
    },
    "populationDensity": {
      "type": [
        "integer",
        "null"
      ]
    },
    "geoLocation": {
      "type": "object",
      "properties": {
        "lat": {
          "type": "number",
          "format": "double",
          "example": 5.6037
        },
        "lng": {
          "type": "number",
          "format": "double",
          "example": -0.187
        }
      }
    },
    "geographicalLevelId": {
      "type": "string",
      "example": "LNG_REFERENCE_DATA_CATEGORY_LOCATION_GEOGRAPHICAL_LEVEL_ADMIN_LEVEL_1"
    },
    "parentLocationId": {
      "type": [
        "string",
        "null"
      ],
      "example": "loc-ghana"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "deleted": {
      "type": "boolean",
      "example": false
    }
  }
}
