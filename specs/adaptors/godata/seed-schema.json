{
  "openapi": "3.0.3",
  "info": {
    "title": "godata — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate godata. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "godata",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "cases": {
        "resource": "Case",
        "schema": {
          "$ref": "#/components/schemas/Case"
        }
      },
      "contacts": {
        "resource": "Contact",
        "schema": {
          "$ref": "#/components/schemas/Contact"
        }
      },
      "locations": {
        "resource": "Location",
        "schema": {
          "$ref": "#/components/schemas/Location"
        }
      },
      "outbreaks": {
        "resource": "Outbreak",
        "schema": {
          "$ref": "#/components/schemas/Outbreak"
        }
      },
      "referenceDatas": {
        "resource": "ReferenceData",
        "schema": {
          "$ref": "#/components/schemas/ReferenceData"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "cases": {
            "type": "object",
            "description": "Records keyed by id for the cases collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Case"
            }
          },
          "contacts": {
            "type": "object",
            "description": "Records keyed by id for the contacts collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Contact"
            }
          },
          "locations": {
            "type": "object",
            "description": "Records keyed by id for the locations collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Location"
            }
          },
          "outbreaks": {
            "type": "object",
            "description": "Records keyed by id for the outbreaks collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Outbreak"
            }
          },
          "referenceDatas": {
            "type": "object",
            "description": "Records keyed by id for the referenceDatas collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/ReferenceData"
            }
          }
        },
        "additionalProperties": false
      },
      "Outbreak": {
        "type": "object",
        "description": "A Go.Data outbreak.",
        "properties": {
          "id": {
            "type": "string",
            "example": "3b5554d7-2c19-41d0-b9af-475ad25a382b"
          },
          "name": {
            "type": "string",
            "example": "Ebola outbreak 2024"
          },
          "description": {
            "type": "string"
          },
          "disease": {
            "type": "string",
            "example": "Ebola virus disease"
          },
          "countries": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "example": "GHA"
                }
              }
            }
          },
          "startDate": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T00:00:00.000Z"
          },
          "endDate": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "active": {
            "type": "boolean",
            "example": true
          },
          "reportingGeographicalLevelId": {
            "type": "string",
            "example": "LNG_REFERENCE_DATA_CATEGORY_LOCATION_GEOGRAPHICAL_LEVEL_ADMIN_LEVEL_1"
          },
          "caseIdMask": {
            "type": "string",
            "example": "*"
          },
          "contactIdMask": {
            "type": "string",
            "example": "*"
          },
          "periodOfFollowup": {
            "type": "integer",
            "example": 21
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "deleted": {
            "type": "boolean",
            "example": false
          }
        }
      },
      "Contact": {
        "type": "object",
        "description": "A Go.Data contact (person exposed to a case).",
        "properties": {
          "id": {
            "type": "string",
            "example": "6f9c1a2b-3d4e-5f60-7890-abcdef123456"
          },
          "firstName": {
            "type": "string",
            "example": "Ama"
          },
          "middleName": {
            "type": "string"
          },
          "lastName": {
            "type": "string",
            "example": "Mensah"
          },
          "gender": {
            "type": "string",
            "example": "LNG_REFERENCE_DATA_CATEGORY_GENDER_FEMALE"
          },
          "dob": {
            "type": "string",
            "format": "date",
            "nullable": true,
            "example": "1990-05-12"
          },
          "age": {
            "type": "object",
            "properties": {
              "years": {
                "type": "integer",
                "example": 34
              },
              "months": {
                "type": "integer",
                "example": 0
              }
            }
          },
          "riskLevel": {
            "type": "string",
            "example": "LNG_REFERENCE_DATA_CATEGORY_RISK_LEVEL_2_MEDIUM"
          },
          "dateOfReporting": {
            "type": "string",
            "format": "date-time",
            "example": "2024-02-01T00:00:00.000Z"
          },
          "visualId": {
            "type": "string",
            "example": "CONTACT-0001"
          },
          "addresses": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Address"
            }
          },
          "documents": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Document"
            }
          },
          "outbreakId": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "deleted": {
            "type": "boolean",
            "example": false
          }
        }
      },
      "Case": {
        "type": "object",
        "description": "A Go.Data case.",
        "properties": {
          "id": {
            "type": "string",
            "example": "a1b2c3d4-e5f6-7890-1234-567890abcdef"
          },
          "firstName": {
            "type": "string",
            "example": "Kwame"
          },
          "middleName": {
            "type": "string"
          },
          "lastName": {
            "type": "string",
            "example": "Owusu"
          },
          "gender": {
            "type": "string",
            "example": "LNG_REFERENCE_DATA_CATEGORY_GENDER_MALE"
          },
          "dob": {
            "type": "string",
            "format": "date",
            "nullable": true
          },
          "age": {
            "type": "object",
            "properties": {
              "years": {
                "type": "integer",
                "example": 42
              },
              "months": {
                "type": "integer",
                "example": 0
              }
            }
          },
          "classification": {
            "type": "string",
            "example": "LNG_REFERENCE_DATA_CATEGORY_CASE_CLASSIFICATION_CONFIRMED"
          },
          "dateOfReporting": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-15T00:00:00.000Z"
          },
          "dateOfOnset": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-10T00:00:00.000Z"
          },
          "outcomeId": {
            "type": "string",
            "example": "LNG_REFERENCE_DATA_CATEGORY_OUTCOME_ALIVE"
          },
          "visualId": {
            "type": "string",
            "example": "CASE-0001"
          },
          "addresses": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Address"
            }
          },
          "documents": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Document"
            }
          },
          "outbreakId": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "deleted": {
            "type": "boolean",
            "example": false
          }
        }
      },
      "Location": {
        "type": "object",
        "description": "A Go.Data location (administrative area).",
        "properties": {
          "id": {
            "type": "string",
            "example": "loc-ghana-greater-accra"
          },
          "name": {
            "type": "string",
            "example": "Greater Accra"
          },
          "synonyms": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "identifiers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                }
              }
            }
          },
          "active": {
            "type": "boolean",
            "example": true
          },
          "populationDensity": {
            "type": "integer",
            "nullable": true
          },
          "geoLocation": {
            "type": "object",
            "properties": {
              "lat": {
                "type": "number",
                "format": "double",
                "example": 5.6037
              },
              "lng": {
                "type": "number",
                "format": "double",
                "example": -0.187
              }
            }
          },
          "geographicalLevelId": {
            "type": "string",
            "example": "LNG_REFERENCE_DATA_CATEGORY_LOCATION_GEOGRAPHICAL_LEVEL_ADMIN_LEVEL_1"
          },
          "parentLocationId": {
            "type": "string",
            "nullable": true,
            "example": "loc-ghana"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "deleted": {
            "type": "boolean",
            "example": false
          }
        }
      },
      "ReferenceData": {
        "type": "object",
        "description": "A Go.Data reference-data entry (categorized lookup value).",
        "properties": {
          "id": {
            "type": "string",
            "example": "LNG_REFERENCE_DATA_CATEGORY_GENDER_FEMALE"
          },
          "categoryId": {
            "type": "string",
            "example": "LNG_REFERENCE_DATA_CATEGORY_GENDER"
          },
          "value": {
            "type": "string",
            "example": "LNG_REFERENCE_DATA_CATEGORY_GENDER_FEMALE"
          },
          "description": {
            "type": "string",
            "example": "LNG_REFERENCE_DATA_CATEGORY_GENDER_FEMALE_DESCRIPTION"
          },
          "readOnly": {
            "type": "boolean",
            "example": false
          },
          "active": {
            "type": "boolean",
            "example": true
          },
          "colorCode": {
            "type": "string",
            "example": "#e91e63"
          },
          "order": {
            "type": "integer",
            "nullable": true,
            "example": 1
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "deleted": {
            "type": "boolean",
            "example": false
          }
        }
      },
      "Address": {
        "type": "object",
        "properties": {
          "typeId": {
            "type": "string",
            "example": "LNG_REFERENCE_DATA_CATEGORY_ADDRESS_TYPE_USUAL_PLACE_OF_RESIDENCE"
          },
          "country": {
            "type": "string",
            "example": "Ghana"
          },
          "city": {
            "type": "string",
            "example": "Accra"
          },
          "addressLine1": {
            "type": "string"
          },
          "postalCode": {
            "type": "string"
          },
          "locationId": {
            "type": "string",
            "example": "loc-ghana-greater-accra"
          },
          "phoneNumber": {
            "type": "string"
          }
        }
      },
      "Document": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "example": "LNG_REFERENCE_DATA_CATEGORY_DOCUMENT_TYPE_PASSPORT"
          },
          "number": {
            "type": "string",
            "example": "G1234567"
          }
        }
      }
    }
  }
}
