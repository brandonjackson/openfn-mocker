  "components": {
    "schemas": {
      "GenericResponse": {
        "type": "object",
        "description": "Arbitrary JSON payload for the generic request/get/post passthrough operations.",
        "additionalProperties": true,
        "properties": {
          "data": { "type": "object", "additionalProperties": true }
        }
      },
      "Project": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "c1f2e3d4-0001-4a2b-9c3d-000000000001" },
          "name": { "type": "string", "example": "Malaria Reporting" },
          "description": { "type": "string", "example": "Aggregate malaria case data" },
          "inserted_at": { "type": "string", "format": "date-time", "example": "2026-01-15T09:00:00Z" },
          "updated_at": { "type": "string", "format": "date-time", "example": "2026-06-01T12:30:00Z" }
        }
      },
      "ProjectList": {
        "type": "object",
        "properties": {
          "projects": { "type": "array", "items": { "$ref": "#/components/schemas/Project" } }
        }
      },
      "Workflow": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "a2b3c4d5-0002-4a2b-9c3d-000000000002" },
          "name": { "type": "string", "example": "Sync patients to DHIS2" },
          "project_id": { "type": "string", "example": "c1f2e3d4-0001-4a2b-9c3d-000000000001" },
          "inserted_at": { "type": "string", "format": "date-time", "example": "2026-01-15T09:05:00Z" }
        }
      },
      "WorkflowList": {
        "type": "object",
        "properties": {
          "workflows": { "type": "array", "items": { "$ref": "#/components/schemas/Workflow" } }
        }
      },
      "Job": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "b3c4d5e6-0003-4a2b-9c3d-000000000003" },
          "name": { "type": "string", "example": "test job" },
          "body": { "type": "string", "example": "fn(state => state)" },
          "adaptor": { "type": "string", "example": "@openfn/language-http@latest" },
          "trigger_id": { "type": "string", "example": "d5e6f7a8-0004-4a2b-9c3d-000000000004" },
          "project_id": { "type": "string", "example": "c1f2e3d4-0001-4a2b-9c3d-000000000001" },
          "workflow_id": { "type": "string", "example": "a2b3c4d5-0002-4a2b-9c3d-000000000002" },
          "enabled": { "type": "boolean", "example": true }
        }
      },
      "JobList": {
        "type": "object",
        "properties": {
          "jobs": { "type": "array", "items": { "$ref": "#/components/schemas/Job" } }
        }
      },
      "Trigger": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "d5e6f7a8-0004-4a2b-9c3d-000000000004" },
          "type": { "type": "string", "enum": ["webhook", "cron"], "example": "cron" },
          "cron_expression": { "type": "string", "example": "0 8 * * *" },
          "enabled": { "type": "boolean", "example": true },
          "workflow_id": { "type": "string", "example": "a2b3c4d5-0002-4a2b-9c3d-000000000002" }
        }
      },
      "TriggerList": {
        "type": "object",
        "properties": {
          "triggers": { "type": "array", "items": { "$ref": "#/components/schemas/Trigger" } }
        }
      },
      "Run": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "e6f7a8b9-0005-4a2b-9c3d-000000000005" },
          "job_id": { "type": "string", "example": "b3c4d5e6-0003-4a2b-9c3d-000000000003" },
          "workflow_id": { "type": "string", "example": "a2b3c4d5-0002-4a2b-9c3d-000000000002" },
          "dataclip_id": { "type": "string", "example": "f7a8b9c0-0006-4a2b-9c3d-000000000006" },
          "state": { "type": "string", "enum": ["available", "claimed", "started", "success", "failed", "crashed"], "example": "success" },
          "started_at": { "type": "string", "format": "date-time", "example": "2026-06-01T08:00:00Z" },
          "finished_at": { "type": "string", "format": "date-time", "example": "2026-06-01T08:00:03Z" }
        }
      },
      "RunList": {
        "type": "object",
        "properties": {
          "runs": { "type": "array", "items": { "$ref": "#/components/schemas/Run" } }
        }
      },
      "Credential": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "a0b1c2d3-0007-4a2b-9c3d-000000000007" },
          "name": { "type": "string", "example": "DHIS2 Play" },
          "schema": { "type": "string", "example": "dhis2" },
          "production": { "type": "boolean", "example": false }
        }
      },
      "CredentialList": {
        "type": "object",
        "properties": {
          "credentials": { "type": "array", "items": { "$ref": "#/components/schemas/Credential" } }
        }
      },
      "Dataclip": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "f7a8b9c0-0006-4a2b-9c3d-000000000006" },
          "type": { "type": "string", "enum": ["http_request", "global", "step_result", "saved_input"], "example": "http_request" },
          "body": { "type": "object", "additionalProperties": true, "example": { "name": "Jane Doe", "age": 33 } },
          "project_id": { "type": "string", "example": "c1f2e3d4-0001-4a2b-9c3d-000000000001" },
          "inserted_at": { "type": "string", "format": "date-time", "example": "2026-06-01T07:59:00Z" }
        }
      },
      "DataclipList": {
        "type": "object",
        "properties": {
          "dataclips": { "type": "array", "items": { "$ref": "#/components/schemas/Dataclip" } }
        }
      }
    }
  }
