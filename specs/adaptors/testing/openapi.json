{
  "openapi": "3.0.3",
  "info": {
    "title": "OpenFn testing adaptor (dev/test harness surface)",
    "version": "1.0.0",
    "description": "The @openfn/language-testing adaptor is a test/dev harness used to exercise automation and deployment in the OpenFn adaptors monorepo. It is not intended for public use and does NOT target a real external vendor API. Its public surface is minimal: it re-exports generic helpers (fn, combine, log) from @openfn/language-common and adds a version() operation. This OpenAPI document is a SYNTHESIZED representation of that adaptor surface, modelling each meaningful operation as an httpbin-style endpoint against a local mock server so the mocker has a concrete surface to serve. No real endpoints, paths, or auth are described.",
    "x-openfn-adaptor": "testing"
  },
  "servers": [
    {
      "url": "http://localhost:4010",
      "description": "Mock placeholder server. The testing adaptor has no external vendor API; this base URL is only for the mocker to serve synthesized echo/state endpoints."
    }
  ],
  "paths": {
    "/fn": {
      "post": {
        "operationId": "fn",
        "summary": "Run a custom function against state (mirrors fn()).",
        "description": "Creates a custom step/operation for flexible job writing. Takes an arbitrary state object, applies the function, and returns the resulting state.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/State" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The resulting state after the function runs.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/State" }
              }
            }
          }
        }
      }
    },
    "/combine": {
      "post": {
        "operationId": "combine",
        "summary": "Combine multiple operations into one (mirrors combine()).",
        "description": "Applies a sequence of operations to state and returns the combined resulting state.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/State" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The resulting state after all operations run.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/State" }
              }
            }
          }
        }
      }
    },
    "/log": {
      "post": {
        "operationId": "log",
        "summary": "Log a message (mirrors log()).",
        "description": "Prints a message to the run log and passes state through unchanged.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LogRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The log acknowledgement.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LogEntry" }
              }
            }
          }
        }
      }
    },
    "/version": {
      "get": {
        "operationId": "version",
        "summary": "Get the adaptor package version (mirrors version()).",
        "description": "Returns the installed @openfn/language-testing package version.",
        "responses": {
          "200": {
            "description": "The adaptor version info.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Version" }
              }
            }
          }
        }
      }
    },
    "/get": {
      "get": {
        "operationId": "getEcho",
        "summary": "Echo a GET request (httpbin-style test endpoint).",
        "description": "Returns details of the incoming GET request (query args, headers, origin). Used by test jobs to verify request wiring.",
        "parameters": [
          {
            "name": "arg",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Arbitrary query argument echoed back in args."
          }
        ],
        "responses": {
          "200": {
            "description": "The echoed request.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EchoResponse" }
              }
            }
          }
        }
      }
    },
    "/post": {
      "post": {
        "operationId": "postEcho",
        "summary": "Echo a POST request (httpbin-style test endpoint).",
        "description": "Returns details of the incoming POST request, including the parsed JSON body.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/State" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The echoed request with body.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EchoResponse" }
              }
            }
          }
        }
      }
    },
    "/status/{code}": {
      "get": {
        "operationId": "getStatus",
        "summary": "Return a response with the given HTTP status (httpbin-style).",
        "description": "Used by test jobs to exercise error handling. Returns a body describing the requested status code.",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "minimum": 100, "maximum": 599 },
            "description": "The HTTP status code to simulate."
          }
        ],
        "responses": {
          "200": {
            "description": "Status simulation acknowledgement.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatusResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "State": {
        "type": "object",
        "description": "The OpenFn execution state passed between operations. Arbitrary shape; commonly carries data, references, and configuration.",
        "properties": {
          "data": {
            "type": "object",
            "additionalProperties": true,
            "description": "Working data for the step."
          },
          "references": {
            "type": "array",
            "items": { "type": "object", "additionalProperties": true },
            "description": "History of prior operation results."
          },
          "configuration": {
            "type": "object",
            "additionalProperties": true,
            "description": "Credential/configuration object."
          }
        },
        "additionalProperties": true
      },
      "LogRequest": {
        "type": "object",
        "description": "A request to emit a log message.",
        "properties": {
          "message": {
            "type": "string",
            "description": "The message to log."
          },
          "level": {
            "type": "string",
            "enum": ["info", "warn", "error", "debug"],
            "default": "info",
            "description": "Log severity."
          }
        },
        "required": ["message"]
      },
      "LogEntry": {
        "type": "object",
        "description": "A recorded log entry.",
        "properties": {
          "message": { "type": "string" },
          "level": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" }
        },
        "required": ["message", "timestamp"]
      },
      "Version": {
        "type": "object",
        "description": "Adaptor package version information.",
        "properties": {
          "name": { "type": "string", "example": "@openfn/language-testing" },
          "version": { "type": "string", "example": "1.0.0" }
        },
        "required": ["name", "version"]
      },
      "EchoResponse": {
        "type": "object",
        "description": "An httpbin-style echo of the incoming request.",
        "properties": {
          "args": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "description": "Query string arguments."
          },
          "headers": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "description": "Request headers."
          },
          "origin": {
            "type": "string",
            "description": "Client origin IP."
          },
          "url": {
            "type": "string",
            "description": "The full request URL."
          },
          "json": {
            "type": "object",
            "additionalProperties": true,
            "nullable": true,
            "description": "Parsed JSON body, if any."
          }
        }
      },
      "StatusResponse": {
        "type": "object",
        "description": "Result of a simulated-status request.",
        "properties": {
          "status": { "type": "integer", "description": "The simulated HTTP status code." },
          "description": { "type": "string", "description": "Human-readable status description." }
        },
        "required": ["status"]
      }
    }
  }
}
