{
  "openapi": "3.0.3",
  "info": {
    "title": "surveycto — mocker seed-data schema",
    "version": "1.0.0",
    "description": "Schema for the seed data openfn-mocker needs to impersonate surveycto. Derived from the adaptor's OpenAPI spec. A seed dump is { collection: { id: record } }; each record validates against its resource schema below.",
    "x-openfn-adaptor": "surveycto",
    "x-derived-from": "openapi.json",
    "x-captured-at": "2026-07-06"
  },
  "x-seed": {
    "shape": "{ collection: { id: record } }",
    "collections": {
      "datasets": {
        "resource": "Dataset",
        "schema": {
          "$ref": "#/components/schemas/Dataset"
        }
      },
      "datasetRecords": {
        "resource": "DatasetRecord",
        "schema": {
          "$ref": "#/components/schemas/DatasetRecord"
        }
      },
      "submissions": {
        "resource": "Submission",
        "schema": {
          "$ref": "#/components/schemas/Submission"
        }
      },
      "uploadResults": {
        "resource": "UploadResult",
        "schema": {
          "$ref": "#/components/schemas/UploadResult"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SeedData": {
        "type": "object",
        "description": "Full seed dump loaded by mocker: one property per collection.",
        "properties": {
          "datasets": {
            "type": "object",
            "description": "Records keyed by id for the datasets collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Dataset"
            }
          },
          "datasetRecords": {
            "type": "object",
            "description": "Records keyed by id for the datasetRecords collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/DatasetRecord"
            }
          },
          "submissions": {
            "type": "object",
            "description": "Records keyed by id for the submissions collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Submission"
            }
          },
          "uploadResults": {
            "type": "object",
            "description": "Records keyed by id for the uploadResults collection.",
            "additionalProperties": {
              "$ref": "#/components/schemas/UploadResult"
            }
          }
        },
        "additionalProperties": false
      },
      "Submission": {
        "type": "object",
        "description": "A single form submission in wide format. Fields are dynamic per form; the metadata fields below are always present.",
        "additionalProperties": true,
        "properties": {
          "KEY": {
            "type": "string",
            "description": "Unique submission instance key (uuid)."
          },
          "SubmissionDate": {
            "type": "string",
            "description": "Timestamp the submission was received, SurveyCTO format."
          },
          "CompletionDate": {
            "type": "string",
            "description": "Timestamp the form was completed on the device."
          },
          "review_status": {
            "type": "string",
            "description": "Review status of the submission.",
            "example": "approved"
          },
          "formdef_version": {
            "type": "string",
            "description": "Version of the form definition used."
          }
        }
      },
      "Dataset": {
        "type": "object",
        "description": "A SurveyCTO server dataset.",
        "properties": {
          "id": {
            "type": "string",
            "description": "Dataset id."
          },
          "title": {
            "type": "string",
            "description": "Human-readable dataset title."
          },
          "discriminator": {
            "type": "string",
            "description": "Dataset discriminator/category, e.g. ENUMERATORS."
          },
          "allowOfflineUpdates": {
            "type": "boolean",
            "description": "Whether offline updates are allowed."
          },
          "locationContext": {
            "$ref": "#/components/schemas/LocationContext"
          },
          "idFormatOptions": {
            "$ref": "#/components/schemas/IdFormatOptions"
          }
        },
        "required": [
          "id"
        ]
      },
      "LocationContext": {
        "type": "object",
        "description": "Placement of the dataset within the server folder/group structure.",
        "properties": {
          "parentGroupId": {
            "type": "integer"
          },
          "siblingAbove": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "itemClass": {
                "type": "string",
                "example": "DATASET"
              }
            }
          }
        }
      },
      "IdFormatOptions": {
        "type": "object",
        "description": "Auto-generated id format configuration for dataset records.",
        "properties": {
          "prefix": {
            "type": "string"
          },
          "suffix": {
            "type": "string"
          },
          "numberOfDigits": {
            "type": "string"
          },
          "allowCapitalLetters": {
            "type": "boolean"
          }
        }
      },
      "DatasetRecord": {
        "type": "object",
        "description": "A single dataset record. Fields are dynamic per dataset; id is always present.",
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "description": "Record id."
          }
        },
        "required": [
          "id"
        ]
      },
      "DatasetListResponse": {
        "type": "object",
        "description": "Paginated list of datasets.",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Dataset"
            }
          },
          "total": {
            "type": "integer",
            "description": "Total number of items returned."
          },
          "nextCursor": {
            "type": "string",
            "nullable": true,
            "description": "Cursor for the next page, or null when exhausted."
          }
        }
      },
      "RecordListResponse": {
        "type": "object",
        "description": "Paginated list of dataset records.",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DatasetRecord"
            }
          },
          "total": {
            "type": "integer",
            "description": "Total number of items returned."
          },
          "nextCursor": {
            "type": "string",
            "nullable": true,
            "description": "Cursor for the next page, or null when exhausted."
          }
        }
      },
      "UploadMetadata": {
        "type": "object",
        "description": "Optional metadata controlling how uploaded records are processed.",
        "properties": {
          "uploadMode": {
            "type": "string",
            "enum": [
              "APPEND",
              "MERGE",
              "CLEAR"
            ],
            "default": "APPEND",
            "description": "Upload mode."
          },
          "joiningField": {
            "type": "string",
            "description": "Field name to join on. Required when uploadMode is MERGE."
          }
        }
      },
      "UploadResult": {
        "type": "object",
        "description": "Result summary returned after a bulk record upload.",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "recordsProcessed": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}
