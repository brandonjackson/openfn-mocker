{
  "openapi": "3.0.3",
  "info": {
    "title": "SurveyCTO REST API (mocker subset)",
    "version": "2.0.0",
    "description": "Hand-authored OpenAPI subset of the SurveyCTO REST API covering the endpoints exercised by the OpenFn surveycto adaptor: form submission data export (wide JSON and CSV) and the Datasets API (list/get/create/update datasets, list/patch/upload dataset records). Synthesized from SurveyCTO vendor docs (developer.surveycto.com, support.surveycto.com). The real API base is https://{servername}.surveycto.com/api/{apiVersion}, protected by HTTP Basic auth.",
    "x-openfn-adaptor": "surveycto"
  },
  "servers": [
    {
      "url": "https://{servername}.surveycto.com/api/{apiVersion}",
      "description": "SurveyCTO server instance",
      "variables": {
        "servername": {
          "default": "example",
          "description": "The SurveyCTO server/subdomain name (server console URL prefix)."
        },
        "apiVersion": {
          "default": "v2",
          "enum": ["v1", "v2"],
          "description": "API version. Datasets endpoints require v2; legacy exports use v1."
        }
      }
    }
  ],
  "security": [{ "basicAuth": [] }],
  "paths": {
    "/forms/data/wide/json/{formId}": {
      "get": {
        "operationId": "getFormDataWideJson",
        "summary": "Fetch form submissions as wide-format JSON",
        "description": "Returns all submissions for a form in wide JSON format. Used by the adaptor's fetchSubmissions() when format is json.",
        "parameters": [
          { "$ref": "#/components/parameters/FormId" },
          { "$ref": "#/components/parameters/DateFilter" },
          { "$ref": "#/components/parameters/ReviewStatus" }
        ],
        "responses": {
          "200": {
            "description": "Array of form submissions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Submission" }
                }
              }
            }
          }
        }
      }
    },
    "/forms/data/csv/{formId}": {
      "get": {
        "operationId": "getFormDataCsv",
        "summary": "Fetch form submissions as CSV",
        "description": "Returns all submissions for a form as a CSV text payload. Used by the adaptor's fetchSubmissions() when format is csv.",
        "parameters": [
          { "$ref": "#/components/parameters/FormId" },
          { "$ref": "#/components/parameters/DateFilter" },
          { "$ref": "#/components/parameters/ReviewStatus" }
        ],
        "responses": {
          "200": {
            "description": "CSV text of submissions",
            "content": {
              "text/plain": {
                "schema": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "/datasets": {
      "get": {
        "operationId": "listDatasets",
        "summary": "List datasets",
        "description": "Returns a paginated list of server datasets. Used by list('datasets').",
        "parameters": [
          { "$ref": "#/components/parameters/Limit" },
          { "$ref": "#/components/parameters/Cursor" }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of datasets",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DatasetListResponse" }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createDataset",
        "summary": "Create a dataset",
        "description": "Creates a new dataset. Used by upsertDataset() when the dataset does not already exist.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Dataset" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The created dataset",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Dataset" }
              }
            }
          }
        }
      }
    },
    "/datasets/{datasetId}": {
      "get": {
        "operationId": "getDataset",
        "summary": "Get a dataset",
        "description": "Fetches a single dataset by id. Used by upsertDataset() to test for existence.",
        "parameters": [{ "$ref": "#/components/parameters/DatasetId" }],
        "responses": {
          "200": {
            "description": "The requested dataset",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Dataset" }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateDataset",
        "summary": "Update a dataset",
        "description": "Updates an existing dataset. Used by upsertDataset() when the dataset already exists.",
        "parameters": [{ "$ref": "#/components/parameters/DatasetId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Dataset" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The updated dataset",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Dataset" }
              }
            }
          }
        }
      }
    },
    "/datasets/{datasetId}/records": {
      "get": {
        "operationId": "listDatasetRecords",
        "summary": "List dataset records",
        "description": "Returns a paginated list of records for a dataset. Used by list('datasets/{id}/records').",
        "parameters": [
          { "$ref": "#/components/parameters/DatasetId" },
          { "$ref": "#/components/parameters/Limit" },
          { "$ref": "#/components/parameters/Cursor" }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of dataset records",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RecordListResponse" }
              }
            }
          }
        }
      }
    },
    "/datasets/{datasetId}/record": {
      "patch": {
        "operationId": "patchDatasetRecord",
        "summary": "Create or update a dataset record",
        "description": "Upserts a single record in a dataset. Used by upsertRecord(). The record's id is passed via the recordId query parameter.",
        "parameters": [
          { "$ref": "#/components/parameters/DatasetId" },
          {
            "name": "recordId",
            "in": "query",
            "required": false,
            "description": "Id of the record to upsert.",
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DatasetRecord" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The upserted record",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DatasetRecord" }
              }
            }
          }
        }
      }
    },
    "/datasets/{datasetId}/records/upload": {
      "post": {
        "operationId": "uploadDatasetRecords",
        "summary": "Bulk upload dataset records via CSV",
        "description": "Uploads records to a dataset from a CSV file, with optional metadata controlling upload mode. Used by uploadCsvRecords().",
        "parameters": [{ "$ref": "#/components/parameters/DatasetId" }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "CSV file of records to upload."
                  },
                  "metadata": {
                    "$ref": "#/components/schemas/UploadMetadata"
                  }
                },
                "required": ["file"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Upload result summary",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UploadResult" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "SurveyCTO username and password via HTTP Basic authentication."
      }
    },
    "parameters": {
      "FormId": {
        "name": "formId",
        "in": "path",
        "required": true,
        "description": "The form id (form definition id).",
        "schema": { "type": "string" }
      },
      "DatasetId": {
        "name": "datasetId",
        "in": "path",
        "required": true,
        "description": "The dataset id.",
        "schema": { "type": "string" }
      },
      "DateFilter": {
        "name": "date",
        "in": "query",
        "required": false,
        "description": "Only return submissions after this timestamp, in SurveyCTO format 'MMM dd, yyyy h:mm:ss a' (UTC).",
        "schema": { "type": "string" }
      },
      "ReviewStatus": {
        "name": "r",
        "in": "query",
        "required": false,
        "description": "Review status filter: approved, rejected, pending, or a pipe-combined set e.g. 'approved|rejected'.",
        "schema": { "type": "string" }
      },
      "Limit": {
        "name": "limit",
        "in": "query",
        "required": false,
        "description": "Maximum number of items to return. Defaults to 20, maximum 1000.",
        "schema": { "type": "integer", "default": 20, "maximum": 1000 }
      },
      "Cursor": {
        "name": "cursor",
        "in": "query",
        "required": false,
        "description": "Opaque cursor marking the start of the next page of results.",
        "schema": { "type": "string" }
      }
    },
    "schemas": {
      "Submission": {
        "type": "object",
        "description": "A single form submission in wide format. Fields are dynamic per form; the metadata fields below are always present.",
        "additionalProperties": true,
        "properties": {
          "KEY": {
            "type": "string",
            "description": "Unique submission instance key (uuid)."
          },
          "SubmissionDate": {
            "type": "string",
            "description": "Timestamp the submission was received, SurveyCTO format."
          },
          "CompletionDate": {
            "type": "string",
            "description": "Timestamp the form was completed on the device."
          },
          "review_status": {
            "type": "string",
            "description": "Review status of the submission.",
            "example": "approved"
          },
          "formdef_version": {
            "type": "string",
            "description": "Version of the form definition used."
          }
        }
      },
      "Dataset": {
        "type": "object",
        "description": "A SurveyCTO server dataset.",
        "properties": {
          "id": { "type": "string", "description": "Dataset id." },
          "title": { "type": "string", "description": "Human-readable dataset title." },
          "discriminator": {
            "type": "string",
            "description": "Dataset discriminator/category, e.g. ENUMERATORS."
          },
          "allowOfflineUpdates": {
            "type": "boolean",
            "description": "Whether offline updates are allowed."
          },
          "locationContext": {
            "$ref": "#/components/schemas/LocationContext"
          },
          "idFormatOptions": {
            "$ref": "#/components/schemas/IdFormatOptions"
          }
        },
        "required": ["id"]
      },
      "LocationContext": {
        "type": "object",
        "description": "Placement of the dataset within the server folder/group structure.",
        "properties": {
          "parentGroupId": { "type": "integer" },
          "siblingAbove": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "itemClass": { "type": "string", "example": "DATASET" }
            }
          }
        }
      },
      "IdFormatOptions": {
        "type": "object",
        "description": "Auto-generated id format configuration for dataset records.",
        "properties": {
          "prefix": { "type": "string" },
          "suffix": { "type": "string" },
          "numberOfDigits": { "type": "string" },
          "allowCapitalLetters": { "type": "boolean" }
        }
      },
      "DatasetRecord": {
        "type": "object",
        "description": "A single dataset record. Fields are dynamic per dataset; id is always present.",
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "description": "Record id." }
        },
        "required": ["id"]
      },
      "DatasetListResponse": {
        "type": "object",
        "description": "Paginated list of datasets.",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Dataset" }
          },
          "total": { "type": "integer", "description": "Total number of items returned." },
          "nextCursor": {
            "type": "string",
            "nullable": true,
            "description": "Cursor for the next page, or null when exhausted."
          }
        }
      },
      "RecordListResponse": {
        "type": "object",
        "description": "Paginated list of dataset records.",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/DatasetRecord" }
          },
          "total": { "type": "integer", "description": "Total number of items returned." },
          "nextCursor": {
            "type": "string",
            "nullable": true,
            "description": "Cursor for the next page, or null when exhausted."
          }
        }
      },
      "UploadMetadata": {
        "type": "object",
        "description": "Optional metadata controlling how uploaded records are processed.",
        "properties": {
          "uploadMode": {
            "type": "string",
            "enum": ["APPEND", "MERGE", "CLEAR"],
            "default": "APPEND",
            "description": "Upload mode."
          },
          "joiningField": {
            "type": "string",
            "description": "Field name to join on. Required when uploadMode is MERGE."
          }
        }
      },
      "UploadResult": {
        "type": "object",
        "description": "Result summary returned after a bulk record upload.",
        "properties": {
          "success": { "type": "boolean" },
          "recordsProcessed": { "type": "integer" },
          "message": { "type": "string" }
        }
      }
    }
  }
}
