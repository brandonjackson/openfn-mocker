{
  "openapi": "3.0.0",
  "info": {
    "title": "CommCare HQ Data API (mock subset)",
    "version": "0.5",
    "description": "Focused subset of the CommCare HQ v0.5 Data APIs (Tastypie-style { meta, objects } list envelopes). Domain-scoped paths under /a/{domain}/api/v0.5/. Auth is Basic or ApiKey header; the mock accepts all credentials."
  },
  "servers": [{ "url": "http://localhost:4011" }],
  "paths": {
    "/a/{domain}/api/v0.5/case/": {
      "get": {
        "operationId": "listCases",
        "summary": "List cases (Tastypie envelope)",
        "parameters": [
          { "name": "domain", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "type", "in": "query", "required": false, "schema": { "type": "string" }, "description": "Filter by case_type" },
          { "name": "owner_id", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "offset", "in": "query", "required": false, "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "required": false, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "A paged list of cases.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": { "$ref": "#/components/schemas/Meta" },
                    "objects": { "type": "array", "items": { "$ref": "#/components/schemas/Case" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/a/{domain}/api/v0.5/case/{case_id}/": {
      "get": {
        "operationId": "getCase",
        "summary": "Get a single case by case_id",
        "parameters": [
          { "name": "domain", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "case_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "A single case object.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Case" } } }
          },
          "404": { "description": "Not found" }
        }
      }
    },
    "/a/{domain}/api/v0.5/form/": {
      "get": {
        "operationId": "listForms",
        "summary": "List form submissions (Tastypie envelope)",
        "parameters": [
          { "name": "domain", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "offset", "in": "query", "required": false, "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "required": false, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "A paged list of forms.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": { "$ref": "#/components/schemas/Meta" },
                    "objects": { "type": "array", "items": { "$ref": "#/components/schemas/Form" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/a/{domain}/api/v0.5/form/{id}/": {
      "get": {
        "operationId": "getForm",
        "summary": "Get a single form submission by id",
        "parameters": [
          { "name": "domain", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "A single form object.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Form" } } }
          },
          "404": { "description": "Not found" }
        }
      }
    },
    "/a/{domain}/receiver/": {
      "post": {
        "operationId": "submitForm",
        "summary": "OpenRosa form submission (raw XML body)",
        "parameters": [
          { "name": "domain", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "text/xml": { "schema": { "type": "string" } } }
        },
        "responses": {
          "201": {
            "description": "OpenRosa submit_success response.",
            "content": { "text/xml": { "schema": { "type": "string" } } }
          }
        }
      }
    },
    "/a/{domain}/receiver/{id}/": {
      "post": {
        "operationId": "submitFormWithId",
        "summary": "OpenRosa form submission to a specific app build (raw XML body)",
        "parameters": [
          { "name": "domain", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "text/xml": { "schema": { "type": "string" } } }
        },
        "responses": {
          "201": {
            "description": "OpenRosa submit_success response.",
            "content": { "text/xml": { "schema": { "type": "string" } } }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Meta": {
        "type": "object",
        "properties": {
          "limit": { "type": "integer", "example": 20 },
          "next": { "type": "string", "nullable": true },
          "offset": { "type": "integer", "example": 0 },
          "previous": { "type": "string", "nullable": true },
          "total_count": { "type": "integer", "example": 5 }
        }
      },
      "Case": {
        "type": "object",
        "properties": {
          "case_id": { "type": "string" },
          "case_type": { "type": "string", "example": "patient" },
          "date_opened": { "type": "string", "format": "date-time" },
          "date_modified": { "type": "string", "format": "date-time" },
          "closed": { "type": "boolean", "example": false },
          "owner_id": { "type": "string" },
          "user_id": { "type": "string" },
          "server_date_modified": { "type": "string", "format": "date-time" },
          "indices": { "type": "object" },
          "xform_ids": { "type": "array", "items": { "type": "string" } },
          "properties": {
            "type": "object",
            "properties": {
              "case_name": { "type": "string" },
              "case_type": { "type": "string" },
              "owner_id": { "type": "string" },
              "first_name": { "type": "string" },
              "last_name": { "type": "string" },
              "age": { "type": "string" },
              "village": { "type": "string" }
            }
          }
        }
      },
      "Form": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "received_on": { "type": "string", "format": "date-time" },
          "app_id": { "type": "string" },
          "domain": { "type": "string" },
          "form": {
            "type": "object",
            "properties": {
              "@xmlns": { "type": "string" },
              "meta": {
                "type": "object",
                "properties": {
                  "instanceID": { "type": "string" },
                  "userID": { "type": "string" },
                  "timeEnd": { "type": "string", "format": "date-time" }
                }
              }
            }
          },
          "metadata": { "type": "object" }
        }
      }
    }
  }
}
