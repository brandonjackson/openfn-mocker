{
  "openapi": "3.0.0",
  "info": {
    "title": "Primero API (mock subset)",
    "version": "v2",
    "description": "Focused subset of the Primero v2 API used by OpenFn workflows: token exchange plus cases, incidents and referrals. Primero nests business fields under a `data` object and wraps list responses in `{ data, metadata }`."
  },
  "servers": [{ "url": "http://localhost:4017" }],
  "paths": {
    "/api/v2/tokens": {
      "post": {
        "operationId": "createToken",
        "summary": "Token exchange (accept any credentials).",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TokenRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "A bearer token to use on subsequent requests.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TokenResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v2/cases": {
      "get": {
        "operationId": "listCases",
        "summary": "List cases.",
        "parameters": [
          { "name": "query", "in": "query", "schema": { "type": "string" } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "per", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "A page of cases.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CaseList" }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createCase",
        "summary": "Create a case.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CaseWrite" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The created case.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CaseSingle" }
              }
            }
          }
        }
      }
    },
    "/api/v2/cases/{id}": {
      "get": {
        "operationId": "getCase",
        "summary": "Fetch a single case.",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": {
            "description": "The case.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CaseSingle" }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updateCase",
        "summary": "Update a case (merges nested data).",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CaseWrite" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The updated case.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CaseSingle" }
              }
            }
          }
        }
      }
    },
    "/api/v2/incidents": {
      "get": {
        "operationId": "listIncidents",
        "summary": "List incidents.",
        "responses": {
          "200": {
            "description": "A page of incidents.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IncidentList" }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createIncident",
        "summary": "Create an incident.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/IncidentWrite" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The created incident.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IncidentSingle" }
              }
            }
          }
        }
      }
    },
    "/api/v2/referrals": {
      "post": {
        "operationId": "createReferral",
        "summary": "Create a referral.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ReferralWrite" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The created referral.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ReferralSingle" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TokenRequest": {
        "type": "object",
        "properties": {
          "user": {
            "type": "object",
            "properties": {
              "user_name": { "type": "string", "example": "primero" },
              "password": { "type": "string", "example": "mock" }
            }
          }
        }
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "token": { "type": "string", "example": "mock_primero_token" }
        }
      },
      "CaseData": {
        "type": "object",
        "properties": {
          "name_first": { "type": "string", "example": "Jane" },
          "name_last": { "type": "string", "example": "Doe" },
          "age": { "type": "integer", "example": 12 },
          "sex": { "type": "string", "example": "female" },
          "protection_concerns": {
            "type": "array",
            "items": { "type": "string" },
            "example": ["neglect"]
          },
          "risk_level": { "type": "string", "example": "high" }
        }
      },
      "Case": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "case_id": { "type": "string", "example": "CP-2024-001" },
          "status": { "type": "string", "example": "open" },
          "registration_date": { "type": "string", "format": "date", "example": "2024-01-15" },
          "owned_by": { "type": "string", "example": "caseworker1" },
          "created_at": { "type": "string", "format": "date-time" },
          "data": { "$ref": "#/components/schemas/CaseData" }
        }
      },
      "CaseWrite": {
        "type": "object",
        "properties": {
          "data": { "$ref": "#/components/schemas/CaseData" }
        }
      },
      "CaseSingle": {
        "type": "object",
        "properties": {
          "data": { "$ref": "#/components/schemas/Case" }
        }
      },
      "CaseList": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Case" } },
          "metadata": { "$ref": "#/components/schemas/Metadata" }
        }
      },
      "IncidentData": {
        "type": "object",
        "properties": {
          "incident_date": { "type": "string", "format": "date", "example": "2024-02-01" },
          "description": { "type": "string", "example": "Reported neglect incident" },
          "cp_incident_violence_type": { "type": "string", "example": "neglect" }
        }
      },
      "Incident": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "incident_id": { "type": "string", "example": "IN-2024-001" },
          "status": { "type": "string", "example": "open" },
          "owned_by": { "type": "string", "example": "caseworker1" },
          "created_at": { "type": "string", "format": "date-time" },
          "case_id": { "type": "string" },
          "data": { "$ref": "#/components/schemas/IncidentData" }
        }
      },
      "IncidentWrite": {
        "type": "object",
        "properties": {
          "data": { "$ref": "#/components/schemas/IncidentData" }
        }
      },
      "IncidentSingle": {
        "type": "object",
        "properties": {
          "data": { "$ref": "#/components/schemas/Incident" }
        }
      },
      "IncidentList": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Incident" } },
          "metadata": { "$ref": "#/components/schemas/Metadata" }
        }
      },
      "ReferralData": {
        "type": "object",
        "properties": {
          "record_id": { "type": "string" },
          "record_type": { "type": "string", "example": "case" },
          "transitioned_to": { "type": "string", "example": "social_worker2" },
          "transitioned_by": { "type": "string", "example": "caseworker1" },
          "notes": { "type": "string", "example": "Please follow up on housing support." }
        }
      },
      "ReferralWrite": {
        "type": "object",
        "properties": {
          "data": { "$ref": "#/components/schemas/ReferralData" }
        }
      },
      "Referral": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "status": { "type": "string", "example": "in_progress" },
          "created_at": { "type": "string", "format": "date-time" },
          "data": { "$ref": "#/components/schemas/ReferralData" }
        }
      },
      "ReferralSingle": {
        "type": "object",
        "properties": {
          "data": { "$ref": "#/components/schemas/Referral" }
        }
      },
      "Metadata": {
        "type": "object",
        "properties": {
          "total": { "type": "integer", "example": 5 },
          "per": { "type": "integer", "example": 20 },
          "page": { "type": "integer", "example": 1 }
        }
      }
    }
  }
}
